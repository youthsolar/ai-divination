                 		{
                 			gregorianYear = solarDate.getYear();
                 			lichunDateTime = lichunCache.get(gregorianYear);
                 			baziYear = gregorianYear;
                 			if(lichunDateTime != null && solarDate < lichunDateTime)
                 			{
                 				baziYear = gregorianYear - 1;
                 			}
                 			// 計算年柱
                 			yearDiff = baziYear - baseYear;
                 			yearStemIndex = (baseStemIndex + yearDiff) % 10;
