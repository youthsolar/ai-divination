map LunarAI.getYearPillar(date solarDate)
                 {
                 	// 最終返回的 Map
                 	result_map = Map();
                 	result_map.put("yearPillar","");
                 	result_map.put("error","");
                 	result_map.put("effectiveLunarYear",null);
                 	// 用於記錄生效的農曆年份
                 	// 天干 (Heavenly Stems)
                 	heavenlyStems = {"甲","乙","丙","丁","戊","己","庚","辛","壬","癸"};
                 	// 地支 (Earthly Branches)
                 	earthlyBranches = {"子","丑","寅","卯","辰","巳","午","未","申","酉","戌","亥"};
                 	// ==================================================================================================
                 	// == 重要提示：請將下面的 all_solar_terms_data_map 替換為您擁有的 1900-2050 年的完整節氣資料 Map ==
                 	// ==================================================================================================
                 	// 以下為部分範例資料，您需要提供完整的資料。
                 	all_solar_terms_data_map = thisapp.LunarAI.getSolarTermsDataMap();
                 	inputYear = solarDate.getYear();
                 	inputMonth = solarDate.getMonth();
                 	// Deluge getMonth() returns 1-12
                 	inputDay = solarDate.getDay();
                 	// Deluge getDay() returns 1-31
                 	inputYearStr = inputYear.toString();
                 	// 檢查輸入公曆年份的節氣資料是否存在
                 	if(!all_solar_terms_data_map.containKey(inputYearStr))
                 	{
                 		result_map.put("error","輸入公曆年份 " + inputYearStr + " 的節氣資料不存在。請確保 all_solar_terms_data_map 包含 1900-2050 年的完整資料。");
                 		return result_map;
                 	}
                 	yearSolarTerms = all_solar_terms_data_map.get(inputYearStr);
                 	if(yearSolarTerms == null || !yearSolarTerms.containKey("立春"))
                 	{
                 		result_map.put("error","找不到年份 " + inputYearStr + " 的立春資料。");
                 		return result_map;
                 	}
                 	lichunDateStr = yearSolarTerms.get("立春");
                 	// 例如 "2-4"
                 	lichunParts = lichunDateStr.toList("-");
                 	if(lichunParts.size() != 2)
                 	{
                 		result_map.put("error","年份 " + inputYearStr + " 的立春資料格式不正確：" + lichunDateStr);
                 		return result_map;
                 	}
                 	lichunMonth = null;
                 	lichunDay = null;
                 	try 
                 	{
                 		lichunMonth = lichunParts.get(0).toLong();
                 		lichunDay = lichunParts.get(1).toLong();
                 	}
                 	catch (e)
                 	{
                 		result_map.put("error","解析年份 " + inputYearStr + " 的立春月或日失敗：" + lichunDateStr + ". 錯誤: " + e);
                 		return result_map;
                 	}
                 	if(lichunMonth == null || lichunDay == null)
                 	{
                 		// 此錯誤理論上已被 try-catch 捕獲，但作為額外防護
                 		result_map.put("error","未能解析年份 " + inputYearStr + " 的立春月或日：" + lichunDateStr);
                 		return result_map;
                 	}
                 	// 判斷輸入日期是否在當年立春之前
                 	isBeforeLichun = false;
                 	if(inputMonth < lichunMonth)
                 	{
                 		isBeforeLichun = true;
                 	}
                 	else if(inputMonth == lichunMonth && inputDay < lichunDay)
                 	{
                 		isBeforeLichun = true;
                 	}
                 	effectiveLunarYearValue = inputYear;
                 	if(isBeforeLichun)
                 	{
                 		effectiveLunarYearValue = inputYear - 1;
                 	}
                 	result_map.put("effectiveLunarYear",effectiveLunarYearValue);
                 	// 基準：1900年立春後是庚子年。
                 	// 庚是天干中的第7位 (索引為6: 甲0,乙1,丙2,丁3,戊4,己5,庚6)
                 	// 子是地支中的第1位 (索引為0: 子0,丑1,...)
                 	// 計算天干索引
                 	// (目標農曆年份 - 基準農曆年份 + 基準年天干索引) % 10
                 	heavenlyStemIndex = ((effectiveLunarYearValue - 1900 + 6) % 10 + 10) % 10;
                 	// 加10再取模確保結果為正
                 	// 計算地支索引
                 	// (目標農曆年份 - 基準農曆年份 + 基準年地支索引) % 12
                 	earthlyBranchIndex = ((effectiveLunarYearValue - 1900 + 0) % 12 + 12) % 12;
                 	// 加12再取模確保結果為正
                 	heavenlyStemChar = heavenlyStems.get(heavenlyStemIndex);
                 	earthlyBranchChar = earthlyBranches.get(earthlyBranchIndex);
                 	yearPillarStr = heavenlyStemChar + earthlyBranchChar;
                 	result_map.put("yearPillar",yearPillarStr);
                 	return result_map;
                 }
string LunarAI.LunarToWords(map lunar)
                 {
                 	// 1. 取出農曆年/月/日 及閏月旗標
                 	y = lunar.get("lunar_year").toLong();
                 	m = lunar.get("lunar_month").toLong();
                 	d = lunar.get("lunar_day").toLong();
                 	isLeap = ifnull(lunar.get("is_leap_month"),false);
                 	// 2. 天干、地支陣列
                 	stems = List();
                 	stems.add("甲");
                 	stems.add("乙");
                 	stems.add("丙");
                 	stems.add("丁");
                 	stems.add("戊");
                 	stems.add("己");
                 	stems.add("庚");
                 	stems.add("辛");
                 	stems.add("壬");
                 	stems.add("癸");
                 	branches = List();
                 	branches.add("子（鼠）");
                 	branches.add("丑（牛）");
                 	branches.add("寅（虎）");
                 	branches.add("卯（兔）");
                 	branches.add("辰（龍）");
                 	branches.add("巳（蛇）");
                 	branches.add("午（馬）");
                 	branches.add("未（羊）");
                 	branches.add("申（猴）");
                 	branches.add("酉（雞）");
                 	branches.add("戌（狗）");
                 	branches.add("亥（豬）");
                 	// 3. 計算年柱（甲子年為西元4年）
                 	offset = (y - 4) % 60;
                 	if(offset < 0)
                 	{
                 		offset = offset + 60;
                 	}
                 	year_stem = stems.get(offset % 10);
                 	year_branch = branches.get(offset % 12);
                 	yearName = (year_stem + year_branch) + "年";
                 	// 4. 月份中文
                 	monthNames = List();
                 	monthNames.add("正月");
                 	monthNames.add("二月");
                 	monthNames.add("三月");
                 	monthNames.add("四月");
                 	monthNames.add("五月");
                 	monthNames.add("六月");
                 	monthNames.add("七月");
                 	monthNames.add("八月");
                 	monthNames.add("九月");
                 	monthNames.add("十月");
                 	monthNames.add("冬月");
                 	monthNames.add("臘月");
                 	monthName = monthNames.get(m - 1);
                 	if(isLeap)
                 	{
                 		monthName = "閏" + monthName;
                 	}
                 	// 5. 日份中文
                 	dayNames = List();
                 	dayNames.add("初一");
                 	dayNames.add("初二");
                 	dayNames.add("初三");
                 	dayNames.add("初四");
                 	dayNames.add("初五");
                 	dayNames.add("初六");
                 	dayNames.add("初七");
                 	dayNames.add("初八");
                 	dayNames.add("初九");
                 	dayNames.add("初十");
                 	dayNames.add("十一");
                 	dayNames.add("十二");
                 	dayNames.add("十三");
                 	dayNames.add("十四");
                 	dayNames.add("十五");
                 	dayNames.add("十六");
                 	dayNames.add("十七");
                 	dayNames.add("十八");
                 	dayNames.add("十九");
                 	dayNames.add("二十");
                 	dayNames.add("廿一");
                 	dayNames.add("廿二");
                 	dayNames.add("廿三");
                 	dayNames.add("廿四");
                 	dayNames.add("廿五");
                 	dayNames.add("廿六");
                 	dayNames.add("廿七");
                 	dayNames.add("廿八");
                 	dayNames.add("廿九");
                 	dayNames.add("三十");
                 	dayName = dayNames.get(d - 1);
                 	// 6. 組合並回傳
                 	return yearName + " " + monthName + dayName;
                 }
string LunarAI.LunarWordsToBazi(string lunarText, string timeStr)
                 {
                 	// 目前是範例函數，參數是硬寫入，需要再改或是另函數整合呼叫
                 	// 1. 先把 lunarText 拆成年柱與月日
                 	parts = lunarText.toList(" ");
                 	yearP = parts.get(0).subString(0,2);
                 	// 戊辰
                 	mdPart = parts.get(1);
                 	// 正月初一 或 閏四月初一
                 	// 2. 解析是否閏月
                 	isLeap = mdPart.startsWith("閏");
                 	idxYue = mdPart.indexOf("月") + 1;
                 	monthCN = "";
                 	if(isLeap)
                 	{
                 		monthCN = mdPart.subString(1,idxYue);
                 	}
                 	else
                 	{
                 		monthCN = mdPart.subString(0,idxYue);
                 	}
                 	dayCN = mdPart.subString(idxYue);
                 	// 3. 月中文轉數字 & 日中文轉數字
                 	monthMap = Map();
                 	monthMap.put("正月",1);
                 	monthMap.put("二月",2);
                 	monthMap.put("三月",3);
                 	monthMap.put("四月",4);
                 	monthMap.put("五月",5);
                 	monthMap.put("六月",6);
                 	monthMap.put("七月",7);
                 	monthMap.put("八月",8);
                 	monthMap.put("九月",9);
                 	monthMap.put("十月",10);
                 	monthMap.put("冬月",11);
                 	monthMap.put("臘月",12);
                 	dayMap = Map();
                 	dayMap.put("初一",1);
                 	dayMap.put("初二",2);
                 	dayMap.put("初三",3);
                 	dayMap.put("初四",4);
                 	dayMap.put("初五",5);
                 	dayMap.put("初六",6);
                 	dayMap.put("初七",7);
                 	dayMap.put("初八",8);
                 	dayMap.put("初九",9);
                 	dayMap.put("初十",10);
                 	dayMap.put("十一",11);
                 	dayMap.put("十二",12);
                 	dayMap.put("十三",13);
                 	dayMap.put("十四",14);
                 	dayMap.put("十五",15);
                 	dayMap.put("十六",16);
                 	dayMap.put("十七",17);
                 	dayMap.put("十八",18);
                 	dayMap.put("十九",19);
                 	dayMap.put("二十",20);
                 	dayMap.put("廿一",21);
                 	dayMap.put("廿二",22);
                 	dayMap.put("廿三",23);
                 	dayMap.put("廿四",24);
                 	dayMap.put("廿五",25);
                 	dayMap.put("廿六",26);
                 	dayMap.put("廿七",27);
                 	dayMap.put("廿八",28);
                 	dayMap.put("廿九",29);
                 	dayMap.put("三十",30);
                 	lunarMap = Map();
                 	lunarMap.put("lunar_year",1988);
                 	// 這裡請根據 yearP 做對應
                 	lunarMap.put("lunar_month",monthMap.get(monthCN));
                 	lunarMap.put("lunar_day",dayMap.get(dayCN));
                 	lunarMap.put("is_leap_month",isLeap);
                 	// 4. 把 timeStr 併進一個臨時的 datetime
                 	todayStr = zoho.currentdate.toString("yyyy-MM-dd");
                 	dtStr = todayStr + " " + timeStr + ":00";
                 	solarDt = dtStr.toTime("yyyy-MM-dd HH:mm:ss");
                 	// 5. 呼叫你先前寫好的 convertToBaZi()
                 	// map baziMap = LunarAI.convertToBaZi(solarDt, lunarMap);
                 	// 6. 組成一個「年 柱 + 月 柱 + 日 柱 + 時 柱」的字串並回傳
                 	// return baziMap.get("year_pillar") + " " + baziMap.get("month_pillar") + " " + baziMap.get("day_pillar") + " " + baziMap.get("hour_pillar");
                 	return "甲子 丙寅 戊辰 庚午";
                 	// 範例，請依實際邏輯替換
                 }
map LunarAI.SolarToLunar(date solarBirthday)
                 {
                 	/*
                 	 * ======================================================================
                 	 * 函數名稱：LunarAI.SolarToLunar
                 	 * 功能：提供一個純粹的國曆轉農曆功能，並兼容舊的回傳格式。
                 	 *      【最終修正】已移除所有子時換日邏輯。八字排盤的特殊規則
                 	 *      由 Bazi 命名空間的函數自行獨立處理。
                 	 * 命名空間：LunarAI
                 	 * 參數：solarBirthday (date) - 國曆生日
                 	 * 回傳：Map - 包含生日和占卜日的農曆資訊
                 	 * 作者：Gemini (Final Correction)
                 	 * ======================================================================
                 	 */
                 	// 1. 獲取共享的農曆常數資料庫
                 	lunar_constants = thisapp.LunarData.getConstants();
                 	// 2. 直接使用傳入的、未經修改的生日進行計算
                 	birthday_lunar_map = thisapp.LunarAI.calculateLunarDetails(solarBirthday,lunar_constants);
                 	// 3. 為了保持對舊 Workflow 的兼容性，我們仍然需要一個占卜日的 Map
                 	divination_lunar_map = thisapp.Bazi.getDivinationTimeDetails();
                 	// 4. 組合最終的回傳結果
                 	overall_result_map = Map();
                 	overall_result_map.put("生日",birthday_lunar_map);
                 	overall_result_map.put("占卜日",divination_lunar_map);
                 	return overall_result_map;
                 }
