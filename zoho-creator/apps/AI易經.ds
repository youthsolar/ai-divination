	pages
	{
		page DashBoard
		{
			displayname = "Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\twebDeviceConfig='{\"layout\":{\"displayType\":\"plain\",\"design\":\"fluid\",\"style\":\"padding-right:0px;padding-top:0px;padding-bottom:0px;padding-left:0px;\"}}'\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<search \n\telementName='Search'\n\tpaddingTop = '0px'\n\tpaddingLeft = '0px'\n\tpaddingRight = '0px'\n\tpaddingBottom = '0px'\n\tbgtype = 'none'\n\tbgColor = 'transparent'\n\n\tshape = 'flat'\n\tresultComponent = 'report'\n\tlinkName = 'I_Ching_Form_Report'\n\ttarget = 'new-window'\n\tcriteriaString = 'yao.contains(input.searchString)'\n\tfontFamily = 'default'\n\tappLinkName = 'thisapp'\n\tstyle = '4'\n\tplaceholder = 'Enter \u723B'\n\n>\n<searchbar color=\"#000000\" bgColor=\"#FFFFFF\" fontSize=\"15px\"\n/><searchbutton color=\"#FFFFFF\" bgColor=\"#09AB03\" \nfontSize=\"15px\"  /></search>\n</column>\n</row><row>\n\t<column\n   \t\t width='32%'\n   \t>\n\t<panel elementName='Welcome_Panel 1'\n \n >\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpaddingTop = '17px'\n\tpaddingLeft = '17px'\n\tpaddingRight = '0px'\n\tpaddingBottom = '17px'\n\tbgColor = '#FFFFFF'\n\n\t\twidth = '100%'\n\t\thAlign = 'left'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<image  \n\t\tmarginBottom = '0px'\n\tmarginTop = '0px'\n\n\tcolor = '#FF596F'\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\twidth = '40px'\n\theight = '40px'\n\ttype = 'icon'\n\tvalue = 'emoticons-smile'\n\tsize = '22px'\n\tcornerRadius = '10px'\n\ticonType = 'outline'\n/>\n</pc><pc \n\t\tpadding = '5px'\n\n>\n\t<pr \n\t>\n\t<pc \n\t\n>\n\t<text \n\n\tmarginLeft = '10px'\n\tmarginRight = '0px' \n\tmarginBottom = '10px'\n\tcolor = '#000000'\n\tsize = '16px'\n\ttype = 'Text'\n\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\n\n\n\n\n\n\t  value = 'Welcome'\n>\n</text>\n\n</pc>\n</pr><pr \n\t>\n\t<pc \n\t\n>\n\t<text \n\n\tmarginLeft = '10px'\n\tmarginBottom = '0px'\n\tmarginTop = '0px'\n\tcolor = '#1F58B8'\n\tsize = '20px'\n\tbold = 'true' \n\ttype = 'Text'\n\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\n\n\n\n\n\n\t  value = '${zoho.loginuserid}'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>\n</column><column\n   \t\t width='35%'\n   \t>\n\t<panel elementName='Default_Panel 1'\n \n >\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpadding = '0px'\n\tbgColor = '#FAE8FF'\n\n\t\twidth = '100%'\n\t\thAlign = 'center'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpadding = '20px'\n\tbgColor = '#1F58B8'\n\n\t\twidth = '77%'\n\t\thAlign = 'left'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<text \n\n\tcolor = '#FFFFFF'\n\tsize = '20px'\n\ttype = 'Text'\n\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\n\n\n\n\n\n\t  value = 'Total \u6613\u7D93'\n>\n</text>\n\n</pc>\n</pr>\n</pc><pc \n\t\tpaddingTop = '20px'\n\tpaddingLeft = '0px'\n\tpaddingRight = '20px'\n\tpaddingBottom = '20px'\n\tbgColor = '#1F58B8'\n\n\t\twidth = '23%'\n\t\thAlign = 'right'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<image  \n\t\n\tcolor = '#FFFFFF'\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\twidth = '40px'\n\theight = '40px'\n\ttype = 'icon'\n\tvalue = 'business-laptop-71'\n\tsize = '22px'\n\tcornerRadius = '20px'\n\ticonType = 'outline'\n/>\n</pc><pc \n\t\n>\n\t<text \n\n\tcolor = '#FFFFFF'\n\tsize = '20px'\n\tbold = 'true' \n\ttype = 'Form Data'\n\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\n\n\tdisplayType = 'actual'\n\tthousandsSeperator = 'LOCALE'\n\tdecimalSeperator = 'DOT'\n\tnumberScale = 'none'\n\n\n\n\n\t  value = 'thisapp.I_Ching_Form.ID.count'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>\n</column><column\n   \t\t width='33%'\n   \t>\n\t<panel elementName='Panel_Button 1'\n \n >\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpadding = '0px'\n\tbgColor = '#EAE3FF'\n\n\t\twidth = '100%'\n\t\thAlign = 'center'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpaddingTop = '20px'\n\tpaddingLeft = '20px'\n\tpaddingRight = '0px'\n\tpaddingBottom = '20px'\n\tbgColor = '#FF596F'\n\n\t\twidth = '60%'\n\t\thAlign = 'left'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<text \n\n\tmarginRight = '10px' \n\tcolor = '#FFFFFF'\n\tsize = '20px'\n\tbold = 'true' \n\ttype = 'Text'\n\n\tbgColor = 'transparent'\n        bgColorType = 'noFill'\n\n\n\n\n\n\n\t  value = 'Quick Links:'\n>\n</text>\n\n</pc>\n</pr>\n</pc><pc \n\t\tpaddingTop = '20px'\n\tpaddingLeft = '0px'\n\tpaddingRight = '50px'\n\tpaddingBottom = '20px'\n\tbgColor = '#FF596F'\n\n\t\twidth = '40%'\n\t\thAlign = 'right'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n\t\tvAlign = 'middle'\n>\n\t<button \n\t\tmarginLeft = '0px'\n\tmarginRight = '0px' \n\tmarginBottom = '0px'\n\tmarginTop = '0px'\n\n    action = 'OpenForm'\n\t\tcomponentLinkName = 'I_Ching_Form'\n\t\ttarget = 'new-window'\n\tcolor = '#000000'\n\tsize = '12px'\n\ttext ='Add New \u6613\u7D93'\n\t\tbgColor = '#FFFFFF'\n\t\tcornerRadius = '3px' \n/>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>\n</column>\n</row><row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<chart \n\telementName='Chart 1'\n\n\t\n\ttitle = 'Distribution by \u7B26\u4EE45'\n\t\n\t\ttitleColor = '#444444'\n\ttype = 'Bar'\n\txtitle = '\u7B26\u4EE45'\n\tytitle = 'Count of \u7B26\u4EE45'\n\tbgColor = '#FFFFFF'\n\ttheme = 'theme1'\n\tlegendPos = 'none'\n\theightType = 'auto'\n\theightValue = '300px'\n\tappLinkName = 'thisapp'\n\tformLinkName = 'I_Ching_Form'\n\txfield = 'symbol_5'\n\tyfields = 'count:symbol_5'\n\t\tDelugeCriteria = 'symbol_5 is not null &amp;&amp; symbol_5 != &quot;&quot;'\n/>\n\n</column>\n</row><row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<report \n\telementName='Report'\n\n\t\tappLinkName = 'thisapp'\n\t\tlinkName = 'I_Ching_Form_Report'\n\t\n\t\tiszreport = 'false'\n\t\t\t\t\tzc_AddRec = 'false'\n\t\t\t\t\tzc_EditRec = 'false'\n\t\t\t\t\tzc_Print = 'false'\n\t\t\t\t\tzc_Export = 'false'\n\t\t\t\t\tzc_DelRec = 'false'\n\t\t\t\t\tzc_DuplRec = 'false'\n\t\t\t\t\tzc_Search = 'false'\n\t\t\t\t\tzc_EditBulkRec = 'false'\n\t\t\t\t\tzc_BulkDelete = 'false'\n\t\t\t\t\tzc_BulkDuplicate = 'false'\n\theightType = 'auto'\n\theightValue = '700'\n\n/>\n</column>\n</row>\n</layout>\n</zml>"
		}
		page htmlview
		{
			displayname = "生日選擇器"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet' elementName='BirthDateTimeSelector'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet()\ncontent\n&lt;%{\n\t%&gt;\n&lt;div id=&quot;birth-selector-container&quot; style=&quot;max-width:350px;margin:20px auto;padding:20px;border:1px solid #ddd;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);background:#fff;font-family:&apos;Helvetica Neue&apos;,Arial,sans-serif&quot;&gt;\n  \n  &lt;div style=&quot;text-align:center;margin-bottom:20px&quot;&gt;\n    &lt;h3 style=&quot;margin:0;color:#BE6F80;font-size:20px;font-weight:600&quot;&gt;\u3010\u627E\u98A8\u554F\u5E78\u798F\u3011&lt;/h3&gt;\n  &lt;/div&gt;\n\n  &lt;div style=&quot;margin-bottom:16px&quot;&gt;\n    &lt;label style=&quot;display:block;margin-bottom:6px;color:#333;font-weight:500;font-size:14px&quot;&gt;\u897F\u5143\u751F\u65E5&lt;/label&gt;\n    &lt;input \n      id=&quot;birthDate&quot; \n      type=&quot;date&quot; \n      min=&quot;1900-01-01&quot; \n      max=&quot;2035-12-31&quot;\n      value=&quot;2000-01-01&quot;\n      style=&quot;width:100%;max-width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px;box-sizing:border-box;transition:border-color 0.3s;overflow:hidden&quot;\n      onfocus=&quot;this.style.borderColor=&apos;#BE6F80&apos;&quot;\n      onblur=&quot;this.style.borderColor=&apos;#e0e0e0&apos;&quot;\n    &gt;\n  &lt;/div&gt;\n\n  &lt;div style=&quot;margin-bottom:20px&quot;&gt;\n    &lt;label style=&quot;display:block;margin-bottom:6px;color:#333;font-weight:500;font-size:14px&quot;&gt;\u51FA\u751F\u6642\u9593&lt;/label&gt;\n    &lt;input \n      id=&quot;birthTime&quot; \n      type=&quot;time&quot; \n      step=&quot;300&quot;\n      value=&quot;12:00&quot;\n      style=&quot;width:100%;max-width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px;box-sizing:border-box;transition:border-color 0.3s;overflow:hidden&quot;\n      onfocus=&quot;this.style.borderColor=&apos;#BE6F80&apos;&quot;\n      onblur=&quot;this.style.borderColor=&apos;#e0e0e0&apos;&quot;\n    &gt;\n  &lt;/div&gt;\n\n  &lt;!-- \u78BA\u8A8D\u751F\u65E5\u7121\u8AA4 checkbox --&gt;\n  &lt;div style=&quot;margin-bottom:20px;display:flex;align-items:center;gap:8px&quot;&gt;\n    &lt;input \n      id=&quot;confirmBirthData&quot; \n      type=&quot;checkbox&quot; \n      style=&quot;width:16px;height:16px;accent-color:#BE6F80&quot;\n    &gt;\n    &lt;label for=&quot;confirmBirthData&quot; style=&quot;color:#333;font-size:14px;cursor:pointer&quot;&gt;\u78BA\u8A8D\u751F\u65E5\u7121\u8AA4&lt;/label&gt;\n  &lt;/div&gt;\n\n  &lt;button \n    id=&quot;confirmBirth&quot;\n    style=&quot;width:100%;padding:14px;background:#BE6F80;color:#fff;border:0;border-radius:30px;font-size:16px;font-weight:600;cursor:pointer;transition:all 0.3s;box-shadow:0 2px 4px rgba(190,111,128,0.3)&quot;\n    onmouseover=&quot;this.style.transform=&apos;translateY(-2px)&apos;;this.style.boxShadow=&apos;0 4px 8px rgba(190,111,128,0.4)&apos;&quot;\n    onmouseout=&quot;this.style.transform=&apos;translateY(0)&apos;;this.style.boxShadow=&apos;0 2px 4px rgba(190,111,128,0.3)&apos;&quot;\n    onclick=&quot;\n      console.log(&apos;\u6309\u9215\u88AB\u9EDE\u64CA\u4E86&apos;);\n      var dateInput = document.getElementById(&apos;birthDate&apos;);\n      var timeInput = document.getElementById(&apos;birthTime&apos;);\n      var confirmCheckbox = document.getElementById(&apos;confirmBirthData&apos;);\n      var messageDiv = document.getElementById(&apos;birthMessage&apos;);\n      \n      var birthDate = dateInput.value;\n      var birthTime = timeInput.value;\n      \n      console.log(&apos;\u78BA\u8A8D\u6846\u72C0\u614B:&apos;, confirmCheckbox.checked);\n      \n      if (!birthDate) {\n        messageDiv.style.display = &apos;block&apos;;\n        messageDiv.textContent = &apos;\u8ACB\u9078\u64C7\u4F60\u7684\u751F\u65E5&apos;;\n        messageDiv.style.background = &apos;#f8d7da&apos;;\n        messageDiv.style.color = &apos;#721c24&apos;;\n        messageDiv.style.border = &apos;1px solid #f5c6cb&apos;;\n        dateInput.focus();\n        setTimeout(function() { messageDiv.style.display = &apos;none&apos;; }, 3000);\n        return;\n      }\n      \n      if (!birthTime) {\n        messageDiv.style.display = &apos;block&apos;;\n        messageDiv.textContent = &apos;\u8ACB\u9078\u64C7\u51FA\u751F\u6642\u9593&apos;;\n        messageDiv.style.background = &apos;#f8d7da&apos;;\n        messageDiv.style.color = &apos;#721c24&apos;;\n        messageDiv.style.border = &apos;1px solid #f5c6cb&apos;;\n        timeInput.focus();\n        setTimeout(function() { messageDiv.style.display = &apos;none&apos;; }, 3000);\n        return;\n      }\n      \n      if (!confirmCheckbox.checked) {\n        console.log(&apos;\u78BA\u8A8D\u6846\u672A\u52FE\u9078\uFF0C\u986F\u793A\u932F\u8AA4\u8A0A\u606F&apos;);\n        messageDiv.style.display = &apos;block&apos;;\n        messageDiv.textContent = &apos;\u8ACB\u78BA\u8A8D\u751F\u65E5\u7121\u8AA4&apos;;\n        messageDiv.style.background = &apos;#f8d7da&apos;;\n        messageDiv.style.color = &apos;#721c24&apos;;\n        messageDiv.style.border = &apos;1px solid #f5c6cb&apos;;\n        confirmCheckbox.focus();\n        setTimeout(function() { messageDiv.style.display = &apos;none&apos;; }, 3000);\n        return;\n      }\n      \n      var dateObj = new Date(birthDate + &apos;T&apos; + birthTime);\n      var formattedDate = dateObj.toLocaleDateString(&apos;zh-TW&apos;, {\n        year: &apos;numeric&apos;,\n        month: &apos;long&apos;,\n        day: &apos;numeric&apos;\n      });\n      var formattedTime = dateObj.toLocaleTimeString(&apos;zh-TW&apos;, {\n        hour: &apos;2-digit&apos;,\n        minute: &apos;2-digit&apos;,\n        hour12: false\n      });\n      \n      messageDiv.style.display = &apos;block&apos;;\n      messageDiv.textContent = &apos;\u5DF2\u8A18\u9304\uFF1A&apos; + formattedDate + &apos;&apos; + formattedTime;\n      messageDiv.style.background = &apos;#d4edda&apos;;\n      messageDiv.style.color = &apos;#155724&apos;;\n      messageDiv.style.border = &apos;1px solid #c3e6cb&apos;;\n      \n      console.log(&apos;\u751F\u65E5\u6642\u9593\u5DF2\u9078\u64C7:&apos;, {\n        date: birthDate,\n        time: birthTime,\n        datetime: birthDate + &apos;T&apos; + birthTime\n      });\n      \n      // \u900F\u904E SalesIQ SDK \u5BEB\u5165\u8A2A\u5BA2\u8CC7\u8A0A\u548C Session\n      if (typeof $zoho !== &apos;undefined&apos; &amp;&amp; $zoho.salesiq) {\n          // \u66F4\u65B0 SalesIQ \u8A2A\u5BA2\u8CC7\u6599\n          $zoho.salesiq.visitor.set({\n              &apos;Birthday&apos;: birthDate,\n              &apos;BirthTime&apos;: birthTime,\n              &apos;LastInteractionType&apos;: &apos;BirthDataCollection&apos;,\n              &apos;LastInteractionDate&apos;: new Date().toISOString()\n          });\n          \n          // \u540C\u6642\u5BEB\u5165 Session \u4F9B\u63D2\u4EF6\u4F7F\u7528\n          $zoho.salesiq.session.set(&apos;dateOfBirth&apos;, birthDate);\n          $zoho.salesiq.session.set(&apos;timeOfBirth&apos;, birthTime);\n          $zoho.salesiq.session.set(&apos;birthDataConfirmed&apos;, &apos;true&apos;);\n          \n          // \u53D6\u5F97 Visitor ID \u4F9B\u5F8C\u7E8C\u4F7F\u7528\n          var visitorId = $zoho.salesiq.visitor.uniqueid();\n          console.log(&apos;SalesIQ Visitor ID:&apos;, visitorId);\n      }\n      \n      // \u5099\u7528\u65B9\u6848\uFF1A\u4F7F\u7528 postMessage\n      if (typeof parent !== &apos;undefined&apos; &amp;&amp; parent.postMessage) {\n          parent.postMessage({\n              type: &apos;birth_data_collected&apos;,\n              data: {\n                  birthDate: birthDate,\n                  birthTime: birthTime,\n                  dateTime: birthDate + &apos;T&apos; + birthTime,\n                  visitorId: visitorId || &apos;unknown&apos;\n              }\n          }, &apos;*&apos;);\n      }\n    &quot;\n  &gt;\n    \u9001\u51FA\n  &lt;/button&gt;\n\n  &lt;div id=&quot;birthMessage&quot; style=&quot;margin-top:16px;padding:12px;border-radius:6px;font-size:14px;text-align:center;display:none&quot;&gt;&lt;/div&gt;\n\n  &lt;div style=&quot;margin-top:20px;padding-top:16px;border-top:1px solid #f0f0f0&quot;&gt;\n    &lt;details open style=&quot;cursor:pointer&quot;&gt;\n      &lt;summary style=&quot;color:#BE6F80;font-size:13px;font-weight:500&quot;&gt;\u6EAB\u99A8\u63D0\u9192&lt;/summary&gt;\n      &lt;div style=&quot;margin-top:12px;padding:12px;background:#f9f9f9;border-radius:6px;font-size:12px;color:#666&quot;&gt;\n        &lt;p style=&quot;margin:0&quot;&gt;\u6642\u9593\u8D8A\u7CBE\u78BA\uFF0C\u5360\u535C\u7D50\u679C\u8D8A\u6E96\u78BA&lt;/p&gt;\n      &lt;/div&gt;\n    &lt;/details&gt;\n  &lt;/div&gt;\n\n&lt;/div&gt;\n\n\n\n&lt;style&gt;\n@media (max-width: 480px) {\n  #birth-selector-container {\n    max-width: 320px !important;\n    margin: 10px auto !important;\n    padding: 16px !important;\n  }\n}\n\n#birthDate:focus, #birthTime:focus {\n  outline: none;\n  box-shadow: 0 0 0 3px rgba(190, 111, 128, 0.2);\n}\n\n#confirmBirth:active {\n  transform: translateY(1px);\n}\n&lt;/style&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
	}

