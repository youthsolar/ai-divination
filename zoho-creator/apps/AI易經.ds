map Star.getLunarMansion(date solar_date)
                 {
                 	//
                 	// Star.getLunarMansion
                 	//
                 	// @description: 根據國曆生日查詢對應的二十八星宿。
                 	//               此函數會先將國曆轉為農曆，再用農曆月日去查詢星宿總表。
                 	//
                 	// @param solar_date (date) - 必填，使用者的國曆生日。
                 	//
                 	// @return (map) - 回傳一個 map，包含以下鍵值：
                 	//                 "success": (boolean) 操作是否成功。
                 	//                 "mansion_name": (string) 查詢到的星宿名稱 (例如："角宿")。
                 	//                 "error": (string) 錯誤訊息 (如果 success 為 false)。
                 	//
                 	// 初始化回傳的 Map
                 	response = Map();
                 	response.put("success",false);
                 	// 1. 驗證輸入參數
                 	if(solar_date == null)
                 	{
                 		response.put("error","輸入的國曆生日不可為空。");
                 		return response;
                 	}
                 	// 2. 呼叫核心函數將國曆轉換為農曆
                 	lunar_result = thisapp.LunarAI.SolarToLunar(solar_date);
                 	// 3. 檢查轉換結果，並從巢狀 Map 中提取生日資訊
                 	birthday_map = lunar_result.get("生日");
                 	if(birthday_map == null || birthday_map.get("error") != "")
                 	{
                 		// 將底層函數的錯誤訊息向上传遞
                 		error_message = if(birthday_map != null,birthday_map.get("error"),"SolarToLunar 回傳格式不符預期。");
                 		response.put("error","國曆轉農曆失敗：" + error_message);
                 		return response;
                 	}
                 	// 4. 從生日 Map 中獲取純數字的農曆月和日
                 	//    使用純數字欄位是為了避開 "閏四月" 這類文字導致的查詢問題
                 	lunar_month_num = birthday_map.get("lunar_month_numeric");
                 	lunar_day_num = birthday_map.get("lunar_day_numeric");
                 	if(lunar_month_num == null || lunar_day_num == null)
                 	{
                 		response.put("error","從 SolarToLunar 的回傳中找不到 'lunar_month_numeric' 或 'lunar_day_numeric'。");
                 		return response;
                 	}
                 	// 5. 查詢星宿對照總表 (Lunar_Mansion_Atlas)
                 	mansion_record = Lunar_Mansion_Atlas[Month_field == lunar_month_num && Day_field == lunar_day_num];
                 	// 6. 處理查詢結果
                 	if(mansion_record != null)
                 	{
                 		response.put("success",true);
                 		response.put("mansion_name",mansion_record.Mansion_Name);
                 	}
                 	else
                 	{
                 		response.put("error","在星宿對照總表(Lunar_Mansion_Atlas)中找不到對應的記錄。農曆：" + lunar_month_num + "月" + lunar_day_num + "日");
                 	}
                 	return response;
                 }
map Talisman.generateTalismanExplanation(string question_type, map hexagram_info, string talisman_element, string client_name)
                 {
                 	//
                 	// 函數名稱：Talisman.generateTalismanExplanation
                 	// 函數說明：【AI 符令說明生成函數】此函數是提升客戶購買意願的關鍵。它根據卦象的生剋關係、
                 	//             客戶問題類型和推薦的符令，利用 OpenAI 生成一段個人化、有說服力的文字，
                 	//             解釋為何推薦此符令，以及它如何幫助客戶平衡當前狀況。
                 	//
                 	// @param question_type (string) - 客戶問題的類型 (例如："工作", "愛情", "財運")。
                 	// @param hexagram_info (map) - 包含卦象核心資訊的 Map，應有 "appearance" 和 "life_and_death" 兩個 key。
                 	// @param talisman_element (string) - 當前推薦符令的五行屬性 (例如："金", "木", "水", "火", "土")。
                 	// @param client_name (string) - 客戶的稱呼，用於生成更個人化的文案。
                 	//
                 	// @return map - 回傳一個 map，包含處理結果。
                 	//  - success (boolean): true 代表成功，false 代表失敗。
                 	//  - explanation (string): AI 生成的個人化符令說明文字。
                 	//  - error (string): 如果 success 為 false，此欄位會包含錯誤原因。
                 	//
                 	// 初始化回傳值
                 	response_map = Map();
                 	response_map.put("success",false);
                 	try 
                 	{
                 		// --- 步驟 1: 參數驗證 ---
                 		if(question_type == null || question_type.trim() == "" || hexagram_info == null || talisman_element == null || talisman_element.trim() == "")
                 		{
                 			response_map.put("error","輸入參數不完整，無法生成符令說明。");
                 			return response_map;
                 		}
                 		// --- 步驟 2: 設計 AI Prompt ---
                 		appearance = hexagram_info.get("appearance");
                 		life_and_death = hexagram_info.get("life_and_death");
                 		// 系統 Prompt: 設定 AI 的角色和任務
                 		system_prompt = "你是一位精通易經五行生剋哲學的靈學導師。你的語氣溫和、專業且充滿智慧。你的核心任務是解釋一張「五行符令」如何幫助客戶平衡他們當前的能量狀態。你的解釋必須基於卦象的「生剋關係」，並結合客戶關心的「問題類型」，讓說明聽起來既專業又有針對性。你的最終目標是增加客戶的信任感和購買意願。";
                 		// 使用者 Prompt: 根據實際參數組合指令
                 		// 這裡我們為不同的生剋關係設計不同的解釋框架，讓 AI 的回答更有邏輯
                 		explanation_framework = "";
                 		if(life_and_death == "相生")
                 		{
                 			explanation_framework = "此卦象呈現「相生」的祥和之兆，代表能量流動順暢。這張「" + talisman_element + "」屬性的符令，作用在於「順勢增強」，如同為順行的舟船加上一把推力，能幫助您在「" + question_type + "」的道路上更加穩固、順利，放大目前的良好態勢，使其效果加倍。";
                 		}
                 		else if(life_and_death == "相剋")
                 		{
                 			explanation_framework = "此卦象呈現「相剋」的挑戰之象，代表能量間存在一些阻礙與不協調。這張「" + talisman_element + "」屬性的符令，作用在於「制衡化解」。它能引入一股新的能量來調和衝突，緩解您在「" + question_type + "」方面遇到的壓力與阻礙，避免情況惡化，並尋求突破的機會。";
                 		}
                 		else if(life_and_death == "持之")
                 		{
                 			explanation_framework = "此卦象呈現「持之」(比和)的穩定狀態，代表當前能量均衡但缺乏突破的動力。這張「" + talisman_element + "」屬性的符令，作用在於「鞏固強化」。它能為您注入一股純粹而集中的力量，幫助您在「" + question_type + "」的目標上更加專注，鞏固現有基礎，並積蓄下一步躍升的能量。";
                 		}
                 		else if(life_and_death == "弱生" || life_and_death == "弱剋")
                 		{
                 			explanation_framework = "此卦象呈現較為微妙的能量互動關係，需要溫和的調整。這張「" + talisman_element + "」屬性的符令，作用在於「扶助與微調」。它像一位溫柔的嚮導，能精準地補充您在「" + question_type + "」方面所需的那份細微能量，或化解潛在的小阻礙，讓整體運勢趨於和諧平順。";
                 		}
                 		else if(life_and_death == "立破")
                 		{
                 			explanation_framework = "此卦象呈現「立破」的轉變契機，代表舊有結構即將改變，是破舊立新的時刻。這張「" + talisman_element + "」屬性的符令，作用在於「重建根基」。它能提供強大的守護與支持力量，幫助您在「" + question_type + "」的重大轉變中站穩腳步，掃除障礙，為一個全新的、更美好的開始奠定穩固基礎。";
                 		}
                 		else
                 		{
                 			explanation_framework = "這張「" + talisman_element + "」屬性的符令，是根據您本次占卜的「" + appearance + "」卦象所特別推薦的。它能針對您在「" + question_type + "」方面所關心的問題，提供最核心的能量支持與平衡。";
                 		}
                 		user_prompt = "請根據以下框架，為客戶「" + client_name + "」生成一段約 80-100 字、有說服力的個人化符令購買說明。請直接輸出最終文案，不要包含任何前言或標題。\n\n解釋框架：" + explanation_framework;
                 		// --- 步驟 3: 呼叫 OpenAI API (使用 postUrl) ---
                 		// 經過多次測試，Deluge 的 invokeUrl 在處理複雜字串 content 時存在解析器 Bug。
                 		// 因此，我們回歸使用在此專案中已驗證可行的 postUrl + Map.toString() 的方式。
                 		// 1. 建立訊息列表
                 		messages = List();
                 		system_message = Map();
                 		system_message.put("role","system");
                 		system_message.put("content",system_prompt);
                 		messages.add(system_message);
                 		user_message = Map();
                 		user_message.put("role","user");
                 		user_message.put("content",user_prompt);
                 		messages.add(user_message);
                 		// 2. 建立完整的 API 參數 Map
                 		api_params = Map();
                 		api_params.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		api_params.put("messages",messages);
                 		api_params.put("max_tokens",400);
                 		api_params.put("temperature",0.75);
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		// 3. 使用 postUrl 進行 API 呼叫
                 		api_response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,api_params.toString(),headers);
                 		// --- 步驟 4: 解析 API 回應 ---
                 		// postUrl 的回應直接就是 JSON 解析後的 Map，不需額外處理
                 		if(api_response.get("choices") != null && api_response.get("choices").size() > 0)
                 		{
                 			ai_explanation = api_response.get("choices").get(0).get("message").get("content").trim();
                 			// 簡單檢查回應是否合理
                 			if(ai_explanation.length() > 20)
                 			{
                 				response_map.put("success",true);
                 				response_map.put("explanation",ai_explanation);
                 			}
                 			else
                 			{
                 				// AI 回應長度異常，提供一個通用但仍具備基本邏輯的回應
                 				response_map.put("success",true);
                 				response_map.put("explanation",explanation_framework);
                 				// 使用我們預設的框架作為備用
                 				response_map.put("note","AI 回應異常，已使用預設解釋框架。");
                 			}
                 		}
                 		else
                 		{
                 			// API 回應格式異常
                 			response_map.put("error","OpenAI API 回應格式異常或為空。API Response: " + api_response);
                 		}
                 	}
                 	catch (e)
                 	{
                 		// 捕獲所有未預期的錯誤
                 		response_map.put("error","在生成符令說明過程中發生未預期錯誤：" + e);
                 	}
                 	return response_map;
                 }
map Talisman.getBasicRecommendation(string divination_log_id)
                 {
                 	//
                 	// 函數名稱：Talisman.getBasicRecommendation
                 	// 函數說明：此為基礎符令推薦函數。根據提供的「占卜記錄ID」，查詢客戶下一次應推薦的符令資料。
                 	//
                 	// @param divination_log_id (string) - 「占卜記錄」(Divination_Logs) 表單的紀錄 ID。
                 	//
                 	// @return map - 回傳一個 map，包含處理結果、推薦符令的資料或錯誤訊息。
                 	//  - success (boolean): true 代表成功，false 代表失敗。
                 	//  - talisman_index (int): 推薦的符令編號 (1-5)。
                 	//  - talisman_element (string): 推薦符令的五行屬性 (例如："金", "木", "水", "火", "土")。
                 	//  - hexagram_image (image): 該卦象的本位卦符圖片 (Gua_symbol_Image)。
                 	//  - hexagram_info (map): 包含卦象的名稱(appearance)與生剋(life_and_death)
                 	//  - message (string): 執行的結果訊息。
                 	//  - error (string): 如果 success 為 false，此欄位會包含錯誤原因。
                 	//
                 	// 初始化回傳值，預設為失敗
                 	response_map = Map();
                 	response_map.put("success",false);
                 	try 
                 	{
                 		// 1. 參數驗證
                 		if(divination_log_id == null || divination_log_id.trim() == "")
                 		{
                 			response_map.put("error","輸入的占卜記錄 ID 為空。");
                 			return response_map;
                 		}
                 		// 2. 查詢占卜記錄
                 		divination_log = Divination_Logs[ID == divination_log_id.toLong()];
                 		if(divination_log.count() == 0)
                 		{
                 			response_map.put("error","根據 ID [" + divination_log_id + "] 找不到對應的占卜記錄。");
                 			return response_map;
                 		}
                 		// 3. 檢查當前推薦進度
                 		current_talisman_index = divination_log.Current_Talisman_Index;
                 		current_talisman_index_num = current_talisman_index.toLong();
                 		if(current_talisman_index_num > 5)
                 		{
                 			response_map.put("success",true);
                 			// 這是一個正常的業務流程，不算錯誤
                 			response_map.put("message","此占卜的所有符令皆已推薦完畢，已達推薦上限。");
                 			response_map.put("talisman_index",6);
                 			// 使用 6 來表示已完成
                 			return response_map;
                 		}
                 		// 4. 查詢關聯的易經卦象資料
                 		hexagram_record_id = divination_log.Hexagram_Code;
                 		if(hexagram_record_id == null)
                 		{
                 			response_map.put("error","此占卜記錄缺少關聯的卦象資訊。");
                 			return response_map;
                 		}
                 		hexagram_record = I_Ching_Form[ID == hexagram_record_id];
                 		if(hexagram_record.count() == 0)
                 		{
                 			response_map.put("error","根據卦象 ID [" + hexagram_record_id + "] 找不到對應的易經資料。");
                 			return response_map;
                 		}
                 		// 5. 動態獲取對應的符令資料
                 		// 由於 Deluge 的紀錄物件不支援動態 .get() 語法，我們使用 if/else if 來明確指定欄位。
                 		talisman_element = null;
                 		if(current_talisman_index_num == 1)
                 		{
                 			talisman_element = hexagram_record.symbol_1;
                 		}
                 		else if(current_talisman_index_num == 2)
                 		{
                 			talisman_element = hexagram_record.symbol_2;
                 		}
                 		else if(current_talisman_index_num == 3)
                 		{
                 			talisman_element = hexagram_record.symbol_3;
                 		}
                 		else if(current_talisman_index_num == 4)
                 		{
                 			talisman_element = hexagram_record.symbol_4;
                 		}
                 		else if(current_talisman_index_num == 5)
                 		{
                 			talisman_element = hexagram_record.symbol_5;
                 		}
                 		hexagram_image = hexagram_record.Gua_symbol_Image;
                 		// 準備 AI 解說需要的額外資料
                 		hexagram_info = Map();
                 		hexagram_info.put("appearance",hexagram_record.appearance);
                 		hexagram_info.put("life_and_death",hexagram_record.life_and_death);
                 		// 6. 組合成功的回應
                 		response_map.put("success",true);
                 		response_map.put("message","成功獲取下一張推薦符令資料。");
                 		response_map.put("talisman_index",current_talisman_index);
                 		response_map.put("talisman_element",talisman_element);
                 		response_map.put("hexagram_image",hexagram_image);
                 		response_map.put("hexagram_info",hexagram_info);
                 	}
                 	catch (e)
                 	{
                 		// 捕獲所有未預期的錯誤
                 		response_map.put("error","在處理過程中發生未預期錯誤：" + e);
                 	}
                 	return response_map;
                 }
map Talisman.getCompleteRecommendation(string divination_log_id, string client_name)
                 {
                 	//
                 	// 函數名稱：Talisman.getCompleteRecommendation
                 	// 函數說明：【完整符令推薦主函數】此為一個高層級的整合函數，作為符令推薦系統的主要入口。
                 	//             它會自動完成所有子任務，包括獲取基礎推薦、呼叫 AI 生成個人化說明，
                 	//             並將所有資訊打包成一個完整的推薦方案回傳。
                 	//
                 	// @param divination_log_id (string) - 「占卜記錄」(Divination_Logs) 表單的紀錄 ID。
                 	// @param client_name (string) - 客戶的稱呼，用於生成更個人化的 AI 文案。
                 	//
                 	// @return map - 包含完整推薦資訊的 map。
                 	//  - success (boolean): 整個流程是否成功。
                 	//  - message (string): 描述執行結果的訊息。
                 	//  - recommendation_data (map): 包含所有推薦細節的子 Map，或在流程結束時為 null。
                 	//    - talisman_index (int): 推薦的符令編號 (1-6，6代表已完成)。
                 	//    - talisman_element (string): 符令的五行屬性。
                 	//    - hexagram_image (image): 卦象的圖片。
                 	//    - ai_explanation (string): AI 生成的個人化說明文字。
                 	//    - price (int): 符令價格。
                 	//  - error (string): 如果 success 為 false，此欄位會包含錯誤原因。
                 	//
                 	final_response = Map();
                 	final_response.put("success",false);
                 	final_response.put("recommendation_data",null);
                 	try 
                 	{
                 		info "--- 步驟 1: 呼叫基礎推薦函數 ---";
                 		basic_rec_result = thisapp.Talisman.getBasicRecommendation(divination_log_id);
                 		if(basic_rec_result.get("success") == false)
                 		{
                 			// 如果基礎推薦失敗，直接回傳其錯誤資訊
                 			final_response.put("error","獲取基礎推薦失敗：" + basic_rec_result.get("error"));
                 			return final_response;
                 		}
                 		talisman_index = basic_rec_result.get("talisman_index");
                 		// --- 步驟 2: 檢查推薦是否已達上限 ---
                 		if(talisman_index > 5)
                 		{
                 			// 已完成所有推薦，這是一個正常的結束流程
                 			final_response.put("success",true);
                 			final_response.put("message","此占卜的所有符令皆已推薦完畢，感謝您的支持！");
                 			return final_response;
                 		}
                 		info "--- 步驟 3: 呼叫 AI 生成個人化說明 ---";
                 		// 從基礎推薦結果中獲取所需參數
                 		hexagram_info = basic_rec_result.get("hexagram_info");
                 		talisman_element = basic_rec_result.get("talisman_element");
                 		// 需要從占卜記錄中獲取問題類型
                 		divination_log = Divination_Logs[ID == divination_log_id.toLong()];
                 		question_type = divination_log.Question_Type_AI;
                 		if(question_type == null)
                 		{
                 			question_type = "綜合";
                 			// 給一個預設值
                 		}
                 		ai_explanation = "系統預設推薦說明：這張 " + talisman_element + " 符令是針對您本次 " + hexagram_info.get("appearance") + " 卦象所推薦，有助於平衡您在 " + question_type + " 方面的能量。";
                 		ai_result = thisapp.Talisman.generateTalismanExplanation(question_type,hexagram_info,talisman_element,client_name);
                 		if(ai_result.get("success"))
                 		{
                 			ai_explanation = ai_result.get("explanation");
                 			info "AI 說明生成成功。";
                 		}
                 		else
                 		{
                 			info "AI 說明生成失敗：" + ai_result.get("error") + "，將使用預設說明。";
                 		}
                 		// --- 步驟 4: 打包最終推薦結果 ---
                 		recommendation_data = Map();
                 		recommendation_data.put("talisman_index",talisman_index);
                 		recommendation_data.put("talisman_element",talisman_element);
                 		recommendation_data.put("hexagram_image",basic_rec_result.get("hexagram_image"));
                 		recommendation_data.put("ai_explanation",ai_explanation);
                 		recommendation_data.put("price",360);
                 		final_response.put("success",true);
                 		final_response.put("message","成功生成完整推薦方案。");
                 		final_response.put("recommendation_data",recommendation_data);
                 	}
                 	catch (e)
                 	{
                 		final_response.put("error","在生成完整推薦過程中發生未預期錯誤：" + e);
                 		info "系統錯誤：" + e;
                 	}
                 	return final_response;
                 }
string Talisman.getRecommendationReason(string life_death, string element, string question_type)
                 {
                 	//
                 	// 函數名稱：Talisman.getRecommendationReason
                 	// 功能：根據生剋性質和五行生成推薦理由
                 	// 參數：
                 	//   - life_death: 生剋性質
                 	//   - element: 符令五行
                 	//   - question_type: 問題類型
                 	// 回傳：推薦理由字串
                 	//
                 	reason = "";
                 	if(life_death == "持之")
                 	{
                 		reason = "保持穩定，持續發展。";
                 	}
                 	else if(life_death == "相生")
                 	{
                 		reason = "增強運勢，促進發展。";
                 	}
                 	else if(life_death == "相剋")
                 	{
                 		reason = "化解衝突，平衡能量。";
                 	}
                 	else if(life_death == "弱生")
                 	{
                 		reason = "溫和提升，漸進改善。";
                 	}
                 	else if(life_death == "弱剋")
                 	{
                 		reason = "緩解壓力，減輕阻礙。";
                 	}
                 	else if(life_death == "立破")
                 	{
                 		reason = "突破困境，開創新局。";
                 	}
                 	else
                 	{
                 		reason = "平衡能量，改善運勢。";
                 	}
                 	// 根據問題類型加入具體建議
                 	if(question_type == "工作")
                 	{
                 		reason = reason + "特別適合提升工作運勢和職場發展。";
                 	}
                 	else if(question_type == "感情")
                 	{
                 		reason = reason + "有助於改善感情關係和人際互動。";
                 	}
                 	else if(question_type == "財運")
                 	{
                 		reason = reason + "能夠增強財運和投資機會。";
                 	}
                 	else if(question_type == "健康")
                 	{
                 		reason = reason + "有助於身體健康和心靈平衡。";
                 	}
                 	else if(question_type == "學業")
                 	{
                 		reason = reason + "適合提升學習效果和考試運勢。";
                 	}
                 	else if(question_type == "家庭")
                 	{
                 		reason = reason + "有助於家庭和諧和親子關係。";
                 	}
                 	else if(question_type == "事業")
                 	{
                 		reason = reason + "能夠促進事業發展和創業成功。";
                 	}
                 	return reason;
                 }
map Talisman.getTalismanRecommendation(int divination_log_id)
                 {
                 	//
                 	// 函式名稱：Talisman.getTalismanRecommendation
                 	// 功能描述：根據指定的占卜記錄，推薦下一張適合的數位符令。
                 	//
                 	// 參數：
                 	// divination_log_id (int)：來自 "Divination_Logs" 表單的紀錄 ID。
                 	//
                 	// 回傳值 (map)：
                 	// success (boolean)：操作是否成功。
                 	// recommendation_available (boolean)：是否還有可推薦的符令。
                 	// message (string)：操作結果的文字說明。
                 	// talisman_index (int)：推薦的符令序列號 (1-5)。
                 	// talisman_element (string)：推薦符令的五行屬性 (金、木、水、火、土)。
                 	// hexagram_code (string)：對應的易經爻碼 (例如 "111010")。
                 	// hexagram_appearance (string)：卦象的中文名稱 (例如 "天水訟")。
                 	// hexagram_image_url (string)：卦象的本位卦符圖片 URL。
                 	// divination_log_id (int)：傳入的占卜記錄 ID。
                 	// error (string)：如果 success 為 false，則包含錯誤訊息。
                 	//
                 	final_response = Map();
                 	final_response.put("success",false);
                 	final_response.put("recommendation_available",false);
                 	final_response.put("divination_log_id",divination_log_id);
                 	try 
                 	{
                 		// 步驟 1：根據傳入的 ID 查找占卜記錄
                 		log_record = Divination_Logs[ID == divination_log_id.toLong()];
                 		if(log_record == null)
                 		{
                 			final_response.put("error","找不到 ID 為 " + divination_log_id + " 的占卜記錄。");
                 			return final_response;
                 		}
                 		// 步驟 2：從占卜記錄中獲取當前符令進度與對應的爻碼
                 		// Current_Talisman_Index 記錄了「已購買」的符令數量，初始值為 0
                 		current_index = ifnull(log_record.Current_Talisman_Index,0);
                 		hexagram_code = log_record.Hexagram_Code;
                 		// 步驟 3：計算下一張要推薦的符令序列
                 		next_talisman_index = current_index + 1;
                 		// 步驟 4：檢查是否所有符令都已推薦完畢
                 		if(next_talisman_index > 5)
                 		{
                 			final_response.put("success",true);
                 			final_response.put("recommendation_available",false);
                 			final_response.put("message","此卦象的5張符令均已推薦完畢。");
                 			return final_response;
                 		}
                 		// 步驟 5：根據爻碼查詢易經表單，獲取符令與卦象的詳細資料
                 		// **型別轉換**：I_Ching_Form 的 'yao' (文字) vs log_record.Hexagram_Code (數字)
                 		i_ching_record = I_Ching_Form[yao == hexagram_code.toString()];
                 		if(i_ching_record == null)
                 		{
                 			final_response.put("error","在 I_Ching_Form 中找不到爻碼為 " + hexagram_code + " 的資料。");
                 			return final_response;
                 		}
                 		// 步驟 6：根據推薦的序列號 (1-5)，動態獲取對應符令的五行屬性
                 		talisman_element = "";
                 		if(next_talisman_index == 1)
                 		{
                 			talisman_element = i_ching_record.symbol_1;
                 		}
                 		else if(next_talisman_index == 2)
                 		{
                 			talisman_element = i_ching_record.symbol_2;
                 		}
                 		else if(next_talisman_index == 3)
                 		{
                 			talisman_element = i_ching_record.symbol_3;
                 		}
                 		else if(next_talisman_index == 4)
                 		{
                 			talisman_element = i_ching_record.symbol_4;
                 		}
                 		else if(next_talisman_index == 5)
                 		{
                 			talisman_element = i_ching_record.symbol_5;
                 		}
                 		// 步驟 7：獲取並解析卦符圖片的 URL
                 		// Zoho Creator 的圖片欄位會回傳一個 <img> HTML 標籤，我們需要從中提取 src 屬性
                 		image_html = i_ching_record.Gua_symbol_Image;
                 		image_url = "";
                 		if(image_html != null && image_html.contains("src='"))
                 		{
                 			start_index = image_html.indexOf("'") + 1;
                 			end_index = image_html.lastIndexOf("'");
                 			if(start_index < end_index)
                 			{
                 				image_url = image_html.substring(start_index,end_index);
                 			}
                 		}
                 		// 步驟 8：準備成功的回傳結果
                 		final_response.put("success",true);
                 		final_response.put("recommendation_available",true);
                 		final_response.put("message","成功推薦第 " + next_talisman_index + " 張符令。");
                 		final_response.put("talisman_index",next_talisman_index);
                 		final_response.put("talisman_element",talisman_element);
                 		final_response.put("hexagram_code",hexagram_code);
                 		final_response.put("hexagram_appearance",i_ching_record.appearance);
                 		final_response.put("hexagram_image_url",image_url);
                 	}
                 	catch (e)
                 	{
                 		final_response.put("error","在推薦符令時發生未知錯誤：" + e);
                 	}
                 	return final_response;
                 }
map Tarot.completeTarotDivination(string firstName, string lastName, string phoneNumber, string email, string dateOfBirth, string timeOfBirth, string userQuestion)
                 {
                 	finalResponse = Map();
                 	try 
                 	{
                 		if(firstName == null || firstName.trim() == "" || lastName == null || lastName.trim() == "" || userQuestion == null || userQuestion.trim() == "")
                 		{
                 			finalResponse.put("success",false);
                 			finalResponse.put("error","必要參數不完整：姓名和問題為必填項目");
                 			return finalResponse;
                 		}
                 		fullBirthDatetime = "";
                 		if(dateOfBirth != null && dateOfBirth.trim() != "")
                 		{
                 			if(timeOfBirth != null && timeOfBirth.trim() != "")
                 			{
                 				fullBirthDatetime = dateOfBirth + " " + timeOfBirth + ":00";
                 			}
                 			else
                 			{
                 				fullBirthDatetime = dateOfBirth + " 12:00:00";
                 			}
                 		}
                 		else
                 		{
                 			fullBirthDatetime = "1990-01-01 12:00:00";
                 		}
                 		clientId = "";
                 		existingClients = List();
                 		if(phoneNumber != null && phoneNumber.trim() != "")
                 		{
                 			existingClients = Clients_Report[Phone_Number == phoneNumber];
                 		}
                 		else if(email != null && email.trim() != "")
                 		{
                 			existingClients = Clients_Report[Email == email];
                 		}
                 		if(existingClients.count() > 0)
                 		{
                 			for each  existingClient in existingClients
                 			{
                 				clientId = existingClient.ID;
                 				// 直接使用現有客戶，不進行更新（避免複雜的 Name field 更新問題）
                 				break;
                 			}
                 		}
                 		else
                 		{
                 			clientInsertResponse = insert into Clients_Report
                 			[
                 				Added_User=zoho.loginuser
                 				Visitor_Name.first_name=firstName
                 				Visitor_Name.last_name=lastName
                 				Client_Type="真實"
                 				Phone_Number=if(phoneNumber != null && phoneNumber.trim() != "",phoneNumber,null)
                 				Email=if(email != null && email.trim() != "",email,null)
                 				Date_Of_Birth=fullBirthDatetime.toDateTime()
                 				Timezone_Of_Birth="(UTC+08:00) 台北 (Asia/Taipei)"
                 			];
                 			clientId = clientInsertResponse;
                 		}
                 		// 調用塔羅占卜函數（2個參數：client_id, user_question）
                 		tarotResult = thisapp.Tarot.TarotDivinationFunction(clientId.toString(),userQuestion);
                 		if(tarotResult.get("success") == true)
                 		{
                 			divinationId = tarotResult.get("divination_id");
                 			primaryPolarity = tarotResult.get("primary_polarity");
                 			primaryCardId = tarotResult.get("primary_card_id");
                 			fullName = lastName + firstName;
                 			// 取得完整的占卜記錄以提供詳細資訊
                 			completeDivinationInfo = "";
                 			try 
                 			{
                 				divinationRecords = Divination_Logs[ID == divinationId.toLong()];
                 				for each  divinationRecord in divinationRecords
                 				{
                 					// 建立完整的占卜資訊
                 					completeDivinationInfo = "? **" + fullName + " 的塔羅占卜完成！**\n\n";
                 					completeDivinationInfo = completeDivinationInfo + "? **你的問題：** " + userQuestion + "\n";
                 					completeDivinationInfo = completeDivinationInfo + "? **主卦趨勢：** " + primaryPolarity + "\n";
                 					completeDivinationInfo = completeDivinationInfo + "? **占卜編號：** " + divinationId + "\n\n";
                 					// 加入五張牌的詳細資訊
                 					completeDivinationInfo = completeDivinationInfo + "? **詳細牌陣解讀：**\n\n";
                 					// 牌卡 1
                 					if(divinationRecord.Position_a_Meaning != null && divinationRecord.Position_a_Meaning != "")
                 					{
                 						completeDivinationInfo = completeDivinationInfo + "**牌位 1** - " + divinationRecord.Position_a_Meaning + "\n\n";
                 					}
                 					// 牌卡 2
                 					if(divinationRecord.Position_b_Meaning != null && divinationRecord.Position_b_Meaning != "")
                 					{
                 						completeDivinationInfo = completeDivinationInfo + "**牌位 2** - " + divinationRecord.Position_b_Meaning + "\n\n";
                 					}
                 					// 牌卡 3
                 					if(divinationRecord.Position_c_Meaning != null && divinationRecord.Position_c_Meaning != "")
                 					{
                 						completeDivinationInfo = completeDivinationInfo + "**牌位 3** - " + divinationRecord.Position_c_Meaning + "\n\n";
                 					}
                 					// 牌卡 4
                 					if(divinationRecord.Position_d_Meaning != null && divinationRecord.Position_d_Meaning != "")
                 					{
                 						completeDivinationInfo = completeDivinationInfo + "**牌位 4** - " + divinationRecord.Position_d_Meaning + "\n\n";
                 					}
                 					// 牌卡 5
                 					if(divinationRecord.Position_e_Meaning != null && divinationRecord.Position_e_Meaning != "")
                 					{
                 						completeDivinationInfo = completeDivinationInfo + "**牌位 5** - " + divinationRecord.Position_e_Meaning + "\n\n";
                 					}
                 					// 加入 AI 解讀
                 					if(divinationRecord.AI_Interpretation != null && divinationRecord.AI_Interpretation != "")
                 					{
                 						completeDivinationInfo = completeDivinationInfo + "? **AI 個人化解讀：**\n\n";
                 						completeDivinationInfo = completeDivinationInfo + divinationRecord.AI_Interpretation + "\n\n";
                 					}
                 					completeDivinationInfo = completeDivinationInfo + "✨ 想了解你的專屬符令推薦嗎？請回覆「符令」來查看！";
                 					break;
                 				}
                 			}
                 			catch (detailError)
                 			{
                 				// 如果取得詳細資訊失敗，使用簡化版本
                 				completeDivinationInfo = "? " + fullName + " 的塔羅占卜完成！\n\n";
                 				completeDivinationInfo = completeDivinationInfo + "? 你的問題：" + userQuestion + "\n\n";
                 				completeDivinationInfo = completeDivinationInfo + "? 主卦趨勢：" + primaryPolarity + "\n";
                 				completeDivinationInfo = completeDivinationInfo + "? 占卜記錄：" + divinationId + "\n\n";
                 				completeDivinationInfo = completeDivinationInfo + "? 詳細解讀正在準備中，請稍候片刻...";
                 				completeDivinationInfo = completeDivinationInfo + "\n\n錯誤：" + detailError;
                 			}
                 			finalResponse.put("success",true);
                 			finalResponse.put("message",completeDivinationInfo);
                 			finalResponse.put("clientId",clientId);
                 			finalResponse.put("divinationId",divinationId);
                 			finalResponse.put("primaryPolarity",primaryPolarity);
                 			finalResponse.put("primaryCardId",primaryCardId);
                 			finalResponse.put("fullName",fullName);
                 		}
                 		else
                 		{
                 			errorMessage = "很抱歉，占卜過程中遇到了一些靈性干擾。請稍後再試，或調整你的問題重新占卜。";
                 			if(tarotResult.get("message") != null)
                 			{
                 				errorMessage = errorMessage + "\n\n技術訊息：" + tarotResult.get("message");
                 			}
                 			finalResponse.put("success",false);
                 			finalResponse.put("error",errorMessage);
                 			finalResponse.put("clientId",clientId);
                 		}
                 	}
                 	catch (e)
                 	{
                 		finalResponse.put("success",false);
                 		finalResponse.put("error","系統發生意外錯誤：" + e);
                 	}
                 	return finalResponse;
                 }
map Tarot.determinePrimaryCard(list card_ids, list reversed_statuses)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]] [[memory:6341405]]
                 	// ==================================================================================
                 	// 函數名稱：Tarot.determinePrimaryCard
                 	// 函數目的：【主卦代表牌判斷函數】
                 	//
                 	// 根據主副卦理論（少數為主導）和牌卡優先級規則，從5張牌中選出主卦代表牌
                 	//
                 	// 優先級規則：
                 	// 1. 大阿爾克那 > 小阿爾克那
                 	// 2. 宮廷牌(11-14) > 非宮廷牌(1-10) 
                 	// 3. 數字大 > 數字小
                 	// 4. 火 > 水 > 風 > 土
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// card_ids (list) - 5張牌的ID列表
                 	// reversed_statuses (list) - 5張牌的正逆位狀態列表 (true=逆位, false=正位)
                 	//
                 	// 回傳：
                 	// {"success": true/false, "primary_polarity": "正位/逆位", "primary_card_id": 牌卡ID}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	result = Map();
                 	try 
                 	{
                 		// --- 步驟 1: 計算主卦極性（少數為主導）---
                 		reversed_count = 0;
                 		total_cards = reversed_statuses.size();
                 		for each  is_reversed in reversed_statuses
                 		{
                 			if(is_reversed == true)
                 			{
                 				reversed_count = reversed_count + 1;
                 			}
                 		}
                 		// 判斷主卦極性
                 		primary_polarity = "";
                 		if(reversed_count <= total_cards / 2)
                 		{
                 			primary_polarity = "逆位";
                 			// 逆位是少數，為主卦
                 		}
                 		else
                 		{
                 			primary_polarity = "正位";
                 			// 正位是少數，為主卦
                 		}
                 		// --- 步驟 2: 篩選出主卦極性的牌 ---
                 		primary_card_ids = List();
                 		// 使用 Deluge 支援的迴圈方式
                 		indices = {0,1,2,3,4};
                 		for each  i in indices
                 		{
                 			if(i < card_ids.size())
                 			{
                 				card_id = card_ids.get(i);
                 				is_reversed = reversed_statuses.get(i);
                 				// 檢查是否符合主卦極性
                 				card_matches_primary = false;
                 				if(primary_polarity == "逆位" && is_reversed == true)
                 				{
                 					card_matches_primary = true;
                 				}
                 				else if(primary_polarity == "正位" && is_reversed == false)
                 				{
                 					card_matches_primary = true;
                 				}
                 				if(card_matches_primary)
                 				{
                 					primary_card_ids.add(card_id);
                 				}
                 			}
                 		}
                 		// --- 步驟 3: 從主卦牌中選出優先級最高的代表牌 ---
                 		if(primary_card_ids.size() > 0)
                 		{
                 			best_card_id = null;
                 			best_priority_score = -1;
                 			for each  card_id in primary_card_ids
                 			{
                 				// 查詢牌卡詳細資訊
                 				card_collection = All_Tarot_Cards[ID == card_id];
                 				// DEBUG: 檢查是否找到牌卡
                 				if(card_collection.count() == 0)
                 				{
                 					// 找不到牌卡，跳過此ID
                 					continue;
                 				}
                 				for each  card_record in card_collection
                 				{
                 					// 計算優先級分數
                 					priority_score = 0;
                 					// 1. 大阿爾克那優先 (加 10000 分)
                 					if(card_record.Minor_Arcana == false)
                 					{
                 						priority_score = priority_score + 10000;
                 					}
                 					// 2. 數字分數 (直接加數字值 * 100)
                 					if(card_record.Element_Card_Number != null)
                 					{
                 						priority_score = priority_score + card_record.Element_Card_Number * 100;
                 					}
                 					// 3. 宮廷牌加分 (11-14 再加 1000 分)
                 					if(card_record.Element_Card_Number != null && card_record.Element_Card_Number >= 11)
                 					{
                 						priority_score = priority_score + 1000;
                 					}
                 					// 4. 五行元素分數 (火=4, 水=3, 風=2, 土=1)
                 					element = "";
                 					if(primary_polarity == "逆位")
                 					{
                 						element = card_record.Reversed_Outsight_Element;
                 					}
                 					else
                 					{
                 						element = card_record.Outsight_Element;
                 					}
                 					if(element == "火")
                 					{
                 						priority_score = priority_score + 4;
                 					}
                 					else if(element == "水")
                 					{
                 						priority_score = priority_score + 3;
                 					}
                 					else if(element == "風")
                 					{
                 						priority_score = priority_score + 2;
                 					}
                 					else if(element == "土")
                 					{
                 						priority_score = priority_score + 1;
                 					}
                 					// 更新最佳選擇
                 					if(priority_score > best_priority_score)
                 					{
                 						best_priority_score = priority_score;
                 						best_card_id = card_id;
                 					}
                 					break;
                 				}
                 			}
                 			result.put("success",true);
                 			result.put("primary_polarity",primary_polarity);
                 			result.put("primary_card_id",best_card_id);
                 		}
                 		else
                 		{
                 			result.put("success",false);
                 			result.put("error","沒有找到符合主卦極性的牌");
                 		}
                 	}
                 	catch (e)
                 	{
                 		result.put("success",false);
                 		result.put("error","主卦分析發生錯誤：" + e);
                 	}
                 	return result;
                 }
list Tarot.drawRandomSpread()
                 {
                 	// =========================================================================
                 	// 本函數使用「ID列表隨機法」為「占卜塔羅」抽出一個五張牌的牌陣。
                 	// @return (list) - 一個包含五張牌結果圖(Map)的列表。
                 	//
                 	// 版本 3.0 更新：
                 	// - 採用全新的、更穩健的抽牌邏輯，只對簡單的ID列表進行隨機操作，
                 	//   從根本上解決了之前操作複雜紀錄列表時遇到的所有執行錯誤。
                 	// =========================================================================
                 	// 初始化回傳用的列表
                 	spread_results = List();
                 	// 1. 取得所有牌卡的ID，建立一個純粹的ID列表
                 	all_cards_collection = All_Tarot_Cards[ID != 0];
                 	card_id_list = List();
                 	for each  card in all_cards_collection
                 	{
                 		card_id_list.add(card.ID);
                 	}
                 	// 檢查ID列表是否成功建立
                 	if(card_id_list.size() > 0)
                 	{
                 		// 2. 執行五次抽牌迴圈
                 		loop_count = {1,2,3,4,5};
                 		for each  i in loop_count
                 		{
                 			// 3. 從ID列表中隨機抽出一張牌的ID
                 			// 檢查列表是否還有ID可抽
                 			if(card_id_list.size() > 0)
                 			{
                 				deck_size = card_id_list.size();
                 				random_index = zoho.currenttime.toLong() % deck_size;
                 				// 取得並移除該ID
                 				drawn_id = card_id_list.remove(random_index);
                 				// 4. 使用抽出的ID，獲取完整的牌卡紀錄集合
                 				card_collection = All_Tarot_Cards[ID == drawn_id];
                 				// 關鍵修正：使用 for each 迴圈從集合中安全地取出唯一的紀錄物件
                 				// 這是最穩健的方法，可以避免所有關於集合物件操作的相容性問題
                 				if(card_collection.count() > 0)
                 				{
                 					for each  drawn_card_record in card_collection
                 					{
                 						// 5. 決定正逆位
                 						orientation = zoho.currenttime.toLong() % 2;
                 						// 產生 0 或 1
                 						// 準備儲存單張牌結果的 Map
                 						card_result_map = Map();
                 						card_result_map.put("Card_ID",drawn_card_record.ID);
                 						if(orientation == 1)
                 						{
                 							// 正位
                 							card_result_map.put("Card_Image",drawn_card_record.Upright_Image);
                 							card_result_map.put("Card_Meaning",drawn_card_record.Upright_Meaning);
                 							card_result_map.put("Is_Reversed",false);
                 						}
                 						else
                 						{
                 							// 逆位
                 							card_result_map.put("Card_Image",drawn_card_record.Reversed_Image);
                 							card_result_map.put("Card_Meaning",drawn_card_record.Reversed_Meaning);
                 							card_result_map.put("Is_Reversed",true);
                 						}
                 						// 6. 將這張牌的結果加入最終的列表
                 						spread_results.add(card_result_map);
                 						// 因為是透過ID查詢，只會有一筆紀錄，處理完就跳出迴圈
                 						break;
                 					}
                 				}
                 			}
                 		}
                 	}
                 	// 7. 回傳包含五張牌結果的列表
                 	return spread_results;
                 }
map Tarot.getLifePathTarot(date solar_date)
                 {
                 	// =========================================================================
                 	// 本函數根據「本命塔羅」新版規則，透過使用者的公曆生日計算出其本命塔羅牌。
                 	// @param solar_date - (date) 使用者的公曆生日(包含時間)。
                 	// @return (map) - 一個包含所有牌卡紀錄ID與圖片URL的Map。
                 	//
                 	// 版本 4.0 更新：
                 	// - 完全重寫計算邏輯，採用 (年+月+日)%22, 21-n, 及數字根等新規則。
                 	// - 函數現在會回傳牌卡的紀錄ID和圖片URL，以便Workflow直接更新表單。
                 	// - 增加業力過重牌的判斷邏輯，以決定是否計算第四張牌。
                 	// =========================================================================
                 	// 初始化回傳用的 Map
                 	response_map = Map();
                 	// 定義業力過重的牌卡名稱列表
                 	heavy_karma_cards = {"惡魔","高塔","寶劍十","寶劍九","寶劍三"};
                 	// -------------------------------------------------------------------------
                 	// 1. 計算第一張牌【本世功課】
                 	// 規則: (年 + 月 + 日) % 22
                 	// -------------------------------------------------------------------------
                 	year_val = solar_date.getYear();
                 	month_val = solar_date.getMonth();
                 	day_val = solar_date.getDay();
                 	card1_number = (year_val + month_val + day_val) % 22;
                 	card1_record = All_Tarot_Cards[Card_Number == card1_number && Minor_Arcana == false];
                 	if(card1_record != null)
                 	{
                 		response_map.put("Ben_Ming_Tarot_ID",card1_record.ID);
                 		response_map.put("Ben_Ming_Tarot_Image_Value",card1_record.Upright_Image);
                 		// -------------------------------------------------------------------------
                 		// 2. 計算第二張牌【時事地】
                 		// 規則: 21 - [第一張牌的 Card_Number]
                 		// -------------------------------------------------------------------------
                 		card2_number = 21 - card1_number;
                 		card2_record = All_Tarot_Cards[Card_Number == card2_number && Minor_Arcana == false];
                 		if(card2_record != null)
                 		{
                 			response_map.put("Xian_Zhuang_Tarot_ID",card2_record.ID);
                 			response_map.put("Xian_Zhuang_Tarot_Image_Value",card2_record.Upright_Image);
                 			// -------------------------------------------------------------------------
                 			// 3. 計算第三張牌【業力因果】
                 			// 規則: 21 - [第二張牌的 Card_Number]
                 			// -------------------------------------------------------------------------
                 			card3_number = 21 - card2_number;
                 			card3_record = All_Tarot_Cards[Card_Number == card3_number && Minor_Arcana == false];
                 			if(card3_record != null)
                 			{
                 				response_map.put("Ye_Li_Tarot_ID",card3_record.ID);
                 				response_map.put("Ye_Li_Tarot_Image_Value",card3_record.Upright_Image);
                 				// -------------------------------------------------------------------------
                 				// 4. 判斷並計算第四張牌【有無佛緣】
                 				// 條件: 第三張牌的名稱不在業力過重列表中。
                 				// 規則: 生日年份的數字根。
                 				// -------------------------------------------------------------------------
                 				if(!heavy_karma_cards.contains(card3_record.Card_Name))
                 				{
                 					// 計算數字根
                 					year_str = year_val.toString();
                 					digital_root = 0;
                 					for each  digit_char in year_str.toList()
                 					{
                 						digital_root = digital_root + digit_char.toLong();
                 					}
                 					// 如果結果是兩位數，再次相加
                 					if(digital_root > 9)
                 					{
                 						root_str = digital_root.toString();
                 						digital_root = root_str.subString(0,1).toLong() + root_str.subString(1,2).toLong();
                 					}
                 					card4_number = digital_root;
                 					card4_record = All_Tarot_Cards[Card_Number == card4_number && Minor_Arcana == false];
                 					if(card4_record != null)
                 					{
                 						response_map.put("Tian_Yuan_Tarot_ID",card4_record.ID);
                 						response_map.put("Tian_Yuan_Tarot_Image_Value",card4_record.Upright_Image);
                 					}
                 				}
                 			}
                 		}
                 	}
                 	// 回傳包含所有結果的 Map
                 	return response_map;
                 }
map Tarot.getPositionMeanings(string question_type)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]]
                 	// ==================================================================================
                 	// 函數名稱：Tarot.getPositionMeanings
                 	// 函數目的：【塔羅牌陣牌位意義定義函數】
                 	//
                 	// 根據問題類型返回5張牌牌陣中每個牌位的具體意義。這個函數是塔羅占卜系統的
                 	// 核心組件，它確保每次占卜都有明確的牌位定義，讓AI解讀時能夠準確理解每張
                 	// 牌在特定語境中的含義。
                 	//
                 	// 核心設計理念：
                 	// 1. 統一使用5張牌牌陣，保持系統一致性
                 	// 2. 根據問題類型調整牌位意義，提高針對性
                 	// 3. 每個牌位都有清晰的中文描述，便於AI理解和用戶閱讀
                 	// 4. 涵蓋時間軸（過去-現在-未來）和影響因子分析
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// question_type (string) - 問題類型（愛情、婚姻、工作、財運、健康、入煞、其他）
                 	//
                 	// 回傳：
                 	// 一個 Map，包含5個牌位的意義定義
                 	// {"position_1": "牌位1意義", "position_2": "牌位2意義", ..., "position_5": "牌位5意義"}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	position_meanings = Map();
                 	try 
                 	{
                 		// --- 根據問題類型定義牌位意義 ---
                 		if(question_type == "愛情")
                 		{
                 			position_meanings.put("position_1","內心狀態");
                 			position_meanings.put("position_2","對方心意");
                 			position_meanings.put("position_3","關係現況");
                 			position_meanings.put("position_4","阻礙因素");
                 			position_meanings.put("position_5","未來發展");
                 		}
                 		else if(question_type == "婚姻")
                 		{
                 			position_meanings.put("position_1","婚姻基礎");
                 			position_meanings.put("position_2","溝通狀況");
                 			position_meanings.put("position_3","家庭和諧");
                 			position_meanings.put("position_4","挑戰考驗");
                 			position_meanings.put("position_5","長遠展望");
                 		}
                 		else if(question_type == "工作")
                 		{
                 			position_meanings.put("position_1","個人能力");
                 			position_meanings.put("position_2","工作環境");
                 			position_meanings.put("position_3","目前狀況");
                 			position_meanings.put("position_4","成長機會");
                 			position_meanings.put("position_5","事業前景");
                 		}
                 		else if(question_type == "財運")
                 		{
                 			position_meanings.put("position_1","財務現況");
                 			position_meanings.put("position_2","收入來源");
                 			position_meanings.put("position_3","支出管理");
                 			position_meanings.put("position_4","投資機會");
                 			position_meanings.put("position_5","財富累積");
                 		}
                 		else if(question_type == "健康")
                 		{
                 			position_meanings.put("position_1","身體狀況");
                 			position_meanings.put("position_2","心理狀態");
                 			position_meanings.put("position_3","生活習慣");
                 			position_meanings.put("position_4","注意事項");
                 			position_meanings.put("position_5","康復建議");
                 		}
                 		else if(question_type == "入煞")
                 		{
                 			position_meanings.put("position_1","靈性狀態");
                 			position_meanings.put("position_2","負能影響");
                 			position_meanings.put("position_3","防護能力");
                 			position_meanings.put("position_4","化解方法");
                 			position_meanings.put("position_5","淨化指引");
                 		}
                 		else
                 		{
                 			// "其他" 或未知類型
                 			// 通用牌陣：適用於各種問題的萬能牌位
                 			position_meanings.put("position_1","過去影響");
                 			position_meanings.put("position_2","現在狀況");
                 			position_meanings.put("position_3","核心問題");
                 			position_meanings.put("position_4","外在因素");
                 			position_meanings.put("position_5","未來指引");
                 		}
                 		// 加入元數據
                 		position_meanings.put("question_type",question_type);
                 		position_meanings.put("spread_name","專業五牌陣");
                 		position_meanings.put("total_cards",5);
                 	}
                 	catch (e)
                 	{
                 		// 發生錯誤時使用預設的通用牌陣
                 		position_meanings.put("position_1","過去影響");
                 		position_meanings.put("position_2","現在狀況");
                 		position_meanings.put("position_3","核心問題");
                 		position_meanings.put("position_4","外在因素");
                 		position_meanings.put("position_5","未來指引");
                 		position_meanings.put("question_type","其他");
                 		position_meanings.put("spread_name","通用五牌陣");
                 		position_meanings.put("total_cards",5);
                 		position_meanings.put("error","使用預設牌陣：" + e);
                 	}
                 	return position_meanings;
                 }
map Tarot.getPrimaryTalismanForSalesIQ(string client_id)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]] [[memory:6341405]]
                 	// ==================================================================================
                 	// 函數名稱：Tarot.getPrimaryTalismanForSalesIQ
                 	// 函數目的：【SalesIQ 專用符令取得函數】
                 	//
                 	// 為 SalesIQ 提供占卜記錄的主卦符令圖片和基本資訊
                 	// 包含完整的符令空值檢查，避免符令尚未上傳時發生錯誤
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// client_id (string) - 占卜記錄 ID (從 SalesIQ 傳遞過來的 divination_id)
                 	//
                 	// 回傳：
                 	// {
                 	//   "success": true/false,
                 	//   "talisman_image_url": "符令圖片 URL",
                 	//   "card_name": "牌卡名稱", 
                 	//   "polarity": "正位/逆位",
                 	//   "element": "五行元素",
                 	//   "has_paid": true/false,
                 	//   "divination_id": 占卜ID
                 	// }
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	result = Map();
                 	try 
                 	{
                 		// 參數驗證
                 		if(client_id == null || client_id == "")
                 		{
                 			result.put("success",false);
                 			result.put("error","占卜記錄 ID 不能為空");
                 			return result;
                 		}
                 		divination_id_long = client_id.toLong();
                 		// 直接查找指定的占卜記錄
                 		divination_records = Divination_Logs[ID == divination_id_long];
                 		if(divination_records.count() == 0)
                 		{
                 			result.put("success",false);
                 			result.put("error","找不到指定的占卜記錄 ID: " + client_id);
                 			return result;
                 		}
                 		// 取得指定的占卜記錄
                 		latest_record = null;
                 		for each  record in divination_records
                 		{
                 			latest_record = record;
                 			break;
                 		}
                 		// 檢查是否有主卦符令資料
                 		if(latest_record.Primary_Talisman_Card_ID == null)
                 		{
                 			result.put("success",false);
                 			result.put("error","該占卜記錄尚未進行主卦分析");
                 			return result;
                 		}
                 		// 取得主卦牌卡詳細資訊
                 		primary_card_collection = All_Tarot_Cards[ID == latest_record.Primary_Talisman_Card_ID];
                 		if(primary_card_collection.count() == 0)
                 		{
                 			result.put("success",false);
                 			result.put("error","找不到主卦牌卡詳細資訊");
                 			return result;
                 		}
                 		primary_card = null;
                 		for each  card in primary_card_collection
                 		{
                 			primary_card = card;
                 			break;
                 		}
                 		// 準備符令圖片 URL 和其他資料
                 		polarity = latest_record.Primary_Trend_Polarity;
                 		element = "";
                 		talisman_image_url = "";
                 		// 根據正逆位取得對應的符令圖片和五行元素
                 		if(polarity == "逆位")
                 		{
                 			element = primary_card.Reversed_Outsight_Element;
                 			// 符令空值檢查：逆位符令（寬容處理）
                 			if(primary_card.Reverse_Talisman_Image != null && primary_card.Reverse_Talisman_Image != "")
                 			{
                 				talisman_image_url = primary_card.Reverse_Talisman_Image;
                 			}
                 			else
                 			{
                 				// 符令尚未準備時，提供預設資訊而非錯誤
                 				talisman_image_url = "";
                 				result.put("talisman_status","pending");
                 			}
                 		}
                 		else
                 		{
                 			element = primary_card.Outsight_Element;
                 			// 符令空值檢查：正位符令（寬容處理）
                 			if(primary_card.Upright_Talisman_Image != null && primary_card.Upright_Talisman_Image != "")
                 			{
                 				talisman_image_url = primary_card.Upright_Talisman_Image;
                 			}
                 			else
                 			{
                 				// 符令尚未準備時，提供預設資訊而非錯誤
                 				talisman_image_url = "";
                 				result.put("talisman_status","pending");
                 			}
                 		}
                 		// 所有檢查通過，回傳成功結果
                 		result.put("success",true);
                 		result.put("talisman_image_url",talisman_image_url);
                 		result.put("card_name",primary_card.Card_Name);
                 		result.put("polarity",polarity);
                 		result.put("element",element);
                 		result.put("divination_id",latest_record.ID);
                 		// 檢查付費狀態（如果欄位存在）
                 		if(latest_record.Has_Paid_Report != null)
                 		{
                 			result.put("has_paid",latest_record.Has_Paid_Report);
                 		}
                 		else
                 		{
                 			result.put("has_paid",false);
                 		}
                 		// 如果沒有設定 talisman_status，表示符令正常
                 		try 
                 		{
                 			test_status = result.get("talisman_status");
                 			if(test_status == null)
                 			{
                 				result.put("talisman_status","ready");
                 			}
                 		}
                 		catch (e)
                 		{
                 			result.put("talisman_status","ready");
                 		}
                 	}
                 	catch (e)
                 	{
                 		result.put("success",false);
                 		result.put("error","系統錯誤：" + e);
                 	}
                 	return result;
                 }
map Tarot.TarotDivinationFunction(string client_id, string user_question)
                 {
                 	// ==================================================================================
                 	// 函數名稱：Tarot.TarotDivinationFunction
                 	// 函數目的：【完整塔羅占卜流程函數】
                 	//
                 	// 這是將原 tarot_divination workflow 改寫的函數版本
                 	// 測試方式：先在 Divination_Logs 表單的 Original_Question 欄位寫入問題，
                 	//          再調用此函數執行完整占卜流程
                 	//
                 	// 流程：
                 	// 1. 問題分類與抽牌建立紀錄
                 	// 2. 圖片填入與牌義強化  
                 	// 3. 主卦分析與符令生成
                 	// 4. AI 解讀生成
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// client_id (string) - 個案 ID
                 	//
                 	// 回傳：
                 	// {"success": true/false, "message": "結果訊息", "divination_id": 占卜記錄ID}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	result = Map();
                 	try 
                 	{
                 		// 參數驗證
                 		if(client_id == null || client_id == "")
                 		{
                 			result.put("success",false);
                 			result.put("message","個案 ID 不能為空");
                 			return result;
                 		}
                 		clientID = client_id.toLong();
                 		// --- 步驟 1: 驗證參數並取得個案記錄 ---
                 		// 檢查問題參數
                 		if(user_question == null || user_question == "")
                 		{
                 			result.put("success",false);
                 			result.put("message","請提供占卜問題");
                 			return result;
                 		}
                 		// Client_Link 在 Workflow 中可以直接使用 ID，不需要記錄物件
                 		// --- 步驟 2: 執行 AI 問題分類 ---
                  		classification_result = thisapp.AIInterpreter.classifyQuestionType(user_question);
                  		question_type = "其他";
                  		if(classification_result != null && classification_result.get("success") == true && classification_result.get("question_type") != null)
                  		{
                  			question_type = classification_result.get("question_type");
                  		}
                 		// --- 步驟 3: 獲取牌位意義 ---
                 		position_meanings = thisapp.Tarot.getPositionMeanings(question_type);
                 		// --- 步驟 4: 執行抽牌 ---
                 		tarot_results_list = thisapp.Tarot.drawRandomSpread();
                 		if(tarot_results_list.size() > 0)
                 		{
                 			// --- 步驟 5: 建立占卜記錄 ---
                 			try 
                 			{
                 				// 加入調試信息
                 				result.put("debug_info","準備插入記錄 - 個案ID: " + clientID + ", 問題: " + user_question + ", 分類: " + question_type + ", 抽到牌數: " + tarot_results_list.size());
                 				insert_response = insert into Divination_Logs
                 				[
                 					Added_User=zoho.loginuser
                 					Client_Link=clientID
                 					Original_Question=user_question
                 					Question_Type_AI=question_type
                 					Divination_Method="塔羅"
                 					Position_a_Meaning=position_meanings.get("position_1")
                 					Position_b_Meaning=position_meanings.get("position_2")
                 					Position_c_Meaning=position_meanings.get("position_3")
                 					Position_d_Meaning=position_meanings.get("position_4")
                 					Position_e_Meaning=position_meanings.get("position_5")
                 					Card_1_Link=if(tarot_results_list.size() > 0,tarot_results_list.get(0).get("Card_ID"),null)
                 					Card_1_Reversed=if(tarot_results_list.size() > 0,tarot_results_list.get(0).get("Is_Reversed"),false)
                 					Card_2_Link=if(tarot_results_list.size() > 1,tarot_results_list.get(1).get("Card_ID"),null)
                 					Card_2_Reversed=if(tarot_results_list.size() > 1,tarot_results_list.get(1).get("Is_Reversed"),false)
                 					Card_3_Link=if(tarot_results_list.size() > 2,tarot_results_list.get(2).get("Card_ID"),null)
                 					Card_3_Reversed=if(tarot_results_list.size() > 2,tarot_results_list.get(2).get("Is_Reversed"),false)
                 					Card_4_Link=if(tarot_results_list.size() > 3,tarot_results_list.get(3).get("Card_ID"),null)
                 					Card_4_Reversed=if(tarot_results_list.size() > 3,tarot_results_list.get(3).get("Is_Reversed"),false)
                 					Card_5_Link=if(tarot_results_list.size() > 4,tarot_results_list.get(4).get("Card_ID"),null)
                 					Card_5_Reversed=if(tarot_results_list.size() > 4,tarot_results_list.get(4).get("Is_Reversed"),false)
                 				];
                 				// insert_response 本身就是 ID，不需要 .get("ID")
                 				new_log_id = insert_response;
                 				if(new_log_id == null || new_log_id == 0)
                 				{
                 					result.put("success",false);
                 					result.put("message","建立占卜記錄失敗：insert_response 為空");
                 					result.put("insert_response",insert_response);
                 					return result;
                 				}
                 				// 驗證記錄是否真的被建立（跨表單查詢測試）
                 				verification_id = new_log_id;
                 				if(verification_id != null && verification_id != 0)
                 				{
                 					// 按照 Workflow 環境寫法，直接查詢
                 					try 
                 					{
                 						verification_records = Divination_Logs[ID == verification_id];
                 						if(verification_records.count() == 0)
                 						{
                 							result.put("success",false);
                 							result.put("message","記錄建立後無法查詢到，可能是跨表單同步問題");
                 							result.put("new_log_id",new_log_id);
                 							result.put("verification_id",verification_id);
                 							return result;
                 						}
                 						else
                 						{
                 							result.put("verification_success","記錄建立並成功查詢，共 " + verification_records.count() + " 筆");
                 						}
                 					}
                 					catch (verification_error)
                 					{
                 						result.put("verification_warning","ID轉換失敗：" + verification_error);
                 					}
                 				}
                 				// 加入調試信息
                 				result.put("new_log_id_success",new_log_id);
                 			}
                 			catch (insert_error)
                 			{
                 				result.put("success",false);
                 				result.put("message","建立占卜記錄時發生錯誤：" + insert_error);
                 				return result;
                 			}
                 			// --- 步驟 6: 主卦分析與符令生成 ---
                 			// 準備主卦分析所需的資料
                 			card_ids_for_analysis = List();
                 			reversed_statuses_for_analysis = List();
                 			for each  tarot_result in tarot_results_list
                 			{
                 				card_ids_for_analysis.add(tarot_result.get("Card_ID"));
                 				reversed_statuses_for_analysis.add(tarot_result.get("Is_Reversed"));
                 			}
                 			// 執行主卦分析
                 			primary_analysis = thisapp.Tarot.determinePrimaryCard(card_ids_for_analysis,reversed_statuses_for_analysis);
                 			if(primary_analysis.get("success") == true)
                 			{
                 				primary_polarity = primary_analysis.get("primary_polarity");
                 				primary_card_id = primary_analysis.get("primary_card_id");
                 				// 取得主卦牌卡的符令圖片，按照 Action2 寫法
                 				primary_card_collection = All_Tarot_Cards[ID == primary_card_id];
                 				primary_talisman_image = null;
                 				for each  primary_card in primary_card_collection
                 				{
                 					if(primary_polarity == "逆位")
                 					{
                 						if(primary_card.Reverse_Talisman_Image != null && primary_card.Reverse_Talisman_Image != "")
                 						{
                 							primary_talisman_image = primary_card.Reverse_Talisman_Image;
                 						}
                 					}
                 					else
                 					{
                 						if(primary_card.Upright_Talisman_Image != null && primary_card.Upright_Talisman_Image != "")
                 						{
                 							primary_talisman_image = primary_card.Upright_Talisman_Image;
                 						}
                 					}
                 					break;
                 				}
                 				// 更新記錄的主卦資訊，按照 Action2 寫法
                 				latest_divination = Divination_Logs[ID == new_log_id];
                 				for each  div_record in latest_divination
                 				{
                 					div_record.Primary_Trend_Polarity=primary_polarity;
                 					div_record.Primary_Talisman_Card_ID=primary_card_id;
                 					if(primary_talisman_image != null)
                 					{
                 						div_record.Primary_Talisman_Image=primary_talisman_image;
                 					}
                 					break;
                 				}
                 			}
                 			// --- 步驟 7: 圖片填入與牌義強化 ---
                 			// 查找剛剛建立的塔羅占卜紀錄並處理圖片和強化牌位意義，按照 Action2 寫法
                 			latest_divination_for_images = Divination_Logs[ID == new_log_id];
                 			for each  latest_record in latest_divination_for_images
                 			{
                 				// 為每張牌填入正確的圖片和強化牌位意義
                 				// Card 1
                 				if(latest_record.Card_1_Link != null)
                 				{
                 					card_collection = All_Tarot_Cards[ID == latest_record.Card_1_Link];
                 					for each  card_record in card_collection
                 					{
                 						// 填入圖片
                 						latest_record.Card_1_Image=if(latest_record.Card_1_Reversed,card_record.Reversed_Image,card_record.Upright_Image);
                 						// 強化牌位意義
                 						base_meaning = latest_record.Position_a_Meaning;
                 						if(base_meaning == null || base_meaning == "")
                 						{
                 							base_meaning = "牌位1意義";
                 						}
                 						card_name = card_record.Card_Name;
                 						element = if(latest_record.Card_1_Reversed,card_record.Reversed_Outsight_Element,card_record.Outsight_Element);
                 						card_meaning = if(latest_record.Card_1_Reversed,card_record.Reversed_Meaning,card_record.Upright_Meaning);
                 						talisman = if(latest_record.Card_1_Reversed,card_record.Reversed_Talisman,card_record.Upright_Talisman);
                 						card_description = card_record.Card_Description;
                 						// 處理符令為空的情況
                 						if(talisman == null || talisman == "")
                 						{
                 							talisman = "未知元素";
                 						}
                 						position_status = if(latest_record.Card_1_Reversed,"逆位","正位");
                 						talisman_note = if(latest_record.Card_1_Reversed,"（但是現在是逆位的牌，要使用" + talisman + "元素來生剋）","（要使用" + talisman + "元素來生剋）");
                 						// 移除符令的強制檢查，允許符令為空值時繼續執行
                 						if(card_name != null && card_name != "" && element != null && element != "" && card_meaning != null && card_meaning != "" && card_description != null && card_description != "")
                 						{
                 							enhanced_meaning = "【" + base_meaning + "】：" + position_status + card_name + "（" + element + "元素），" + card_meaning + "，這個牌面的描述是：" + card_description + talisman_note;
                 							latest_record.Position_a_Meaning=enhanced_meaning;
                 						}
                 						break;
                 					}
                 				}
                 				// Card 2
                 				if(latest_record.Card_2_Link != null)
                 				{
                 					card_collection = All_Tarot_Cards[ID == latest_record.Card_2_Link];
                 					for each  card_record in card_collection
                 					{
                 						latest_record.Card_2_Image=if(latest_record.Card_2_Reversed,card_record.Reversed_Image,card_record.Upright_Image);
                 						base_meaning = latest_record.Position_b_Meaning;
                 						if(base_meaning == null || base_meaning == "")
                 						{
                 							base_meaning = "牌位2意義";
                 						}
                 						card_name = card_record.Card_Name;
                 						element = if(latest_record.Card_2_Reversed,card_record.Reversed_Outsight_Element,card_record.Outsight_Element);
                 						card_meaning = if(latest_record.Card_2_Reversed,card_record.Reversed_Meaning,card_record.Upright_Meaning);
                 						talisman = if(latest_record.Card_2_Reversed,card_record.Reversed_Talisman,card_record.Upright_Talisman);
                 						card_description = card_record.Card_Description;
                 						// 處理符令為空的情況
                 						if(talisman == null || talisman == "")
                 						{
                 							talisman = "未知元素";
                 						}
                 						position_status = if(latest_record.Card_2_Reversed,"逆位","正位");
                 						talisman_note = if(latest_record.Card_2_Reversed,"（但是現在是逆位的牌，要使用" + talisman + "元素來生剋）","（要使用" + talisman + "元素來生剋）");
                 						// 移除符令的強制檢查，允許符令為空值時繼續執行
                 						if(card_name != null && card_name != "" && element != null && element != "" && card_meaning != null && card_meaning != "" && card_description != null && card_description != "")
                 						{
                 							enhanced_meaning = "【" + base_meaning + "】：" + position_status + card_name + "（" + element + "元素），" + card_meaning + "，這個牌面的描述是：" + card_description + talisman_note;
                 							latest_record.Position_b_Meaning=enhanced_meaning;
                 						}
                 						break;
                 					}
                 				}
                 				// Card 3
                 				if(latest_record.Card_3_Link != null)
                 				{
                 					card_collection = All_Tarot_Cards[ID == latest_record.Card_3_Link];
                 					for each  card_record in card_collection
                 					{
                 						latest_record.Card_3_Image=if(latest_record.Card_3_Reversed,card_record.Reversed_Image,card_record.Upright_Image);
                 						base_meaning = latest_record.Position_c_Meaning;
                 						if(base_meaning == null || base_meaning == "")
                 						{
                 							base_meaning = "牌位3意義";
                 						}
                 						card_name = card_record.Card_Name;
                 						element = if(latest_record.Card_3_Reversed,card_record.Reversed_Outsight_Element,card_record.Outsight_Element);
                 						card_meaning = if(latest_record.Card_3_Reversed,card_record.Reversed_Meaning,card_record.Upright_Meaning);
                 						talisman = if(latest_record.Card_3_Reversed,card_record.Reversed_Talisman,card_record.Upright_Talisman);
                 						card_description = card_record.Card_Description;
                 						// 處理符令為空的情況
                 						if(talisman == null || talisman == "")
                 						{
                 							talisman = "未知元素";
                 						}
                 						position_status = if(latest_record.Card_3_Reversed,"逆位","正位");
                 						talisman_note = if(latest_record.Card_3_Reversed,"（但是現在是逆位的牌，要使用" + talisman + "元素來生剋）","（要使用" + talisman + "元素來生剋）");
                 						// 移除符令的強制檢查，允許符令為空值時繼續執行
                 						if(card_name != null && card_name != "" && element != null && element != "" && card_meaning != null && card_meaning != "" && card_description != null && card_description != "")
                 						{
                 							enhanced_meaning = "【" + base_meaning + "】：" + position_status + card_name + "（" + element + "元素），" + card_meaning + "，這個牌面的描述是：" + card_description + talisman_note;
                 							latest_record.Position_c_Meaning=enhanced_meaning;
                 						}
                 						break;
                 					}
                 				}
                 				// Card 4
                 				if(latest_record.Card_4_Link != null)
                 				{
                 					card_collection = All_Tarot_Cards[ID == latest_record.Card_4_Link];
                 					for each  card_record in card_collection
                 					{
                 						latest_record.Card_4_Image=if(latest_record.Card_4_Reversed,card_record.Reversed_Image,card_record.Upright_Image);
                 						base_meaning = latest_record.Position_d_Meaning;
                 						if(base_meaning == null || base_meaning == "")
                 						{
                 							base_meaning = "牌位4意義";
                 						}
                 						card_name = card_record.Card_Name;
                 						element = if(latest_record.Card_4_Reversed,card_record.Reversed_Outsight_Element,card_record.Outsight_Element);
                 						card_meaning = if(latest_record.Card_4_Reversed,card_record.Reversed_Meaning,card_record.Upright_Meaning);
                 						talisman = if(latest_record.Card_4_Reversed,card_record.Reversed_Talisman,card_record.Upright_Talisman);
                 						card_description = card_record.Card_Description;
                 						// 處理符令為空的情況
                 						if(talisman == null || talisman == "")
                 						{
                 							talisman = "未知元素";
                 						}
                 						position_status = if(latest_record.Card_4_Reversed,"逆位","正位");
                 						talisman_note = if(latest_record.Card_4_Reversed,"（但是現在是逆位的牌，要使用" + talisman + "元素來生剋）","（要使用" + talisman + "元素來生剋）");
                 						// 移除符令的強制檢查，允許符令為空值時繼續執行
                 						if(card_name != null && card_name != "" && element != null && element != "" && card_meaning != null && card_meaning != "" && card_description != null && card_description != "")
                 						{
                 							enhanced_meaning = "【" + base_meaning + "】：" + position_status + card_name + "（" + element + "元素），" + card_meaning + "，這個牌面的描述是：" + card_description + talisman_note;
                 							latest_record.Position_d_Meaning=enhanced_meaning;
                 						}
                 						break;
                 					}
                 				}
                 				// Card 5
                 				if(latest_record.Card_5_Link != null)
                 				{
                 					card_collection = All_Tarot_Cards[ID == latest_record.Card_5_Link];
                 					for each  card_record in card_collection
                 					{
                 						latest_record.Card_5_Image=if(latest_record.Card_5_Reversed,card_record.Reversed_Image,card_record.Upright_Image);
                 						base_meaning = latest_record.Position_e_Meaning;
                 						if(base_meaning == null || base_meaning == "")
                 						{
                 							base_meaning = "牌位5意義";
                 						}
                 						card_name = card_record.Card_Name;
                 						element = if(latest_record.Card_5_Reversed,card_record.Reversed_Outsight_Element,card_record.Outsight_Element);
                 						card_meaning = if(latest_record.Card_5_Reversed,card_record.Reversed_Meaning,card_record.Upright_Meaning);
                 						talisman = if(latest_record.Card_5_Reversed,card_record.Reversed_Talisman,card_record.Upright_Talisman);
                 						card_description = card_record.Card_Description;
                 						// 處理符令為空的情況
                 						if(talisman == null || talisman == "")
                 						{
                 							talisman = "未知元素";
                 						}
                 						position_status = if(latest_record.Card_5_Reversed,"逆位","正位");
                 						talisman_note = if(latest_record.Card_5_Reversed,"（但是現在是逆位的牌，要使用" + talisman + "元素來生剋）","（要使用" + talisman + "元素來生剋）");
                 						// 移除符令的強制檢查，允許符令為空值時繼續執行
                 						if(card_name != null && card_name != "" && element != null && element != "" && card_meaning != null && card_meaning != "" && card_description != null && card_description != "")
                 						{
                 							enhanced_meaning = "【" + base_meaning + "】：" + position_status + card_name + "（" + element + "元素），" + card_meaning + "，這個牌面的描述是：" + card_description + talisman_note;
                 							latest_record.Position_e_Meaning=enhanced_meaning;
                 						}
                 						break;
                 					}
                 				}
                 				// --- 步驟 8: Flow AI 解讀 ---
                 				// 準備傳遞給 Flow 的資料
                 				tarot_data = Map();
                 				// 加入基本資訊
                 				question_text = latest_record.Original_Question;
                 				question_type_final = latest_record.Question_Type_AI;
                 				// 加入所有牌位意義
                 				tarot_data.put("Position_1_Meaning",latest_record.Position_a_Meaning);
                 				tarot_data.put("Position_2_Meaning",latest_record.Position_b_Meaning);
                 				tarot_data.put("Position_3_Meaning",latest_record.Position_c_Meaning);
                 				tarot_data.put("Position_4_Meaning",latest_record.Position_d_Meaning);
                 				tarot_data.put("Position_5_Meaning",latest_record.Position_e_Meaning);
                 				// 加入牌卡的正逆位資訊
                 				tarot_data.put("Card_1_Reversed",latest_record.Card_1_Reversed);
                 				tarot_data.put("Card_2_Reversed",latest_record.Card_2_Reversed);
                 				tarot_data.put("Card_3_Reversed",latest_record.Card_3_Reversed);
                 				tarot_data.put("Card_4_Reversed",latest_record.Card_4_Reversed);
                 				tarot_data.put("Card_5_Reversed",latest_record.Card_5_Reversed);
                 				// === Thread ID 管理：查找客戶最近的 Thread ID ===
                 				existing_thread_id = "";
                 				if(client_id != null && client_id != "")
                 				{
                 					// 查找該客戶最近的占卜記錄以獲得 Thread ID
                 					recent_divinations = Divination_Logs[Client_Link == clientID && Thread_ID != null && Thread_ID != ""];
                 					// 手動找到最新的記錄（依據ID，ID越大表示越新）
                 					latest_thread_record = null;
                 					latest_record_id = 0;
                 					if(recent_divinations.count() > 0)
                 					{
                 						for each  recent_divination in recent_divinations
                 						{
                 							current_id = recent_divination.ID;
                 							if(current_id > latest_record_id)
                 							{
                 								latest_record_id = current_id;
                 								latest_thread_record = recent_divination;
                 							}
                 						}
                 						if(latest_thread_record != null)
                 						{
                 							existing_thread_id = latest_thread_record.Thread_ID;
                 							info "找到現有Thread ID：" + existing_thread_id + "，支援連續對話";
                 						}
                 					}
                 				}
                 				// 檢查是否有足夠的資料進行 AI 解讀
                 				result.put("ai_debug_question",question_text);
                 				result.put("ai_debug_type",question_type_final);
                 				result.put("ai_debug_position_a",latest_record.Position_a_Meaning);
                 				result.put("ai_debug_thread_id",existing_thread_id);
                 				if(question_text != null && question_text != "" && question_type_final != null && question_type_final != "" && latest_record.Position_a_Meaning != null && latest_record.Position_a_Meaning != "")
                 				{
                 					// 呼叫 Flow 觸發函數進行 AI 解讀
                 					result.put("ai_debug_calling","正在呼叫 Flow AI 解讀");
                 					flowTriggerResult = thisapp.Flow.triggerTarotFlowProcessor({"divinationId":new_log_id.toString(),"questionText":question_text,"questionType":question_type_final,"tarotSpreadData":tarot_data,"clientId":client_id,"threadId":existing_thread_id});
                 					result.put("ai_debug_flow_result",flowTriggerResult);
                 					// 處理 Flow 結果
                 					if(flowTriggerResult.get("success") == true)
                 					{
                 						processingMethod = flowTriggerResult.get("processingMethod");
                 						if(processingMethod == "Flow異步")
                 						{
                 							// Flow 異步處理：等待完成（需要後續輪詢機制）
                 							latest_record.AI_Interpretation="? AI正在為您進行深度解讀，請稍候2-3分鐘...";
                 							latest_record.Status="處理中";
                 							result.put("processing_method","Flow異步處理");
                 							result.put("message","占卜抽牌完成！AI正在進行深度解讀，預計2-3分鐘內完成。");
                 						}
                 						else if(processingMethod == "備援ChatGPT")
                 						{
                 							// ChatGPT 同步處理完成
                 							interpretation_text = flowTriggerResult.get("interpretation");
                 							latest_record.AI_Interpretation=interpretation_text;
                 							latest_record.Status="已完成";
                 							result.put("processing_method","備援ChatGPT處理");
                 						}
                 					}
                 					else
                 					{
                 						// Flow 觸發失敗，使用預設訊息
                 						latest_record.AI_Interpretation="很抱歉，AI解讀暫時無法使用，但您的塔羅牌已抽取完成。請稍後查看解讀結果。";
                 						latest_record.Status="已提問";
                 						result.put("processing_method","抽牌完成");
                 					}
                 				}
                 				else
                 				{
                 					latest_record.AI_Interpretation="很抱歉，由於占卜資料不完整，無法提供完整的解讀。請重新進行占卜或聯繫客服協助。";
                 					latest_record.Status="資料不完整";
                 				}
                 				break;
                 			}
                 			result.put("success",true);
                 			result.put("message","塔羅占卜完成！問題：" + user_question);
                 			result.put("divination_id",new_log_id);
                 			result.put("primary_polarity",primary_polarity);
                 			result.put("primary_card_id",primary_card_id);
                 		}
                 		else
                 		{
                 			result.put("success",false);
                 			result.put("message","抽牌過程發生問題，請稍後再試");
                 		}
                 	}
                 	catch (e)
                 	{
                 		result.put("success",false);
                 		result.put("message","塔羅占卜過程發生錯誤：" + e);
                 	}
                 	return result;
                 }
void TEST.sendSampleDataToFlow()
                 {
                 	// =============================================================================
                 	// 函數名稱：TEST.sendSampleDataToFlow
                 	// 函數用途：這是一個一次性的測試函數，用於向 Zoho Flow 發送一筆範例資料，
                 	//          以便 Flow 的 Webhook 觸發器能夠學習並識別資料結構。
                 	//          執行成功後即可刪除。
                 	// =============================================================================
                	// 1. 這是你在 Zoho Flow 拿到的 Webhook URL
                	flowWebhookUrl = if(thisapp.variables.System.FlowWebhookUrl != null,thisapp.variables.System.FlowWebhookUrl.toString(),"");
                	if(flowWebhookUrl == "")
                	{
                		info "Flow webhook URL 未設定，取消測試";
                		return;
                	}
                 	// 2. 準備一筆模擬的報告請求資料 (Map)
                 	sampleData = Map();
                 	sampleData.put("reportTitle","關於事業發展的塔羅指引");
                 	sampleData.put("reportSubtitle","客戶：王大明");
                 	sampleData.put("reportContentMarkdown","## 牌陣：三牌時間流\n\n### 現在\n寶劍三 (逆位)\n\n### 未來\n太陽 (正位)");
                 	sampleData.put("reportTone","溫暖同理");
                 	sampleData.put("imagePrompt","神秘學、星空、魔法光暈");
                 	sampleData.put("creatorRecordId","1234567890");
                 	// 3. 準備 HTTP 標頭 (Headers)，這是修正的關鍵
                 	requestHeaders = Map();
                 	requestHeaders.put("Content-Type","application/json");
                 	// 4. 透過 invokeurl 將資料發送給 Flow (使用正確的語法)
                 	response = invokeurl
                 	[
                 		url :flowWebhookUrl
                 		type :POST
                 		parameters:sampleData.toString()
                 		headers:requestHeaders
                 	];
                 	// 5. 在控制台印出回應，方便我們確認是否成功
                 	info "已成功發送測試資料到 Zoho Flow！";
                 	info "Flow 的回應：" + response;
                 }
map Tools.getTimezoneFromIP(string ip_address)
                 {
                 	//
                 	// 從 IP 位址獲取時區資訊
                 	//
                 	// @param ip_address (string) - 要查詢的公開 IP 位址。
                 	// @return (map) - 回傳一個 map，包含以下鍵值：
                 	//                   "success": (boolean) 操作是否成功。
                 	//                   "timezone": (string) 時區的字串表示，例如 "Asia/Taipei" (如果成功)。
                 	//                   "error": (string) 錯誤訊息 (如果失敗)。
                 	//
                 	// 初始化回傳的 map
                 	response_map = Map();
                 	// 檢查傳入的 IP 位址是否為空或無效
                 	if(ip_address == null || ip_address.trim() == "")
                 	{
                 		response_map.put("success",false);
                 		response_map.put("error","傳入的 IP 位址為空。");
                 		return response_map;
                 	}
                 	// 使用免費的 ip-api.com 服務來查詢
                 	api_url = "http://ip-api.com/json/" + ip_address;
                 	try 
                 	{
                 		// 呼叫 API
                 		api_response = invokeurl
                 		[
                 			url :api_url
                 			type :GET
                 		];
                 		// 檢查 API 回應的狀態
                 		if(api_response.get("status") == "success")
                 		{
                 			// 從 JSON 回應中提取時區資訊
                 			timezone = api_response.get("timezone");
                 			// 檢查時區資訊是否存在
                 			if(timezone != null)
                 			{
                 				response_map.put("success",true);
                 				response_map.put("timezone",timezone);
                 			}
                 			else
                 			{
                 				response_map.put("success",false);
                 				response_map.put("error","API 回應中未找到時區資訊。");
                 			}
                 		}
                 		else
                 		{
                 			// API 查詢失敗
                 			error_message = "IP 位址查詢失敗: " + api_response.get("message");
                 			response_map.put("success",false);
                 			response_map.put("error",error_message);
                 		}
                 	}
                 	catch (e)
                 	{
                 		// 捕捉 invokeurl 可能發生的例外
                 		response_map.put("success",false);
                 		response_map.put("error","呼叫 IP 查詢 API 時發生錯誤: " + e);
                 	}
                 	return response_map;
                 }
void Tools.populateTaisuiDeityNames()
                 {
                 	//
                 	// 函數名稱：populateTaisuiDeityNames
                 	// 命名空間：Tools
                 	//
                 	// 功能描述：
                 	// 此為一個一次性執行的工具腳本。其主要功能是讀取一個預先定義好的「六十干支與太歲星君」對照表，
                 	// 然後遍歷 `Sixty_GanZhi_Table` 表單中的所有記錄，將對應的太歲星君名稱，
                 	// 批量填充到每一筆記錄的 `Taisui_Deity_Name` 欄位中。
                 	//
                 	// 使用情境：
                 	// 當 `Sixty_GanZhi_Table` 表單已建立完畢，但 `Taisui_Deity_Name` 欄位為空時，
                 	// 可執行此腳本進行一次性的資料填充作業。
                 	//
                 	// 參數：
                 	//  - 無
                 	//
                 	// 回傳：
                 	//  - void (無回傳值)
                 	//
                 	// 相依性：
                 	//  - 表單 `Sixty_GanZhi_Table` 必須存在，且包含 `GanZhi_Combination` 和 `Taisui_Deity_Name` 欄位。
                 	//
                 	// 注意事項：
                 	//  - 這是一個臨時的工具函數，執行成功後即可從系統中刪除，以保持程式碼庫的整潔。
                 	//  - 執行前請確認 `taisui_map` 中的干支名稱與 `Sixty_GanZhi_Table` 表單中的 `GanZhi_Combination` 內容完全一致。
                 	//
                 	info "準備開始更新六十太歲星君名稱...";
                 	// 步驟 1: 在記憶體中建立一個從「干支組合」到「太歲星君名稱」的完整對照 Map。
                 	// 這是所有更新操作的資料來源。
                 	taisui_map = Map();
                 	taisui_map.put("甲子","金辦將軍");
                 	taisui_map.put("乙丑","陳材將軍");
                 	taisui_map.put("丙寅","耿章將軍");
                 	taisui_map.put("丁卯","沈興將軍");
                 	taisui_map.put("戊辰","趙達將軍");
                 	taisui_map.put("己巳","郭燦將軍");
                 	taisui_map.put("庚午","王清將軍");
                 	taisui_map.put("辛未","李素將軍");
                 	taisui_map.put("壬申","劉旺將軍");
                 	taisui_map.put("癸酉","康志將軍");
                 	taisui_map.put("甲戌","施廣將軍");
                 	taisui_map.put("乙亥","任保將軍");
                 	taisui_map.put("丙子","郭嘉將軍");
                 	taisui_map.put("丁丑","汪文將軍");
                 	taisui_map.put("戊寅","曾光將軍");
                 	taisui_map.put("己卯","龍仲將軍");
                 	taisui_map.put("庚辰","董德將軍");
                 	taisui_map.put("辛巳","鄭但將軍");
                 	taisui_map.put("壬午","陸明將軍");
                 	taisui_map.put("癸未","魏仁將軍");
                 	taisui_map.put("甲申","方杰將軍");
                 	taisui_map.put("乙酉","蔣崇將軍");
                 	taisui_map.put("丙戌","白敏將軍");
                 	taisui_map.put("丁亥","封濟將軍");
                 	taisui_map.put("戊子","鄒鏜將軍");
                 	taisui_map.put("己丑","潘佐將軍");
                 	taisui_map.put("庚寅","鄔桓將軍");
                 	taisui_map.put("辛卯","范寧將軍");
                 	taisui_map.put("壬辰","彭泰將軍");
                 	taisui_map.put("癸巳","徐華將軍");
                 	taisui_map.put("甲午","章詞將軍");
                 	taisui_map.put("乙未","楊仙將軍");
                 	taisui_map.put("丙申","管仲將軍");
                 	taisui_map.put("丁酉","唐傑將軍");
                 	taisui_map.put("戊戌","姜武將軍");
                 	taisui_map.put("己亥","謝燾將軍");
                 	taisui_map.put("庚子","虞起將軍");
                 	taisui_map.put("辛丑","楊信將軍");
                 	taisui_map.put("壬寅","賢諤將軍");
                 	taisui_map.put("癸卯","皮時將軍");
                 	taisui_map.put("甲辰","李誠將軍");
                 	taisui_map.put("乙巳","吳遂將軍");
                 	taisui_map.put("丙午","文哲將軍");
                 	taisui_map.put("丁未","繆丙將軍");
                 	taisui_map.put("戊申","徐浩將軍");
                 	taisui_map.put("己酉","程寶將軍");
                 	taisui_map.put("庚戌","倪秘將軍");
                 	taisui_map.put("辛亥","葉堅將軍");
                 	taisui_map.put("壬子","丘德將軍");
                 	taisui_map.put("癸丑","朱得將軍");
                 	taisui_map.put("甲寅","張朝將軍");
                 	taisui_map.put("乙卯","萬清將軍");
                 	taisui_map.put("丙辰","辛亞將軍");
                 	taisui_map.put("丁巳","楊彥將軍");
                 	taisui_map.put("戊午","黎卿將軍");
                 	taisui_map.put("己未","傅黨將軍");
                 	taisui_map.put("庚申","毛梓將軍");
                 	taisui_map.put("辛酉","石政將軍");
                 	taisui_map.put("壬戌","洪充將軍");
                 	taisui_map.put("癸亥","虞程將軍");
                 	// 步驟 2: 從資料庫中一次性獲取所有 `Sixty_GanZhi_Table` 的記錄。
                 	// 條件 `ID != 0` 是獲取所有記錄的標準做法。
                 	all_ganzhi_records = Sixty_GanZhi_Table[ID != 0];
                 	// 初始化計數器，用於追蹤更新結果。
                 	updated_count = 0;
                 	not_found_count = 0;
                 	// 步驟 3: 使用 for each 迴圈遍歷從資料庫中獲取的每一筆干支記錄。
                 	for each  record in all_ganzhi_records
                 	{
                 		// 從記錄中取得作為 key 的干支組合字串 (例如 "甲子")。
                 		ganzhi_key = record.GanZhi_Combination;
                 		// 步驟 4: 使用 .get() 方法從先前建立的 Map 中查找對應的太歲星君名稱。
                 		deity_name = taisui_map.get(ganzhi_key);
                 		// 步驟 5: 檢查是否成功找到了名稱。
                 		if(deity_name != null)
                 		{
                 			// 如果找到了，則直接更新當前記錄的 `Taisui_Deity_Name` 欄位。
                 			// 這裡的更新是針對記憶體中的記錄物件。
                 			record.Taisui_Deity_Name=deity_name;
                 			updated_count = updated_count + 1;
                 		}
                 		else
                 		{
                 			// 如果在 Map 中找不到，表示資料可能不一致，發出警告訊息便於除錯。
                 			info "警告：在 Map 中找不到干支 '" + ganzhi_key + "' 對應的太歲星君。";
                 			not_found_count = not_found_count + 1;
                 		}
                 	}
                 	// 步驟 6: 在迴圈結束後，報告最終的執行結果。
                 	info "✅ 更新完成！成功更新 " + updated_count + " 筆記錄。";
                 	if(not_found_count > 0)
                 	{
                 		info "⚠️ 有 " + not_found_count + " 筆記錄未找到對應的太歲星君，請檢查以上的警告訊息。";
                 	}
                 }
void Training.generateVirtualClient()
                 {
                 	//
                 	// 函數名稱：generateVirtualClient
                 	// 命名空間：Training
                 	//
                 	// 功能描述：
                 	// 創建一個虛擬的客戶資料並將其插入到「個案表單」(Clients_Report) 中。
                 	// 此版本會一次性生成 5 筆資料。
                 	// 這個函數會自動生成一個隨機的生日、時間，並呼叫 OpenAI API 來生成一個隨機的中文姓名。
                 	// 主要用於系統測試、功能演示、以及教學目的。
                 	//
                 	// 參數：
                 	//  - 無
                 	//
                 	// 回傳：
                 	//  - void (無回傳值)，但會在成功時 info 一條訊息。
                 	//
                 	// 相依性：
                 	//  - thisapp.variables.OpenAI.* (需要設定 OpenAI 相關的應用程式變數)
                 	//  - Clients_Report (表單)
                 	//
                 	info "--- 開始批次生成 5 位虛擬個案資料 ---";
                 	// 使用 for each 迴圈來執行三次
                 	iterations = {1,2,3,4,5};
                 	for each  i in iterations
                 	{
                 		info "--- 正在生成第 " + i + " 位個案 ---";
                 		// --- 1. 產生隨機生日與時間 ---
                 		// Deluge 沒有 random(min, max) 語法。我們用 toLong() 作為亂數種子，並透過取餘數來得到範圍內的數字。
                 		// 為了在單次執行中產生多個不同的亂數，我們在每次計算後都用其結果來擾動下一次的種子。
                 		// 我們也用迴圈索引 i 來擾動初始種子，確保每輪迴圈的結果都不同。
                 		random_seed = zoho.currenttime.toLong() * i;
                 		// a. 產生年齡在 18 到 50 歲之間的隨機年份
                 		current_year = zoho.currentdate.getYear();
                 		random_age = 18 + (random_seed % 33).toLong();
                 		// 18 到 50 (範圍 33)
                 		random_year = current_year - random_age;
                 		random_seed = zoho.currenttime.toLong() + random_age;
                 		// 更新種子
                 		// b. 產生隨機月份和日期
                 		random_month = 1 + (random_seed % 12).toLong();
                 		// 1 到 12
                 		random_seed = zoho.currenttime.toLong() + random_month;
                 		// 更新種子
                 		// 為了簡化，我們將日期限制在 1 到 28 之間，以避免處理不同月份天數的問題
                 		random_day = 1 + (random_seed % 28).toLong();
                 		// 1 到 28
                 		random_seed = zoho.currenttime.toLong() + random_day;
                 		// 更新種子
                 		// c. 產生隨機時間 (0-23時, 0-59分)
                 		random_hour = (random_seed % 24).toLong();
                 		// 0 到 23
                 		random_seed = zoho.currenttime.toLong() + random_hour;
                 		// 更新種子
                 		random_minute = (random_seed % 60).toLong();
                 		// 0 到 59
                 		// d. 組合完整的 datetime 物件
                 		random_datetime_str = random_year + "-" + random_month + "-" + random_day + " " + random_hour + ":" + random_minute + ":00";
                 		random_birthday = random_datetime_str.toTime("yyyy-MM-dd HH:mm:ss");
                 		info "1. 已生成隨機生日: " + random_birthday;
                 		// --- 2. 呼叫 OpenAI API 產生隨機姓名 ---
                 		// a. 隨機決定要產生的姓名性別 (女性 75%, 男性 25%)
                 		target_gender = "男";
                 		// 預設為男性
                 		random_seed = zoho.currenttime.toLong() + random_minute;
                 		// 再次更新種子
                 		probability_gender = 1 + (random_seed % 100).toLong();
                 		// 產生 1-100 的亂數
                 		if(probability_gender <= 75)
                 		{
                 			target_gender = "女";
                 		}
                 		info "2. 準備為「" + target_gender + "性」生成隨機姓名...";
                 		// b. 建立 OpenAI 請求
                 		messages = list();
                 		system_prompt = "你是一位中文命名專家。你的任務是產生聽起來自然、優雅又好聽，且符合現代的中文姓名。請避免使用過於常見的名字(如：市場名)，但同時也要避免過度小說化的人名。你的回答格式必須是「姓氏,名字」，例如「陳,宇翔」或「林,佳穎」。不要包含任何其他文字或解釋。";
                 		// 提供範例以確保格式正確 (Few-shot prompting)
                 		messages.add({"role":"system","content":system_prompt});
                 		messages.add({"role":"user","content":"請給我一個男性的名字"});
                 		messages.add({"role":"assistant","content":"陳,宇翔"});
                 		messages.add({"role":"user","content":"請給我一個女性的名字"});
                 		messages.add({"role":"assistant","content":"林,佳穎"});
                 		messages.add({"role":"user","content":"請給我一個" + target_gender + "性的名字"});
                 		openai_payload = Map();
                 		openai_payload.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		openai_payload.put("messages",messages);
                 		openai_payload.put("temperature",1.0);
                 		openai_payload.put("max_tokens",30);
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		// c. 執行 API 呼叫
                 		last_name = "";
                 		first_name = "";
                 		try 
                 		{
                 			response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,openai_payload.toString(),headers);
                 			info "3. OpenAI API 回應: " + response;
                 			if(response.get("choices") != null && response.get("choices").size() > 0)
                 			{
                 				content_str = response.get("choices").get(0).get("message").get("content").trim();
                 				// 將回傳的 "姓,名" 字串，用逗號分割成 List
                 				name_list = content_str.toList(",");
                 				if(name_list.size() == 2)
                 				{
                 					last_name = name_list.get(0);
                 					first_name = name_list.get(1);
                 				}
                 			}
                 		}
                 		catch (e)
                 		{
                 			info "OpenAI API 呼叫失敗: " + e;
                 		}
                 		// d. 如果 API 呼叫失敗，提供一組預設的姓名以確保流程能繼續
                 		if(last_name == "" || first_name == "")
                 		{
                 			info "API 姓名生成失敗，使用預設姓名。";
                 			if(target_gender == "男")
                 			{
                 				last_name = "王";
                 				first_name = "一飛";
                 			}
                 			else
                 			{
                 				last_name = "林";
                 				first_name = "羽嬌";
                 			}
                 		}
                 		info "4. 已生成姓名: " + last_name + " " + first_name;
                 		// --- 3. 將虛擬個案資料寫入表單 ---
                 		if(last_name != "" && first_name != "" && random_birthday != null)
                 		{
                 			try 
                 			{
                 				insert into Clients_Report
                 				[
                 					Added_User=zoho.loginuser
                 					Visitor_Name.last_name=last_name
                 					Visitor_Name.first_name=first_name
                 					Date_Of_Birth=random_birthday
                 					Client_Type="虛擬"
                 				]
                 				info "--- 成功! --- 已建立虛擬個案: " + last_name + first_name + "，生日為 " + random_birthday;
                 			}
                 			catch (e)
                 			{
                 				info "寫入 Clients_Report 表單失敗: " + e;
                 			}
                 		}
                 		else
                 		{
                 			info "--- 失敗! --- 因缺少姓名或生日資訊，無法建立個案紀錄。";
                 		}
                 	}
                 	info "--- 批次生成 5 位虛擬個案作業完成 ---";
                 }
map Webhook.handleECPayReturn()
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：【Webhook專用】接收綠界 ReturnURL/NotifyURL 回調，並進行處理
                 	// 版本：3.5 (極簡版本)
                 	// 日期：2025-01-21
                 	//
                 	// 邏輯：
                 	// 1. 此函式被設定為 Zoho Creator 的 API 端點，專門接收綠界的回調請求
                 	// 2. 透過 Vercel 代理接收付款結果通知
                 	// 3. 更新最新的 Pending 訂單狀態
                 	// 4. 回傳 "1|OK" 給綠界，告知已收到通知
                 	//
                 	// @return (map): Custom API 格式，包含 status 和 code 回傳給綠界 ECPay
                 	//
                 	info "======= ECPay 回調接收 =======";
                 	info "收到回調請求";
                 	info "時間: " + zoho.currenttime;
                 	// 初始化回傳結果
                 	result = Map();
                 	result.put("status","1|OK");
                 	result.put("code","3000");
                 	info "開始處理付款回調";
                 	// 查詢 Pending 訂單
                 	pendingOrders = Talisman_Purchases[Status == "Pending"];
                 	// 檢查是否有訂單
                 	hasOrders = false;
                 	for each  order in pendingOrders
                 	{
                 		hasOrders = true;
                 		break;
                 	}
                 	if(hasOrders)
                 	{
                 		info "找到 Pending 訂單，準備更新";
                 		for each  order in pendingOrders
                 		{
                 			order.Status="Paid";
                 			order.Purchase_Timestamp=zoho.currenttime;
                 			// 簡化的交易編號生成
                 			timeNow = zoho.currenttime;
                 			order.Transaction_ID="ECPay_" + timeNow.toString("yyyyMMddHHmmss");
                 			info "已更新訂單為 Paid 狀態";
                 			// === 新增：自動交付機制 ===
                 			// 取得訂單 ID
                 			order_id = order.ID;
                 			info "開始自動交付流程，訂單 ID：" + order_id.toString();
                 			// 檢查是否為首次購買，以便觸發完整報告生成
                 			is_first_purchase = order.Is_First_Purchase;
                 			report_included = order.Report_Included;
                 			info "訂單類型檢查：首次購買=" + is_first_purchase.toString() + "，包含報告=" + report_included.toString();
                 			try 
                 			{
                 				// 調用郵件發送函數（內含首次購買完整報告生成邏輯）
                 				email_result = thisapp.Email.sendTalismanReport(order_id.toString());
                 				if(email_result.get("success") == true)
                 				{
                 					info "符令報告發送成功";
                 					// 檢查是否成功生成了完整報告
                 					if(email_result.get("is_first_purchase") == true && email_result.get("report_included") == true)
                 					{
                 						info "首次購買：3000字完整報告已生成並發送";
                 					}
                 					else
                 					{
                 						info "後續購買：符令和原有解讀已發送";
                 					}
                 				}
                 				else
                 				{
                 					info "符令報告發送失敗：" + email_result.get("message");
                 				}
                 			}
                 			catch (e)
                 			{
                 				info "自動交付過程發生錯誤：" + e;
                 			}
                 			break;
                 		}
                 	}
                 	else
                 	{
                 		info "沒有找到 Pending 狀態的訂單";
                 	}
                 	info "======= 回調處理完成 =======";
                 	return result;
                 }
void Webhook.handleSimplyBook(map simplybook_data)
                 {
                 	//
                 	// ===================================================================================
                 	// ==                                                                               ==
                 	// ==   重要開發註記 (Future-Proofing Note)                                         ==
                 	// ==                                                                               ==
                 	// ==   當日後正式串接 SimplyBook API 時，請務必優先檢查其 Webhook 回傳的資料中，  ==
                 	// ==   是否直接包含了客戶的時區資訊 (e.g., "timezone": "Asia/Taipei")。            ==
                 	// ==                                                                               ==
                 	// ==   如果 SimplyBook 已提供時區：                                                ==
                 	// ==   1. 請直接使用該時區，不要再透過 IP 位址進行查詢。                           ==
                 	// ==   2. 可以將下面的 IP 查詢邏輯標記為備用方案或移除，以提高處理效率和準確性。   ==
                 	// ==                                                                               ==
                 	// ===================================================================================
                 	//
                 	// 處理 SimplyBook Webhook 傳來的資料，自動判斷時區，並同步到 Zoho CRM。
                 	//
                 	// @param simplybook_data (map) - 從 SimplyBook Webhook 接收到的完整資料 map。
                 	//
                 	// 初始化準備傳遞給 CRM 同步函數的資料 map
                 	contact_data = Map();
                 	// 這裡的欄位名稱 "client_email", "client_first_name" 等是基於通用慣例的「假設」。
                 	// 實際串接時，需要根據 SimplyBook Webhook 的真實資料結構進行調整。
                 	contact_data.put("Email",simplybook_data.get("client_email"));
                 	contact_data.put("First_Name",simplybook_data.get("client_first_name"));
                 	contact_data.put("Last_Name",simplybook_data.get("client_last_name"));
                 	contact_data.put("Phone",simplybook_data.get("client_phone"));
                 	// 假設生日日期時間欄位為 "booking_start_datetime"，這也需要確認
                 	// 這裡我們假設 SimplyBook 會提供一個可用於計算的精確時間
                 	if(simplybook_data.containKey("precise_birth_time"))
                 	{
                 		contact_data.put("Precise_Birth_Time",simplybook_data.get("precise_birth_time"));
                 	}
                 	// --- 時區自動判斷 ---
                 	// 步驟 1: 獲取觸發此 Webhook 的使用者 IP 位址
                 	user_ip = zoho.ipaddress;
                 	// 步驟 2: 呼叫工具函數，從 IP 查詢時區
                 	timezone_result = thisapp.Tools.getTimezoneFromIP(user_ip);
                 	// 步驟 3: 如果查詢成功，將時區加入到 contact_data 中
                 	if(timezone_result.get("success") == true)
                 	{
                 		contact_data.put("Timezone",timezone_result.get("timezone"));
                 	}
                 	else
                 	{
                 		// 查詢失敗，可以記錄錯誤日誌或設置一個預設值，例如 "Asia/Taipei"
                 		// info "時區查詢失敗: " + timezone_result.get("error") + "，將使用預設時區。";
                 		contact_data.put("Timezone","Asia/Taipei");
                 	}
                 	// 將 "Lead_Source" 硬編碼為 "SimplyBook"，以便追蹤客戶來源
                 	contact_data.put("Lead_Source","SimplyBook");
                 	// --- 核心同步 ---
                 	// 最後，呼叫核心的 CRM 同步函數，將打包好的資料傳遞過去
                 	thisapp.CRM.syncContact(contact_data);
                 }
map Webhook.processChatMessage(string jsonPayload)
                 {
                 	// =============================================================================
                 	// 函數名稱：processChatMessage
                 	// 函數用途：處理SalesIQ Codeless Bot的Webhook請求，整合OpenAI Assistant與RAG
                 	// 平台：Zoho Creator Custom API (Entire JSON 模式)
                 	// 命名空間：Webhook
                 	// 
                 	// 功能描述：
                 	// - 處理SalesIQ的HTTP HEAD驗證請求（回傳200狀態）
                 	// - 接收並處理訪客聊天訊息
                 	// - 整合OpenAI Assistant進行智能回應
                 	// - 查詢RAG知識庫提供個人化建議
                 	// - 回傳結構化的JSON回應給SalesIQ
                 	// 
                 	// 參數說明：
                 	// @param jsonPayload (string) - SalesIQ發送的完整JSON字串
                 	//   - HEAD請求時可能為空字串
                 	//   - POST請求時包含完整的請求資料
                 	// 
                 	// 回傳格式：
                 	// @return (map) - 符合SalesIQ Webhook規範的回應格式
                 	// =============================================================================
                 	api_result = Map();
                 	try 
                 	{
                 		info "=== SalesIQ Webhook 請求處理 (Entire JSON 模式) ===";
                 		info "收到JSON Payload：" + jsonPayload;
                 		// === 檢查是否為空字串 (HEAD 請求) ===
                 		if(jsonPayload == null || jsonPayload.trim() == "")
                 		{
                 			info "收到空 JSON Payload，判斷為 HEAD 驗證請求";
                 			api_result.put("status","ok");
                 			api_result.put("message","Webhook endpoint is ready (Entire JSON mode)");
                 			api_result.put("timestamp",zoho.currenttime.toString("yyyy-MM-dd HH:mm:ss"));
                 			return api_result;
                 		}
                 		// === 解析JSON字串 ===
                 		request_data = Map();
                 		try 
                 		{
                 			request_data = jsonPayload.toMap();
                 			info "JSON 解析成功：" + request_data.toString();
                 		}
                 		catch (json_error)
                 		{
                 			info "JSON 解析失敗：" + json_error.toString();
                 			api_result.put("success",false);
                 			api_result.put("error","無法解析JSON資料：" + json_error.toString());
                 			return api_result;
                 		}
                 		// === 處理實際的POST聊天訊息 ===
                 		info "處理 SalesIQ 聊天訊息請求 (JSON 模式)";
                 		// === 取得訊息參數（支援多種JSON格式） ===
                 		message_text = null;
                 		user_id = null;
                 		session_id = null;
                 		// 方法1：直接參數格式
                 		message_text = request_data.get("message");
                 		user_id = request_data.get("userid");
                 		session_id = request_data.get("sessionid");
                 		// 方法2：Session格式（SalesIQ可能的標準格式）
                 		if(request_data.get("session") != null)
                 		{
                 			session_data = request_data.get("session");
                 			if(session_data.get("message") != null)
                 			{
                 				if(session_data.get("message").get("value") != null)
                 				{
                 					message_text = session_data.get("message").get("value").toString();
                 				}
                 				else
                 				{
                 					message_text = session_data.get("message").toString();
                 				}
                 			}
                 			if(session_data.get("userid") != null)
                 			{
                 				if(session_data.get("userid").get("value") != null)
                 				{
                 					user_id = session_data.get("userid").get("value").toString();
                 				}
                 				else
                 				{
                 					user_id = session_data.get("userid").toString();
                 				}
                 			}
                 			if(session_data.get("sessionid") != null)
                 			{
                 				if(session_data.get("sessionid").get("value") != null)
                 				{
                 					session_id = session_data.get("sessionid").get("value").toString();
                 				}
                 				else
                 				{
                 					session_id = session_data.get("sessionid").toString();
                 				}
                 			}
                 		}
                 		// 方法3：Body格式
                 		if(message_text == null && request_data.get("body") != null)
                 		{
                 			body_data = request_data.get("body");
                 			message_text = body_data.get("message");
                 			user_id = body_data.get("userid");
                 			session_id = body_data.get("sessionid");
                 		}
                 		// 方法4：檢查所有可能的欄位名稱變體
                 		if(message_text == null)
                 		{
                 			possible_message_keys = {"text","msg","content","value"};
                 			for each  key in possible_message_keys
                 			{
                 				if(request_data.get(key) != null)
                 				{
                 					message_text = request_data.get(key).toString();
                 					break;
                 				}
                 			}
                 		}
                 		info "訊息內容：" + if(message_text != null,message_text,"空訊息");
                 		info "用戶ID：" + if(user_id != null,user_id,"未提供");
                 		info "會話ID：" + if(session_id != null,session_id,"未提供");
                 		// === 輸入驗證 ===
                 		if(message_text == null || message_text.trim() == "")
                 		{
                 			api_result.put("success",false);
                 			api_result.put("error","訊息內容不能為空");
                 			api_result.put("received_json",request_data);
                 			return api_result;
                 		}
                 		// === 初始化回應結構 ===
                 		replies = List();
                 		// === 簡單的回應邏輯（暫時） ===
                 		if(message_text.toLowerCase().contains("hello") || message_text.contains("你好"))
                 		{
                 			replies.add("? 歡迎來到我們的靈性世界！我是你的專屬占卜助理，很高興為你服務！");
                 			replies.add("✨ 我可以幫你進行塔羅占卜、八字命理分析，還可以推薦適合的靈性方案。");
                 			replies.add("? 請告訴我你的姓名，讓我們開始這段神奇的探索之旅吧！");
                 		}
                 		else if(message_text.contains("塔羅") || message_text.toLowerCase().contains("tarot"))
                 		{
                 			replies.add("? 塔羅占卜是我的專長！我會根據你的問題，抽取最適合的牌組為你解答。");
                 			replies.add("? 在開始占卜前，需要先建立你的個人檔案，這樣占卜會更加精準。");
                 			replies.add("? 請提供你的基本資料：姓名、電子郵件和手機號碼。");
                 		}
                 		else if(message_text.contains("八字") || message_text.contains("命理"))
                 		{
                 			replies.add("? 八字命理分析需要你的精確出生資訊！");
                 			replies.add("⏰ 請提供：出生年月日和出生時間（越精確越好）");
                 			replies.add("? 有了完整的時間資訊，我就能為你推算專屬的本命星盤。");
                 		}
                 		else
                 		{
                 			// 一般回應
                 			replies.add("✨ 謝謝你的訊息！我正在學習如何更好地為你服務。");
                 			replies.add("? 你可以試試問我關於「塔羅占卜」或「八字命理」的問題。");
                 			replies.add("? 或者直接告訴我你的姓名，讓我們開始建立你的靈性檔案！");
                 		}
                 		// === 建立回應格式（直接回傳SalesIQ期望的格式） ===
                 		api_result.put("replies",replies);
                 		// === 加入調試信息 ===
                 		api_result.put("debug_info",Map());
                 		debug_info = api_result.get("debug_info");
                 		debug_info.put("processed_message",message_text);
                 		debug_info.put("user_id",user_id);
                 		debug_info.put("session_id",session_id);
                 		debug_info.put("original_json",request_data);
                 		debug_info.put("timestamp",zoho.currenttime.toString("yyyy-MM-dd HH:mm:ss"));
                 		// === TODO: 未來整合功能 ===
                 		// 1. OpenAI Assistant API 調用
                 		// 2. RAG 知識庫查詢
                 		// 3. 用戶檔案建立和更新
                 		// 4. 複雜的對話狀態管理
                 		info "成功處理訊息並準備回應";
                 	}
                 	catch (error)
                 	{
                 		api_result.put("success",false);
                 		api_result.put("error","處理請求時發生錯誤：" + error.toString());
                 		info "Webhook 處理錯誤：" + error.toString();
                 	}
                 	return api_result;
                 }
string Widget.getBirthSelectorHTML()
                 {
                 	// Creator Custom API: 回傳生日選擇器的 HTML 內容
                 	// 用途：供 SalesIQ Widget 調用，獲取生日選擇器的 HTML 代碼
                 	// 採用單一出口模式確保所有路徑都有 return 語句
                 	result = "";
                 	try 
                 	{
                 		// 建立生日選擇器的 HTML 內容
                 		htmlContent = "<div id='birth-selector-container' style='max-width:350px;margin:20px auto;padding:20px;border:1px solid #ddd;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);background:#fff;font-family:\"Helvetica Neue\",Arial,sans-serif'>" + "<div style='text-align:center;margin-bottom:20px'>" + "<h3 style='margin:0;color:#BE6F80;font-size:20px;font-weight:600'>【找風問幸福】</h3>" + "</div>" + "<div style='margin-bottom:16px'>" + "<label style='display:block;margin-bottom:6px;color:#333;font-weight:500;font-size:14px'>西元生日</label>" + "<input id='birthDate' type='date' min='1900-01-01' max='2035-12-31' value='2000-01-01' style='width:100%;max-width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px;box-sizing:border-box;transition:border-color 0.3s;overflow:hidden' onfocus='this.style.borderColor=\"#BE6F80\"' onblur='this.style.borderColor=\"#e0e0e0\"'>" + "</div>" + "<div style='margin-bottom:20px'>" + "<label style='display:block;margin-bottom:6px;color:#333;font-weight:500;font-size:14px'>出生時間</label>" + "<input id='birthTime' type='time' step='300' value='12:00' style='width:100%;max-width:100%;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px;box-sizing:border-box;transition:border-color 0.3s;overflow:hidden' onfocus='this.style.borderColor=\"#BE6F80\"' onblur='this.style.borderColor=\"#e0e0e0\"'>" + "</div>" + "<div style='margin-bottom:20px;display:flex;align-items:center;gap:8px'>" + "<input id='confirmBirthData' type='checkbox' style='width:16px;height:16px;accent-color:#BE6F80'>" + "<label for='confirmBirthData' style='color:#333;font-size:14px;cursor:pointer'>確認生日無誤</label>" + "</div>" + "<button id='confirmBirth' onclick='submitBirthData()' style='width:100%;padding:14px;background:#BE6F80;color:#fff;border:0;border-radius:30px;font-size:16px;font-weight:600;cursor:pointer;transition:all 0.3s;box-shadow:0 2px 4px rgba(190,111,128,0.3)' onmouseover='this.style.transform=\"translateY(-2px)\";this.style.boxShadow=\"0 4px 8px rgba(190,111,128,0.4)\"' onmouseout='this.style.transform=\"translateY(0)\";this.style.boxShadow=\"0 2px 4px rgba(190,111,128,0.3)\"'>" + "送出" + "</button>" + "<div id='birthMessage' style='margin-top:16px;padding:12px;border-radius:6px;font-size:14px;text-align:center;display:none'></div>" + "<div style='margin-top:20px;padding-top:16px;border-top:1px solid #f0f0f0'>" + "<details open style='cursor:pointer'>" + "<summary style='color:#BE6F80;font-size:13px;font-weight:500'>溫馨提醒</summary>" + "<div style='margin-top:12px;padding:12px;background:#f9f9f9;border-radius:6px;font-size:12px;color:#666'>" + "<p style='margin:0'>時間越精確，占卜結果越準確</p>" + "</div>" + "</details>" + "</div>" + "</div>";
                 		// 加入 JavaScript 功能
                 		jsContent = "<script>" + "function submitBirthData() {" + "  var dateInput = document.getElementById('birthDate');" + "  var timeInput = document.getElementById('birthTime');" + "  var confirmCheckbox = document.getElementById('confirmBirthData');" + "  var messageDiv = document.getElementById('birthMessage');" + "  var birthDate = dateInput.value;" + "  var birthTime = timeInput.value;" + "  if (!birthDate) {" + "    messageDiv.style.display = 'block';" + "    messageDiv.textContent = '請選擇你的生日';" + "    messageDiv.style.background = '#f8d7da';" + "    messageDiv.style.color = '#721c24';" + "    messageDiv.style.border = '1px solid #f5c6cb';" + "    dateInput.focus();" + "    setTimeout(function() { messageDiv.style.display = 'none'; }, 3000);" + "    return;" + "  }" + "  if (!birthTime) {" + "    messageDiv.style.display = 'block';" + "    messageDiv.textContent = '請選擇出生時間';" + "    messageDiv.style.background = '#f8d7da';" + "    messageDiv.style.color = '#721c24';" + "    messageDiv.style.border = '1px solid #f5c6cb';" + "    timeInput.focus();" + "    setTimeout(function() { messageDiv.style.display = 'none'; }, 3000);" + "    return;" + "  }" + "  if (!confirmCheckbox.checked) {" + "    messageDiv.style.display = 'block';" + "    messageDiv.textContent = '請確認生日無誤';" + "    messageDiv.style.background = '#f8d7da';" + "    messageDiv.style.color = '#721c24';" + "    messageDiv.style.border = '1px solid #f5c6cb';" + "    confirmCheckbox.focus();" + "    setTimeout(function() { messageDiv.style.display = 'none'; }, 3000);" + "    return;" + "  }" + "  var dateObj = new Date(birthDate + 'T' + birthTime);" + "  var formattedDate = dateObj.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });" + "  var formattedTime = dateObj.toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit', hour12: false });" + "  messageDiv.style.display = 'block';" + "  messageDiv.textContent = '已記錄：' + formattedDate + ' ' + formattedTime;" + "  messageDiv.style.background = '#d4edda';" + "  messageDiv.style.color = '#155724';" + "  messageDiv.style.border = '1px solid #c3e6cb';" + "  if (typeof $zoho !== 'undefined' && $zoho.salesiq) {" + "    $zoho.salesiq.visitor.set({ 'Birthday': birthDate, 'BirthTime': birthTime, 'LastInteractionType': 'BirthDataCollection', 'LastInteractionDate': new Date().toISOString() });" + "    $zoho.salesiq.session.set('dateOfBirth', birthDate);" + "    $zoho.salesiq.session.set('timeOfBirth', birthTime);" + "    $zoho.salesiq.session.set('birthDataConfirmed', 'true');" + "    var visitorId = $zoho.salesiq.visitor.uniqueid();" + "  }" + "  if (typeof parent !== 'undefined' && parent.postMessage) {" + "    parent.postMessage({ type: 'birth_data_collected', data: { birthDate: birthDate, birthTime: birthTime, dateTime: birthDate + 'T' + birthTime, visitorId: visitorId || 'unknown' } }, '*');" + "  }" + "}" + "</script>";
                 		// 加入 CSS 樣式
                 		cssContent = "<style>" + "@media (max-width: 480px) {" + "  #birth-selector-container { max-width: 320px !important; margin: 10px auto !important; padding: 16px !important; }" + "}" + "#birthDate:focus, #birthTime:focus { outline: none; box-shadow: 0 0 0 3px rgba(190, 111, 128, 0.2); }" + "#confirmBirth:active { transform: translateY(1px); }" + "</style>";
                 		// 組合完整的 HTML
                 		fullHTML = htmlContent + jsContent + cssContent;
                 		info "getBirthSelectorHTML API 調用成功";
                 		// 設定成功結果
                 		result = fullHTML;
                 	}
                 	catch (error)
                 	{
                 		// 錯誤處理 - 設定錯誤 HTML
                 		result = "<div style='padding:20px;text-align:center;color:#721c24;background:#f8d7da;border:1px solid #f5c6cb;border-radius:8px'>生日選擇器載入失敗，請稍後再試</div>";
                 		info "getBirthSelectorHTML API 錯誤：" + error.toString();
                 	}
                 	// 單一出口點
                 	return result;
                 }
map Zodiac.getChineseZodiacSign(date solar_date)
                 {
                 	//
                 	// Zodiac.getChineseZodiacSign
                 	//
                 	// @description: 根據國曆生日查詢對應的生肖資訊。
                 	//               此函數以農曆新年作為生肖的切換點。
                 	//
                 	// @param solar_date (date) - 必填，使用者的國曆生日。
                 	//
                 	// @return (map) - 回傳一個 map，包含以下鍵值：
                 	//                 "success": (boolean) 操作是否成功。
                 	//                 "zodiac_id": (bigint) 查詢到的生肖記錄 ID (來自 Earthly_Branches 表單)。
                 	//                 "zodiac_name": (string) 生肖的中文名稱，例如 "龍"。
                 	//                 "zodiac_year": (int) 用於計算生肖的有效農曆年份。
                 	//                 "error": (string) 錯誤訊息 (如果 success 為 false)。
                 	//
                 	// 初始化回傳的 Map
                 	response = Map();
                 	response.put("success",false);
                 	// 1. 驗證輸入參數
                 	if(solar_date == null)
                 	{
                 		response.put("error","輸入的國曆生日不可為空。");
                 		return response;
                 	}
                 	// 2. 確定用於計算生肖的有效農曆年份
                 	// 預設使用國曆年份，但如果生日在該年農曆新年前，則生肖年份需減一。
                 	solar_year = solar_date.getYear();
                 	zodiac_year = solar_year;
                 	lunar_data_record = LunarData[Solar_Year == solar_year];
                 	if(lunar_data_record.count() > 0)
                 	{
                 		lunar_new_year_date = lunar_data_record.Lunar_New_Year;
                 		// 子時換日政策（A）：若 solar_date 含時間且落在 23:00–23:59，視為隔日
                 		effective_solar_date = solar_date;
                 		try
                 		{
                 			norm_z = thisapp.Calendar.normalizeToTaipei(solar_date);
                 			if(norm_z.get("success"))
                 			{
                 				zr_z = thisapp.Calendar.applyZiHourDayRollover(norm_z.get("value"));
                 				if(zr_z.get("success"))
                 				{
                 					effective_solar_date = zr_z.get("value");
                 				}
                 			}
                 		}
                 		catch(_e_z)
                 		{
                 			effective_solar_date = solar_date;
                 		}
                 		if(effective_solar_date < lunar_new_year_date)
                 		{
                 			zodiac_year = solar_year - 1;
                 		}
                 	}
                 	else
                 	{
                 		response.put("error","在 LunarData 表中找不到 " + solar_year + " 年的農曆新年資料，無法計算生肖。");
                 		return response;
                 	}
                 	// 3. 根據有效的農曆年份計算地支
                 	// (zodiac_year - 4) % 12 的算法是基於西元4年(甲子年)為鼠年(子)首。
                 	branches = {"子","丑","寅","卯","辰","巳","午","未","申","酉","戌","亥"};
                 	branch_index = (zodiac_year - 4) % 12;
                 	if(branch_index < 0)
                 	{
                 		branch_index = branch_index + 12;
                 	}
                 	target_branch_name = branches.get(branch_index);
                 	// 4. 使用計算出的地支名稱，去查詢 Earthly_Branches 表單
                 	branch_record = Earthly_Branches[Branch_Name == target_branch_name];
                 	// 5. 處理查詢結果
                 	if(branch_record != null)
                 	{
                 		response.put("success",true);
                 		response.put("zodiac_id",branch_record.ID);
                 		response.put("zodiac_name",branch_record.Chinese_Zodiac);
                 		// 假設表單中有一個 Chinese_Zodiac 欄位
                 		response.put("zodiac_year",zodiac_year);
                 	}
                 	else
                 	{
                 		response.put("error","在 Earthly_Branches 表中找不到地支為 '" + target_branch_name + "' 的記錄。");
                 	}
                 	return response;
                 }
map Zodiac.getTaisuiStatus(date solar_date, int query_year)
                 {
                 	//
                 	// Zodiac.getTaisuiStatus
                 	//
                 	// @description: 根據生日和查詢年份，判斷犯太歲狀態並返回相關干支資訊。
                 	//               使用結構化的 Map 來定義「值沖刑害破」規則，易於維護。
                 	//
                 	// @param solar_date (date) - 必填，個案的國曆生日。
                 	// @param query_year (int) - 必填，要查詢的年份 (例如 2024)。
                 	//
                 	// @return (map) - 回傳一個 map，包含以下鍵值：
                 	//                 "success": (boolean) 操作是否成功。
                 	//                 "is_conflicting": (boolean) 是否構成犯太歲。
                 	//                 "conflict_type": (string) 犯太歲的類型 (例如："本命年犯太歲", "沖太歲", "無犯太歲")。
                 	//                 "birth_ganzhi_id": (bigint) 本命干支在 `Sixty_GanZhi_Table` 中的記錄 ID。
                 	//                 "query_year_ganzhi_id": (bigint) 流年干支在 `Sixty_GanZhi_Table` 中的記錄 ID。
                 	//                 "error": (string) 錯誤訊息 (如果 success 為 false)。
                 	//
                 	// 初始化回傳的 Map
                 	response = Map();
                 	response.put("success",false);
                 	response.put("is_conflicting",false);
                 	response.put("conflict_type","無犯太歲");
                 	// 1. 驗證輸入參數
                 	if(solar_date == null || query_year == null)
                 	{
                 		response.put("error","輸入的國曆生日和查詢年份不可為空。");
                 		return response;
                 	}
                 	// 2. 獲取本命地支和本命干支ID
                 	// 2.1 獲取本命的有效農曆年份 (zodiac_year)，需考慮農曆新年
                 	birth_year = solar_date.getYear();
                 	birth_lunar_year = birth_year;
                 	birth_lunar_data = LunarData[Solar_Year == birth_year];
                 	if(birth_lunar_data.count() > 0)
                 	{
                 		if(solar_date < birth_lunar_data.Lunar_New_Year)
                 		{
                 			birth_lunar_year = birth_year - 1;
                 		}
                 	}
                 	else
                 	{
                 		response.put("error","在 LunarData 表中找不到 " + birth_year + " 年的資料。");
                 		return response;
                 	}
                 	// 2.2 根據本命農曆年份計算出本命干支
                 	stems = {"甲","乙","丙","丁","戊","己","庚","辛","壬","癸"};
                 	branches = {"子","丑","寅","卯","辰","巳","午","未","申","酉","戌","亥"};
                 	birth_stem_index = (birth_lunar_year - 4) % 10;
                 	birth_branch_index = (birth_lunar_year - 4) % 12;
                 	birth_stem = stems.get(birth_stem_index);
                 	birth_branch = branches.get(birth_branch_index);
                 	birth_ganzhi = birth_stem + birth_branch;
                 	// 2.3 查詢本命干支對應的記錄ID
                 	birth_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == birth_ganzhi];
                 	if(birth_ganzhi_record == null)
                 	{
                 		response.put("error","在 Sixty_GanZhi_Table 中找不到本命干支為 '" + birth_ganzhi + "' 的記錄。");
                 		return response;
                 	}
                 	response.put("birth_ganzhi_id",birth_ganzhi_record.ID);
                 	// 3. 獲取流年地支和流年干支ID
                 	// 3.1 流年不需要考慮農曆新年，直接使用公元年份計算
                 	query_stem_index = (query_year - 4) % 10;
                 	query_branch_index = (query_year - 4) % 12;
                 	query_stem = stems.get(query_stem_index);
                 	query_branch = branches.get(query_branch_index);
                 	query_ganzhi = query_stem + query_branch;
                 	// 3.2 查詢流年干支對應的記錄ID
                 	query_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == query_ganzhi];
                 	if(query_ganzhi_record == null)
                 	{
                 		response.put("error","在 Sixty_GanZhi_Table 中找不到流年干支為 '" + query_ganzhi + "' 的記錄。");
                 		return response;
                 	}
                 	response.put("query_year_ganzhi_id",query_ganzhi_record.ID);
                 	// 4. 判斷犯太歲關係
                 	// 預先定義好所有地支的沖刑害破關係，查詢效率高且易於維護
                 	conflict_rules = Map();
                 	conflict_rules.put("子",{"值":"子","沖":"午","刑":"卯","害":"未","破":"酉"});
                 	conflict_rules.put("丑",{"值":"丑","沖":"未","刑":"戌","害":"午","破":"辰"});
                 	conflict_rules.put("寅",{"值":"寅","沖":"申","刑":"巳","害":"巳","破":"亥"});
                 	conflict_rules.put("卯",{"值":"卯","沖":"酉","刑":"子","害":"辰","破":"午"});
                 	conflict_rules.put("辰",{"值":"辰","沖":"戌","刑":"辰","害":"卯","破":"丑"});
                 	conflict_rules.put("巳",{"值":"巳","沖":"亥","刑":"申","害":"寅","破":"申"});
                 	conflict_rules.put("午",{"值":"午","沖":"子","刑":"午","害":"丑","破":"卯"});
                 	conflict_rules.put("未",{"值":"未","沖":"丑","刑":"丑","害":"子","破":"戌"});
                 	conflict_rules.put("申",{"值":"申","沖":"寅","刑":"巳","害":"亥","破":"巳"});
                 	conflict_rules.put("酉",{"值":"酉","沖":"卯","刑":"酉","害":"戌","破":"子"});
                 	conflict_rules.put("戌",{"值":"戌","沖":"辰","刑":"未","害":"酉","破":"未"});
                 	conflict_rules.put("亥",{"值":"亥","沖":"巳","刑":"亥","害":"申","破":"寅"});
                 	rules_for_query_year = conflict_rules.get(query_branch);
                 	if(rules_for_query_year != null)
                 	{
                 		if(rules_for_query_year.get("值") == birth_branch)
                 		{
                 			response.put("is_conflicting",true);
                 			response.put("conflict_type","本命年犯太歲");
                 		}
                 		else if(rules_for_query_year.get("沖") == birth_branch)
                 		{
                 			response.put("is_conflicting",true);
                 			response.put("conflict_type","沖太歲");
                 		}
                 		else if(rules_for_query_year.get("刑") == birth_branch)
                 		{
                 			response.put("is_conflicting",true);
                 			response.put("conflict_type","刑太歲");
                 		}
                 		else if(rules_for_query_year.get("害") == birth_branch)
                 		{
                 			response.put("is_conflicting",true);
                 			response.put("conflict_type","害太歲");
                 		}
                 		else if(rules_for_query_year.get("破") == birth_branch)
                 		{
                 			response.put("is_conflicting",true);
                 			response.put("conflict_type","破太歲");
                 		}
                 	}
                 	// 5. 操作成功
                 	response.put("success",true);
                 	return response;
                 }
map Zodiac.getZodiacSign(date solar_date)
                 {
                 	//
                 	// Zodiac.getZodiacSign
                 	//
                 	// @description: 根據國曆生日查詢對應的星座資訊。
                 	//               此函數透過查詢 `Zodiac_Signs` 表單來實現，能正確處理跨年星座(如摩羯座)。
                 	//
                 	// @param solar_date (date) - 必填，使用者的國曆生日。
                 	//
                 	// @return (map) - 回傳一個 map，包含以下鍵值：
                 	//                 "success": (boolean) 操作是否成功。
                 	//                 "sign_id": (bigint) 查詢到的星座記錄 ID。
                 	//                 "sign_name": (string) 查詢到的星座名稱 (例如："牡羊宮（Aries, ♈︎）")。
                 	//                 "error": (string) 錯誤訊息 (如果 success 為 false)。
                 	//
                 	// 初始化回傳的 Map
                 	response = Map();
                 	response.put("success",false);
                 	// 1. 驗證輸入參數
                 	if(solar_date == null)
                 	{
                 		response.put("error","輸入的國曆生日不可為空。");
                 		return response;
                 	}
                 	// 2. 提取生日的月份和日期
                 	month = solar_date.getMonth();
                 	day = solar_date.getDay();
                 	// 3. 查詢所有星座資料
                 	// 由於 Deluge 查詢語法限制，我們先獲取所有記錄，再於迴圈中進行邏輯判斷。
                 	all_zodiacs = Zodiac_Signs[ID != 0];
                 	// 4. 遍歷所有星座記錄，找到匹配的星座
                 	for each  sign in all_zodiacs
                 	{
                 		start_month = sign.Start_Month.toLong();
                 		start_day = sign.Start_Day;
                 		end_month = sign.End_Month.toLong();
                 		end_day = sign.End_Day;
                 		// 判斷是否為跨年星座 (例如：摩羯座 Start_Month=12, End_Month=1)
                 		is_cross_year_sign = start_month > end_month;
                 		if(is_cross_year_sign)
                 		{
                 			// 對於跨年星座，生日需滿足以下任一條件：
                 			// 1. 在起始月份，且日期大於等於起始日 (例如：12月22日之後)
                 			// 2. 在結束月份，且日期小於等於結束日 (例如：1月19日之前)
                 			if((month == start_month && day >= start_day) || (month == end_month && day <= end_day))
                 			{
                 				response.put("success",true);
                 				response.put("sign_name",sign.Sign_Name);
                 				response.put("sign_id",sign.ID);
                 				return response;
                 			}
                 		}
                 		else
                 		{
                 			// 對於常規星座，生日必須在起始月日和結束月日之間。
                 			is_after_start = month > start_month || (month == start_month && day >= start_day);
                 			is_before_end = month < end_month || (month == end_month && day <= end_day);
                 			if(is_after_start && is_before_end)
                 			{
                 				response.put("success",true);
                 				response.put("sign_name",sign.Sign_Name);
                 				response.put("sign_id",sign.ID);
                 				return response;
                 			}
                 		}
                 	}
                 	// 5. 如果遍歷完所有星座都找不到，則回傳錯誤
                 	response.put("error","在星座表(Zodiac_Signs)中找不到對應的星座。日期：" + month + "月" + day + "日");
                 	return response;
                 }
			 }
		 }
		workflow
		{
		form
		{
			GPTAutoReply as "GPTAutoReply"
			{
				type =  form
				form = Divination_Logs

				record event = on add or edit
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// 輸入問題取得答案（目前有錯誤）
										// A. 檢查問題是否填寫
										if(input.Original_Question == null || input.Original_Question.trim() == "")
										{
											alert "請輸入占卜問題";
											cancel submit;
										}
										// Log 輸入資料
										info "▶ 使用者輸入的問題：" + input.Original_Question;
										info "▶ 選擇的爻碼 ID：" + input.Hexagram_Code.ID.toString();
										info "▶ 選擇的語氣：" + input.Tone_Style;
										try 
										{
											// B. 取得卦象資料：改用 Hexagram.getHexagramByYaoCode
											rec = I_Ching_Form[ID == input.Hexagram_Code.ID];
											// 請將 "Yao_Code" 換成你表單中爻碼欄位的 API 名稱
											yaoCode = rec.get("Yao_Code");
											info "▶ 讀取到的爻碼字串：" + yaoCode;
											hex_data = thisapp.Hexagram.getHexagramByYaoCode(yaoCode);
											info "▶ 卦象資料內容如下：" + hex_data.toString();
											if(hex_data.isEmpty())
											{
												alert "找不到對應的卦象資料，請確認選擇的爻碼";
												cancel submit;
											}
											// C. 組 Prompt
											prompt = thisapp.OpenAI.combineDivinationPrompt(input.Original_Question,hex_data,input.Tone_Style);
											info "▶ 組合後的 Prompt：" + prompt;
											// D. 呼叫 GPT
											response = thisapp.OpenAI.callChatGPT(prompt);
											info "▶ GPT 回應內容：" + response;
											// E. 存入結果欄位
											input.AI_Interpretation = response;
										}
										catch (err)
										{
											info "❌ 發生錯誤：" + err.toString();
											alert "處理過程發生錯誤，請稍後再試或聯絡管理員。";
											cancel submit;
										}
						)
					}
				}

			}
			GenerateDivinationPrompt as "GenerateDivinationPrompt"
			{
				type =  form
				form = Divination_Logs

				record event = on add or edit
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											// 組合AI占卜的 Prompt（目前有錯誤）
										// A. 抓出表單資料欄位
										user_question = input.Original_Question;
										tone_style = input.Tone_Style;
										// B. 抓出選取的 I_Ching_Form_Report 記錄物件
										yao_record = I_Ching_Form[ID == input.Hexagram_Code];
										// C. Debug 確認
										info "▶ [DEBUG] 使用者選擇的爻記錄 ID：" + input.Hexagram_Code.toString();
										info "▶ [DEBUG] 撈到的記錄物件：" + yao_record.toString();
										// D. 取得爻碼字串（請改成你表單中爻碼欄位的 API 名稱）
										yaoCode = yao_record.get("Yao_Code");
										info "▶ [DEBUG] 取出的爻碼字串：" + yaoCode;
										// E. 改用 Hexagram.getHexagramByYaoCode 取卦象資料
										hex_data = thisapp.Hexagram.getHexagramByYaoCode(yaoCode);
										info "✅ [DEBUG] hex_data：" + hex_data.toString();
										// F. 組合 Prompt
										prompt = thisapp.OpenAI.combineDivinationPrompt(user_question,hex_data,tone_style);
										// G. 顯示或寫入 Prompt
										info "✅ 組合後的 Prompt：" + prompt;
										Prompt_Generated = prompt;
						)
					}
				}

			}
			Bazi_Constellation_Zodiac as "Bazi_Constellation_Zodiac_Gender_Manner_Generate"
			{
				type =  form
				form = Clients_Report

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnEdit_SetGenderFromAIPrediction.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「客戶性別」(Clients_Gender) 欄位為空，且「訪客姓名」(Visitor_Name) 存在時，
										//               此腳本會呼叫 OpenAI API，根據名字預測性別，並自動填入欄位。
										//
										// @trigger_event: On User Input / On Load (使用者輸入時 / 載入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Visitor_Name (訪客姓名)
										//
										// @notes:
										//   - 這是第一階段的性別判斷。
										//   - API 呼叫失敗或回傳非預期結果時，性別預設為「男」。
										//
										// @dependencies: 
										//   - thisapp.variables.OpenAI.OpenAI_Model (應用程式變數：OpenAI 模型名稱)
										//   - thisapp.variables.OpenAI.OpenAI_API_URL (應用程式變數：OpenAI API 端點)
										//   - thisapp.variables.OpenAI.OpenAI_API_Key (應用程式變數：OpenAI API 金鑰)
										//
										// @placement: 應設定於 Clients_Report 表單的 Workflow 中，
										//             例如在 Visitor_Name 欄位的 "On User Input" 事件，
										//             或表單的 "On Add -> On Load" / "On Edit -> On Load" 事件。
										//
										// 檢查是否需要執行性別預測
										if(input.Clients_Gender == null && input.Visitor_Name.first_name != null && input.Visitor_Name.first_name != "")
										{
											// FUTURE_ENHANCEMENT: 此處為第一階段的性別判斷。
											// 未來在占卜流程中，可加入第二階段判斷，根據個案的問題內容與語氣，再次驗證或修正性別。
											// 屆時可在此 AI 初步判斷的基礎上，建立新的邏輯來覆寫 input.Clients_Gender 的值。
											fname = input.Visitor_Name.first_name.trim();
											// --- 準備 OpenAI API 請求 ---
											messages = list();
											// 設定系統提示 (System Prompt)，指導 AI 的行為
											systemMsg = Map();
											systemMsg.put("role","system");
											systemMsg.put("content","你是一個中文名字性別判斷專家。根據使用者提供的名字，判斷其最可能的性別。你的回答必須只能是「男」或「女」，不能包含任何其他標點符號、文字或解釋。");
											messages.add(systemMsg);
											// 提供少量範例 (Few-shot Examples) 來提高準確性
											messages.add({"role":"user","content":"王大明"});
											messages.add({"role":"assistant","content":"男"});
											messages.add({"role":"user","content":"陳淑芬"});
											messages.add({"role":"assistant","content":"女"});
											messages.add({"role":"user","content":"林俊傑"});
											messages.add({"role":"assistant","content":"男"});
											messages.add({"role":"user","content":"李玉蓮"});
											messages.add({"role":"assistant","content":"女"});
											messages.add({"role":"user","content":"陳子晴"});
											messages.add({"role":"assistant","content":"女"});
											messages.add({"role":"user","content":"黃宇翔"});
											messages.add({"role":"assistant","content":"男"});
											// 準備要預測的使用者名字
											userMsg = Map();
											userMsg.put("role","user");
											userMsg.put("content",fname);
											messages.add(userMsg);
											// 組合完整的請求 payload
											openaiMap = Map();
											openaiMap.put("model",thisapp.variables.OpenAI.OpenAI_Model);
											openaiMap.put("messages",messages);
											openaiMap.put("temperature",0.1);
											openaiMap.put("max_tokens",5);
											// 設定請求標頭
											headers = Map();
											headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
											headers.put("Content-Type","application/json");
											// --- 執行 API 呼叫並處理回應 ---
											try 
											{
												response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,openaiMap.toString(),headers);
												reply = "";
												if(response.get("choices") != null && response.get("choices").size() > 0)
												{
													reply = response.get("choices").get(0).get("message").get("content").trim();
												}
												// 根據 AI 回應設定性別
												if(reply == "女")
												{
													input.Clients_Gender = "女";
												}
												else if(reply == "男")
												{
													input.Clients_Gender = "男";
												}
												else
												{
													// 如果 AI 回傳非預期內容，給予預設值
													input.Clients_Gender = "男";
												}
											}
											catch (e)
											{
												// 如果 API 呼叫失敗，給予預設值
												input.Clients_Gender = "男";
											}
										}
						)
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnEdit_UpdateZodiacAndTaisui.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會自動計算並
										//               填充星座、生肖、虛歲和犯太歲狀態等相關命理欄位。
										//               如果生日欄位被清空，此腳本會同步清空所有相關的衍生欄位。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.Zodiac.getZodiacSign (函數)
										//   - thisapp.Zodiac.getChineseZodiacSign (函數)
										//   - thisapp.Zodiac.getTaisuiStatus (函數)
										//   - LunarData (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// ======================================================================
											// 星座功能
											// ======================================================================
											zodiac_result = thisapp.Zodiac.getZodiacSign(input.Date_Of_Birth);
											if(zodiac_result.get("success") == true)
											{
												input.Zodiac_Signs = zodiac_result.get("sign_id");
											}
											else
											{
												input.Zodiac_Signs = null;
											}
											// ======================================================================
											// 生肖功能
											// ======================================================================
											chinese_zodiac_result = thisapp.Zodiac.getChineseZodiacSign(input.Date_Of_Birth);
											if(chinese_zodiac_result.get("success") == true)
											{
												input.Chinese_Zodiac = chinese_zodiac_result.get("zodiac_id");
												// ======================================================================
												// 虛歲功能
												// ======================================================================
												birth_lunar_year = chinese_zodiac_result.get("zodiac_year");
												current_year = zoho.currentdate.getYear();
												current_lunar_year = current_year;
												// 判斷當前日期是否已過農曆新年，以決定當前的農曆年份
												current_lunar_data_record = LunarData[Solar_Year == current_year];
												if(current_lunar_data_record.count() > 0)
												{
													current_lunar_new_year = current_lunar_data_record.Lunar_New_Year;
													if(zoho.currentdate < current_lunar_new_year.toDate())
													{
														current_lunar_year = current_year - 1;
													}
													// 虛歲 = 當前農曆年份 - 出生農曆年份 + 1
													nominal_age = current_lunar_year - birth_lunar_year + 1;
													input.Nominal_Age = nominal_age;
												}
												else
												{
													input.Nominal_Age = null;
												}
											}
											else
											{
												input.Chinese_Zodiac = null;
												input.Nominal_Age = null;
											}
											// ======================================================================
											// 犯太歲功能
											// ======================================================================
											current_year_for_taisui = zoho.currentdate.getYear();
											taisui_result = thisapp.Zodiac.getTaisuiStatus(input.Date_Of_Birth,current_year_for_taisui);
											if(taisui_result.get("success") == true)
											{
												// 更新「本命太歲」和「流年太歲」的 Lookup 欄位
												input.Taisui_Deity_Name_Birth = taisui_result.get("birth_ganzhi_id");
												input.Taisui_Deity_Name_Year = taisui_result.get("query_year_ganzhi_id");
												// 更新「犯太歲狀態」下拉選單欄位
												input.Taisui_Conflict_Status = taisui_result.get("conflict_type");
											}
											else
											{
												// 如果計算失敗，清空相關欄位
												input.Taisui_Deity_Name_Birth = null;
												input.Taisui_Deity_Name_Year = null;
												input.Taisui_Conflict_Status = null;
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空所有相關的衍生欄位
											input.Zodiac_Signs = null;
											input.Chinese_Zodiac = null;
											input.Nominal_Age = null;
											input.Taisui_Deity_Name_Birth = null;
											input.Taisui_Deity_Name_Year = null;
											input.Taisui_Conflict_Status = null;
										}
						)
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnEdit_UpdateZodiacAndTaisui.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會自動計算並
										//               填充星座、生肖、虛歲和犯太歲狀態等相關命理欄位。
										//               如果生日欄位被清空，此腳本會同步清空所有相關的衍生欄位。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.Zodiac.getZodiacSign (函數)
										//   - thisapp.Zodiac.getChineseZodiacSign (函數)
										//   - thisapp.Zodiac.getTaisuiStatus (函數)
										//   - LunarData (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// ======================================================================
											// 星座功能
											// ======================================================================
											zodiac_result = thisapp.Zodiac.getZodiacSign(input.Date_Of_Birth);
											if(zodiac_result.get("success") == true)
											{
												input.Zodiac_Signs = zodiac_result.get("sign_id");
