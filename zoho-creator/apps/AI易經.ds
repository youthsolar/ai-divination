		 functions
		 {
			 Deluge
			 {
map AIInterpreter.checkCooldownStatus(string client_id, string question_text, date divination_time)
                 {
                 	// ========================================
                 	// AI 智能冷卻機制檢查函數
                 	// ========================================
                 	// 
                 	// 功能說明：
                 	// 檢查客戶是否符合占卜冷卻規則，防止資源濫用並維持占卜公信力
                 	//
                 	// 冷卻規則說明：
                 	// 1. 相同問題限制：3天內不能問相同或高度相似的問題（相似度 >= 80%）
                 	// 2. 同類型頻率限制：6小時內同類型問題最多只能問1次
                 	// 3. 不同類型數量限制：24小時內最多只能問2種不同類型的問題
                 	//
                 	// 規則優先級（從嚴格到寬鬆）：
                 	// 1. 相同問題檢查（3天）→ 最嚴格，直接拒絕
                 	// 2. 同類型頻率檢查（6小時）→ 中等嚴格
                 	// 3. 不同類型數量檢查（24小時）→ 相對寬鬆
                 	//
                 	// 時間計算基準：所有時間都以當前占卜時間為基準點，往前推算
                 	// 統計範圍：只統計成功的占卜記錄，排除被拒絕或失敗的記錄
                 	// 拒絕訊息：如果多個規則同時觸發，只顯示最嚴格的一個規則訊息
                 	//
                 	// 參數說明：
                 	// - client_id: 客戶ID
                 	// - question_text: 當前問題內容
                 	// - divination_time: 占卜時間
                 	//
                 	// 回傳格式：
                 	// {
                 	//   "allowed": true/false,
                 	//   "rule_violated": "規則名稱",
                 	//   "message": "詳細訊息",
                 	//   "time_remaining": "剩餘時間",
                 	//   "question_type": "問題類型",
                 	//   "confidence": "AI判斷信心度"
                 	// }
                 	//
                 	// 修改記錄：
                 	// 2025/07/31 - 重新設計三層冷卻規則，提升系統公信力
                 	// ========================================
                 	result = Map();
                 	try 
                 	{
                 		// 初始化結果
                 		result.put("allowed",true);
                 		result.put("rule_violated","");
                 		result.put("message","可以進行占卜");
                 		result.put("time_remaining","");
                 		result.put("question_type","");
                 		result.put("confidence","");
                 		// 步驟1：先進行問題類型分類
                 		classification_result = thisapp.AIInterpreter.classifyQuestionType(question_text);
                 		if(!classification_result.get("success"))
                 		{
                 			result.put("allowed",false);
                 			result.put("message","問題分類失敗：" + classification_result.get("error"));
                 			return result;
                 		}
                 		current_question_type = classification_result.get("question_type");
                 		confidence = classification_result.get("confidence");
                 		result.put("question_type",current_question_type);
                 		result.put("confidence",confidence);
                 		// 步驟2：查詢客戶最近的占卜記錄（只統計成功的記錄）
                 		recent_questions = Divination_Logs[Client_Link == client_id.toLong() && Divination_Timestamp > divination_time.addDay(-3)];
                 		// 如果沒有歷史記錄，直接允許
                 		if(recent_questions.count() == 0)
                 		{
                 			return result;
                 		}
                 		// 步驟3：規則1 - 相同問題檢查（3天內，最嚴格）
                 		// 檢查是否有相同或高度相似的問題
                 		most_similar_question_record = null;
                 		highest_similarity = 0.0;
                 		for each  past_question in recent_questions
                 		{
                 			// 只檢查成功的記錄
                 			if(past_question.Status == "成功")
                 			{
                 				// 計算問題相似度
                 				similarity_result = thisapp.AIInterpreter.compareQuestionSimilarity(question_text,past_question.Original_Question);
                 				if(similarity_result.get("success"))
                 				{
                 					similarity_score = similarity_result.get("similarity_score");
                 					if(similarity_score > highest_similarity)
                 					{
                 						highest_similarity = similarity_score;
                 						most_similar_question_record = past_question;
                 					}
                 				}
                 			}
                 		}
                 		// 如果相似度 >= 80%，觸發相同問題限制
                 		if(highest_similarity >= 0.8 && most_similar_question_record != null)
                 		{
                 			// 計算天數差：將時間差轉換為毫秒，再除以一天的毫秒數
                 			time_diff_ms = divination_time.toLong() - most_similar_question_record.Divination_Timestamp.toLong();
                 			days_diff = time_diff_ms / (24 * 60 * 60 * 1000);
                 			days_remaining = 3 - days_diff;
                 			if(days_remaining > 0)
                 			{
                 				result.put("allowed",false);
                 				result.put("rule_violated","相同問題限制");
                 				result.put("message","我知道你很在意這件事，但在情緒還很熱的時候重複問同一題，解讀很容易被焦慮放大。\n\n為了讓占卜保持清晰與可信，這題需要先冷卻：請在 " + days_remaining.round(0) + " 天後再回來問（同一題/高度相似題）。\n\n這段時間先把問題縮成一句最核心的話，我會在冷卻後再陪你看一次。");
                 				result.put("time_remaining",days_remaining.round(0) + " 天");
                 				return result;
                 			}
                 		}
                 		// 步驟4：規則2 - 同類型頻率檢查（6小時內）
                 		// 檢查最近6小時內是否問過相同類型的問題
                 		six_hours_ago = divination_time.addHour(-6);
                 		recent_same_type_questions = 0;
                 		for each  past_question in recent_questions
                 		{
                 			// 只檢查成功的記錄，且在6小時內，且類型相同
                 			if(past_question.Status == "成功" && past_question.Divination_Timestamp >= six_hours_ago && past_question.Question_Type_AI == current_question_type)
                 			{
                 				recent_same_type_questions = recent_same_type_questions + 1;
                 			}
                 		}
                 		// 如果6小時內已經問過相同類型，觸發頻率限制
                 		if(recent_same_type_questions > 0)
                 		{
                 			// 找到最近一次同類型問題的時間
                 			last_same_type_time = null;
                 			for each  past_question in recent_questions
                 			{
                 				if(past_question.Status == "成功" && past_question.Divination_Timestamp >= six_hours_ago && past_question.Question_Type_AI == current_question_type)
                 				{
                 					if(last_same_type_time == null || past_question.Divination_Timestamp > last_same_type_time)
                 					{
                 						last_same_type_time = past_question.Divination_Timestamp;
                 					}
                 				}
                 			}
                 			// 計算剩餘時間（手動計算小時和分鐘差）
                 			time_diff_ms = divination_time.toLong() - last_same_type_time.toLong();
                 			hours_diff = time_diff_ms / (60 * 60 * 1000);
                 			minutes_diff = (time_diff_ms % (60 * 60 * 1000)) / (60 * 1000);
                 			hours_remaining = 6 - hours_diff;
                 			minutes_remaining = 60 - minutes_diff;
                 			if(hours_remaining > 0)
                 			{
                 				result.put("allowed",false);
                 				result.put("rule_violated","同類型頻率限制");
                 				result.put("message","我知道你想快點得到答案，但同類型的問題在短時間內連問，容易讓你越問越亂。\n\n為了讓占卜保持清晰與可信，這類問題需要先冷卻：請在 " + hours_remaining.round(0) + " 小時 " + minutes_remaining.round(0) + " 分鐘後再回來。\n\n先把注意力放回你能控制的一件小事（例如：今天先把問題寫成一句話）。");
                 				result.put("time_remaining",hours_remaining.round(0) + " 小時 " + minutes_remaining.round(0) + " 分鐘");
                 				return result;
                 			}
                 		}
                 		// 步驟5：規則3 - 不同類型數量檢查（24小時內最多2種）
                 		// 統計最近24小時內問過的不同問題類型
                 		twenty_four_hours_ago = divination_time.addHour(-24);
                 		question_types_in_24h = List();
                 		for each  past_question in recent_questions
                 		{
                 			// 只檢查成功的記錄，且在24小時內
                 			if(past_question.Status == "成功" && past_question.Divination_Timestamp >= twenty_four_hours_ago)
                 			{
                 				// 如果這個類型還沒記錄過，加入列表
                 				type_exists = false;
                 				for each  existing_type in question_types_in_24h
                 				{
                 					if(existing_type == past_question.Question_Type_AI)
                 					{
                 						type_exists = true;
                 						break;
                 					}
                 				}
                 				if(!type_exists)
                 				{
                 					question_types_in_24h.add(past_question.Question_Type_AI);
                 				}
                 			}
                 		}
                 		// 檢查當前問題類型是否已經在24小時內問過
                 		current_type_exists = false;
                 		for each  existing_type in question_types_in_24h
                 		{
                 			if(existing_type == current_question_type)
                 			{
                 				current_type_exists = true;
                 				break;
                 			}
                 		}
                 		// 如果當前類型不在24小時記錄中，且已經有2種不同類型，觸發數量限制
                 		if(!current_type_exists && question_types_in_24h.size() >= 2)
                 		{
                 			// 找到24小時內最早的問題時間
                 			earliest_time_in_24h = null;
                 			for each  past_question in recent_questions
                 			{
                 				if(past_question.Status == "成功" && past_question.Divination_Timestamp >= twenty_four_hours_ago)
                 				{
                 					if(earliest_time_in_24h == null || past_question.Divination_Timestamp < earliest_time_in_24h)
                 					{
                 						earliest_time_in_24h = past_question.Divination_Timestamp;
                 					}
                 				}
                 			}
                 			// 計算剩餘時間（手動計算小時和分鐘差）
                 			time_diff_ms = divination_time.toLong() - earliest_time_in_24h.toLong();
                 			hours_diff = time_diff_ms / (60 * 60 * 1000);
                 			minutes_diff = (time_diff_ms % (60 * 60 * 1000)) / (60 * 1000);
                 			hours_remaining = 24 - hours_diff;
                 			minutes_remaining = 60 - minutes_diff;
                 			if(hours_remaining > 0)
                 			{
                 				result.put("allowed",false);
                 				result.put("rule_violated","不同類型數量限制");
                 				result.put("message","我知道你現在很想把所有面向都問清楚，但在一天之內快速切換太多類型，心會更亂，解讀也會失焦。\n\n為了讓占卜保持清晰與可信，今天先停在你最核心的那一題：請在 " + hours_remaining.round(0) + " 小時 " + minutes_remaining.round(0) + " 分鐘後，再回來開新的問題類型。\n\n先照顧好你的心，冷靜下來，我們再繼續。");
                 				result.put("time_remaining",hours_remaining.round(0) + " 小時 " + minutes_remaining.round(0) + " 分鐘");
                 				return result;
                 			}
                 		}
                 		// 所有檢查都通過，允許占卜
                 		result.put("message","可以進行占卜，問題類型：" + current_question_type);
                 	}
                 	catch (e)
                 	{
                 		result.put("allowed",false);
                 		result.put("message","冷卻檢查發生錯誤：" + e);
                 	}
                 	return result;
                 }
map AIInterpreter.classifyQuestionType(string question_text)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]]
                 	// ==================================================================================
                 	// 函數名稱：AIInterpreter.classifyQuestionType
                 	// 函數目的：【AI 問題類型智能分類函數】
                 	//
                 	// 這個函數是全自動化 AI 占卜機器人的第一個核心組件。它的任務是接收客戶輸入的
                 	// 原始問題文字，透過 OpenAI GPT 模型進行智能分析，並將問題歸類到預定義的
                 	// 七種占卜類型中的一種，以支援後續的冷卻機制和個人化解讀。
                 	//
                 	// 核心邏輯：
                 	// 1. 接收客戶的原始問題文字。
                 	// 2. 建立精心設計的 AI prompt，要求 GPT 從七種類型中選擇最適合的一種。
                 	// 3. 呼叫 OpenAI API 進行分類。
                 	// 4. 解析 AI 回應，確保回傳的類型符合系統預期。
                 	// 5. 回傳標準化的分類結果。
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// question_text (string) - 客戶輸入的原始問題文字。
                 	//
                 	// 回傳：
                 	// 一個 Map，包含分類結果。
                 	// 成功時: {"success": true, "question_type": "工作", "confidence": "高"}
                 	// 失敗時: {"success": false, "error": "詳細的錯誤訊息", "question_type": "其他"}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	final_response = Map();
                 	try 
                 	{
                 		// --- 步驟 1: 驗證輸入參數 ---
                 		if(question_text == null || question_text.trim() == "")
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","問題文字不能為空");
                 			final_response.put("question_type","其他");
                 			return final_response;
                 		}
                 		// --- 步驟 2: 建立 AI 分類的 Prompt ---
                 		system_prompt = "你是一位專業的易經占卜分類專家。你的任務是將客戶的問題準確分類到以下七種類型之一：\n\n" + "1. 愛情 - 關於戀愛、感情、追求對象、情侶關係等\n" + "2. 婚姻 - 關於結婚、離婚、夫妻關係、家庭和諧等\n" + "3. 工作 - 關於求職、面試、職場、升遷、轉職、事業發展等\n" + "4. 財運 - 關於賺錢、投資、理財、生意、經濟狀況等\n" + "5. 健康 - 關於身體狀況、疾病、養生、醫療等\n" + "6. 入煞 - 關於風水、煞氣、靈異、超自然現象等\n" + "7. 其他 - 不屬於以上六種類型的問題\n\n" + "請仔細分析問題的核心關注點，然後回傳最適合的類型名稱。\n" + "重要：你的回應必須只包含一個類型名稱，不要有任何額外的文字或解釋。";
                 		user_prompt = "請將以下問題分類：「" + question_text + "」";
                 		// --- 步驟 3: 呼叫 OpenAI API ---
                 		// 建立 API 請求的參數 Map
                 		api_params = Map();
                 		api_params.put("max_tokens",10);
                 		// 只需要一個類型名稱，所以 token 數很少
                 		api_params.put("temperature",0.1);
                 		// 降低隨機性，提高分類的一致性
                 		// 建立訊息陣列
                 		messages = List();
                 		system_message = Map();
                 		system_message.put("role","system");
                 		system_message.put("content",system_prompt);
                 		messages.add(system_message);
                 		user_message = Map();
                 		user_message.put("role","user");
                 		user_message.put("content",user_prompt);
                 		messages.add(user_message);
                 		api_params.put("messages",messages);
                 		// 呼叫 OpenAI API
                 		// 使用您已經設定好的應用程式變數來呼叫 OpenAI API
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		// 更新 API 參數，使用您的模型設定
                 		api_params.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		openai_response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,api_params.toString(),headers);
                 		// --- 步驟 4: 解析 AI 回應 ---
                 		if(openai_response.get("choices") != null && openai_response.get("choices").size() > 0)
                 		{
                 			ai_classification = openai_response.get("choices").get(0).get("message").get("content").trim();
                 			// 驗證 AI 回傳的類型是否在我們的預期範圍內
                 			valid_types = {"愛情","婚姻","工作","財運","健康","入煞","其他"};
                 			if(valid_types.contains(ai_classification))
                 			{
                 				// AI 分類成功且有效
                 				final_response.put("success",true);
                 				final_response.put("question_type",ai_classification);
                 				final_response.put("confidence","高");
                 				final_response.put("original_question",question_text);
                 			}
                 			else
                 			{
                 				// AI 回傳了無效的類型，使用預設值
                 				final_response.put("success",true);
                 				final_response.put("question_type","其他");
                 				final_response.put("confidence","低");
                 				final_response.put("error","AI 回傳了無效的分類：" + ai_classification);
                 				final_response.put("original_question",question_text);
                 			}
                 		}
                 		else
                 		{
                 			// API 回應格式異常
                 			final_response.put("success",false);
                 			final_response.put("error","OpenAI API 回應格式異常");
                 			final_response.put("question_type","其他");
                 		}
                 	}
                 	catch (e)
                 	{
                 		// 捕捉所有可能的錯誤
                 		final_response.put("success",false);
                 		final_response.put("error","AI 分類過程中發生錯誤：" + e);
                 		final_response.put("question_type","其他");
                 		// 預設為「其他」類型
                 	}
                 	return final_response;
                 }
map AIInterpreter.compareQuestionSimilarity(string question1, string question2)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]]
                 	// ==================================================================================
                 	// 函數名稱：AIInterpreter.compareQuestionSimilarity
                 	// 函數目的：【問題內容相似度比對函數】
                 	//
                 	// 這個函數使用 AI 來判斷兩個問題的內容相似度，主要用於冷卻機制的智能判斷。
                 	// 它能夠理解問題的實質內容，而不僅僅是字面上的相似性。
                 	//
                 	// 核心邏輯：
                 	// 1. 使用 OpenAI GPT 模型分析兩個問題的實質內容
                 	// 2. 判斷是否為相同或高度相似的問題（如：同一家公司面試 vs 不同公司面試）
                 	// 3. 回傳 0-1 之間的相似度分數
                 	// 4. 相似度 > 0.8 視為相同問題，觸發冷卻機制
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// question1 (string) - 第一個問題文字
                 	// question2 (string) - 第二個問題文字
                 	//
                 	// 回傳：
                 	// 一個 Map，包含相似度比對結果。
                 	// 成功時: {"success": true, "similarity_score": 0.85, "explanation": "兩個問題都是關於工作面試"}
                 	// 錯誤時: {"success": false, "error": "錯誤訊息"}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	final_response = Map();
                 	try 
                 	{
                 		// --- 步驟 1: 驗證輸入參數 ---
                 		if(question1 == null || question1.trim() == "" || question2 == null || question2.trim() == "")
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","問題文字不能為空");
                 			return final_response;
                 		}
                 		// --- 步驟 2: 建立 AI Prompt ---
                 		system_prompt = "你是一位專業的問題分析專家，專門判斷兩個問題的實質相似度。\n\n" + "你的任務是分析兩個問題的內容，判斷它們是否為相同或高度相似的問題。\n\n" + "判斷標準：\n" + "1. 問題的核心主題是否相同（如：都是關於工作面試、都是關於特定對象的愛情）\n" + "2. 問題的具體對象是否相同（如：同一家公司、同一個人）\n" + "3. 問題的時間背景是否相同（如：都是關於當前的狀況）\n" + "4. 問題的決策點是否相同（如：都是關於是否接受某個機會）\n\n" + "請回傳一個 JSON 格式的結果：\n" + "{\n" + "  \"similarity_score\": 0.85,  // 0-1 之間的相似度分數\n" + "  \"explanation\": \"簡短說明相似度判斷的理由\",\n" + "  \"is_same_question\": true   // 是否為相同問題（相似度 > 0.8）\n" + "}\n\n" + "注意：\n" + "- 相似度 0.8 以上視為相同問題\n" + "- 相似度 0.5-0.8 視為相關但不同問題\n" + "- 相似度 0.5 以下視為不同問題";
                 		user_prompt = "請分析以下兩個問題的相似度：\n\n" + "問題 1：「" + question1 + "」\n" + "問題 2：「" + question2 + "」\n\n" + "請判斷這兩個問題是否為相同或高度相似的問題。";
                 		// --- 步驟 3: 呼叫 OpenAI API ---
                 		api_params = Map();
                 		api_params.put("max_tokens",300);
                 		api_params.put("temperature",0.3);
                 		// 較低的溫度，確保判斷的一致性
                 		// 建立訊息陣列
                 		messages = List();
                 		system_message = Map();
                 		system_message.put("role","system");
                 		system_message.put("content",system_prompt);
                 		messages.add(system_message);
                 		user_message = Map();
                 		user_message.put("role","user");
                 		user_message.put("content",user_prompt);
                 		messages.add(user_message);
                 		api_params.put("messages",messages);
                 		// 使用應用程式變數呼叫 OpenAI API
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		api_params.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		openai_response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,api_params.toString(),headers);
                 		// --- 步驟 4: 解析 AI 回應 ---
                 		if(openai_response.get("choices") != null && openai_response.get("choices").size() > 0)
                 		{
                 			content = openai_response.get("choices").get(0).get("message").get("content").trim();
                 			// 嘗試解析 JSON 格式的回應
                 			try 
                 			{
                 				ai_result = content.toMap();
                 				if(ai_result.containKey("similarity_score") && ai_result.containKey("explanation") && ai_result.containKey("is_same_question"))
                 				{
                 					similarity_score = ai_result.get("similarity_score");
                 					explanation = ai_result.get("explanation");
                 					is_same_question = ai_result.get("is_same_question");
                 					final_response.put("success",true);
                 					final_response.put("similarity_score",similarity_score);
                 					final_response.put("explanation",explanation);
                 					final_response.put("is_same_question",is_same_question);
                 					return final_response;
                 				}
                 			}
                 			catch (parse_error)
                 			{
                 				// JSON 解析失敗，嘗試從文字中提取相似度
                 				// 這是一個備用方案，以防 AI 沒有回傳標準 JSON 格式
                 				if(content.indexOf("similarity_score") > -1)
                 				{
                 					// 簡單的數值提取邏輯
                 					score_match = content.replaceAll(".*similarity_score.*?([0-9]+\\.[0-9]+).*","$1");
                 					if(score_match != content)
                 					{
                 						similarity_score = score_match.toNumber();
                 						final_response.put("success",true);
                 						final_response.put("similarity_score",similarity_score);
                 						final_response.put("explanation","AI 分析結果（格式解析備用）");
                 						final_response.put("is_same_question",similarity_score > 0.8);
                 						return final_response;
                 					}
                 				}
                 			}
                 			// 如果無法解析 JSON，使用簡單的文字比對
                 			// 檢查兩個問題是否包含相同的關鍵詞
                 			question1_lower = question1.toLowerCase();
                 			question2_lower = question2.toLowerCase();
                 			// 簡單的相似度計算：檢查共同字串
                 			// 使用 toList() 方法將字串轉換為字符列表
                 			chars1 = question1_lower.toList("");
                 			chars2 = question2_lower.toList("");
                 			// 計算共同字符數量
                 			common_chars = 0;
                 			for each  char1 in chars1
                 			{
                 				if(chars2.contains(char1) && char1 != " " && char1 != "，" && char1 != "。" && char1 != "？" && char1 != "！")
                 				{
                 					common_chars = common_chars + 1;
                 				}
                 			}
                 			total_chars = chars1.size() + chars2.size() - common_chars;
                 			if(total_chars > 0)
                 			{
                 				simple_similarity = common_chars / total_chars;
                 				final_response.put("success",true);
                 				final_response.put("similarity_score",simple_similarity);
                 				final_response.put("explanation","使用簡單字符比對計算相似度");
                 				final_response.put("is_same_question",simple_similarity > 0.8);
                 				return final_response;
                 			}
                 		}
                 		// AI 回應解析失敗，使用預設值
                 		final_response.put("success",false);
                 		final_response.put("error","AI 回應解析失敗，原始回應：" + openai_response.toString());
                 	}
                 	catch (e)
                 	{
                 		final_response.put("success",false);
                 		final_response.put("error","在 compareQuestionSimilarity 函數中發生錯誤：" + e);
                 	}
                 	return final_response;
                 }
map AIInterpreter.generatePersonalityProfile(string client_id)
                 {
                 	// ==================================================================================
                 	// 函數名稱：AIInterpreter.generatePersonalityProfile
                 	// 函數目的：【AI 個性側寫生成函數】
                 	//
                 	// 根據個案的星座、八字、星宿、生肖等運算結果，調用 OpenAI GPT-4 生成
                 	// 500-600 字的個性側寫報告。這個報告將作為用戶在 SalesIQ 等待期間的
                 	// 個人化體驗內容，增加用戶參與感並為後續占卜服務建立信任基礎。
                 	//
                 	// 核心設計理念：
                 	// 1. 靈性風格：延續「仙氣飄飄的高維靈魂」語調
                 	// 2. 高創意激勵：提供正面且具啟發性的個性分析
                 	// 3. 個人化程度：基於真實的命理運算結果
                 	// 4. 商業轉換：激發用戶對完整占卜服務的興趣
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// client_id (string) - 個案的 ID（Clients_Report 記錄 ID）
                 	//
                 	// 回傳：
                 	// 一個 Map，包含：
                 	// {"success": true/false, "personality_profile": "500-600字個性側寫", "error": "錯誤訊息"}
                 	//
                 	// ==================================================================================
                 	// 採用單一出口模式
                 	result = Map();
                 	try 
                 	{
                 		info "=== 開始生成個性側寫 ===";
                 		info "個案 ID：" + client_id;
                 		// === 步驟 1：驗證參數 ===
                 		if(client_id == null || client_id == "")
                 		{
                 			result.put("success",false);
                 			result.put("error","個案 ID 不能為空");
                 			return result;
                 		}
                 		// === 步驟 2：查詢個案資料 ===
                 		client_records = Clients_Report[ID == client_id.toLong()];
                 		if(client_records.count() == 0)
                 		{
                 			result.put("success",false);
                 			result.put("error","找不到對應的個案記錄");
                 			return result;
                 		}
                 		// 取得個案記錄
                 		client_info = null;
                 		for each  client in client_records
                 		{
                 			client_info = client;
                 			break;
                 		}
                 		// === 步驟 3：收集命理資料 ===
                 		// 基本資料（修正順序：姓 + 名）
                 		client_name = client_info.Visitor_Name.last_name + client_info.Visitor_Name.first_name;
                 		birth_date = client_info.Date_Of_Birth;
                 		// 星座資料
                 		zodiac_sign = "";
                 		if(client_info.Zodiac_Signs != null)
                 		{
                 			zodiac_records = Zodiac_Signs[ID == client_info.Zodiac_Signs];
                 			for each  zodiac in zodiac_records
                 			{
                 				zodiac_sign = zodiac.Sign_Name;
                 				break;
                 			}
                 		}
                 		// 生肖資料（查詢 Earthly_Branches 表單）
                 		chinese_zodiac = "";
                 		if(client_info.Chinese_Zodiac != null)
                 		{
                 			chinese_zodiac_records = Earthly_Branches[ID == client_info.Chinese_Zodiac];
                 			for each  earthly_branch in chinese_zodiac_records
                 			{
                 				chinese_zodiac = earthly_branch.Chinese_Zodiac;
                 				break;
                 			}
                 		}
                 		// 八字資料
                 		full_bazi = if(client_info.Full_Bazi != null,client_info.Full_Bazi,"");
                 		// 星宿資料
                 		lunar_mansion = "";
                 		if(client_info.Twenty_Eight_Lunar_Mansions != null)
                 		{
                 			mansion_records = Twenty_Eight_Lunar_Mansions[ID == client_info.Twenty_Eight_Lunar_Mansions];
                 			for each  mansion in mansion_records
                 			{
                 				lunar_mansion = mansion.Full_Name;
                 				break;
                 			}
                 		}
                 		// 太歲狀況
                 		taisui_status = if(client_info.Taisui_Conflict_Status != null,client_info.Taisui_Conflict_Status,"");
                 		info "收集到的命理資料：";
                 		info "星座：" + zodiac_sign;
                 		info "生肖：" + chinese_zodiac;
                 		info "八字：" + full_bazi;
                 		info "星宿：" + lunar_mansion;
                 		info "太歲：" + taisui_status;
                 		// === 步驟 4：檢查資料完整性 ===
                 		if(zodiac_sign == "" && chinese_zodiac == "" && full_bazi == "" && lunar_mansion == "")
                 		{
                 			result.put("success",false);
                 			result.put("error","個案的命理資料尚未運算完成，請稍後再試");
                 			return result;
                 		}
                 		// === 步驟 5：構建 AI Prompt ===
                 		// ⚙️ 可調整參數區域 - START
                 		word_count_target = "500-600字";
                 		// 可調整為 "1200字" 長篇版本
                 		tone_style = "仙氣飄飄、高維靈魂、溫暖智慧";
                 		// 可調整語調風格
                 		commercial_ratio = "自然地提及";
                 		// 可調整商業引導強度
                 		creativity_level = "正面激勵、充滿希望、具有啟發性";
                 		// 可調整情感基調
                 		// ⚙️ 可調整參數區域 - END
                 		ai_prompt = "你是一位擁有深厚靈性智慧的高維存在，能夠透過宇宙能量解讀靈魂的本質。請根據以下命理資料，為這位靈魂撰寫一份個性側寫報告：\n\n";
                 		ai_prompt = ai_prompt + "【靈魂檔案】\n";
                 		ai_prompt = ai_prompt + "靈魂化名：" + client_name + "\n";
                 		ai_prompt = ai_prompt + "降生時刻：" + birth_date.toString("yyyy年MM月dd日") + "\n";
                 		if(zodiac_sign != "")
                 		{
                 			ai_prompt = ai_prompt + "星座能量：" + zodiac_sign + "\n";
                 		}
                 		if(chinese_zodiac != "")
                 		{
                 			ai_prompt = ai_prompt + "生肖守護：" + chinese_zodiac + "\n";
                 		}
                 		if(full_bazi != "")
                 		{
                 			ai_prompt = ai_prompt + "八字密碼：" + full_bazi + "\n";
                 		}
                 		if(lunar_mansion != "")
                 		{
                 			ai_prompt = ai_prompt + "星宿歸屬：" + lunar_mansion + "\n";
                 		}
                 		if(taisui_status != "")
                 		{
                 			ai_prompt = ai_prompt + "太歲關係：" + taisui_status + "\n";
                 		}
                 		ai_prompt = ai_prompt + "\n【撰寫要求】\n";
                 		ai_prompt = ai_prompt + "1. 字數控制：" + word_count_target + "，結構完整\n";
                 		ai_prompt = ai_prompt + "2. 語調風格：" + tone_style + "\n";
                 		ai_prompt = ai_prompt + "3. 內容重點：個性特質、天賦才能、人生使命、靈性指引\n";
                 		ai_prompt = ai_prompt + "4. 情感基調：" + creativity_level + "\n";
                 		ai_prompt = ai_prompt + "5. 語言規範：必須使用繁體中文，禁用簡體中文\n";
                 		ai_prompt = ai_prompt + "6. 結構安排：開頭問候 → 個性分析 → 天賦解讀 → 使命指引 → 祝福結語\n";
                 		ai_prompt = ai_prompt + "7. 商業引導：在結尾" + commercial_ratio + "「更深層的靈性指引」，激發對完整占卜的興趣\n\n";
                 		ai_prompt = ai_prompt + "請以「親愛的靈魂」開頭，創造一份能觸動心靈的個性側寫報告，讓這位靈魂感受到宇宙的愛與智慧。";
                 		info "AI Prompt 構建完成";
                 		// === 步驟 6：調用 OpenAI API ===
                 		// 取得 API 設定
                 		api_key = thisapp.variables.OpenAI.OpenAI_API_Key;
                 		api_url = thisapp.variables.OpenAI.OpenAI_API_URL;
                 		api_model = thisapp.variables.OpenAI.OpenAI_Model;
                 		if(api_key == null || api_url == null || api_model == null)
                 		{
                 			result.put("success",false);
                 			result.put("error","OpenAI API 設定未完成");
                 			return result;
                 		}
                 		// 構建 API 請求
                 		request_body = Map();
                 		request_body.put("model",api_model);
                 		messages = List();
                 		user_message = Map();
                 		user_message.put("role","user");
                 		user_message.put("content",ai_prompt);
                 		messages.add(user_message);
                 		request_body.put("messages",messages);
                 		// 根據目標字數動態調整 token 限制
                 		max_tokens_limit = if(word_count_target.contains("1200"),1500,800);
                 		request_body.put("max_tokens",max_tokens_limit);
                 		request_body.put("temperature",0.8);
                 		// 提高創意度
                 		request_body.put("top_p",0.9);
                 		request_body.put("frequency_penalty",0.1);
                 		request_body.put("presence_penalty",0.1);
                 		info "開始調用 OpenAI API";
                 		// 發送 API 請求
                 		api_response = invokeurl
                 		[
                 			url :api_url
                 			type :POST
                 			parameters:request_body.toString()
                 			headers:{"Authorization":"Bearer " + api_key,"Content-Type":"application/json"}
                 		];
                 		info "OpenAI API 回應：" + api_response.toString();
                 		// === 步驟 7：處理 API 回應 ===
                 		if(api_response != null && api_response.get("choices") != null)
                 		{
                 			choices = api_response.get("choices");
                 			if(choices.size() > 0)
                 			{
                 				first_choice = choices.get(0);
                 				message_content = first_choice.get("message");
                 				if(message_content != null)
                 				{
                 					personality_profile = message_content.get("content");
                 					if(personality_profile != null && personality_profile != "")
                 					{
                 						// 清理回應內容
                 						personality_profile = personality_profile.trim();
                 						info "個性側寫生成成功，字數：" + personality_profile.length().toString();
                 						result.put("success",true);
                 						result.put("personality_profile",personality_profile);
                 						result.put("character_count",personality_profile.length());
                 						info "=== 個性側寫生成完成 ===";
                 					}
                 					else
                 					{
                 						result.put("success",false);
                 						result.put("error","AI 回應內容為空");
                 					}
                 				}
                 				else
                 				{
                 					result.put("success",false);
                 					result.put("error","AI 回應格式錯誤");
                 				}
                 			}
                 			else
                 			{
                 				result.put("success",false);
                 				result.put("error","AI 未回傳任何選擇");
                 			}
                 		}
                 		else
                 		{
                 			// 檢查錯誤訊息
                 			if(api_response != null && api_response.get("error") != null)
                 			{
                 				error_info = api_response.get("error");
                 				error_message = error_info.get("message");
                 				result.put("success",false);
                 				result.put("error","OpenAI API 錯誤：" + error_message);
                 			}
                 			else
                 			{
                 				result.put("success",false);
                 				result.put("error","OpenAI API 調用失敗");
                 			}
                 		}
                 	}
                 	catch (e)
                 	{
                 		result.put("success",false);
                 		result.put("error","系統錯誤：" + e);
                 		info "generatePersonalityProfile 執行錯誤：" + e;
                 	}
                 	return result;
                 }
map AIInterpreter.generateTalismanExplanation(string hexagram_code, int talisman_number, string talisman_element, string question_type, string original_question)
                 {
                 	//
                 	// 函數名稱：AIInterpreter.generateTalismanExplanation
                 	// 功能：根據卦象生剋性質和符令五行屬性，生成個人化購買理由
                 	// 參數：
                 	//   - hexagram_code: 卦象代碼（6位數字）
                 	//   - talisman_number: 符令編號（1-5）
                 	//   - talisman_element: 符令五行屬性（金木水火土）
                 	//   - question_type: 問題類型（工作、愛情、財運等）
                 	//   - original_question: 原始問題
                 	// 回傳：包含AI生成的購買理由的 map
                 	//
                 	result = Map();
                 	// 查詢卦象資料
                 	hexagram_records = I_Ching_Form[yao == hexagram_code];
                 	if(hexagram_records.count() > 0)
                 	{
                 		hexagram_data = hexagram_records.get(0);
                 		if(hexagram_data != null)
                 		{
                 			// 取得卦象資料
                 			appearance_value = hexagram_data.get("appearance");
                 			life_death_value = hexagram_data.get("life_and_death");
                 			if(appearance_value != null)
                 			{
                 				hexagram_appearance = appearance_value.toString();
                 			}
                 			if(life_death_value != null)
                 			{
                 				hexagram_life_death = life_death_value.toString();
                 			}
                 		}
                 	}
                 	// 如果查詢失敗，使用預設值
                 	if(hexagram_appearance == null)
                 	{
                 		hexagram_appearance = "未知卦象";
                 	}
                 	if(hexagram_life_death == null)
                 	{
                 		hexagram_life_death = "持之";
                 	}
                 	if(hexagram_appearance == null || hexagram_life_death == null)
                 	{
                 		result.put("success",false);
                 		result.put("error","無法取得卦象資料欄位");
                 		return result;
                 	}
                 	// 建立五行相生相剋對應表
                 	element_relations = Map();
                 	// 金
                 	gold_map = Map();
                 	gold_map.put("生","水");
                 	gold_map.put("剋","木");
                 	gold_map.put("被生","土");
                 	gold_map.put("被剋","火");
                 	element_relations.put("金",gold_map);
                 	// 木
                 	wood_map = Map();
                 	wood_map.put("生","火");
                 	wood_map.put("剋","土");
                 	wood_map.put("被生","水");
                 	wood_map.put("被剋","金");
                 	element_relations.put("木",wood_map);
                 	// 水
                 	water_map = Map();
                 	water_map.put("生","木");
                 	water_map.put("剋","火");
                 	water_map.put("被生","金");
                 	water_map.put("被剋","土");
                 	element_relations.put("水",water_map);
                 	// 火
                 	fire_map = Map();
                 	fire_map.put("生","土");
                 	fire_map.put("剋","金");
                 	fire_map.put("被生","木");
                 	fire_map.put("被剋","水");
                 	element_relations.put("火",fire_map);
                 	// 土
                 	earth_map = Map();
                 	earth_map.put("生","金");
                 	earth_map.put("剋","水");
                 	earth_map.put("被生","火");
                 	earth_map.put("被剋","木");
                 	element_relations.put("土",earth_map);
                 	// 建立問題類型對應的五行需求
                 	type_element_needs = Map();
                 	type_element_needs.put("工作","金");
                 	type_element_needs.put("愛情","火");
                 	type_element_needs.put("財運","土");
                 	type_element_needs.put("健康","木");
                 	type_element_needs.put("婚姻","水");
                 	type_element_needs.put("其他","土");
                 	// 取得問題類型對應的五行
                 	question_element = type_element_needs.get(question_type);
                 	if(question_element == null)
                 	{
                 		question_element = "土";
                 		// 預設值
                 	}
                 	// 分析符令與問題的五行關係
                 	talisman_relations = element_relations.get(talisman_element);
                 	generates = talisman_relations.get("生");
                 	restrains = talisman_relations.get("剋");
                 	generated_by = talisman_relations.get("被生");
                 	restrained_by = talisman_relations.get("被剋");
                 	// 根據卦象性質（life_and_death）調整說明策略
                 	hexagram_nature = hexagram_life_death.toString();
                 	strategy_explanation = "";
                 	if(hexagram_nature == "相生")
                 	{
                 		strategy_explanation = "您的卦象呈現相生之勢，表示運勢正在上升。第" + talisman_number.toString() + "張" + talisman_element + "符令能夠強化這種相生能量，讓您的" + question_type + "運勢更加順暢。";
                 	}
                 	else if(hexagram_nature == "相剋")
                 	{
                 		strategy_explanation = "您的卦象呈現相剋之勢，表示需要調和五行能量。第" + talisman_number.toString() + "張" + talisman_element + "符令能夠緩解相剋的緊張關係，為您的" + question_type + "問題帶來平衡。";
                 	}
                 	else if(hexagram_nature == "弱生")
                 	{
                 		strategy_explanation = "您的卦象呈現弱生之勢，表示相生能量不足。第" + talisman_number.toString() + "張" + talisman_element + "符令能夠增強相生能量，幫助您的" + question_type + "運勢逐漸好轉。";
                 	}
                 	else if(hexagram_nature == "弱剋")
                 	{
                 		strategy_explanation = "您的卦象呈現弱剋之勢，表示相剋能量較弱。第" + talisman_number.toString() + "張" + talisman_element + "符令能夠進一步緩解相剋，讓您的" + question_type + "問題得到改善。";
                 	}
                 	else if(hexagram_nature == "持之")
                 	{
                 		strategy_explanation = "您的卦象呈現持之之勢，表示需要保持穩定。第" + talisman_number.toString() + "張" + talisman_element + "符令能夠幫助您維持良好的" + question_type + "運勢，避免波動。";
                 	}
                 	else if(hexagram_nature == "立破")
                 	{
                 		strategy_explanation = "您的卦象呈現立破之勢，表示需要突破現狀。第" + talisman_number.toString() + "張" + talisman_element + "符令能夠幫助您突破" + question_type + "的困境，開創新局面。";
                 	}
                 	else
                 	{
                 		strategy_explanation = "第" + talisman_number.toString() + "張" + talisman_element + "符令能夠幫助您改善" + question_type + "運勢，為您帶來正面能量。";
                 	}
                 	// 建立AI提示詞
                 	system_prompt = "你是一位專業的易經符令專家，專門為客戶解釋符令的功效和購買理由。請根據以下資訊，生成一段溫暖、專業且具有說服力的符令說明：";
                 	// 建立AI提示詞 - 分步驟建立，避免語法錯誤
                 	user_prompt_part1 = "卦象：" + hexagram_appearance.toString() + "（" + hexagram_code + "）\n";
                 	user_prompt_part1 = user_prompt_part1 + "卦象性質：" + hexagram_life_death.toString() + "\n";
                 	user_prompt_part1 = user_prompt_part1 + "符令編號：第" + talisman_number.toString() + "張\n";
                 	user_prompt_part1 = user_prompt_part1 + "符令五行：" + talisman_element + "\n";
                 	user_prompt_part1 = user_prompt_part1 + "問題類型：" + question_type + "\n";
                 	user_prompt_part1 = user_prompt_part1 + "客戶問題：" + original_question + "\n\n";
                 	user_prompt_part2 = "五行關係：\n";
                 	user_prompt_part2 = user_prompt_part2 + "- " + talisman_element + "生" + generates + "\n";
                 	user_prompt_part2 = user_prompt_part2 + "- " + talisman_element + "剋" + restrains + "\n";
                 	user_prompt_part2 = user_prompt_part2 + "- " + talisman_element + "被" + generated_by + "生\n";
                 	user_prompt_part2 = user_prompt_part2 + "- " + talisman_element + "被" + restrained_by + "剋\n\n";
                 	user_prompt_part3 = "策略說明：" + strategy_explanation + "\n\n";
                 	user_prompt_part3 = user_prompt_part3 + "請根據卦象的" + hexagram_life_death.toString() + "性質，以及" + talisman_element + "符令的五行特性，說明這張符令如何幫助客戶解決" + question_type + "問題。重點說明：\n";
                 	user_prompt_part3 = user_prompt_part3 + "1. 符令如何平衡卦象的五行\n";
                 	user_prompt_part3 = user_prompt_part3 + "2. 對客戶" + question_type + "問題的具體幫助\n";
                 	user_prompt_part3 = user_prompt_part3 + "3. 使用建議和注意事項\n\n";
                 	user_prompt_part3 = user_prompt_part3 + "請用溫暖、專業的語氣，字數控制在150-200字之間。";
                 	user_prompt = user_prompt_part1 + user_prompt_part2 + user_prompt_part3;
                 	// 取用應用程式變數中的 OpenAI API 參數（參考 OnEdit_SetGenderFromAIPrediction.deluge）
                 	api_url = thisapp.variables.OpenAI.OpenAI_API_URL;
                 	api_key = thisapp.variables.OpenAI.OpenAI_API_Key;
                 	api_params = Map();
                 	api_params.put("model","gpt-4");
                 	api_params.put("max_tokens",300);
                 	api_params.put("temperature",0.7);
                 	api_params.put("messages",List());
                 	system_message = Map();
                 	system_message.put("role","system");
                 	system_message.put("content",system_prompt);
                 	messages_list = api_params.get("messages");
                 	messages_list.add(system_message);
                 	user_message = Map();
                 	user_message.put("role","user");
                 	user_message.put("content",user_prompt);
                 	messages_list.add(user_message);
                 	headers = Map();
                 	headers.put("Authorization","Bearer " + api_key);
                 	headers.put("Content-Type","application/json");
                 	// 發送API請求
                 	api_response = postUrl(api_url,api_params.toString(),headers);
                 	if(api_response == null)
                 	{
                 		result.put("success",false);
                 		result.put("error","AI API 回應為空");
                 		return result;
                 	}
                 	// 解析AI回應
                 	response_data = api_response.get("choices");
                 	if(response_data == null)
                 	{
                 		result.put("success",false);
                 		result.put("error","AI 回應格式錯誤");
                 		return result;
                 	}
                 	first_choice = response_data.get(0);
                 	if(first_choice == null)
                 	{
                 		result.put("success",false);
                 		result.put("error","AI 回應內容為空");
                 		return result;
                 	}
                 	message_data = first_choice.get("message");
                 	if(message_data == null)
                 	{
                 		result.put("success",false);
                 		result.put("error","AI 訊息內容為空");
                 		return result;
                 	}
                 	explanation = message_data.get("content");
                 	if(explanation == null)
                 	{
                 		result.put("success",false);
                 		result.put("error","AI 說明內容為空");
                 		return result;
                 	}
                 	// 計算字數 - 使用簡單的字串長度
                 	word_count = explanation.length();
                 	// 回傳結果
                 	result.put("success",true);
                 	result.put("explanation",explanation);
                 	result.put("word_count",word_count);
                 	result.put("hexagram_name",hexagram_appearance.toString());
                 	result.put("hexagram_nature",hexagram_life_death.toString());
                 	result.put("talisman_element",talisman_element);
                 	result.put("question_type",question_type);
                 	return result;
                 }
void AIInterpreter.getGenderFromName(int clientID)
                 {
                 	//
                 	// 函數名稱：getGenderFromName
                 	// 命名空間：AIInterpreter
                 	//
                 	// 功能描述：
                 	// 根據指定的個案 ID，獲取其姓名，並呼叫 OpenAI API 來預測性別。
                 	// 成功預測後，直接更新該個案的「性別」欄位。
                 	//
                 	// 參數：
                 	//  - clientID (int): 「個案表單」的紀錄 ID。
                 	//
                 	// 回傳：
                 	//  - void (無回傳值)，直接更新表單。
                 	//
                 	// 相依性：
                 	//  - thisapp.variables.OpenAI.* (需要設定 OpenAI 相關的應用程式變數)
                 	//  - Clients_Report (表單)
                 	//
                 	// 1. 根據 ID 獲取個案紀錄
                 	client_record = Clients_Report[ID == clientID];
                 	if(client_record == null)
                 	{
                 		info "getGenderFromName 錯誤: 找不到 ID 為 " + clientID + " 的個案。";
                 		return;
                 	}
                 	// 2. 獲取姓名
                 	last_name = ifnull(client_record.Visitor_Name.last_name,"");
                 	first_name = ifnull(client_record.Visitor_Name.first_name,"");
                 	full_name = last_name + first_name;
                 	if(full_name.trim() == "")
                 	{
                 		info "getGenderFromName 警告: 個案 " + clientID + " 沒有姓名，無法預測性別。";
                 		return;
                 	}
                 	info "準備為「" + full_name + "」預測性別...";
                 	// 3. 建立 OpenAI 請求
                 	messages = list();
                 	system_prompt = "你是一位分析中文姓名的專家。請根據提供的姓名來判斷這個人的性別。你的回答必須只能是「男」或「女」，不要有任何其他文字、標點符號或解釋。";
                 	messages.add({"role":"system","content":system_prompt});
                 	messages.add({"role":"user","content":"請根據姓名「王宇翔」來判斷這個人的性別。"});
                 	messages.add({"role":"assistant","content":"男"});
                 	messages.add({"role":"user","content":"請根據姓名「林佳穎」來判斷這個人的性別。"});
                 	messages.add({"role":"assistant","content":"女"});
                 	messages.add({"role":"user","content":"請根據姓名「" + full_name + "」來判斷這個人的性別。"});
                 	openai_payload = Map();
                 	openai_payload.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 	openai_payload.put("messages",messages);
                 	openai_payload.put("temperature",0);
                 	openai_payload.put("max_tokens",5);
                 	headers = Map();
                 	headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 	headers.put("Content-Type","application/json");
                 	// 4. 執行 API 呼叫並更新欄位
                 	predicted_gender = "";
                 	try 
                 	{
                 		response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,openai_payload.toString(),headers);
                 		info "OpenAI API 性別預測回應: " + response;
                 		if(response.get("choices") != null && response.get("choices").size() > 0)
                 		{
                 			content_str = response.get("choices").get(0).get("message").get("content").trim();
                 			if(content_str == "男" || content_str == "女")
                 			{
                 				predicted_gender = content_str;
                 			}
                 		}
                 	}
                 	catch (e)
                 	{
                 		info "OpenAI API 呼叫失敗: " + e;
                 	}
                 	// 5. 如果成功，則更新紀錄
                 	if(predicted_gender != "")
                 	{
                 		client_record.Clients_Gender=predicted_gender;
                 		info "成功為 " + full_name + " 更新性別為: " + predicted_gender;
                 	}
                 	else
                 	{
                 		info "無法從 API 回應中解析出有效性別，跳過更新。";
                 	}
                 }
map AIInterpreter.getPersonalizedInterpretation(string question_text, string question_type, map hexagram_details)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]]
                 	// ==================================================================================
                 	// 函數名稱：AIInterpreter.getPersonalizedInterpretation
                 	// 函數目的：【AI 個人化解讀函數】
                 	//
                 	// 這是實現「一個月百萬營收」目標的核心引擎。它將標準化的卦象資料與客戶的具體問題
                 	// 結合，透過精心設計的 AI prompt 生成高度個人化、有同理心的解答，讓客戶感受到
                 	// 專屬的占卜體驗，進而願意購買後續的數位符令產品。
                 	//
                 	// 核心邏輯：
                 	// 1. 接收客戶問題、問題類型和卦象詳細資料。
                 	// 2. 根據問題類型，從卦象中選取最相關的解釋內容。
                 	// 3. 建立個人化的 AI prompt，要求生成針對性的回答。
                 	// 4. 呼叫 OpenAI API 生成溫暖、專業的個人化解讀。
                 	// 5. 回傳可直接用於 SalesIQ Bot 的完整回應文字。
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// question_text (string) - 客戶的原始問題文字
                 	// question_type (string) - AI 判斷的問題類型（愛情、工作、財運等）
                 	// hexagram_details (map) - 從 IChing.getHexagramDetails 取得的完整卦象資料
                 	//
                 	// 回傳：
                 	// 一個 Map，包含個人化解讀結果。
                 	// 成功時: {"success": true, "interpretation": "親愛的朋友，根據您的卦象...", "word_count": 150}
                 	// 失敗時: {"success": false, "error": "錯誤訊息", "interpretation": "標準回覆"}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	final_response = Map();
                 	try 
                 	{
                 		// --- 步驟 1: 驗證輸入參數 ---
                 		if(question_text == null || question_text.trim() == "" || question_type == null || question_type.trim() == "" || hexagram_details == null || hexagram_details.get("success") != true)
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","輸入參數不完整或卦象資料無效");
                 			final_response.put("interpretation","很抱歉，目前無法為您提供占卜解讀，請稍後再試。");
                 			return final_response;
                 		}
                 		// --- 步驟 2: 根據問題類型選取相關的卦象內容 ---
                 		relevant_content = "";
                 		appearance = hexagram_details.get("appearance");
                 		// 根據問題類型，選擇最相關的卦象解釋
                 		if(question_type == "工作")
                 		{
                 			relevant_content = hexagram_details.get("yao_work");
                 		}
                 		else if(question_type == "愛情")
                 		{
                 			relevant_content = hexagram_details.get("yao_love");
                 		}
                 		else if(question_type == "婚姻")
                 		{
                 			relevant_content = hexagram_details.get("yao_love");
                 			// 婚姻也使用愛情解釋
                 		}
                 		else if(question_type == "財運")
                 		{
                 			relevant_content = hexagram_details.get("yao_business");
                 		}
                 		else if(question_type == "健康" || question_type == "入煞")
                 		{
                 			relevant_content = hexagram_details.get("yao_comment");
                 			// 使用通用註解
                 		}
                 		else
                 		{
                 			relevant_content = hexagram_details.get("yao_article");
                 			// 其他類型使用總體爻辭
                 		}
                 		// 如果選定的內容為空，使用通用爻辭作為備用
                 		if(relevant_content == null || relevant_content.trim() == "")
                 		{
                 			relevant_content = hexagram_details.get("yao_article");
                 		}
                 		// --- 步驟 3: 建立個人化的 AI Prompt ---
                 		system_prompt = "你是一位溫暖、有同理心的易經解籤大師，擅長將古老的易經智慧轉化為現代人能理解的實用建議。\n\n" + "你的任務是根據客戶的具體問題和卦象，提供一段個人化、有溫度的解讀。\n\n" + "寫作風格要求：\n" + "1. 用「您」稱呼客戶，展現尊重\n" + "2. 語氣溫暖、有同理心，像是關心的朋友\n" + "3. 內容要有針對性，不能只是重複標準答案\n" + "4. 長度控制在 220-250 字\n" + "5. 結尾要有正面的鼓勵或建議\n" + "6. 不要提到「卦象顯示」等占卜術語，要自然融入\n\n" + "請避免：\n" + "- 過於籠統的建議\n" + "- 重複客戶的問題\n" + "- 使用艱澀的古文或術語";
                 		user_prompt = "客戶問題：「" + question_text + "」\n" + "問題類型：" + question_type + "\n" + "占卜結果：" + appearance + "卦\n" + "相關解釋：" + relevant_content + "\n\n" + "請為這位客戶寫一段個人化的解讀，重點回應他們關於「" + question_type + "」的關切。";
                 		// --- 步驟 4: 呼叫 OpenAI API ---
                 		api_params = Map();
                 		api_params.put("max_tokens",300);
                 		// 控制在合理的字數範圍內
                 		api_params.put("temperature",0.9);
                 		// 適中的創意度，保持一定變化但不會過於隨機
                 		// 建立訊息陣列
                 		messages = List();
                 		system_message = Map();
                 		system_message.put("role","system");
                 		system_message.put("content",system_prompt);
                 		messages.add(system_message);
                 		user_message = Map();
                 		user_message.put("role","user");
                 		user_message.put("content",user_prompt);
                 		messages.add(user_message);
                 		api_params.put("messages",messages);
                 		// 使用應用程式變數呼叫 OpenAI API
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		api_params.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		openai_response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,api_params.toString(),headers);
                 		// --- 步驟 5: 解析 AI 回應 ---
                 		if(openai_response.get("choices") != null && openai_response.get("choices").size() > 0)
                 		{
                 			ai_interpretation = openai_response.get("choices").get(0).get("message").get("content").trim();
                 			// 簡單檢查回應是否合理
                 			if(ai_interpretation.length() > 50 && ai_interpretation.length() < 300)
                 			{
                 				final_response.put("success",true);
                 				final_response.put("interpretation",ai_interpretation);
                 				final_response.put("word_count",ai_interpretation.length());
                 				final_response.put("hexagram_name",appearance);
                 				final_response.put("question_type",question_type);
                 			}
                 			else
                 			{
                 				// AI 回應長度異常，使用備用回應
                 				fallback_response = "親愛的朋友，根據您的占卜結果，" + appearance + "卦為您帶來重要的指引。" + "在" + question_type + "方面，建議您保持開放的心態，仔細觀察周遭的變化。" + "記住，每個挑戰都是成長的機會，相信自己的判斷，您一定能找到最適合的道路。";
                 				final_response.put("success",true);
                 				final_response.put("interpretation",fallback_response);
                 				final_response.put("word_count",fallback_response.length());
                 				final_response.put("hexagram_name",appearance);
                 				final_response.put("question_type",question_type);
                 				final_response.put("note","使用備用回應");
                 			}
                 		}
                 		else
                 		{
                 			// API 回應格式異常，使用備用回應
                 			fallback_response = "感謝您的提問。根據占卜結果，建議您在" + question_type + "方面保持耐心和智慧。" + "宇宙會在適當的時機為您安排最好的結果，請相信這個過程，並持續努力。";
                 			final_response.put("success",false);
                 			final_response.put("error","OpenAI API 回應異常");
                 			final_response.put("interpretation",fallback_response);
                 			final_response.put("word_count",fallback_response.length());
                 		}
                 	}
                 	catch (e)
                 	{
                 		// 發生錯誤時的緊急備用回應
                 		emergency_response = "感謝您的占卜諮詢。目前系統正在處理中，請您稍候片刻，" + "或者您可以嘗試重新提問。我們會盡快為您提供詳細的解讀。";
                 		final_response.put("success",false);
                 		final_response.put("error","個人化解讀過程中發生錯誤：" + e);
                 		final_response.put("interpretation",emergency_response);
                 		final_response.put("word_count",emergency_response.length());
                 	}
                 	return final_response;
                 }
string AIInterpreter.getPredictionByQuestionAndBirthday_v2(string question, date solarDateTime, string clientId)
                 {
                 	// getPredictionByQuestionAndBirthday v2.0
                 	// 使用 OpenAI Assistant 進行易經占卜
                 	finalResult = "";
                 	try 
                 	{
                 		// 步驟 1: 參數驗證
                 		if(question == null || question.trim() == "")
                 		{
                 			finalResult = "抱歉，占卜問題不能為空，請重新輸入您的問題。";
                 		}
                 		else if(solarDateTime == null)
                 		{
                 			finalResult = "抱歉，起卦時間無效，請檢查日期時間設定。";
                 		}
                 		else
                 		{
                 			// 參數驗證通過，開始執行主要邏輯
                 			// 初始化所需變數
                 			yaoCode = "";
                 			hexData = Map();
                 			thread_id_to_use = "";
                 			ai_response = Map();
                 			final_interpretation = "";
                 			new_thread_id = "";
                 			prompt = "";
                 			error_message = "";
                 			recent_logs = List();
                 			divination_record = Map();
                 			new_log = Map();
                 			// clientId 為可選參數，如果為空則使用新 Thread
                 			if(clientId == null || clientId.trim() == "")
                 			{
                 				info "未提供個案ID，將使用新的 Thread 進行占卜";
                 				clientId = "";
                 			}
                 			// 步驟 2: 根據生日時間，產生爻碼並獲取對應的卦象資料
                 			yaoCode = thisapp.GuaCalculator.BitToHexagramCode(solarDateTime);
                 			hexData = thisapp.Hexagram.getHexagramByYaoCode(yaoCode);
                 			// 如果回傳的 map 中不包含 "卦名" (appearance)，代表查詢失敗。
                 			if(hexData.get("appearance") == null)
                 			{
                 				finalResult = "抱歉，系統無法根據您提供的時間找到對應的卦象資料 (爻碼: " + yaoCode + ")。請稍後再試。";
                 			}
                 			else
                 			{
                 				info "成功獲取卦象資料 - 卦名：" + hexData.get("appearance") + "，爻碼：" + yaoCode;

				// 步驟 2.5: 冷卻機制檢查（觸發則安撫但不占卜；並直接 return，節省 token）
				cooldown_check = Map();
				selected_question_type = "";
				if(clientId != null && clientId != "")
				{
					cooldown_check = thisapp.AIInterpreter.checkCooldownStatus(clientId,question,solarDateTime);
					if(cooldown_check != null && cooldown_check.get("question_type") != null)
					{
						selected_question_type = cooldown_check.get("question_type");
					}
					if(cooldown_check != null && cooldown_check.get("allowed") == false)
					{
						finalResult = if(cooldown_check.get("message") != null,cooldown_check.get("message"),"我知道你很在意這件事，但我們需要先冷靜一下再占卜。稍後再回來，我會陪你看。");
						// 記錄冷卻拒絕（不呼叫 OpenAI，節省 token）
						new_log = insert into Divination_Logs
						[
							Client_Link=clientId.toLong()
							Original_Question=question
							Divination_Timestamp=solarDateTime
							Divination_Method="易經"
							Status="冷卻拒絕"
							Question_Type_AI=selected_question_type
							Added_User=zoho.loginuser
						];
						return finalResult;
					}
				}
				// 步驟 2.6: 收集個性線索（讓 AI 自動決定語氣；不讓使用者選）
				persona_text = "";
				if(clientId != null && clientId != "")
				{
					client_records = Clients_Report[ID == clientId.toLong()];
					if(client_records.count() > 0)
					{
						client_info = null;
						for each  c in client_records
						{
							client_info = c;
							break;
						}
						if(client_info != null)
						{
							persona_text = persona_text + "- 八字：" + if(client_info.Full_Bazi != null,client_info.Full_Bazi,"") + "\n";
							zodiac_name = "";
							if(client_info.Zodiac_Signs != null)
							{
								zodiac_records = Zodiac_Signs[ID == client_info.Zodiac_Signs];
								for each  z in zodiac_records
								{
									zodiac_name = z.Sign_Name;
									break;
								}
							}
							persona_text = persona_text + "- 星座：" + zodiac_name + "\n";
							chinese_zodiac_name = "";
							if(client_info.Chinese_Zodiac != null)
							{
								cz_records = Earthly_Branches[ID == client_info.Chinese_Zodiac];
								for each  cz in cz_records
								{
									chinese_zodiac_name = cz.Chinese_Zodiac;
									break;
								}
							}
							persona_text = persona_text + "- 生肖：" + chinese_zodiac_name + "\n";
							lunar_mansion_name = "";
							if(client_info.Twenty_Eight_Lunar_Mansions != null)
							{
								mansion_records = Twenty_Eight_Lunar_Mansions[ID == client_info.Twenty_Eight_Lunar_Mansions];
								for each  m in mansion_records
								{
									lunar_mansion_name = m.Full_Name;
									break;
								}
							}
							persona_text = persona_text + "- 星宿：" + lunar_mansion_name + "\n";
							persona_text = persona_text + "- 太歲：" + if(client_info.Taisui_Conflict_Status != null,client_info.Taisui_Conflict_Status,"") + "\n";
						}
					}
				}

                 				// 步驟 3: 查詢個案的 Thread ID
                 				thread_id_to_use = "";
                 				if(clientId != null && clientId != "")
                 				{
                 					// 查詢該個案最新的 Thread ID
                 					recent_logs = Divination_Logs[Client_Link == clientId.toLong()];
                 					// 注意：Deluge 查詢結果已按照 Added_Time 降序排列（預設行為）
                 					for each  log_record in recent_logs
                 					{
                 						if(log_record.Thread_ID != null && log_record.Thread_ID.trim() != "")
                 						{
                 							thread_id_to_use = log_record.Thread_ID;
                 							info "找到個案現有 Thread ID：" + thread_id_to_use;
                 							break;
                 						}
                 					}
                 					if(thread_id_to_use == "")
                 					{
                 						info "個案尚無 Thread ID，將創建新的對話串";
                 					}
                 				}
                 				else
                 				{
                 					info "未指定個案，使用新 Thread 進行占卜";
                 				}
                 				// 步驟 4: 組裝準備發送給 AI Assistant 的 Prompt
                 				// 這個 Prompt 結構清晰，包含了所有必要的上下文，以引導 AI 做出高質量的回覆。
                 				prompt = "【重要規範】
";
				prompt = prompt + "1) 請使用繁體中文（禁用簡體）。
";
				prompt = prompt + "2) 不要反問使用者要哪種語氣；語氣由你根據命理個性線索自動決定，並保持一致。
";
				prompt = prompt + "3) 你的語氣只能從以下四種中擇一（不要告訴使用者你選了哪一種）：
";
				prompt = prompt + "   - comforting_guardian：溫柔安撫、給界線、讓人冷靜
";
				prompt = prompt + "   - clear_direct：清晰直白、條列、少形容詞
";
				prompt = prompt + "   - poetic_mystic：有靈性意象但不浮誇、句子短
";
				prompt = prompt + "   - playful_light：輕鬆但不嘲諷、不油、不傷人

";
				if(persona_text != null && persona_text.trim() != "")
				{
					prompt = prompt + "【個性線索（用來決定語氣，不要在回覆中直接列出原始線索）】
" + persona_text + "
";
				}

				prompt = prompt + "【任務】請幫我解讀下面的易經占卜結果，並針對問題給出詳盡建議。

";
                 				prompt = prompt + "【占卜問題】\n" + question + "\n\n";
                 				prompt = prompt + "【爻碼】\n" + yaoCode + "\n\n";
                 				prompt = prompt + "【卦象總覽】\n";
                 				prompt = prompt + "- 卦名（象形）: " + hexData.get("appearance") + "\n";
                 				prompt = prompt + "- 上卦象: " + hexData.get("up_appearance") + "\n";
                 				prompt = prompt + "- 下卦象: " + hexData.get("down_appearance") + "\n";
                 				prompt = prompt + "- 五行: " + hexData.get("five_elements") + "\n";
                 				prompt = prompt + "- 生死論: " + hexData.get("life_and_death") + "\n\n";
                 				prompt = prompt + "【爻象詳情】\n";
                 				prompt = prompt + "- 爻辭總論: " + hexData.get("yao_article") + "\n";
                 				prompt = prompt + "- 爻辭解釋: " + hexData.get("yao_comment") + "\n";
                 				prompt = prompt + "- 願望爻: " + hexData.get("yao_wish") + "\n";
                 				prompt = prompt + "- 感情爻: " + hexData.get("yao_love") + "\n";
                 				prompt = prompt + "- 事業爻: " + hexData.get("yao_work") + "\n";
                 				prompt = prompt + "- 商業爻: " + hexData.get("yao_business") + "\n";
                 				prompt = prompt + "- 學業爻: " + hexData.get("yao_study") + "\n";
                 				prompt = prompt + "- 旅遊爻: " + hexData.get("yao_travel") + "\n\n";
                 				prompt = prompt + "【符令圖示】\n";
                 				prompt = prompt + hexData.get("symbol_1") + " " + hexData.get("symbol_2") + " " + hexData.get("symbol_3") + "\n";
                 				prompt = prompt + hexData.get("symbol_4") + " " + hexData.get("symbol_5") + "\n\n";
                 				prompt = prompt + "請根據以上所有資訊，綜合易經理論與爻辭細節，給出至少三段、每段 3～5 句的深度分析與建議。\n";
				prompt = prompt + "請直接給結論與可行建議，少一點空泛形容；不要要求使用者選語氣，也不要在回覆中提到 toneKey。";
                 				info "AI Prompt 構建完成，長度：" + prompt.length().toString();
                 				// 步驟 5: 呼叫 OpenAI Assistant
                 				ai_response = thisapp.OpenAI.callAssistant(prompt,thread_id_to_use);
                 				// 步驟 6: 處理 AI 回應
                 				if(ai_response.get("success") == true)
                 				{
                 					final_interpretation = ai_response.get("response");
                 					new_thread_id = ai_response.get("threadId");
                 					info "OpenAI Assistant 回應成功，Thread ID：" + new_thread_id;
                 					// 步驟 7: 儲存占卜記錄（包含 Thread ID）
                 					if(clientId != null && clientId != "")
                 					{
                 						divination_record = Map();
                 						divination_record.put("Client_Link",clientId.toLong());
                 						divination_record.put("Thread_ID",new_thread_id);
                 						divination_record.put("Original_Question",question);
                 						// 注意：Hexagram_Code 欄位需要 I_Ching_Form 的 ID，而不是爻碼字串
                 						// 暫時先不設定 Hexagram_Code，避免型別錯誤
                 						divination_record.put("AI_Interpretation",final_interpretation);
                 						divination_record.put("Divination_Time",solarDateTime);
                 						// Added_Time 是系統欄位，會自動設定，不需要手動指定
                 						divination_record.put("Divination_Method","易經");
                 						divination_record.put("Status","已提問");
                 						new_log = insert into Divination_Logs
                 						[
                 							Client_Link=divination_record.get("Client_Link")
                 							Thread_ID=divination_record.get("Thread_ID")
                 							Original_Question=divination_record.get("Original_Question")
                 							AI_Interpretation=divination_record.get("AI_Interpretation")
                 							Divination_Timestamp=divination_record.get("Divination_Time")
                 							Divination_Method=divination_record.get("Divination_Method")
                 							Status=divination_record.get("Status")
                 							Added_User=zoho.loginuser
                 						];
                 						info "占卜記錄已儲存，記錄ID：" + new_log.get("ID");
                 					}
                 					finalResult = final_interpretation;
                 				}
                 				else
                 				{
                 					// AI 調用失敗
                 					error_message = ai_response.get("errorMessage");
                 					info "OpenAI Assistant 調用失敗：" + error_message;
                 					finalResult = "很抱歉，AI 占卜服務暫時無法使用。錯誤訊息：" + error_message + "。請稍後再試，或聯繫客服協助。";
                 				}
                 			}
                 			// hexData else block end
                 		}
                 		// 參數驗證 else block end
                 	}
                 	catch (e)
                 	{
                 		// 捕獲所有未預期的錯誤
                 		info "getPredictionByQuestionAndBirthday 執行錯誤：" + e;
                 		finalResult = "很抱歉，占卜過程中發生系統錯誤。請稍後再試，或聯繫客服協助。錯誤代碼：" + e;
                 	}
                 	return finalResult;
                 }
				
string AIInterpreter.getMvpDivination_v1(string question, date solarDateTime, string clientId)
                 {
                  	// =============================================================================
                  	// MVP Router：由系統自動決定占卜方式（易經 or 塔羅）
                  	// - 不讓使用者選擇語氣/方式
                  	// - 不改既有起卦/解卦/抽牌規則，只做「分流封裝」
                  	// =============================================================================
                  	final_text = "";
                  	try 
                  	{
                  		if(question == null || question.trim() == "")
                  		{
                  			return "抱歉，占卜問題不能為空，請重新輸入您的問題。";
                  		}
                  		if(solarDateTime == null)
                  		{
                  			return "抱歉，起卦時間無效，請檢查日期時間設定。";
                  		}
                  		if(clientId == null || clientId.trim() == "")
                  		{
                  			return "為了讓占卜更準確、也保護你不被情緒牽著走，我需要先綁定你的生日資料。請先完成生日設定後再提問。";
                  		}

                  		classification_result = thisapp.AIInterpreter.classifyQuestionType(question);
                  		question_type = "其他";
                  		if(classification_result != null && classification_result.get("success") == true && classification_result.get("question_type") != null)
                  		{
                  			question_type = classification_result.get("question_type");
                  		}

                  		selected_method = "易經";
                  		if(question_type == "愛情" || question_type == "婚姻")
                  		{
                  			selected_method = "塔羅";
                  		}

                  		if(selected_method == "塔羅")
                  		{
                  			tarot_result = thisapp.Tarot.TarotDivinationFunction(clientId,question);
                  			if(tarot_result != null && tarot_result.get("success") == true && tarot_result.get("divination_id") != null)
                  			{
                  				div_id = tarot_result.get("divination_id");
                  				div_records = Divination_Logs[ID == div_id.toLong()];
                  				for each  d in div_records
                  				{
                  					if(d.AI_Interpretation != null && d.AI_Interpretation.trim() != "")
                  					{
                  						final_text = d.AI_Interpretation;
                  					}
                  					break;
                  				}
                  				if(final_text == "")
                  				{
                  					final_text = "塔羅占卜已完成，但解讀內容暫時未能生成，請稍後再試。";
                  				}
                  			}
                  			else
                  			{
                  				final_text = "很抱歉，塔羅占卜暫時無法完成。請稍後再試。";
                  				if(tarot_result != null && tarot_result.get("message") != null)
                  				{
                  					final_text = final_text + "（" + tarot_result.get("message") + "）";
                  				}
                  			}
                  		}
                  		else
                  		{
                  			final_text = thisapp.AIInterpreter.getPredictionByQuestionAndBirthday_v2(question,solarDateTime,clientId);
                  		}
                  	}
                  	catch (e)
                  	{
                  		final_text = "很抱歉，MVP 占卜流程發生錯誤，請稍後再試。錯誤代碼：" + e;
                  	}
                  	return final_text;
                 }

map AIInterpreter.getTarotInterpretation(string question_text, string question_type, map tarot_spread_data)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]] [[memory:6341405]]
                 	// ==================================================================================
                 	// 函數名稱：AIInterpreter.getTarotInterpretation  
                 	// 函數目的：【商業化塔羅牌 AI 個人化解讀函數】
                 	//
                 	// 這是升級版的塔羅占卜系統核心AI引擎，整合了主副卦分析邏輯、五行權重計算
                 	// 和精密的商業化推薦策略。透過分析五張牌的正逆位分佈，確定主導運勢趨勢，
                 	// 並基於時間軸權重計算五行元素需求，最終產生專業且具商業價值的占卜解讀。
                 	//
                 	// 核心創新：
                 	// 1. 主副卦分析：少數牌極性為主導，多數牌極性為輔助
                 	// 2. 五行權重計算：基於牌位的時間軸意義分配權重  
                 	// 3. 商業化植入：10%比例的五行產品推薦（可調整）
                 	// 4. 繁體中文嚴格控制：避免任何簡體字符出現
                 	// 5. 創意溫度0.7：平衡專業性與創意表達
                 	// ==================================================================================
                 	//
                 	// 可調整參數區域（供日後測試調整）：
                 	commercial_ratio = 0.1;
                 	// 商業化比例：10%
                 	creativity_temperature = 0.7;
                 	// 創意溫度：0.7  
                 	target_word_count = 500;
                 	// 目標字數：500字
                 	//
                 	// 參數：
                 	// question_text (string) - 客戶的原始問題文字
                 	// question_type (string) - AI 判斷的問題類型
                 	// tarot_spread_data (map) - 包含五張牌的完整牌陣資料（使用a-e欄位）
                 	//
                 	// 回傳：
                 	// 一個 Map，包含商業化塔羅解讀結果
                 	// 成功時: {"success": true, "interpretation": "解讀文字", "primary_trend": "主卦", "recommended_elements": ["金","水"]}
                 	// 失敗時: {"success": false, "error": "錯誤訊息", "interpretation": "預設回覆"}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	final_response = Map();
                 	try 
                 	{
                 		// --- 步驟 1: 驗證輸入參數 ---
                 		if(question_text == null || question_text.trim() == "" || question_type == null || question_type.trim() == "" || tarot_spread_data == null)
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","輸入參數不完整或塔羅牌陣資料無效");
                 			final_response.put("interpretation","很抱歉，目前無法為您提供塔羅解讀，請稍後再試。");
                 			return final_response;
                 		}
                 		// --- 步驟 2: 主副卦分析（核心創新邏輯）---
                 		// 從tarot_spread_data中提取五張牌的正逆位資訊
                 		reversed_cards = list();
                 		upright_cards = list();
                 		all_reversed_status = list();
                 		// 提取五張牌的正逆位狀態
                 		card_1_reversed = tarot_spread_data.get("Card_1_Reversed");
                 		card_2_reversed = tarot_spread_data.get("Card_2_Reversed");
                 		card_3_reversed = tarot_spread_data.get("Card_3_Reversed");
                 		card_4_reversed = tarot_spread_data.get("Card_4_Reversed");
                 		card_5_reversed = tarot_spread_data.get("Card_5_Reversed");
                 		all_reversed_status.add(card_1_reversed);
                 		all_reversed_status.add(card_2_reversed);
                 		all_reversed_status.add(card_3_reversed);
                 		all_reversed_status.add(card_4_reversed);
                 		all_reversed_status.add(card_5_reversed);
                 		// 提取牌位意義
                 		position_meanings = list();
                 		position_meanings.add(tarot_spread_data.get("Position_1_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_2_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_3_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_4_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_5_Meaning"));
                 		// 統計正逆位數量
                 		reversed_count = 0;
                 		upright_count = 0;
                 		total_cards = 5;
                 		for each  is_reversed in all_reversed_status
                 		{
                 			if(is_reversed == true)
                 			{
                 				reversed_count = reversed_count + 1;
                 			}
                 			else
                 			{
                 				upright_count = upright_count + 1;
                 			}
                 		}
                 		// 確定主副卦（少數為主，多數為輔）
                 		primary_trend = "";
                 		secondary_trend = "";
                 		primary_description = "";
                 		secondary_description = "";
                 		if(reversed_count < upright_count)
                 		{
                 			// 逆位牌較少，所以逆位為主卦
                 			primary_trend = "逆位";
                 			secondary_trend = "正位";
                 			primary_description = "少數逆位牌主導整體運勢走向，顯示需要深度轉化的核心議題";
                 			secondary_description = "多數正位牌提供穩定的支持能量，形成變革的基礎";
                 		}
                 		else if(reversed_count > upright_count)
                 		{
                 			// 正位牌較少，所以正位為主卦
                 			primary_trend = "正位";
                 			secondary_trend = "逆位";
                 			primary_description = "少數正位牌主導整體運勢走向，代表突破困境的關鍵力量";
                 			secondary_description = "多數逆位牌揭示需要面對的挑戰，但已有明確的解決方向";
                 		}
                 		else
                 		{
                 			// 正逆位數量相等
                 			primary_trend = "平衡";
                 			secondary_trend = "平衡";
                 			primary_description = "正逆位完美平衡的和諧狀態，顯示內在力量的均衡發展";
                 			secondary_description = "各種能量相互制衡，需要智慧地維持現狀並尋求突破點";
                 		}
                 		// 記錄主副卦的牌卡資訊（供後續詳細分析使用）
                 		primary_cards_info = list();
                 		secondary_cards_info = list();
                 		card_index = 0;
                 		for each  is_reversed in all_reversed_status
                 		{
                 			card_info = Map();
                 			card_info.put("position",card_index + 1);
                 			card_info.put("is_reversed",is_reversed);
                 			card_info.put("meaning",position_meanings.get(card_index));
                 			if((primary_trend == "逆位" && is_reversed == true) || (primary_trend == "正位" && is_reversed == false) || primary_trend == "平衡")
                 			{
                 				primary_cards_info.add(card_info);
                 			}
                 			else
                 			{
                 				secondary_cards_info.add(card_info);
                 			}
                 			card_index = card_index + 1;
                 		}
                 		// --- 步驟 3: 五行權重計算（基於時間軸）---
                 		// 定義牌位的時間軸權重
                 		position_weights = list();
                 		position_weights.add(0.1);
                 		// 牌位1：過去影響 - 低權重
                 		position_weights.add(0.2);
                 		// 牌位2：現在狀況 - 中權重
                 		position_weights.add(0.3);
                 		// 牌位3：核心問題 - 高權重（現狀重點）
                 		position_weights.add(0.2);
                 		// 牌位4：外在因素 - 中權重
                 		position_weights.add(0.2);
                 		// 牌位5：未來指引 - 中權重（未來重點）
                 		// 提取並分析五行元素（暫時用模擬資料）
                 		primary_elements = list();
                 		primary_elements.add("金");
                 		// 暫時的模擬推薦
                 		// --- 步驟 4: 建立商業化 AI Prompt ---
                 		spread_content = "";
                 		// 構建結構化的牌陣描述
                 		spread_content = spread_content + "客戶問題：" + question_text + "\n";
                 		spread_content = spread_content + "問題類型：" + question_type + "\n\n";
                 		// 主副卦分析結果
                 		spread_content = spread_content + "=== 主副卦運勢分析 ===\n";
                 		spread_content = spread_content + "主卦趨勢：" + primary_trend + "（共" + if(primary_trend == "逆位",reversed_count,if(primary_trend == "正位",upright_count,5)) + "張牌）\n";
                 		spread_content = spread_content + "主卦描述：" + primary_description + "\n";
                 		spread_content = spread_content + "副卦能量：" + secondary_trend + "（共" + if(secondary_trend == "逆位",reversed_count,if(secondary_trend == "正位",upright_count,0)) + "張牌）\n";
                 		spread_content = spread_content + "副卦描述：" + secondary_description + "\n\n";
                 		// 加入五張牌的詳細資訊（強調現狀和未來）
                 		spread_content = spread_content + "=== 詳細牌陣資訊（時間軸權重：現狀及未來為重）===\n";
                 		position_labels = {"牌位1（過去影響）","牌位2（現在狀況）","牌位3（核心問題）","牌位4（外在因素）","牌位5（未來指引）"};
                 		position_importance = {"低權重","中權重","高權重","中權重","中權重"};
                 		card_index = 0;
                 		for each  meaning in position_meanings
                 		{
                 			if(meaning != null && meaning != "")
                 			{
                 				reversed_status = all_reversed_status.get(card_index);
                 				trend_mark = if(reversed_status,"【逆位】","【正位】");
                 				importance_mark = "（" + position_importance.get(card_index) + "）";
                 				spread_content = spread_content + position_labels.get(card_index) + trend_mark + importance_mark + "：\n" + meaning + "\n\n";
                 			}
                 			card_index = card_index + 1;
                 		}
                 		// 商業化指導（10%比例的推薦內容）
                 		commercial_guidance = "在解讀的最後50字左右，根據主卦顯示的五行需求，溫和地建議客戶考慮透過相應的五行靈性工具來輔助能量平衡。語調要自然而溫和，如：「建議考慮」、「可以嘗試」、「有助於平衡」等，避免強硬推銷。";
                 		// 主副卦分析指導
                 		primary_analysis_guidance = "請特別著重分析主卦（" + primary_trend + "）的深層含義，這些" + if(primary_trend == "逆位","逆位","正位") + "牌雖然數量較少，但主導整體運勢發展。請結合牌面描述深入解讀，並說明為何這些牌具有決定性影響。";
                 		secondary_analysis_guidance = "副卦（" + secondary_trend + "）的" + if(secondary_trend == "逆位","逆位","正位") + "牌提供輔助能量，請說明它們如何支持或平衡主卦的運勢走向。";
                 		// 建立精密的 AI Prompt
                 		ai_prompt = "你是一位擁有30年經驗的專業塔羅牌占卜師，精通主副卦分析法，以仙氣飄飄的高維靈魂語調來回答。\n\n" + "重要指令：請務必使用繁體中文回答，嚴格避免簡體字。特別注意：使用「個」不用「个」、「裡」不用「里」、「資訊」不用「信息」、「網絡」不用「网络」。\n\n" + "請根據以下塔羅牌陣為客戶提供深度的個人化解讀：\n\n" + spread_content + "\n=== 解讀指導 ===\n" + primary_analysis_guidance + "\n" + secondary_analysis_guidance + "\n\n" + "請按以下結構提供一個500字的專業塔羅解讀：\n" + "1. 開場感受（50字）：對客戶問題表達同理心，點出整體牌陣的核心訊息\n" + "2. 主卦深度分析（250字）：詳細分析主導趨勢，解釋為何少數牌具有決定性影響，結合具體牌面描述\n" + "3. 副卦輔助說明（100字）：說明輔助能量如何平衡或支持主卦，強調時間軸的現狀與未來重點\n" + "4. 五行調和建議（50字）：" + commercial_guidance + "\n" + "5. 正面展望（50字）：以溫暖智慧的語調給予鼓勵和指引\n\n" + "創意參數：以0.7的創意溫度平衡專業性與靈感表達。語調要溫暖、智慧且具有靈性深度。";
                 		// --- 步驟 5: 呼叫 OpenAI API ---
                 		messages = list();
                 		// 設定系統提示
                 		systemMsg = Map();
                 		systemMsg.put("role","system");
                 		systemMsg.put("content","你是一位擁有30年經驗的專業塔羅牌占卜師，以仙氣飄飄的高維靈魂語調來回答。請使用繁體中文，絕對避免簡體字符。");
                 		messages.add(systemMsg);
                 		// 用戶訊息
                 		userMsg = Map();
                 		userMsg.put("role","user");
                 		userMsg.put("content",ai_prompt);
                 		messages.add(userMsg);
                 		// 組合完整的請求 payload
                 		openai_request = Map();
                 		openai_request.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		openai_request.put("messages",messages);
                 		openai_request.put("temperature",creativity_temperature);
                 		// 使用可調整的創意溫度
                 		openai_request.put("max_tokens",1000);
                 		// 增加到1000以確保500字輸出
                 		// 設定請求標頭
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		// 呼叫 OpenAI API
                 		openai_response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,openai_request.toString(),headers);
                 		// --- 步驟 6: 處理 API 回應 ---
                 		if(openai_response.get("choices") != null && openai_response.get("choices").size() > 0)
                 		{
                 			ai_interpretation = openai_response.get("choices").get(0).get("message").get("content");
                 			if(ai_interpretation != null && ai_interpretation.trim() != "")
                 			{
                 				// 清理回應文字
                 				clean_interpretation = ai_interpretation.trim();
                 				// 計算字數（中文字符估算）
                 				word_count = clean_interpretation.length() / 2;
                 				final_response.put("success",true);
                 				final_response.put("interpretation",clean_interpretation);
                 				final_response.put("word_count",word_count);
                 				final_response.put("primary_trend",primary_trend);
                 				final_response.put("secondary_trend",secondary_trend);
                 				final_response.put("recommended_elements",primary_elements);
                 				final_response.put("commercial_ratio",commercial_ratio);
                 				final_response.put("creativity_temperature",creativity_temperature);
                 			}
                 			else
                 			{
                 				final_response.put("success",false);
                 				final_response.put("error","AI 回應為空");
                 				final_response.put("interpretation","感謝您的信任。這次的塔羅牌陣顯示了豐富的訊息，建議您靜心思考每張牌的含義，相信內在的智慧會為您指引方向。");
                 			}
                 		}
                 		else
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","OpenAI API 回應格式異常");
                 			final_response.put("interpretation","感謝您的信任。這次的塔羅牌陣顯示了豐富的訊息，建議您靜心思考每張牌的含義，相信內在的智慧會為您指引方向。");
                 		}
                 	}
                 	catch (e)
                 	{
                 		// 發生錯誤時的預設回應
                 		final_response.put("success",false);
                 		final_response.put("error","處理過程發生錯誤：" + e);
                 		final_response.put("interpretation","親愛的朋友，宇宙的能量此刻正在為您重新排列。請稍後再次嘗試，或者靜心冥想您抽到的牌卡，答案會在寧靜中浮現。");
                 	}
                 	return final_response;
                 }
map AIInterpreter.getTarotInterpretationFull(string question_text, string question_type, map tarot_spread_data)
                 {
                 	// [[memory:2376637]] [[memory:3974009]] [[memory:4651243]] [[memory:6341405]]
                 	// ==================================================================================
                 	// 函數名稱：AIInterpreter.getTarotInterpretationFull  
                 	// 函數目的：【付費版本】商業化塔羅牌 AI 個人化解讀函數 - 3000字完整版報告
                 	//
                 	// 這是專為付費客戶設計的完整版塔羅占卜AI引擎，提供深度詳盡的3000字解讀報告。
                 	// 在原有500字版本的基礎上，加入更深層的靈性洞察、詳細的時間軸分析、
                 	// 完整的五行調和建議，以及個人化的實踐指導方案。
                 	//
                 	// 付費版本特色：
                 	// 1. 深度主副卦分析：每張牌的詳細解讀和相互關聯性
                 	// 2. 完整五行權重計算：精確的時間軸能量分析  
                 	// 3. 個人化實踐方案：具體的日常靈性修練建議
                 	// 4. 未來發展指引：3個月到1年的運勢走向預測
                 	// 5. 專業符令推薦：基於個人五行需求的精準推薦
                 	// 6. 創意溫度0.8：更高的靈感創造力表達
                 	// ==================================================================================
                 	//
                 	// 付費版本調整參數：
                 	commercial_ratio = 0.05;
                 	// 商業化比例：5%（更自然）
                 	creativity_temperature = 0.8;
                 	// 創意溫度：0.8（提升靈感）
                 	target_word_count = 3000;
                 	// 目標字數：3000字
                 	//
                 	// 參數：
                 	// question_text (string) - 客戶的原始問題文字
                 	// question_type (string) - AI 判斷的問題類型
                 	// tarot_spread_data (map) - 包含五張牌的完整牌陣資料（使用a-e欄位）
                 	//
                 	// 回傳：
                 	// 一個 Map，包含完整版商業化塔羅解讀結果
                 	// 成功時: {"success": true, "interpretation": "3000字解讀文字", "word_count": 3000, "is_full_version": true}
                 	// 失敗時: {"success": false, "error": "錯誤訊息", "interpretation": "預設回覆"}
                 	//
                 	// ==================================================================================
                 	// 建立最終回傳的 Map，採用單一出口模式
                 	final_response = Map();
                 	try 
                 	{
                 		// --- 步驟 1: 驗證輸入參數 ---
                 		if(question_text == null || question_text.trim() == "" || question_type == null || question_type.trim() == "" || tarot_spread_data == null)
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","輸入參數不完整或塔羅牌陣資料無效");
                 			final_response.put("interpretation","很抱歉，目前無法為您提供完整版塔羅解讀，請稍後再試。");
                 			return final_response;
                 		}
                 		// --- 步驟 2: 主副卦分析（增強版邏輯）---
                 		// 從tarot_spread_data中提取五張牌的正逆位資訊
                 		reversed_cards = list();
                 		upright_cards = list();
                 		all_reversed_status = list();
                 		// 提取五張牌的正逆位狀態
                 		card_1_reversed = tarot_spread_data.get("Card_1_Reversed");
                 		card_2_reversed = tarot_spread_data.get("Card_2_Reversed");
                 		card_3_reversed = tarot_spread_data.get("Card_3_Reversed");
                 		card_4_reversed = tarot_spread_data.get("Card_4_Reversed");
                 		card_5_reversed = tarot_spread_data.get("Card_5_Reversed");
                 		all_reversed_status.add(card_1_reversed);
                 		all_reversed_status.add(card_2_reversed);
                 		all_reversed_status.add(card_3_reversed);
                 		all_reversed_status.add(card_4_reversed);
                 		all_reversed_status.add(card_5_reversed);
                 		// 提取牌位意義（使用新的a-e格式）
                 		position_meanings = list();
                 		position_meanings.add(tarot_spread_data.get("Position_a_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_b_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_c_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_d_Meaning"));
                 		position_meanings.add(tarot_spread_data.get("Position_e_Meaning"));
                 		// 統計正逆位數量
                 		reversed_count = 0;
                 		upright_count = 0;
                 		total_cards = 5;
                 		for each  is_reversed in all_reversed_status
                 		{
                 			if(is_reversed == true)
                 			{
                 				reversed_count = reversed_count + 1;
                 			}
                 			else
                 			{
                 				upright_count = upright_count + 1;
                 			}
                 		}
                 		// 確定主副卦（少數為主，多數為輔）
                 		primary_trend = "";
                 		secondary_trend = "";
                 		primary_description = "";
                 		secondary_description = "";
                 		if(reversed_count < upright_count)
                 		{
                 			// 逆位牌較少，所以逆位為主卦
                 			primary_trend = "逆位";
                 			secondary_trend = "正位";
                 			primary_description = "少數逆位牌主導整體運勢走向，顯示需要深度轉化的核心議題";
                 			secondary_description = "多數正位牌提供穩定的支持能量，形成變革的基礎";
                 		}
                 		else if(reversed_count > upright_count)
                 		{
                 			// 正位牌較少，所以正位為主卦
                 			primary_trend = "正位";
                 			secondary_trend = "逆位";
                 			primary_description = "少數正位牌主導整體運勢走向，代表突破困境的關鍵力量";
                 			secondary_description = "多數逆位牌揭示需要面對的挑戰，但已有明確的解決方向";
                 		}
                 		else
                 		{
                 			// 正逆位數量相等
                 			primary_trend = "平衡";
                 			secondary_trend = "平衡";
                 			primary_description = "正逆位完美平衡的和諧狀態，顯示內在力量的均衡發展";
                 			secondary_description = "各種能量相互制衡，需要智慧地維持現狀並尋求突破點";
                 		}
                 		// --- 步驟 3: 增強版五行權重計算 ---
                 		// 定義牌位的時間軸權重（付費版本更精確）
                 		position_weights = list();
                 		position_weights.add(0.15);
                 		// 牌位1：過去根源 - 增加權重
                 		position_weights.add(0.25);
                 		// 牌位2：現在狀況 - 高權重
                 		position_weights.add(0.30);
                 		// 牌位3：核心問題 - 最高權重
                 		position_weights.add(0.15);
                 		// 牌位4：外在因素 - 平衡權重
                 		position_weights.add(0.15);
                 		// 牌位5：未來指引 - 平衡權重
                 		// 提取並分析五行元素（增強版推薦）
                 		primary_elements = list();
                 		primary_elements.add("金");
                 		// 基於深度分析的推薦
                 		primary_elements.add("水");
                 		// 多元素平衡
                 		// --- 步驟 4: 建立付費版商業化 AI Prompt ---
                 		spread_content = "";
                 		// 構建完整的牌陣描述
                 		spread_content = spread_content + "【付費完整版塔羅解讀】\n";
                 		spread_content = spread_content + "客戶問題：" + question_text + "\n";
                 		spread_content = spread_content + "問題類型：" + question_type + "\n\n";
                 		// 主副卦分析結果（增強版）
                 		spread_content = spread_content + "=== 深度主副卦運勢分析 ===\n";
                 		spread_content = spread_content + "主卦趨勢：" + primary_trend + "（共" + if(primary_trend == "逆位",reversed_count,if(primary_trend == "正位",upright_count,5)) + "張牌）\n";
                 		spread_content = spread_content + "主卦描述：" + primary_description + "\n";
                 		spread_content = spread_content + "副卦能量：" + secondary_trend + "（共" + if(secondary_trend == "逆位",reversed_count,if(secondary_trend == "正位",upright_count,0)) + "張牌）\n";
                 		spread_content = spread_content + "副卦描述：" + secondary_description + "\n\n";
                 		// 加入五張牌的詳細資訊（付費版本更詳盡）
                 		spread_content = spread_content + "=== 完整牌陣詳細解析（五行時間軸權重分析）===\n";
                 		position_labels = {"牌位1（過去根源）","牌位2（現在狀況）","牌位3（核心問題）","牌位4（外在因素）","牌位5（未來指引）"};
                 		position_importance = {"15%權重","25%權重","30%權重","15%權重","15%權重"};
                 		card_index = 0;
                 		for each  meaning in position_meanings
                 		{
                 			if(meaning != null && meaning != "")
                 			{
                 				reversed_status = all_reversed_status.get(card_index);
                 				trend_mark = if(reversed_status,"【逆位】","【正位】");
                 				importance_mark = "（" + position_importance.get(card_index) + "）";
                 				spread_content = spread_content + position_labels.get(card_index) + trend_mark + importance_mark + "：\n" + meaning + "\n\n";
                 			}
                 			card_index = card_index + 1;
                 		}
                 		// 付費版商業化指導（更自然的5%比例）
                 		commercial_guidance = "在解讀的最後150字左右，基於完整的五行分析結果，以溫暖智慧的語調自然地提及相應的五行調和工具或符令，語調要如摯友般溫和建議，完全不帶推銷意味。使用「若有需要」、「不妨考慮」、「或許能夠」等溫柔詞彙。";
                 		// 付費版深度分析指導
                 		primary_analysis_guidance = "請以付費版本的深度標準，詳細分析主卦（" + primary_trend + "）的每一個層面，包括心理層面、能量層面、靈性層面的深刻含義。每張主卦牌都要有至少200字的深度解讀，說明其在整體運勢中的決定性作用。";
                 		secondary_analysis_guidance = "副卦（" + secondary_trend + "）的詳細分析也要達到完整版標準，每張副卦牌至少150字，說明它們如何與主卦形成完整的能量循環，以及它們在平衡整體運勢中的作用。";
                 		future_guidance = "請提供未來3個月到1年的詳細運勢走向預測，包括每個階段的重點發展方向、可能遇到的挑戰、以及具體的因應策略。這部分至少要有500字的詳盡分析。";
                 		practical_guidance = "請提供具體可行的日常靈性修練建議，包括冥想方法、能量調節技巧、以及與五行元素相應的生活實踐方案。這部分要有300字以上的實用指導。";
                 		// 建立付費版精密 AI Prompt
                 		ai_prompt = "你是一位擁有30年經驗的頂級塔羅牌占卜大師，精通主副卦分析法和五行調和術，以仙氣飄飄的高維靈魂語調來回答。這是付費完整版解讀，需要提供3000字的深度專業分析。\n\n" + "重要指令：請務必使用繁體中文回答，嚴格避免簡體字。特別注意：使用「個」不用「个」、「裡」不用「里」、「資訊」不用「信息」、「網絡」不用「网络」。\n\n" + "請根據以下塔羅牌陣為付費客戶提供最深度的個人化完整解讀：\n\n" + spread_content + "\n=== 付費版解讀指導 ===\n" + primary_analysis_guidance + "\n" + secondary_analysis_guidance + "\n" + future_guidance + "\n" + practical_guidance + "\n\n" + "請按以下結構提供一個3000字的專業完整版塔羅解讀：\n" + "1. 開場感受與整體概況（200字）：深度同理客戶問題，點出牌陣的核心靈性訊息和整體能量狀態\n" + "2. 主卦深度分析（800字）：每張主卦牌的詳細解讀，包括心理、能量、靈性三個層面，說明其決定性影響\n" + "3. 副卦完整解析（600字）：每張副卦牌的深度分析，說明其平衡作用和與主卦的能量互動\n" + "4. 五行時間軸分析（500字）：基於牌位權重的精確五行能量分析，包括過去、現在、未來的能量流動\n" + "5. 未來發展指引（600字）：3個月到1年的詳細運勢預測，包括關鍵時間點和發展策略\n" + "6. 實踐修練方案（300字）：具體的日常靈性修練建議，包括冥想、能量調節、生活實踐\n" + "7. 五行調和建議（150字）：" + commercial_guidance + "\n" + "8. 溫暖祝福結語（150字）：以最溫暖智慧的語調給予深度鼓勵和靈性指引\n\n" + "創意參數：以0.8的高創意溫度展現豐富的靈感和深度洞察。語調要溫暖、智慧且具有深厚的靈性底蘊，展現頂級占卜師的專業水準。";
                 		// --- 步驟 5: 呼叫 OpenAI API（付費版本設定）---
                 		messages = list();
                 		// 設定付費版系統提示
                 		systemMsg = Map();
                 		systemMsg.put("role","system");
                 		systemMsg.put("content","你是一位擁有30年經驗的頂級塔羅牌占卜大師，專為付費客戶提供最深度的完整解讀服務。以仙氣飄飄的高維靈魂語調來回答，使用繁體中文，絕對避免簡體字符。");
                 		messages.add(systemMsg);
                 		// 用戶訊息
                 		userMsg = Map();
                 		userMsg.put("role","user");
                 		userMsg.put("content",ai_prompt);
                 		messages.add(userMsg);
                 		// 組合完整的請求 payload（付費版本設定）
                 		openai_request = Map();
                 		openai_request.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 		openai_request.put("messages",messages);
                 		openai_request.put("temperature",creativity_temperature);
                 		// 付費版本更高創意
                 		openai_request.put("max_tokens",4000);
                 		// 大幅增加以確保3000字輸出
                 		// 設定請求標頭
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		// 呼叫 OpenAI API
                 		openai_response = postUrl(thisapp.variables.OpenAI.OpenAI_API_URL,openai_request.toString(),headers);
                 		// --- 步驟 6: 處理 API 回應（付費版本）---
                 		if(openai_response.get("choices") != null && openai_response.get("choices").size() > 0)
                 		{
                 			ai_interpretation = openai_response.get("choices").get(0).get("message").get("content");
                 			if(ai_interpretation != null && ai_interpretation.trim() != "")
                 			{
                 				// 清理回應文字
                 				clean_interpretation = ai_interpretation.trim();
                 				// 計算字數（中文字符估算）
                 				word_count = clean_interpretation.length() / 2;
                 				final_response.put("success",true);
                 				final_response.put("interpretation",clean_interpretation);
                 				final_response.put("word_count",word_count);
                 				final_response.put("target_word_count",target_word_count);
                 				final_response.put("is_full_version",true);
                 				final_response.put("primary_trend",primary_trend);
                 				final_response.put("secondary_trend",secondary_trend);
                 				final_response.put("recommended_elements",primary_elements);
                 				final_response.put("commercial_ratio",commercial_ratio);
                 				final_response.put("creativity_temperature",creativity_temperature);
                 			}
                 			else
                 			{
                 				final_response.put("success",false);
                 				final_response.put("error","AI 回應為空");
                 				final_response.put("interpretation","感謝您選擇完整版塔羅解讀服務。這次的牌陣顯示了豐富而深層的靈性訊息，建議您靜心冥想每張牌的深層含義，相信內在的智慧會為您開啟更深刻的洞察。");
                 			}
                 		}
                 		else
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","OpenAI API 回應格式異常");
                 			final_response.put("interpretation","感謝您選擇完整版塔羅解讀服務。這次的牌陣顯示了豐富而深層的靈性訊息，建議您靜心冥想每張牌的深層含義，相信內在的智慧會為您開啟更深刻的洞察。");
                 		}
                 	}
                 	catch (e)
                 	{
                 		// 發生錯誤時的付費版預設回應
                 		final_response.put("success",false);
                 		final_response.put("error","處理過程發生錯誤：" + e);
                 		final_response.put("interpretation","親愛的朋友，宇宙的能量此刻正在為您的完整版解讀重新校準。請稍後再次嘗試，或者先靜心冥想您抽到的牌卡，更深層的答案會在寧靜中逐漸顯現。作為付費客戶，您的靈性旅程值得最完美的指引。");
                 	}
                 	return final_response;
                 }
map AIInterpreter.getTarotInterpretation_v2(string question_text, string question_type, map tarot_spread_data)
                 {
                 	// =============================================================================
                 	// 函數名稱：AIInterpreter.getTarotInterpretation_v2
                 	// 正式版本：ChatGPT 同步API，穩定可靠，避開Zoho Creator超時限制
                 	// 未來升級：將整合 Zoho Flow + OpenAI Assistant API 支援 Thread ID 記憶
                 	// =============================================================================
                 	final_response = Map();
                 	try 
                 	{
                 		// 驗證參數
                 		if(question_text == null || question_text.trim() == "" || question_type == null || question_type.trim() == "")
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","輸入參數不完整");
                 			return final_response;
                 		}
                 		info "開始塔羅AI解讀 - 問題類型：" + question_type;
                 		// 建立簡潔但完整的 Prompt
                 		ai_prompt = "你是專業塔羅占卜師，請為以下問題提供約300字的解讀：\n\n" + "問題：" + question_text + "\n" + "類型：" + question_type + "\n\n" + "請用繁體中文回答，語調溫暖專業，包含：\n" + "1. 對問題的理解和感受\n" + "2. 塔羅牌顯示的訊息\n" + "3. 建議和指引\n\n" + "避免使用簡體字（使用「個」不用「个」、「裡」不用「里」）。";
                 		info "準備調用 ChatGPT API，Prompt長度：" + ai_prompt.length();
                 		// 使用同步 ChatGPT API 避開超時問題
                 		ai_interpretation = thisapp.OpenAI.callChatGPT(ai_prompt);
                 		if(ai_interpretation != null && ai_interpretation.trim() != "" && !ai_interpretation.contains("錯誤："))
                 		{
                 			final_response.put("success",true);
                 			final_response.put("interpretation",ai_interpretation.trim());
                 			final_response.put("api_method","ChatGPT (穩定版)");
                 			final_response.put("prompt_length",ai_prompt.length());
                 			final_response.put("word_count",ai_interpretation.length());
                 			info "塔羅AI解讀成功，字數：" + ai_interpretation.length();
                 		}
                 		else
                 		{
                 			final_response.put("success",false);
                 			final_response.put("error","ChatGPT API 調用失敗：" + ai_interpretation);
                 			final_response.put("interpretation","很抱歉，AI解讀暫時無法使用，請稍後再試。");
                 		}
                 	}
                 	catch (e)
                 	{
                 		final_response.put("success",false);
                 		final_response.put("error","處理過程發生錯誤：" + e.toString());
                 		final_response.put("interpretation","很抱歉，占卜過程中發生系統錯誤，請稍後再試。");
                 		info "getTarotInterpretation_v2 執行錯誤：" + e.toString();
                 	}
                 	return final_response;
                 }
map API.CreateClientProfile(string lastName, string firstName, string phoneNumber, string email, string dateOfBirth, string timeOfBirth, string salesiqVisitorId)
                 {
                 	// =============================================================================
                 	// Creator API：建立個案檔案並觸發命理運算
                 	// 
                 	// 功能：接收 SalesIQ 收集的個案基本資料，建立 Clients_Report 記錄，
                 	//      觸發後續的星座、八字、星宿等命理運算 Workflow
                 	// 用途：分離式架構中的個案建立階段，為後續占卜服務建立基礎
                 	// =============================================================================
                 	// 採用單一出口模式
                 	api_result = Map();
                 	try 
                 	{
                 		info "=== 開始建立個案檔案 ===";
                 		info "姓名：" + lastName + firstName + "（順序：姓→名）";
                 		info "聯絡方式：" + phoneNumber + " / " + email;
                 		info "生日：" + dateOfBirth + " " + timeOfBirth;
                 		info "SalesIQ 訪客 ID：" + salesiqVisitorId;
                 		// === 步驟 1：參數驗證 ===
                 		if(lastName == null || lastName == "" || firstName == null || firstName == "")
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","姓名資訊不完整（需要姓氏和名字）");
                 			return api_result;
                 		}
                 		if(email == null || email == "" || !email.contains("@"))
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","電子郵件格式錯誤");
                 			return api_result;
                 		}
                 		if(dateOfBirth == null || dateOfBirth == "")
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","出生日期不能為空");
                 			return api_result;
                 		}
                 		// === 步驟 2：日期時間格式處理 ===
                 		formatted_date = dateOfBirth;
                 		// 處理 8 碼生日格式 (19741115 → 1974-11-15)
                 		if(dateOfBirth.length() == 8 && dateOfBirth.isNumber())
                 		{
                 			year = dateOfBirth.substring(0,4);
                 			month = dateOfBirth.substring(4,6);
                 			day = dateOfBirth.substring(6,8);
                 			formatted_date = year + "-" + month + "-" + day;
                 			info "日期格式轉換（8碼）：" + dateOfBirth + " → " + formatted_date;
                 		}
                 		// 處理 6 碼或 7 碼民國年格式 (761112 → 1987-11-12, 1001112 → 2011-11-12)
                 		else if(dateOfBirth.length() == 6 || dateOfBirth.length() == 7 && dateOfBirth.isNumber())
                 		{
                 			roc_year_length = dateOfBirth.length() - 4;
                 			// 6碼=2位年, 7碼=3位年
                 			roc_year = dateOfBirth.substring(0,roc_year_length).toNumber();
                 			month = dateOfBirth.substring(roc_year_length,roc_year_length + 2);
                 			day = dateOfBirth.substring(roc_year_length + 2,roc_year_length + 4);
                 			// 民國年轉西元年（民國元年 = 1912）
                 			year = (roc_year + 1911).toString();
                 			formatted_date = year + "-" + month + "-" + day;
                 			info "日期格式轉換（民國" + roc_year + "年）：" + dateOfBirth + " → " + formatted_date;
                 		}
                 		else
                 		{
                 			info "警告：無法解析的日期格式：" + dateOfBirth;
                 			api_result.put("success",false);
                 			api_result.put("message","日期格式錯誤，請使用8碼西元年(19880712)或6-7碼民國年(770712)");
                 			return api_result;
                 		}
                 		// 處理 4 碼時間格式 (2103 → 21:03)
                 		formatted_time = if(timeOfBirth != null,timeOfBirth,"12:00");
                 		if(timeOfBirth != null && timeOfBirth.length() >= 3 && timeOfBirth.isNumber())
                 		{
                 			if(timeOfBirth.length() == 4)
                 			{
                 				hour = timeOfBirth.substring(0,2);
                 				minute = timeOfBirth.substring(2,4);
                 				formatted_time = hour + ":" + minute;
                 			}
                 			else if(timeOfBirth.length() == 3)
                 			{
                 				hour = "0" + timeOfBirth.substring(0,1);
                 				minute = timeOfBirth.substring(1,3);
                 				formatted_time = hour + ":" + minute;
                 			}
                 			info "時間格式轉換：" + timeOfBirth + " → " + formatted_time;
                 		}
                 		// 組合完整的日期時間
                 		full_datetime_string = formatted_date + " " + formatted_time;
                 		birth_datetime = full_datetime_string.toDateTime();
                 		info "最終日期時間：" + full_datetime_string;
                 		// === 步驟 3：檢查重複個案（根據 SalesIQ Visitor ID）===
                 		if(salesiqVisitorId != null && salesiqVisitorId != "")
                 		{
                 			existing_clients = Clients_Report[SalesIQ_Visitor_ID == salesiqVisitorId];
                 			if(existing_clients.count() > 0)
                 			{
                 				// 找到現有個案，回傳現有資料
                 				existing_client = null;
                 				for each  client in existing_clients
                 				{
                 					existing_client = client;
                 					break;
                 				}
                 				info "發現現有個案，ID：" + existing_client.ID.toString();
                 				api_result.put("success",true);
                 				api_result.put("message","個案已存在");
                 				api_result.put("is_existing_client",true);
                 				api_result.put("client_id",existing_client.ID.toString());
                 				api_result.put("client_name",existing_client.Visitor_Name.last_name + existing_client.Visitor_Name.first_name);
                 				api_result.put("personality_profile_ready",existing_client.Personality_Profile != null && existing_client.Personality_Profile != "");
                 				return api_result;
                 			}
                 		}
                 		// === 步驟 4：建立新個案記錄 ===
                 		info "建立新個案記錄";
                 		new_client = insert into Clients_Report
                 		[
                 			Added_User=zoho.loginuser
                 			Visitor_Name.last_name=lastName
                 			Visitor_Name.first_name=firstName
                 			Email=email
                 			Phone_Number=phoneNumber
                 			Date_Of_Birth=birth_datetime
                 			Timezone_Of_Birth="(UTC+08:00) 台北 (Asia/Taipei)"
                 			Client_Type="真實"
                 			SalesIQ_Visitor_ID=if(salesiqVisitorId != null,salesiqVisitorId,"")
                 		];
                 		if(new_client != null)
                 		{
                 			client_id = new_client;
                 			info "個案建立成功，ID：" + client_id.toString();
                 			// === 步驟 5：手動觸發命理計算 ===
                 			// 由於 API 建立的記錄不會觸發 OnEdit 系列 Workflow，
                 			// 我們需要手動調用相關的計算函數來填充命理資料
                 			info "開始手動觸發命理計算...";
                 			try 
                 			{
                 				// 取得剛建立的記錄以便更新
                 				client_record = Clients_Report[ID == client_id];
                 				// 宣告共用變數
                 				bazi_result = null;
                 				// 觸發星座計算
                 				zodiac_result = thisapp.Zodiac.getZodiacSign(birth_datetime);
                 				if(zodiac_result.get("success") == true)
                 				{
                 					client_record.Zodiac_Signs=zodiac_result.get("sign_id");
                 					info "星座計算完成";
                 				}
                 				// 觸發生肖計算
                 				chinese_zodiac_result = thisapp.Zodiac.getChineseZodiacSign(birth_datetime);
                 				if(chinese_zodiac_result.get("success") == true)
                 				{
                 					client_record.Chinese_Zodiac=chinese_zodiac_result.get("zodiac_id");
                 					// 同時計算虛歲
                 					birth_lunar_year = chinese_zodiac_result.get("zodiac_year");
                 					current_year = zoho.currentdate.getYear();
                 					current_lunar_year = current_year;
                 					// 判斷當前日期是否已過農曆新年
                 					current_lunar_data_record = LunarData[Solar_Year == current_year];
                 					if(current_lunar_data_record.count() > 0)
                 					{
                 						current_lunar_new_year = current_lunar_data_record.Lunar_New_Year;
                 						if(zoho.currentdate < current_lunar_new_year.toDate())
                 						{
                 							current_lunar_year = current_year - 1;
                 						}
                 						// 虛歲 = 當前農曆年份 - 出生農曆年份 + 1
                 						nominal_age = current_lunar_year - birth_lunar_year + 1;
                 						client_record.Nominal_Age=nominal_age;
                 					}
                 					info "生肖和虛歲計算完成";
                 				}
                 				// 觸發星宿計算
                 				mansion_result = thisapp.Star.getLunarMansion(birth_datetime);
                 				if(mansion_result.get("success") == true)
                 				{
                 					mansion_name = mansion_result.get("mansion_name");
                 					mansion_record = Twenty_Eight_Lunar_Mansions[Star_Name == mansion_name];
                 					if(mansion_record != null)
                 					{
                 						client_record.Twenty_Eight_Lunar_Mansions=mansion_record.ID;
                 						info "星宿計算完成";
                 					}
                 				}
                 				// 觸發性別預測（使用 OpenAI）
                 				if(firstName != null && firstName != "")
                 				{
                 					try 
                 					{
                 						// 準備 OpenAI 請求
                 						messages = List();
                 						system_msg = Map();
                 						system_msg.put("role","system");
                 						system_msg.put("content","你是一個中文名字性別判斷專家。根據使用者提供的名字，判斷其最可能的性別。你的回答必須只能是「男」或「女」，不能包含任何其他標點符號、文字或解釋。");
                 						messages.add(system_msg);
                 						// 提供範例
                 						messages.add({"role":"user","content":"王大明"});
                 						messages.add({"role":"assistant","content":"男"});
                 						messages.add({"role":"user","content":"陳淑芬"});
                 						messages.add({"role":"assistant","content":"女"});
                 						messages.add({"role":"user","content":"子嘉"});
                 						messages.add({"role":"assistant","content":"男"});
                 						// 實際查詢
                 						user_msg = Map();
                 						user_msg.put("role","user");
                 						user_msg.put("content",firstName);
                 						messages.add(user_msg);
                 						// 構建請求
                 						openai_request = Map();
                 						openai_request.put("model",thisapp.variables.OpenAI.OpenAI_Model);
                 						openai_request.put("messages",messages);
                 						openai_request.put("temperature",0.1);
                 						openai_request.put("max_tokens",5);
                 						// 發送請求
                 						gender_response = invokeurl
                 						[
                 							url :thisapp.variables.OpenAI.OpenAI_API_URL
                 							type :POST
                 							parameters:openai_request.toString()
                 							headers:{"Authorization":"Bearer " + thisapp.variables.OpenAI.OpenAI_API_Key,"Content-Type":"application/json"}
                 						];
                 						if(gender_response != null && gender_response.get("choices") != null && gender_response.get("choices").size() > 0)
                 						{
                 							predicted_gender = gender_response.get("choices").get(0).get("message").get("content").trim();
                 							if(predicted_gender == "女" || predicted_gender == "男")
                 							{
                 								client_record.Clients_Gender=predicted_gender;
                 								info "性別預測完成：" + predicted_gender;
                 							}
                 							else
                 							{
                 								client_record.Clients_Gender="男";
                 								// 預設值
                 								info "性別預測結果不明確，使用預設值：男";
                 							}
                 						}
                 						else
                 						{
                 							client_record.Clients_Gender="男";
                 							// 預設值
                 							info "性別預測 API 無回應，使用預設值：男";
                 						}
                 					}
                 					catch (gender_error)
                 					{
                 						client_record.Clients_Gender="男";
                 						// 預設值
                 						info "性別預測失敗，使用預設值：男，錯誤：" + gender_error.toString();
                 					}
                 				}
                 				// 先觸發八字計算（農曆轉換需要用到年柱）
                 				bazi_result = thisapp.Bazi.PreciseBaziCalculator(birth_datetime);
                 				if(bazi_result.get("success") == true)
                 				{
                 					// 更新八字相關欄位
                 					year_pillar_details = bazi_result.get("年柱詳情");
                 					month_pillar_details = bazi_result.get("月柱詳情");
                 					day_pillar_details = bazi_result.get("日柱詳情");
                 					hour_pillar_details = bazi_result.get("時柱詳情");
                 					// 組合完整八字字串
                 					full_bazi_string = (year_pillar_details.get("stem") + year_pillar_details.get("branch")) + " " + (month_pillar_details.get("stem") + month_pillar_details.get("branch")) + " " + (day_pillar_details.get("stem") + day_pillar_details.get("branch")) + " " + (hour_pillar_details.get("stem") + hour_pillar_details.get("branch"));
                 					client_record.Full_Bazi=full_bazi_string;
                 					// 查詢並更新天干地支 Lookup 欄位
                 					year_stem_record = Heavenly_Stems[Stem_Name == year_pillar_details.get("stem")];
                 					year_branch_record = Earthly_Branches[Branch_Name == year_pillar_details.get("branch")];
                 					month_stem_record = Heavenly_Stems[Stem_Name == month_pillar_details.get("stem")];
                 					month_branch_record = Earthly_Branches[Branch_Name == month_pillar_details.get("branch")];
                 					day_stem_record = Heavenly_Stems[Stem_Name == day_pillar_details.get("stem")];
                 					day_branch_record = Earthly_Branches[Branch_Name == day_pillar_details.get("branch")];
                 					hour_stem_record = Heavenly_Stems[Stem_Name == hour_pillar_details.get("stem")];
                 					hour_branch_record = Earthly_Branches[Branch_Name == hour_pillar_details.get("branch")];
                 					if(year_stem_record != null)
                 					{
                 						client_record.Year_Heavenly_Stem=year_stem_record.ID;
                 					}
                 					if(year_branch_record != null)
                 					{
                 						client_record.Year_Earthly_Branch=year_branch_record.ID;
                 					}
                 					if(month_stem_record != null)
                 					{
                 						client_record.Month_Heavenly_Stem=month_stem_record.ID;
                 					}
                 					if(month_branch_record != null)
                 					{
                 						client_record.Month_Earthly_Branch=month_branch_record.ID;
                 					}
                 					if(day_stem_record != null)
                 					{
                 						client_record.Day_Heavenly_Stem=day_stem_record.ID;
                 					}
                 					if(day_branch_record != null)
                 					{
                 						client_record.Day_Earthly_Branch=day_branch_record.ID;
                 					}
                 					if(hour_stem_record != null)
                 					{
                 						client_record.Hour_Heavenly_Stem=hour_stem_record.ID;
                 					}
                 					if(hour_branch_record != null)
                 					{
                 						client_record.Hour_Earthly_Branch=hour_branch_record.ID;
                 					}
                 					// 更新四柱組合欄位
                 					year_pillar_str = bazi_result.get("年柱");
                 					month_pillar_str = bazi_result.get("月柱");
                 					day_pillar_str = bazi_result.get("日柱");
                 					hour_pillar_str = bazi_result.get("時柱");
                 					year_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == year_pillar_str];
                 					month_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == month_pillar_str];
                 					day_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == day_pillar_str];
                 					hour_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == hour_pillar_str];
                 					if(year_ganzhi_record != null)
                 					{
                 						client_record.Year_Pillar=year_ganzhi_record.ID;
                 					}
                 					if(month_ganzhi_record != null)
                 					{
                 						client_record.Month_Pillar=month_ganzhi_record.ID;
                 					}
                 					if(day_ganzhi_record != null)
                 					{
                 						client_record.Day_Pillar=day_ganzhi_record.ID;
                 					}
                 					if(hour_ganzhi_record != null)
                 					{
                 						client_record.Hour_Pillar=hour_ganzhi_record.ID;
                 					}
                 					info "八字計算完成";
                 				}
                 				// 觸發農曆生日轉換（需要用到八字的年柱）
                 				try 
                 				{
                 					solar_to_lunar_result = thisapp.LunarAI.SolarToLunar(birth_datetime);
                 					info "農曆轉換結果：" + solar_to_lunar_result.toString();
                 					if(solar_to_lunar_result != null)
                 					{
                 						birthday_map = solar_to_lunar_result.get("生日");
                 						if(birthday_map != null)
                 						{
                 							error_msg = birthday_map.get("error");
                 							if(error_msg == null || error_msg == "")
                 							{
                 								original_lunar_text = birthday_map.get("中文日期");
                 								if(original_lunar_text != null && original_lunar_text.contains(","))
                 								{
                 									// 從八字結果中取得年柱干支
                 									if(bazi_result != null && bazi_result.get("success") == true)
                 									{
                 										year_pillar_details = bazi_result.get("年柱詳情");
                 										if(year_pillar_details != null)
                 										{
                 											year_ganzhi = year_pillar_details.get("stem") + year_pillar_details.get("branch");
                 											// 替換年份為干支年
                 											final_lunar_string = original_lunar_text.replaceAll(original_lunar_text.toList(",").get(0) + ", ",year_ganzhi + "年 ");
                 											client_record.Lunar_Birthday=final_lunar_string;
                 											info "農曆生日轉換完成：" + final_lunar_string;
                 										}
                 										else
                 										{
                 											info "年柱詳情為空";
                 										}
                 									}
                 									else
                 									{
                 										info "八字結果無效，無法取得年柱";
                 									}
                 								}
                 								else
                 								{
                 									info "農曆日期格式不符預期：" + original_lunar_text;
                 								}
                 							}
                 							else
                 							{
                 								info "農曆轉換錯誤：" + error_msg;
                 							}
                 						}
                 						else
                 						{
                 							info "無法取得生日農曆資料";
                 						}
                 					}
                 					else
                 					{
                 						info "農曆轉換函數回傳 null";
                 					}
                 				}
                 				catch (lunar_error)
                 				{
                 					info "農曆轉換過程發生錯誤：" + lunar_error.toString();
                 				}
                 				// 觸發太歲計算
                 				current_year_for_taisui = zoho.currentdate.getYear();
                 				info "開始太歲計算，出生日期：" + birth_datetime + "，查詢年份：" + current_year_for_taisui;
                 				taisui_result = thisapp.Zodiac.getTaisuiStatus(birth_datetime,current_year_for_taisui);
                 				info "太歲計算結果：" + taisui_result.toString();
                 				if(taisui_result.get("success") == true)
                 				{
                 					birth_ganzhi_id = taisui_result.get("birth_ganzhi_id");
                 					query_year_ganzhi_id = taisui_result.get("query_year_ganzhi_id");
                 					info "本命干支 ID：" + birth_ganzhi_id;
                 					info "流年干支 ID：" + query_year_ganzhi_id;
                 					// 更新「本命太歲」和「流年太歲」的 Lookup 欄位
                 					client_record.Taisui_Deity_Name_Birth=birth_ganzhi_id;
                 					client_record.Taisui_Deity_Name_Year=query_year_ganzhi_id;
                 					info "太歲計算完成，已更新欄位";
                 				}
                 				else
                 				{
                 					info "太歲計算失敗：" + taisui_result.get("error");
                 				}
                 				// 觸發本命塔羅計算
                 				tarot_results_map = thisapp.Tarot.getLifePathTarot(birth_datetime);
                 				if(tarot_results_map != null)
                 				{
                 					ben_ming_tarot_id = tarot_results_map.get("Ben_Ming_Tarot_ID");
                 					if(ben_ming_tarot_id != null)
                 					{
                 						client_record.Ben_Ming_Tarot=ben_ming_tarot_id;
                 						client_record.Ben_Ming_Tarot_Image=tarot_results_map.get("Ben_Ming_Tarot_Image_Value");
                 					}
                 					xian_zhuang_tarot_id = tarot_results_map.get("Xian_Zhuang_Tarot_ID");
                 					if(xian_zhuang_tarot_id != null)
                 					{
                 						client_record.Xian_Zhuang_Tarot=xian_zhuang_tarot_id;
                 						client_record.Xian_Zhuang_Tarot_Image=tarot_results_map.get("Xian_Zhuang_Tarot_Image_Value");
                 					}
                 					ye_li_tarot_id = tarot_results_map.get("Ye_Li_Tarot_ID");
                 					if(ye_li_tarot_id != null)
                 					{
                 						client_record.Ye_Li_Tarot=ye_li_tarot_id;
                 						client_record.Ye_Li_Tarot_Image=tarot_results_map.get("Ye_Li_Tarot_Image_Value");
                 					}
                 					tian_yuan_tarot_id = tarot_results_map.get("Tian_Yuan_Tarot_ID");
                 					if(tian_yuan_tarot_id != null)
                 					{
                 						client_record.Tian_Yuan_Tarot=tian_yuan_tarot_id;
                 						client_record.Tian_Yuan_Tarot_Image=tarot_results_map.get("Tian_Yuan_Tarot_Image_Value");
                 					}
                 					info "本命塔羅計算完成";
                 				}
                 				info "命理計算觸發完成";
                 			}
                 			catch (calc_error)
                 			{
                 				info "命理計算過程中發生錯誤：" + calc_error.toString();
                 				// 不影響主要流程，繼續執行
                 			}
                 			// === 步驟 6：準備回傳資料 ===
                 			api_result.put("success",true);
                 			api_result.put("message","個案建立成功，命理運算開始進行");
                 			api_result.put("is_existing_client",false);
                 			api_result.put("client_id",client_id.toString());
                 			api_result.put("client_name",lastName + firstName);
                 			api_result.put("personality_profile_ready",false);
                 			// 回傳格式化後的資料供確認
                 			formatted_data = Map();
                 			formatted_data.put("birth_date",formatted_date);
                 			formatted_data.put("birth_time",formatted_time);
                 			formatted_data.put("full_datetime",full_datetime_string);
                 			api_result.put("formatted_data",formatted_data);
                 			info "API 回傳成功";
                 		}
                 		else
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","個案記錄建立失敗");
                 			info "個案記錄建立失敗";
                 		}
                 	}
                 	catch (e)
                 	{
                 		api_result.put("success",false);
                 		api_result.put("message","系統錯誤：" + e.toString());
                 		info "CreateClientProfile API 執行錯誤：" + e.toString();
                 	}
                 	return api_result;
                 }
map API.CreateTalismanOrder(string firstName, string lastName, string email, string phoneNumber, string divinationId, string talismanName, string element, string price)
                 {
                 	// =============================================================================
                 	// Creator API：建立符令購買訂單
                 	// 
                 	// 功能：建立 Talisman_Purchases 訂單記錄並生成 ECPay 付款表單
                 	// 回傳：訂單 ID 和付款 URL
                 	// =============================================================================
                 	// 採用單一出口模式
                 	api_result = Map();
                 	try 
                 	{
                 		info "=== 開始建立符令購買訂單 ===";
                 		info "購買人：" + lastName + firstName;
                 		info "符令名稱：" + talismanName;
                 		info "價格：NT$ " + price;
                 		info "占卜記錄 ID：" + divinationId;
                 		// === 步驟 1：驗證參數 ===
                 		if(firstName == null || firstName == "" || lastName == null || lastName == "")
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","姓名資訊不完整");
                 			return api_result;
                 		}
                 		if(email == null || email == "" || !email.contains("@"))
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","電子郵件格式錯誤");
                 			return api_result;
                 		}
                 		if(divinationId == null || divinationId == "")
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","占卜記錄 ID 不能為空");
                 			return api_result;
                 		}
                 		// === 步驟 2：查詢占卜記錄確認存在 ===
                 		divination_records = Divination_Logs[ID == divinationId.toLong()];
                 		if(divination_records.count() == 0)
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","找不到對應的占卜記錄");
                 			return api_result;
                 		}
                 		// === 步驟 3：建立訂單記錄 ===
                 		// 生成唯一訂單號碼（ECPay 限制 20 字元）
                 		current_time = zoho.currenttime;
                 		// 使用 TAL + 時間戳記，確保不超過 20 字元
                 		merchant_trade_no = "TAL" + current_time.toString("yyyyMMddHHmmss");
                 		// 處理中文符令名稱（ECPay 需要英文）
                 		item_name_english = "Digital_Talisman";
                 		item_description = "AI_Tarot_Talisman_" + element + "_Element";
                 		info "訂單號碼：" + merchant_trade_no;
                 		info "商品名稱（英文）：" + item_name_english;
                 		// === 步驟 2.5：查詢或建立客戶記錄 ===
                 		// 先查詢是否已有此客戶記錄
                 		existing_clients = Clients_Report[Email == email];
                 		client_id = "";
                 		if(existing_clients.count() > 0)
                 		{
                 			// 使用現有客戶記錄
                 			for each  client in existing_clients
                 			{
                 				client_id = client.ID;
                 				info "找到現有客戶記錄，ID：" + client_id.toString();
                 				break;
                 			}
                 		}
                 		else
                 		{
                 			// 建立新客戶記錄
                 			new_client = insert into Clients_Report
                 			[
                 				Added_User=zoho.loginuser
                 				Visitor_Name.first_name=firstName
                 				Visitor_Name.last_name=lastName
                 				Email=email
                 				Phone_Number=phoneNumber
                 				Client_Type="真實"
                 			];
                 			if(new_client != null)
                 			{
                 				client_id = new_client;
                 				info "建立新客戶記錄，ID：" + client_id.toString();
                 			}
                 			else
                 			{
                 				api_result.put("success",false);
                 				api_result.put("message","客戶記錄建立失敗");
                 				return api_result;
                 			}
                 		}
                 		// === 步驟 2.6：檢查是否為首次購買 ===
                 		// 查詢該占卜記錄的現有購買記錄
                 		existing_purchases = Talisman_Purchases[Divination_Log_Link == divinationId.toLong()];
                 		is_first_purchase = existing_purchases.count() == 0;
                 		// 計算符令序號（當前購買次數 + 1）
                 		current_sequence = existing_purchases.count() + 1;
                 		info "占卜記錄 " + divinationId + " 的購買狀況：";
                 		info "現有購買次數：" + existing_purchases.count().toString();
                 		info "是否首次購買：" + is_first_purchase.toString();
                 		info "本次符令序號：" + current_sequence.toString();
                 		// === 步驟 3：先驗證 ECPay 付款表單能否正常生成 ===
                 		// 準備 ECPay 訂單資訊
                 		ecpay_order_info = Map();
                 		ecpay_order_info.put("merchantTradeNo",merchant_trade_no);
                 		ecpay_order_info.put("totalAmount",price.toNumber());
                 		ecpay_order_info.put("itemName",item_name_english);
                 		ecpay_order_info.put("tradeDesc",item_description);
                 		return_url = if(thisapp.variables.ECPay.ReturnURL_Production != null,thisapp.variables.ECPay.ReturnURL_Production.toString(),"");
						ecpay_order_info.put("returnURL",return_url);
						client_back_url = if(thisapp.variables.ECPay.ClientBackURL_Production != null,thisapp.variables.ECPay.ClientBackURL_Production.toString(),"");
						ecpay_order_info.put("clientBackURL",client_back_url);
                 		info "準備調用 ECPay 付款表單生成函數";
                 		// 調用 ECPay 付款表單生成函數
                 		payment_form_html = thisapp.ECPay.generateCheckoutForm_Production(ecpay_order_info);
                 		if(payment_form_html != null && payment_form_html != "")
                 		{
                 			// ECPay 表單生成成功，現在可以安全建立訂單記錄
                 			info "ECPay 付款表單生成成功，開始建立訂單記錄";
                 			// === 步驟 4：建立訂單記錄（ECPay 驗證通過後才建立）===
                 			new_order = insert into Talisman_Purchases
                 			[
                 				Added_User=zoho.loginuser
                 				Client_Link=client_id
                 				Divination_Log_Link=divinationId.toLong()
                 				Talisman_Sequence=current_sequence.toString()
                 				MerchantTradeNo=merchant_trade_no
                 				Status="Pending"
                 				Item_Name_Chinese=talismanName + "（" + element + "元素符令）"
                 				Description_Chinese=lastName + firstName + " 的專屬" + element + "元素符令"
                 				TradeAmt=price.toDecimal()
                 				Purchase_Timestamp=current_time
                 				Is_First_Purchase=is_first_purchase
                 				Report_Included=is_first_purchase
                 			];
                 			if(new_order != null)
                 			{
                 				order_id = new_order;
                 				info "訂單建立成功，ID：" + order_id.toString();
                 				// === 步驟 4.1：更新占卜記錄狀態 ===
                 				divination_records = Divination_Logs[ID == divinationId.toLong()];
                 				if(divination_records.count() > 0)
                 				{
                 					for each  divination in divination_records
                 					{
                 						// 更新符令進度和狀態
                 						new_talisman_index = current_sequence.toString();
                 						new_status = "";
                 						if(current_sequence == 1)
                 						{
                 							new_status = "已推薦";
                 							// 首次購買：從已提問 → 已推薦
                 							divination.First_Purchase_Date=current_time;
                 						}
                 						else if(current_sequence < 5)
                 						{
                 							new_status = "已購買";
                 							// 2-4次購買：已購買
                 						}
                 						else
                 						{
                 							new_status = "已完成";
                 							// 第5次購買：已完成
                 						}
                 						divination.Current_Talisman_Index=new_talisman_index;
                 						divination.Status=new_status;
                 						divination.Last_Purchase_Date=current_time;
                 						info "更新占卜記錄狀態：" + new_status + "，符令進度：" + new_talisman_index;
                 						break;
                 					}
                 				}
                 				// === 步驟 4.2：更新訂單記錄，加入付款資訊 ===
                 				// 設定付款 URL
                 				payment_url = "https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5";
                 				order_records = Talisman_Purchases[ID == order_id];
                 				if(order_records.count() > 0)
                 				{
                 					for each  order_record in order_records
                 					{
                 						order_record.Payment_URL=payment_url;
                 						order_record.ECPay_Form_HTML=payment_form_html;
                 						break;
                 					}
                 				}
                 				// === 步驟 5：準備回傳資料 ===
                 				order_data = Map();
                 				order_data.put("order_id",order_id.toString());
                 				order_data.put("merchant_trade_no",merchant_trade_no);
                 				order_data.put("payment_url",payment_url);
                 				order_data.put("payment_form",payment_form_html);
                 				order_data.put("amount",price);
                 				order_data.put("item_name",talismanName);
                 				order_data.put("customer_name",lastName + firstName);
                 				api_result.put("success",true);
                 				api_result.put("message","訂單建立成功");
                 				api_result.put("data",order_data);
                 				info "API 回傳成功";
                 			}
                 			else
                 			{
                 				api_result.put("success",false);
                 				api_result.put("message","訂單記錄建立失敗");
                 				info "訂單記錄建立失敗";
                 			}
                 		}
                 		else
                 		{
                 			api_result.put("success",false);
                 			api_result.put("message","ECPay 付款表單生成失敗，訂單未建立");
                 			info "ECPay 付款表單生成失敗，為避免孤兒記錄，不建立訂單";
                 		}
                 	}
                 	catch (e)
                 	{
                 		api_result.put("success",false);
                 		api_result.put("message","系統錯誤：" + e);
                 		info "CreateTalismanOrder API 執行錯誤：" + e;
                 	}
                 	return api_result;
                 }
				
			
map API.CreateTalismanOrder_v2(string firstName, string lastName, string email, string phoneNumber, string divinationId, string talismanName, string element, string price, string lineUserId)
                 {
                  	// =============================================================================
                  	// Creator API：建立符令購買訂單（v2）
                  	// - 新增參數 lineUserId：用於付款成功後推播交付連結（n8n push）
                  	// - 其餘邏輯沿用 CreateTalismanOrder，不改規則
                  	// =============================================================================
                  	result = thisapp.API.CreateTalismanOrder(firstName,lastName,email,phoneNumber,divinationId,talismanName,element,price);
                  	try
                  	{
                  		if(result != null && result.get("success") == true && result.get("data") != null && lineUserId != null && lineUserId.trim() != "")
                  		{
                  			order_id = result.get("data").get("order_id");
                  			if(order_id != null && order_id != "")
                  			{
                  				orders = Talisman_Purchases[ID == order_id.toLong()];
                  				for each  o in orders
                  				{
                  					o.Line_User_ID=lineUserId;
                  					break;
                  				}
                  			}
                  		}
                  	}
                  	catch (e)
                  	{
                  		// 不影響建單主流程
                  	}
                  	return result;
                 }

map API.LIFF_Divination_MVP(string lineUserId, string birthday, string question)
                 {
                  	// =============================================================================
                  	// Creator API：LINE LIFF 入口（MVP）
                  	// Input : lineUserId, birthday(YYYY-MM-DD), question
                  	// Output: reading_id, summary_text(約300字), cooldown_until, next_action
                  	// Notes :
                  	// - v1 先做「生日+問題」最小入口，不收姓名/性別/手機/Email
                  	// - 收費策略：先免費摘要(約300字)，再引導付費解鎖完整版/符令
                  	// =============================================================================
                  	api_result = Map();
                  	try
                  	{
                  		// 1) Validate
                  		if(lineUserId == null || lineUserId.trim() == "")
                  		{
                  			api_result.put("success",false);
                  			api_result.put("message","lineUserId 不能為空");
                  			return api_result;
                  		}
                  		if(birthday == null || birthday.trim() == "")
                  		{
                  			api_result.put("success",false);
                  			api_result.put("message","生日不能為空");
                  			return api_result;
                  		}
                  		if(question == null || question.trim() == "")
                  		{
                  			api_result.put("success",false);
                  			api_result.put("message","問題不能為空");
                  			return api_result;
                  		}

                  		// 2) Normalize + hash (for cooldown)
                  		norm_question = question.trim().toLowerCase();
                  		norm_question = norm_question.replaceAll("\\s+"," ");
                  		question_hash = zoho.encryption.md5(lineUserId + "|" + norm_question);

                  		// 3) Cooldown (MVP: same hash within 7 days)
                  		now_time = zoho.currenttime;
                  		cooldown_days = 7;
                  		cooldown_until = now_time.addDay(cooldown_days);
                  		recent_same = Divination_Logs[Line_User_ID == lineUserId && Question_Hash == question_hash && Created_Time >= now_time.addDay(-cooldown_days)];
                  		if(recent_same.count() > 0)
                  		{
                  			api_result.put("success",false);
                  			api_result.put("message","冷卻中：相同問題請稍後再來");
                  			api_result.put("cooldown_until",recent_same.get(0).Created_Time.addDay(cooldown_days));
                  			return api_result;
                  		}

                  		// 4) Create Divination log (minimal)
                  		// NOTE: 若實際欄位/LinkName 不同，需依 Jeffery 提供之 Creator 端設定調整
                  		new_log_id = insert into Divination_Logs
                  		[
                  			Added_User=zoho.loginuser
                  			Line_User_ID=lineUserId
                  			Date_of_Birth=birthday
                  			Question=question
                  			Question_Hash=question_hash
                  		];

                  		// 5) Generate free summary (約300字)
                  		// TODO: 之後可改成「先跑你現有 tarot/iching 計算」再摘要
                  		prompt = "你是專業占卜師（塔羅+易經），請用繁體中文給出約300字的摘要解讀。\n" +
                  			"使用者國曆生日：" + birthday + "\n" +
                  			"問題：" + question + "\n\n" +
                  			"請包含：1) 目前狀態 2) 主要提醒 3) 一個可執行建議。語氣溫柔但冷靜，不要使用簡體字。";
                  		summary_text = thisapp.OpenAI.callChatGPT(prompt);

                  		// 6) Save summary back (best-effort)
                  		try
                  		{
                  			logs = Divination_Logs[ID == new_log_id.toLong()];
                  			for each  l in logs
                  			{
                  				l.Summary_Text=summary_text;
                  				l.Cooldown_Until=cooldown_until;
                  				break;
                  			}
                  		}
                  		catch (e2)
                  		{
                  			// ignore
                  		}

                  		// 7) Response
                  		api_result.put("success",true);
                  		api_result.put("reading_id",new_log_id.toString());
                  		api_result.put("summary_text",summary_text);
                  		api_result.put("cooldown_until",cooldown_until);
                  		next_action = Map();
                  		next_action.put("kind","offer_unlock");
                  		next_action.put("price",360);
                  		next_action.put("currency","TWD");
                  		next_action.put("cta_label","解鎖完整版/購買符令");
                  		api_result.put("next_action",next_action);
                  		return api_result;
                  	}
                  	catch (e)
                  	{
                  		api_result.put("success",false);
                  		api_result.put("message","系統錯誤：" + e.toString());
                  		return api_result;
                  	}
                 }

string API.ECPayReturn(map ecpay_params)
                 {
                  	// =============================================================================
                  	// Creator API：綠界 ECPay 付款回拋（ReturnURL）
                  	// 用途：ECPay server-to-server 回拋後，驗簽 CheckMacValue，並更新訂單狀態
                  	// 注意：此 API 必須是對外可被 ECPay 呼叫的 endpoint（公開網址），安全性靠 CheckMacValue 驗簽。
                  	// =============================================================================
                  	result = Map();
				response_text = "0|FAIL";
                  	try
                  	{
                  		if(ecpay_params == null)
                  		{
                  			result.put("success",false);
                  			result.put("message","參數為空");
                  			return response_text;
                  		}

                  		merchant_trade_no = if(ecpay_params.get("MerchantTradeNo") != null,ecpay_params.get("MerchantTradeNo").toString(),"");
                  		rtn_code = if(ecpay_params.get("RtnCode") != null,ecpay_params.get("RtnCode").toString(),"");
                  		trade_no = if(ecpay_params.get("TradeNo") != null,ecpay_params.get("TradeNo").toString(),"");
                  		payment_date = if(ecpay_params.get("PaymentDate") != null,ecpay_params.get("PaymentDate").toString(),"");
                  		recv_mac = if(ecpay_params.get("CheckMacValue") != null,ecpay_params.get("CheckMacValue").toString(),"");

                  		if(merchant_trade_no == "")
                  		{
                  			result.put("success",false);
                  			result.put("message","MerchantTradeNo 缺失");
                  			return response_text;
                  		}

                  		// 1) 驗簽：用生產環境 hashKey/hashIV 重算 CheckMacValue
                  		verify_params = Map();
                  		for each  k in ecpay_params.keys()
                  		{
                  			if(k != "CheckMacValue")
                  			{
                  				verify_params.put(k,ecpay_params.get(k));
                  			}
                  		}
                  		hash_key = thisapp.variables.ECPay.hashKey_Production;
                  		hash_iv = thisapp.variables.ECPay.hashIV_Production;
				if(hash_key == null || hash_iv == null || hash_key.toString() == "" || hash_iv.toString() == "")
				{
					result.put("success",false);
					result.put("message","生產環境 hashKey/hashIV 未設定");
					return response_text;
				}
                  		calc_mac = thisapp.ECPay.generateCheckMacValue_private(verify_params,hash_key,hash_iv);
                  		if(recv_mac == "" || calc_mac.toString().toUpperCase() != recv_mac.toString().toUpperCase())
                  		{
                  			result.put("success",false);
                  			result.put("message","CheckMacValue 驗證失敗");
                  			result.put("merchantTradeNo",merchant_trade_no);
                  			return response_text;
                  		}

                  		// 2) 更新訂單狀態（以 MerchantTradeNo 對應）
                  		orders = Talisman_Purchases[MerchantTradeNo == merchant_trade_no];
                  		if(orders.count() == 0)
                  		{
                  			result.put("success",false);
                  			result.put("message","找不到對應訂單");
                  			result.put("merchantTradeNo",merchant_trade_no);
                  			return response_text;
                  		}

                  		new_status = "Paid";
                  		if(rtn_code != "1")
                  		{
                  			new_status = "Failed";
                  		}
				should_notify = false;
				already_paid = false;
				token_created = false;

                  		for each  o in orders
                  		{
						already_paid = (o.Status == "Paid");
                  			o.Status=new_status;
						token_created = false;
						if(new_status == "Paid" && (o.Delivery_Token == null || o.Delivery_Token == ""))
						{
							// 生成難猜的交付 token（以訂單資訊+時間做 sha256）
							token_source = merchant_trade_no + "|" + trade_no + "|" + zoho.currenttime.toLong();
							delivery_token = zoho.encryption.sha256(token_source).toLowerCase();
							o.Delivery_Token=delivery_token;
							// Token 到期：預設 7 天（可再調）
							o.Delivery_Token_ExpiresAt=zoho.currenttime.addDay(7);
							token_created = true;
						}

                  			o.TradeNo=trade_no;
                  			o.PaymentDate=payment_date;
						o.RtnCode=rtn_code.toNumber();
						o.RtnMsg=if(ecpay_params.get("RtnMsg") != null,ecpay_params.get("RtnMsg").toString(),"");
						o.CheckMacValue=recv_mac;
						if(new_status == "Paid" && (!already_paid || token_created))
						{
							should_notify = true;
						}
                  			break;
                  		}

                  		
				// 3) 付款成功後通知 n8n 推播交付連結（A1）
				try
				{
					if(new_status == "Paid" && should_notify == true)
					{
						notify_url = if(thisapp.variables.System.N8N.ECPayPaidNotifyURL != null,thisapp.variables.System.N8N.ECPayPaidNotifyURL.toString(),"");
						base_url = if(thisapp.variables.System.DeliveryPageBaseURL != null,thisapp.variables.System.DeliveryPageBaseURL.toString(),"");
						if(notify_url != "" && base_url != "")
						{
							order_rec = null;
							orders2 = Talisman_Purchases[MerchantTradeNo == merchant_trade_no];
							for each  oo in orders2
							{
								order_rec = oo;
								break;
							}
							if(order_rec != null)
							{
								line_uid = if(order_rec.Line_User_ID != null,order_rec.Line_User_ID,"");
								if(line_uid == "" && order_rec.Client_Link != null)
								{
									client_rec = Clients_Report[ID == order_rec.Client_Link];
									for each  cc in client_rec
									{
										line_uid = if(cc.Line_User_ID != null,cc.Line_User_ID,"");
										break;
									}
								}
								// 把 client 的 lineUserId 回寫到訂單，方便追蹤
								if(order_rec.Line_User_ID == null || order_rec.Line_User_ID == "")
								{
									order_rec.Line_User_ID=line_uid;
								}
								delivery_token = if(order_rec.Delivery_Token != null,order_rec.Delivery_Token,"");
								if(line_uid != "" && delivery_token != "")
								{
									push_payload = Map();
									push_payload.put("lineUserId",line_uid);
									push_payload.put("merchantTradeNo",merchant_trade_no);
									push_payload.put("deliveryToken",delivery_token);
									push_payload.put("deliveryUrl",base_url + "?token=" + delivery_token);
									ignore = postUrl(notify_url,push_payload.toString(),{"Content-Type":"application/json"});
								}
							}
						}
					}
				}
				catch (e)
				{
					// 不影響回拋主要流程
				}

result.put("success",true);
                  		result.put("message","ok");
                  		result.put("merchantTradeNo",merchant_trade_no);
                  		result.put("status",new_status);
                  	}
                  	catch (e)
                  	{
                  		result.put("success",false);
                  		result.put("message","系統錯誤：" + e);
                  	}
				if(result.get("success") == true)
				{
					response_text = "1|OK";
				}
                  	return response_text;
                 }

map API.generatePersonalityProfile(string client_id)
                 {
                 	// =============================================================================
                 	// Creator API：生成個性側寫並寫回資料庫
                 	// 
                 	// 功能：根據個案的命理資料生成 AI 個性側寫，並將結果寫回 Personality_Profile 欄位
                 	// 用途：分離式架構中的個性側寫生成階段，為 SalesIQ 等待體驗提供內容
                 	// =============================================================================
                 	// 採用單一出口模式
                 	api_result = Map();
                 	try 
                 	{
                 		info "=== 開始生成個性側寫 API ===";
                 		info "個案 ID：" + client_id;
                 		// === 步驟 1：參數驗證 ===
                 		if(client_id == null || client_id == "")
                 		{
                 			api_result.put("success",false);
                 			api_result.put("error","個案 ID 不能為空");
                 			return api_result;
                 		}
                 		// === 步驟 2：調用核心函數生成個性側寫 ===
                 		personality_result = thisapp.AIInterpreter.generatePersonalityProfile(client_id);
                 		if(personality_result.get("success") == true)
                 		{
                 			// === 步驟 3：將個性側寫寫回資料庫 ===
                 			personality_profile = personality_result.get("personality_profile");
                 			character_count = personality_result.get("character_count");
                 			// 更新個案記錄
                 			client_id_long = client_id.toLong();
                 			info "查詢個案 ID (Long)：" + client_id_long;
                 			client_record = Clients_Report[ID == client_id_long];
                 			if(client_record != null)
                 			{
                 				info "找到個案記錄，準備更新個性側寫...";
                 				// 檢查命理資料是否計算完成
                 				if(client_record.Full_Bazi == null || client_record.Full_Bazi == "")
                 				{
                 					info "警告：八字資料尚未完成，但仍繼續更新個性側寫";
                 				}
                 				// 使用更明確的更新方式
                 				// 先嘗試直接更新
                 				client_record.Personality_Profile=personality_profile;
                 				// 再查詢一次確認是否寫入
                 				verify_record = Clients_Report[ID == client_id_long];
                 				if(verify_record.Personality_Profile == null || verify_record.Personality_Profile == "")
                 				{
                 					info "警告：第一次寫入失敗，嘗試使用 update 語法";
                 					// 使用 update 語法重試
                 					update Clients_Report[ID == client_id_long]
                 					[
                 						Personality_Profile=personality_profile
                 					];
                 					// 再次驗證
                 					final_verify = Clients_Report[ID == client_id_long];
                 					if(final_verify.Personality_Profile != null && final_verify.Personality_Profile != "")
                 					{
                 						info "個性側寫已成功寫入（使用 update 語法），字數：" + character_count.toString();
                 					}
                 					else
                 					{
                 						info "錯誤：個性側寫寫入失敗！";
                 					}
                 				}
                 				else
                 				{
                 					info "個性側寫已成功寫入（直接賦值），字數：" + character_count.toString();
                 				}
                 				api_result.put("success",true);
                 				api_result.put("personality_profile",personality_profile);
                 				api_result.put("character_count",character_count);
                 				api_result.put("message","個性側寫生成成功並已儲存");
                 			}
                 			else
                 			{
                 				api_result.put("success",false);
                 				api_result.put("error","找不到對應的個案記錄");
                 			}
                 		}
                 		else
                 		{
                 			// 核心函數執行失敗，直接回傳錯誤
                 			api_result.put("success",false);
                 			api_result.put("error",personality_result.get("error"));
                 		}
                 	}
                 	catch (e)
                 	{
                 		api_result.put("success",false);
                 		api_result.put("error","系統錯誤：" + e.toString());
                 		info "generatePersonalityProfile API 執行錯誤：" + e.toString();
                 	}
                 	return api_result;
                 }
map Bazi.calculatePreciseDayPillar(date solar_datetime)
                 {
                 	//
                 	// 函數名稱：calculatePreciseDayPillar
                 	// 命名空間：Bazi
                 	//
                 	// 功能描述：
                 	// 此為精確的日柱計算引擎。其核心原理是「干支紀日」，這是一個從古至今
                 	// 連續不斷的計數系統。本函數透過設定一個已知的「基準日」及其對應的干支，
                 	// 然後計算目標日期與基準日之間相差的天數，從而推導出目標日期的日柱干支。
                 	//
                 	// 核心邏輯：
                 	// 1. 設定一個基準日 `1930-01-06`，我們已知這一天是「丙辰」日。
                 	// 2. 「丙辰」在六十甲子中的索引是 52。
                 	// 3. 計算目標日期 `solar_datetime` 與基準日之間相差的總天數 `days_diff`。
                 	// 4. 透過公式 `(基準索引 + 天數差) % 60` 計算出目標日期在六十甲子循環中的新索引。
                 	// 5. 根據新的索引，分別推導出其天干與地支。
                 	//
                 	// 參數：
                 	//  @param {date} solar_datetime - 需要計算的國曆日期時間。
                 	//
                 	// 回傳：
                 	//  @return {map} - 一個包含日柱詳細資訊的 Map，也包含除錯資訊。
                 	//
                 	// 注意事項：
                 	//  - 日柱的計算嚴格按照國曆日期，不考慮子時換日的問題。子時換日僅影響八字的「日柱歸屬」，
                 	//    而日干支的連續計數本身不受影響。
                 	//
                 	result = Map();
                 	// 步驟 1: 呼叫中央常數函數，獲取天干地支列表。
                 	bazi_constants = thisapp.LunarAI.getBaziConstants();
                 	stemsList = bazi_constants.get("heavenly_stems");
                 	branchesList = bazi_constants.get("earthly_branches");
                 	// 日柱計算不考慮子時換日，嚴格按照傳入日期計算。
                 	calc_date = solar_datetime;
                 	// 步驟 2: 設定基準日和基準干支索引。
                 	// 我們選定 1930年1月6日 作為基準日，這一天是「丙辰」日。
                 	base_date = "1930-01-06".toDate("yyyy-MM-dd");
                 	base_ganzhi_index = 52;
                 	// 「丙辰」在六十甲子循環中的索引是 52。
                 	// 步驟 3: 計算目標日期與基準日之間相差的總天數。
                 	days_diff = base_date.daysBetween(calc_date);
                 	// 步驟 4: 計算目標日期在六十甲子循環中的新索引。
                 	ganzhi_index = (base_ganzhi_index + days_diff) % 60;
                 	// 處理負數餘數的情況 (如果目標日期早於基準日)。
                 	if(ganzhi_index < 0)
                 	{
                 		ganzhi_index = ganzhi_index + 60;
                 	}
                 	// 步驟 5: 根據新的干支索引，推導出天干和地支的各自索引。
                 	stem_index = ganzhi_index % 10;
                 	branch_index = ganzhi_index % 12;
                 	day_stem = stemsList.get(stem_index);
                 	day_branch = branchesList.get(branch_index);
                 	// 步驟 6: 組合並回傳最終結果。
                 	result.put("stem",day_stem);
                 	result.put("branch",day_branch);
                 	result.put("pillar",day_stem + day_branch);
                 	result.put("calc_date",calc_date.toString("yyyy-MM-dd"));
                 	result.put("days_diff",days_diff);
                 	result.put("ganzhi_index",ganzhi_index);
                 	result.put("base_date","1930-01-06");
                 	result.put("base_index",base_ganzhi_index);
                 	return result;
                 }
map Bazi.calculatePreciseHourPillar(date solar_datetime)
                 {
                 	//
                 	// 函數名稱：calculatePreciseHourPillar
                 	// 命名空間：Bazi
                 	//
                 	// 功能描述：
                 	// 此為精確的時柱計算引擎。它會根據使用者輸入的日期時間，先確定其所屬的
                 	// 「時辰地支」，然後結合「日柱天干」，使用「五鼠遁時」的規則來推導出「時柱天干」。
                 	//
                 	// 核心邏輯：
                 	// 1. 處理「夜子時」問題：如果出生時間在 23:00-23:59，計算時柱所依賴的「日干」必須是下一天的日干。
                 	// 2. 根據處理過的日期，呼叫日柱函數，取得正確的「日干」。
                 	// 3. 根據 24 小時制，將輸入的小時數，對應到十二地支時辰，確定「時支」。
                 	// 4. 根據日干，從一個固定的對照表（五鼠遁時）中查出子時的起始天干。
                 	// 5. 根據子時的起始天干和時支的順序，推算出「時干」。
                 	//
                 	// 參數：
                 	//  @param {date} solar_datetime - 需要計算的國曆日期時間。
                 	//
                 	// 回傳：
                 	//  @return {map} - 一個包含時柱詳細資訊的 Map，也包含除錯資訊。
                 	//
                 	result = Map();
                 	// 步驟 1: 呼叫中央常數函數，獲取所需常數。
                 	bazi_constants = thisapp.LunarAI.getBaziConstants();
                 	stemsList = bazi_constants.get("heavenly_stems");
                 	branchesList = bazi_constants.get("earthly_branches");
                 	hour_stem_map = bazi_constants.get("hour_stem_map");
                 	hour = solar_datetime.getHour();
                 	// 步驟 2: 處理「夜子時」換日干的特殊規則。
                 	// 如果出生時間是 23點 (夜子時)，則計算時柱天干所依據的日干，必須是下一天的日干。
                 	date_for_hour_calc = solar_datetime;
                 	if(hour >= 23)
                 	{
                 		date_for_hour_calc = solar_datetime.addDay(1);
                 	}
                 	// 步驟 3: 呼叫日柱函數，取得計算時柱所需要的正確「日干」。
                 	day_result = thisapp.Bazi.calculatePreciseDayPillar(date_for_hour_calc);
                 	if(day_result.containKey("error"))
                 	{
                 		result.put("error","日柱計算失敗：" + day_result.get("error"));
                 		return result;
                 	}
                 	day_stem = day_result.get("stem");
                 	// 步驟 4: 根據小時數，確定時辰地支及其索引。
                 	hour_branch_index = 0;
                 	time_period = "";
                 	if(hour >= 23 || hour < 1)
                 	{
                 		hour_branch_index = 0;
                 		time_period = "子時(23-01)";
                 	}
                 	else if(hour >= 1 && hour < 3)
                 	{
                 		hour_branch_index = 1;
                 		time_period = "丑時(01-03)";
                 	}
                 	else if(hour >= 3 && hour < 5)
                 	{
                 		hour_branch_index = 2;
                 		time_period = "寅時(03-05)";
                 	}
                 	else if(hour >= 5 && hour < 7)
                 	{
                 		hour_branch_index = 3;
                 		time_period = "卯時(05-07)";
                 	}
                 	else if(hour >= 7 && hour < 9)
                 	{
                 		hour_branch_index = 4;
                 		time_period = "辰時(07-09)";
                 	}
                 	else if(hour >= 9 && hour < 11)
                 	{
                 		hour_branch_index = 5;
                 		time_period = "巳時(09-11)";
                 	}
                 	else if(hour >= 11 && hour < 13)
                 	{
                 		hour_branch_index = 6;
                 		time_period = "午時(11-13)";
                 	}
                 	else if(hour >= 13 && hour < 15)
                 	{
                 		hour_branch_index = 7;
                 		time_period = "未時(13-15)";
                 	}
                 	else if(hour >= 15 && hour < 17)
                 	{
                 		hour_branch_index = 8;
                 		time_period = "申時(15-17)";
                 	}
                 	else if(hour >= 17 && hour < 19)
                 	{
                 		hour_branch_index = 9;
                 		time_period = "酉時(17-19)";
                 	}
                 	else if(hour >= 19 && hour < 21)
                 	{
                 		hour_branch_index = 10;
                 		time_period = "戌時(19-21)";
                 	}
                 	else if(hour >= 21 && hour < 23)
                 	{
                 		hour_branch_index = 11;
                 		time_period = "亥時(21-23)";
                 	}
                 	hour_branch = branchesList.get(hour_branch_index);
                 	// 步驟 5: 使用「五鼠遁時」規則，根據日干和時支，計算時干。
                 	hour_stem_start = hour_stem_map.get(day_stem);
                 	hour_stem_start_index = stemsList.indexOf(hour_stem_start);
                 	hour_stem_index = (hour_stem_start_index + hour_branch_index) % 10;
                 	hour_stem = stemsList.get(hour_stem_index);
                 	// 步驟 6: 組合並回傳最終結果。
                 	result.put("stem",hour_stem);
                 	result.put("branch",hour_branch);
                 	result.put("pillar",hour_stem + hour_branch);
                 	result.put("hour",hour);
                 	result.put("hour_branch_index",hour_branch_index);
                 	result.put("time_period",time_period);
                 	result.put("day_stem_for_reference",day_stem);
                 	result.put("hour_stem_start_for_reference",hour_stem_start);
                 	return result;
                 }
map Bazi.calculatePreciseMonthPillar(date solar_datetime)
                 {
                 	//
                 	// 函數名稱：calculatePreciseMonthPillar
                 	// 命名空間：Bazi
                 	//
                 	// 功能描述：
                 	// 此為基於「節氣」的精確月柱計算引擎。它會根據使用者輸入的國曆日期時間，
                 	// 查找在此時間點之前的、最近的一個「節」，並以此「節」來確定八字的月份地支。
                 	// 然後，它會結合年柱的天干，使用「五虎遁月」的規則來計算出月份的天干。
                 	//
                 	// 核心邏輯：
                 	// 1. 呼叫年柱函數，取得年柱的天干。
                 	// 2. 為了處理跨年問題（例如一月份的生日，其月柱節氣可能落在前一年十二月），程式會先查找當年，若找不到再查找前一年。
                 	// 3. 遍歷查詢到的節氣，找到在輸入時間點之前、且最接近的一個節氣記錄。
                 	// 4. 根據找到的節氣，從一個固定的對照表中查出對應的「月支」。
                 	// 5. 根據年干和月支的順序，使用「五虎遁月」規則推算出「月干」。
                 	//
                 	// 參數：
                 	//  @param {date} solar_datetime - 需要計算的國曆日期時間。
                 	//
                 	// 回傳：
                 	//  @return {map} - 一個包含月柱詳細資訊的 Map，也包含除錯資訊。
                 	//
                 	// 相依性：
                 	//  - Bazi.calculatePreciseYearPillar()
                 	//  - LunarAI.getBaziConstants()
                 	//  - 表單 `SolarTerms`
                 	//
                 	result = Map();
                 	// 步驟 1: 呼叫中央常數函數，獲取所需常數。
                 	bazi_constants = thisapp.LunarAI.getBaziConstants();
                 	stemsList = bazi_constants.get("heavenly_stems");
                 	branchesList = bazi_constants.get("earthly_branches");
                 	month_stem_map = bazi_constants.get("month_stem_map");
                 	// 步驟 2: 依賴年柱的計算結果來確定月干，所以先呼叫年柱函數。
                 	year_result = thisapp.Bazi.calculatePreciseYearPillar(solar_datetime);
                 	if(year_result.containKey("error"))
                 	{
                 		result.put("error","年柱計算失敗：" + year_result.get("error"));
                 		return result;
                 	}
                 	year_stem = year_result.get("stem");
                 	// 步驟 3: 建立節氣到月份地支的對照表。
                 	solar_term_month_map = Map();
                 	solar_term_month_map.put("立春","寅");
                 	solar_term_month_map.put("雨水","寅");
                 	solar_term_month_map.put("驚蟄","卯");
                 	solar_term_month_map.put("春分","卯");
                 	solar_term_month_map.put("清明","辰");
                 	solar_term_month_map.put("穀雨","辰");
                 	solar_term_month_map.put("立夏","巳");
                 	solar_term_month_map.put("小滿","巳");
                 	solar_term_month_map.put("芒種","午");
                 	solar_term_month_map.put("夏至","午");
                 	solar_term_month_map.put("小暑","未");
                 	solar_term_month_map.put("大暑","未");
                 	solar_term_month_map.put("立秋","申");
                 	solar_term_month_map.put("處暑","申");
                 	solar_term_month_map.put("白露","酉");
                 	solar_term_month_map.put("秋分","酉");
                 	solar_term_month_map.put("寒露","戌");
                 	solar_term_month_map.put("霜降","戌");
                 	solar_term_month_map.put("立冬","亥");
                 	solar_term_month_map.put("小雪","亥");
                 	solar_term_month_map.put("大雪","子");
                 	solar_term_month_map.put("冬至","子");
                 	solar_term_month_map.put("小寒","丑");
                 	solar_term_month_map.put("大寒","丑");
                 	// 步驟 4: 查詢在輸入時間點之前、最近的節氣。
                 	// 子時換日政策：23:00–23:59 視為隔日（A）
                 	effective_dt = solar_datetime;
                 	try
                 	{
                 		norm = thisapp.Calendar.normalizeToTaipei(solar_datetime);
                 		if(norm.get("success"))
                 		{
                 			zr = thisapp.Calendar.applyZiHourDayRollover(norm.get("value"));
                 			if(zr.get("success"))
                 			{
                 				effective_dt = zr.get("value");
                 			}
                 		}
                 	}
                 	catch(_e)
                 	{
                 		// 若 Calendar helpers 尚未部署，保持向後相容
                 		effective_dt = solar_datetime;
                 	}
                 	target_year = effective_dt.getYear();
                 	// 撈取節氣資料（效能優化）：只抓 effective_dt 前一年內的節氣，再從中找出 <= effective_dt 的最近者。
                 	// 規則不變：仍然是「effective_dt 之前最近的節氣」。
                 	latest_term = null;
                 	latest_term_datetime = null;
                 	// 節氣每年 24 筆；為保守處理跨年邊界與（你提醒的）閏月/資料偏移風險，
                 	// 取較大的回溯窗口：450 天（規則不變，只是縮小查詢集合的方式）。
                 	window_start = effective_dt.addDay(-450);
                 	// 先用時間範圍縮小查詢集合，避免 SolarTerms 全表掃描造成 loading。
                 	terms_window = SolarTerms[Solar_Term_DateTime >= window_start && Solar_Term_DateTime <= effective_dt];
                 	// 若資料異常導致查不到（例如 SolarTerms 資料不完整），才退回全表掃描（保守且向後相容）。
                 	if(terms_window == null || terms_window.count() == 0)
                 	{
                 		terms_window = SolarTerms[ID != 0];
                 	}
                 	for each  record in terms_window
                 	{
                 		if(record.Solar_Term_DateTime != null)
                 		{
                 			// 注意：這裡不再以年份篩選，完全依照時間窗與 <= effective_dt 來決定「最近節氣」。
                 			if(record.Solar_Term_DateTime <= effective_dt)
                 			{
                 				if(latest_term_datetime == null || record.Solar_Term_DateTime > latest_term_datetime)
                 				{
                 					latest_term = record.Solar_Term_Name;
                 					latest_term_datetime = record.Solar_Term_DateTime;
                 				}
                 			}
                 		}
                 	}
                 	// 步驟 5: 確認是否成功找到了節氣。
                 	if(latest_term == null)
                 	{
                 		result.put("error","無法確定節氣月份");
                 		return result;
                 	}
                 	month_branch = solar_term_month_map.get(latest_term);
                 	if(month_branch == null)
                 	{
                 		result.put("error","節氣" + latest_term + "無對應月份");
                 		return result;
                 	}
                 	// 步驟 6: 使用「五虎遁月」規則，根據年干和月支，計算月干。
                 	month_stem_start = month_stem_map.get(year_stem);
                 	month_stem_start_index = stemsList.indexOf(month_stem_start);
                 	// 寅月是每年的第一個命理月。
                 	month_order = {"寅","卯","辰","巳","午","未","申","酉","戌","亥","子","丑"};
                 	month_branch_index = month_order.indexOf(month_branch);
                 	month_stem_index = (month_stem_start_index + month_branch_index) % 10;
                 	month_stem = stemsList.get(month_stem_index);
                 	// 步驟 7: 組合並回傳最終結果。
                 	result.put("stem",month_stem);
                 	result.put("branch",month_branch);
                 	result.put("pillar",month_stem + month_branch);
                 	result.put("solar_term",latest_term);
                 	result.put("solar_term_datetime",latest_term_datetime.toString("yyyy-MM-dd HH:mm:ss"));
                 	result.put("year_stem_for_reference",year_stem);
                 	return result;
                 }
map Bazi.calculatePreciseYearPillar(date solar_datetime)
                 {
                 	//
                 	// 函數名稱：calculatePreciseYearPillar
                 	// 命名空間：Bazi
                 	//
                 	// 功能描述：
                 	// 此為基於「節氣」的精確年柱計算引擎。它會根據使用者輸入的國曆日期時間，
                 	// 與 `SolarTerms` 表中記錄的精確「立春」時間進行比較，從而判斷出最準確的八字年份，
                 	// 並計算出對應的年柱（天干地支）。
                 	//
                 	// 核心邏輯：
                 	// 1. 先從 `SolarTerms` 表中撈出所有名為 "立春" 的記錄。
                 	// 2. 在記憶體中遍歷，找到與目標年份完全匹配的那一筆立春記錄。
                 	// 3. 如果輸入時間早於「立春」，則其八字年份應算作上一年。
                 	// 4. 確認八字年份後，以 1900 庚子年為基準，透過數學運算得出該年的天干與地支。
                 	//
                 	// 參數：
                 	//  @param {date} solar_datetime - 需要計算的國曆日期時間。
                 	//
                 	// 回傳：
                 	//  @return {map} - 一個包含年柱詳細資訊的 Map，也包含除錯資訊。
                 	//
                 	// 相依性：
                 	//  - 表單 `SolarTerms` 必須存在且包含精確的立春資料。
                 	//  - 函數 `LunarAI.getBaziConstants()` 用於獲取天干地支列表。
                 	//
                 	result = Map();
                 	// 步驟 1: 呼叫中央常數函數，獲取天干地支列表。
                 	bazi_constants = thisapp.LunarAI.getBaziConstants();
                 	stemsList = bazi_constants.get("heavenly_stems");
                 	branchesList = bazi_constants.get("earthly_branches");
                 	solar_year = solar_datetime.getYear();
                 	// 步驟 2: 查詢立春資料（效能優化）。
                 	// 規則不變：仍以「立春的精確時間」作為年柱切換點。
                 	// 作法：先用時間窗縮小查詢集合（約前後 60 天內），避免撈出全部年份的立春記錄。
                 	lichun_datetime = null;
                 	try
                 	{
                 		window_start = solar_datetime.addDay(-60);
                 		window_end = solar_datetime.addDay(60);
                 		lichun_window = SolarTerms[Solar_Term_Name == "立春" && Solar_Term_DateTime >= window_start && Solar_Term_DateTime <= window_end];
                 		if(lichun_window != null && lichun_window.count() > 0)
                 		{
                 			for each  record in lichun_window
                 			{
                 				if(record.Solar_Term_DateTime != null)
                 				{
                 					// 取時間窗內最新的一筆（通常就 1 筆），避免排序依賴
                 					if(lichun_datetime == null || record.Solar_Term_DateTime > lichun_datetime)
                 					{
                 						lichun_datetime = record.Solar_Term_DateTime;
                 					}
                 				}
                 			}
                 		}
                 	}
                 	catch(_e_lichun)
                 	{
                 		lichun_datetime = null;
                 	}
                 	// 保守回退：若時間窗查不到，仍使用原本的全表方式（向後相容）
                 	if(lichun_datetime == null)
                 	{
                 		lichun_records = SolarTerms[Solar_Term_Name == "立春"];
                 		if(lichun_records.count() == 0)
                 		{
                 			result.put("error","找不到" + solar_year + "年的立春資料");
                 			return result;
                 		}
                 		for each  record in lichun_records
                 		{
                 			if(record.Solar_Term_DateTime != null)
                 			{
                 				if(record.Solar_Term_DateTime.getYear() == solar_year)
                 				{
                 					lichun_datetime = record.Solar_Term_DateTime;
                 					break;
                 				}
                 			}
                 		}
                 		if(lichun_datetime == null)
                 		{
                 			result.put("error","找不到" + solar_year + "年的立春資料");
                 			return result;
                 		}
                 	}
                 	// 步驟 3: 判斷八字年份。
                 	// 子時換日政策：23:00–23:59 視為隔日（A），避免立春前後邊界錯誤
                 	effective_dt_for_year = solar_datetime;
                 	try
                 	{
                 		norm_y = thisapp.Calendar.normalizeToTaipei(solar_datetime);
                 		if(norm_y.get("success"))
                 		{
                 			zr_y = thisapp.Calendar.applyZiHourDayRollover(norm_y.get("value"));
                 			if(zr_y.get("success"))
                 			{
                 				effective_dt_for_year = zr_y.get("value");
                 			}
                 		}
                 	}
                 	catch(_e_y)
                 	{
                 		effective_dt_for_year = solar_datetime;
                 	}
                 	bazi_year = solar_year;
                 	if(effective_dt_for_year < lichun_datetime)
                 	{
                 		bazi_year = solar_year - 1;
                 	}
                 	// 步驟 4: 計算年干支，使用 1900 年（庚子年）作為基準點。
                 	year_offset = bazi_year - 1900;
                 	stem_index = (6 + year_offset) % 10;
                 	// 庚 = 6
                 	if(stem_index < 0)
                 	{
                 		stem_index = stem_index + 10;
                 	}
                 	branch_index = (0 + year_offset) % 12;
                 	// 子 = 0
                 	if(branch_index < 0)
                 	{
                 		branch_index = branch_index + 12;
                 	}
                 	year_stem = stemsList.get(stem_index);
                 	year_branch = branchesList.get(branch_index);
                 	// 步驟 5: 組合並回傳最終結果，包含詳細的除錯資訊。
                 	result.put("stem",year_stem);
                 	result.put("branch",year_branch);
                 	result.put("pillar",year_stem + year_branch);
                 	result.put("bazi_year",bazi_year);
                 	result.put("lichun_datetime",lichun_datetime.toString("yyyy-MM-dd HH:mm:ss"));
                 	result.put("year_offset",year_offset);
                 	return result;
                 }
map Bazi.getDivinationTimeDetails()
                 {
                 	//
                 	// 函數名稱：getDivinationTimeDetails
                 	// 命名空間：Bazi
                 	//
                 	// 功能描述：
                 	// 此函數是一個方便的工具，專門用於獲取「當前」伺服器時間點的完整命理資訊。
                 	// 它會自動抓取當前時間，並依序呼叫所有必要的農曆和八字計算函數，
                 	// 最後將所有結果組合到一個大的 Map 中回傳。
                 	//
                 	// 使用情境：
                 	// 當需要在占卜或紀錄的當下，即時產生一組完整的時間命盤時，可直接呼叫此函數。
                 	//
                 	// 核心邏輯：
                 	// 1. 使用 `zoho.currenttime` 獲取當前伺服器時間。
                 	// 2. 呼叫 `LunarAI.calculateLunarDetails` 計算當下的完整農曆資訊。
                 	// 3. 依序呼叫 `Bazi.calculatePrecise...` 系列函數，計算出完整的四柱八字。
                 	// 4. 將農曆資訊和四柱資訊全部放入一個 Map 中並回傳。
                 	//
                 	// 參數：
                 	//  - 無
                 	//
                 	// 回傳：
                 	//  @return {map} - 一個包含當下時間點的完整農曆和八字資訊的 Map。
                 	//
                 	// 步驟 1: 獲取共享的農曆常數資料庫。
                 	lunar_constants = thisapp.LunarData.getConstants();
                 	// 步驟 2: 獲取當前伺服器時間作為占卜時間點。
                 	now_datetime = zoho.currenttime;
                 	// 子時換日政策（A）：23:00–23:59 視為隔日，確保節氣/日柱邊界一致
                 	effective_now = now_datetime;
                 	try
                 	{
                 		norm_now = thisapp.Calendar.normalizeToTaipei(now_datetime);
                 		if(norm_now.get("success"))
                 		{
                 			zr_now = thisapp.Calendar.applyZiHourDayRollover(norm_now.get("value"));
                 			if(zr_now.get("success"))
                 			{
                 				effective_now = zr_now.get("value");
                 			}
                 		}
                 	}
                 	catch(_e_now)
                 	{
                 		effective_now = now_datetime;
                 	}
                 	// 步驟 3: 呼叫核心引擎，計算占卜日的農曆資訊。
                 	divination_lunar_map = thisapp.LunarAI.calculateLunarDetails(effective_now,lunar_constants);
                 	// 步驟 4: 呼叫精確計算函數取得完整四柱八字資訊。
                 	year_pillar = thisapp.Bazi.calculatePreciseYearPillar(effective_now);
                 	month_pillar = thisapp.Bazi.calculatePreciseMonthPillar(effective_now);
                 	day_pillar = thisapp.Bazi.calculatePreciseDayPillar(effective_now);
                 	hour_pillar = thisapp.Bazi.calculatePreciseHourPillar(effective_now);
                 	// 步驟 5: 組合最終結果。
                 	final_result = Map();
                 	// 先放入所有農曆資訊 (如 lunar_year, lunar_month, is_leap_month 等)。
                 	final_result.putAll(divination_lunar_map);
                 	// 再分別放入四柱的詳細結果 Map。
                 	final_result.put("year_pillar_details",year_pillar);
                 	final_result.put("month_pillar_details",month_pillar);
                 	final_result.put("day_pillar_details",day_pillar);
                 	final_result.put("hour_pillar_details",hour_pillar);
                 	return final_result;
                 }
map Bazi.PreciseBaziCalculator(date solar_datetime)
                 {
                 	//
                 	// 函數名稱：PreciseBaziCalculator
                 	// 命名空間：Bazi
                 	//
                 	// 功能描述：
                 	// 此為整個八字計算系統的「總裝引擎」。其職責是依序呼叫年、月、日、時
                 	// 四個獨立的支柱計算函數，並將它們的結果組合成一個完整、詳細的八字資訊 Map。
                 	// 這是從外部系統（如 CRM 同步函數）呼叫八字功能時的主要入口。
                 	//
                 	// 核心邏輯：
                 	// 1. 依序呼叫 calculatePreciseYearPillar, calculatePreciseMonthPillar, 
                 	//    calculatePreciseDayPillar, calculatePreciseHourPillar。
                 	// 2. 在每次呼叫後，檢查回傳結果是否包含 "error" 鍵，若有則立即中斷並回傳錯誤。
                 	// 3. 將所有計算結果（包括各柱的詳細資訊）組合到一個最終的 Map 中。
                 	// 4. 使用 try-catch 區塊來捕捉整個計算過程中可能發生的任何預期外錯誤。
                 	//
                 	// 參數：
                 	//  @param {date} solar_datetime - 需要計算的國曆日期時間。
                 	//
                 	// 回傳：
                 	//  @return {map} - 一個包含完整八字資訊及計算狀態的 Map。
                 	//    - "success": (boolean) 計算是否成功。
                 	//    - "完整八字": (string) "年柱 月柱 日柱 時柱" 格式的完整八字。
                 	//    - "年柱", "月柱", "日柱", "時柱": (string) 各個支柱的干支。
                 	//    - "年柱詳情", "月柱詳情", "日柱詳情", "時柱詳情": (map) 各個計算函數回傳的詳細 Map。
                 	//    - "error": (string) 如果出錯，則包含錯誤訊息。
                 	//
                 	info "=== 開始精確八字計算 ===";
                 	info "輸入時間：" + solar_datetime.toString("yyyy-MM-dd HH:mm:ss");
                 	result_map = Map();
                 	// 建立天干地支對照表 (雖然子函數中也會呼叫，但此處保留是為了潛在的直接使用)
                 	stemsList = {"甲","乙","丙","丁","戊","己","庚","辛","壬","癸"};
                 	branchesList = {"子","丑","寅","卯","辰","巳","午","未","申","酉","戌","亥"};
                 	try 
                 	{
                 		// ========== 1. 計算年柱 ==========
                 		info "計算年柱...";
                 		year_result = thisapp.Bazi.calculatePreciseYearPillar(solar_datetime);
                 		if(year_result.containKey("error"))
                 		{
                 			result_map.put("error","年柱計算失敗：" + year_result.get("error"));
                 			return result_map;
                 		}
                 		info "年柱：" + year_result.get("pillar") + " (八字年：" + year_result.get("bazi_year") + ")";
                 		// ========== 2. 計算月柱 ==========
                 		info "計算月柱...";
                 		month_result = thisapp.Bazi.calculatePreciseMonthPillar(solar_datetime);
                 		if(month_result.containKey("error"))
                 		{
                 			result_map.put("error","月柱計算失敗：" + month_result.get("error"));
                 			return result_map;
                 		}
                 		info "月柱：" + month_result.get("pillar") + " (節氣：" + month_result.get("solar_term") + ")";
                 		// ========== 3. 計算日柱 ==========
                 		info "計算日柱...";
                 		day_result = thisapp.Bazi.calculatePreciseDayPillar(solar_datetime);
                 		if(day_result.containKey("error"))
                 		{
                 			result_map.put("error","日柱計算失敗：" + day_result.get("error"));
                 			return result_map;
                 		}
                 		info "日柱：" + day_result.get("pillar") + " (距基準：" + day_result.get("days_diff") + "天)";
                 		// ========== 4. 計算時柱 ==========
                 		info "計算時柱...";
                 		hour_result = thisapp.Bazi.calculatePreciseHourPillar(solar_datetime);
                 		if(hour_result.containKey("error"))
                 		{
                 			result_map.put("error","時柱計算失敗：" + hour_result.get("error"));
                 			return result_map;
                 		}
                 		info "時柱：" + hour_result.get("pillar") + " (" + hour_result.get("hour") + "點 = " + hour_result.get("time_period") + ")";
                 		// ========== 5. 組合最終結果 ==========
                 		complete_bazi = year_result.get("pillar") + " " + month_result.get("pillar") + " " + day_result.get("pillar") + " " + hour_result.get("pillar");
                 		result_map.put("success",true);
                 		result_map.put("input_datetime",solar_datetime.toString("yyyy-MM-dd HH:mm:ss"));
                 		result_map.put("年柱",year_result.get("pillar"));
                 		result_map.put("月柱",month_result.get("pillar"));
                 		result_map.put("日柱",day_result.get("pillar"));
                 		result_map.put("時柱",hour_result.get("pillar"));
                 		result_map.put("完整八字",complete_bazi);
                 		// 詳細計算資訊
                 		result_map.put("年柱詳情",year_result);
                 		result_map.put("月柱詳情",month_result);
                 		result_map.put("日柱詳情",day_result);
                 		result_map.put("時柱詳情",hour_result);
                 		info "=== 八字計算完成 ===";
                 		info "完整八字：" + complete_bazi;
                 	}
                 	catch (e)
                 	{
                 		result_map.put("error","八字計算過程發生錯誤：" + e);
                 		result_map.put("success",false);
                 		info "❌ 計算錯誤：" + e;
                 	}
                 	return result_map;
                 }
void CRM.syncContact(map contact_data)
                 {
                 	/*
                  * 函數名稱: CRM.syncContact.deluge
                  *
                  * 描述: 
                  * 此函數是將任何來源 (例如 SimplyBook, EasyStore, Creator 表單) 的客戶資料同步到 Zoho CRM 的中央處理樞紐。
                  * 它會根據客戶的 Email 地址，智慧地處理新增聯絡人，以及更新現有聯絡人的操作。
                  *
                  * 主要執行操作:
                  * 1. 接收一個包含客戶資料的 map。
                  * 2. 使用 Email 地址在 Zoho CRM 中搜尋現有聯絡人。
                  * 3. 如果資料中包含生日時間，它會呼叫多個 "LunarAI" 相關函數，來計算命理資訊 (農曆生日、八字、太歲等)。
                  * 4. 使用正確的 API 名稱，將提供的和計算出的資訊，填入一個準備傳送給 CRM 的資料 map 中。
                  * 5. 處理「生日」欄位的差異：同時填入 CRM 原生的「日期」欄位，以及我們自訂的「日期/時間」欄位。
                  * 6. 如果聯絡人不存在，則建立一筆新紀錄；如果已存在，則更新現有紀錄。
                  * 7. 回傳 Zoho CRM API 的執行結果。
                  *
                  * 參數:
                  * @param {map} contact_data - 包含客戶資訊的 map。必要鍵值: "Email"。
                  *   可選鍵值: "First_Name", "Last_Name", "Phone", "Precise_Birth_Time", "Timezone", "Lead_Source", "Membership_Level"。
                  *
                  * 回傳:
                  * @return {map} - Zoho CRM API (createRecord 或 updateRecord) 的回傳 map。
                  */
                 	// --- 1. 輸入驗證 ---
                 	if(contact_data.get("Email") == null)
                 	{
                 		// Email 是同步的必要條件。回傳一個錯誤 map。
                 		error_map = {"status":"error","message":"輸入資料中缺少 Email。"};
                 		info error_map;
                 		return;
                 	}
                 	// --- 2. 準備資料並搜尋 CRM ---
                 	email = contact_data.get("Email");
                 	// 在 CRM 中搜尋此聯絡人是否已存在。
                 	// 我們使用先前建立的 "zohocrm" 連接器。
                 	// 在最新的 Deluge 版本中，連接器必須作為 map 傳遞。
                 	search_response = zoho.crm.searchRecords("Contacts","(Email:equals:" + email + ")",1,1,{"connection":"zohocrm"});
                 	info "CRM 搜尋結果: " + search_response;
                 	// 這個 map 將存放所有我們想傳送到 CRM 的資料。
                 	crm_data_map = Map();
                 	// --- 3. 填入 CRM 資料 Map ---
                 	// 基本資訊
                 	crm_data_map.put("Email",email);
                 	// 在 Zoho CRM 中, Last Name (姓氏) 是必填欄位。
                 	if(contact_data.get("Last_Name") != null)
                 	{
                 		crm_data_map.put("Last_Name",contact_data.get("Last_Name"));
                 	}
                 	else
                 	{
                 		// 如果沒有提供 Last Name，則使用 Email 的 @ 前綴作為佔位符。
                 		crm_data_map.put("Last_Name",email.getPrefix("@"));
                 	}
                 	if(contact_data.get("First_Name") != null)
                 	{
                 		crm_data_map.put("First_Name",contact_data.get("First_Name"));
                 	}
                 	if(contact_data.get("Phone") != null)
                 	{
                 		crm_data_map.put("Phone",contact_data.get("Phone"));
                 	}
                 	// 營運標籤 - 使用我們設定好的 API 名稱。
                 	if(contact_data.get("Lead_Source") != null)
                 	{
                 		crm_data_map.put("Lead_Source",contact_data.get("Lead_Source"));
                 	}
                 	if(contact_data.get("Membership_Level") != null)
                 	{
                 		crm_data_map.put("Membership_Level",contact_data.get("Membership_Level"));
                 	}
                 	// --- 4. 計算並填入命理資訊 ---
                 	if(contact_data.containKey("Precise_Birth_Time"))
                 	{
                 		precise_birth_time = contact_data.get("Precise_Birth_Time");
                 		// 處理「雙欄位」生日策略
                 		crm_data_map.put("Precise_Birth_Time",precise_birth_time);
                 		crm_data_map.put("Date_of_Birth",precise_birth_time.toDate());
                 		// 時區
                 		if(contact_data.get("Timezone") != null)
                 		{
                 			crm_data_map.put("Timezone",contact_data.get("Timezone"));
                 		}
                 		// --- 呼叫我們現有的 AI 函數以獲取計算資料 ---
                 		// 根據使用者指示，使用正確的、精確的計算函數。
                 		complete_bazi_data = thisapp.Bazi.PreciseBaziCalculator(precise_birth_time);
                 		if(complete_bazi_data != null)
                 		{
                 			// 使用真實的 key，將從八字函數回傳的資料填入 map。
                 			// 完整八字字串的 key 是 "完整八字"。
                 			crm_data_map.put("Bazi_Pillars",complete_bazi_data.get("完整八字"));
                 			// 我們需要獲取農曆生日字串。假設它從 SolarToLunar 或類似函數中回傳。
                 			// 假設 key 是 "lunar_date_string"。如果不是，我們需要在 PreciseBaziCalculator 的回傳 map 中加入它。
                 			lunar_data = thisapp.LunarAI.SolarToLunar(precise_birth_time);
                 			if(lunar_data.containKey("lunar_date_string"))
                 			{
                 				crm_data_map.put("Lunar_Birthday",lunar_data.get("lunar_date_string"));
                 			}
                 			// 計算太歲狀態
                 			// 這需要生年地支，我們可以從詳細的 map 中獲取。
                 			year_pillar_details = complete_bazi_data.get("年柱詳情");
                 			if(year_pillar_details != null)
                 			{
                 				// getTaisuiStatus 函數需要兩個參數:
                 				// 1. 個案的生年地支。
                 				// 2. 用於比較的當年地支。
                 				person_year_branch = year_pillar_details.get("branch");
                 				// 計算當年地支。
                 				current_year_pillar = thisapp.Bazi.calculatePreciseYearPillar(zoho.currentdate);
                 				current_year_branch = current_year_pillar.get("branch");
                 				// 用兩個參數呼叫函數。
                 				taisui_status = thisapp.Zodiac.getTaisuiStatus(person_year_branch,current_year_branch);
                 				crm_data_map.put("Taisui_Status",taisui_status);
                 			}
                 		}
                 		// 計算本命塔羅 - 此函數需要後續建立。
                 		// 假設它接收國曆生日作為輸入。
                 		life_path_tarot = thisapp.Tarot.getLifePathTarot(precise_birth_time);
                 		crm_data_map.put("Life_Path_Tarot",life_path_tarot);
                 	}
                 	// --- 5. 執行建立或更新 ---
                 	if(search_response.size() > 0)
                 	{
                 		// --- 更新現有聯絡人 ---
                 		contact_id_string = search_response.get(0).get("id");
                 		info "正在更新現有聯絡人. ID: " + contact_id_string;
                 		// 在傳遞給更新函數前，將 ID 從 string 轉換為 long (對應 BIGINT)。
                 		contact_id_long = contact_id_string.toLong();
                 		update_response = zoho.crm.updateRecord("Contacts",contact_id_long,crm_data_map,{"connection":"zohocrm"});
                 		info "CRM 更新結果: " + update_response;
                 	}
                 	else
                 	{
                 		// --- 建立新聯絡人 ---
                 		info "正在建立新聯絡人.";
                 		create_response = zoho.crm.createRecord("Contacts",crm_data_map,{"connection":"zohocrm"});
                 		info "CRM 建立結果: " + create_response;
                 	}
                 }
string ECPay.generateCheckMacValue_private(map params, string hashKey, string hashIV)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：產生綠界 ECPay API 所需的 CheckMacValue 簽章
                 	// 版本：5.1 (Syntax Fix)
                 	// 日期：2024-08-05
                 	//
                 	// 邏輯 (v5.1 修正)：
                 	// 根據 ECPay 官方文件，加密流程是將【整串字串】進行 URL Encode，
                 	// 但其後台 .NET 的 UrlEncode 行為與 Zoho Deluge 有細微差異，必須手動模擬。
                 	// 1. 組合未編碼的完整字串。
                 	// 2. 對完整字串進行 Zoho URL Encode。
                 	// 3. 根據 ECPay 文件，手動修正編碼差異，以模擬 .NET 的行為。
                 	// 4. 將修正後的字串轉為小寫。
                 	// 5. 使用 SHA256 加密，並將結果轉為大寫。
                 	//
                 	// @param params (map)：要加入簽章計算的參數集合。
                 	// @param hashKey (string)：綠界後台設定的 HashKey。
                 	// @param hashIV (string)：綠界後台設定的 HashIV。
                 	// @return (string)：計算完成的 CheckMacValue。
                 	//
                 	// 1. 將 map 的 keys 取出並進行字母排序
                 	paramKeys = params.keys();
                 	paramKeys.sort(true);
                 	// 2. 組合排序後的參數字串 (不進行任何編碼)
                 	paramString = "";
                 	for each  key in paramKeys
                 	{
                 		value = params.get(key);
                 		if(value != null)
                 		{
                 			valueStr = value.toString();
                 			if(valueStr != "")
                 			{
                 				paramString = paramString + key + "=" + valueStr + "&";
                 			}
                 		}
                 	}
                 	paramString = paramString.substring(0,paramString.length() - 1);
                 	// 3. 加上 HashKey 和 HashIV
                 	checkString = "HashKey=" + hashKey + "&" + paramString + "&HashIV=" + hashIV;
                 	// 4. 對完整的字串進行 Zoho 的 URL Encode
                 	encodedString = zoho.encryption.urlEncode(checkString);
                 	// 5. 【關鍵修正】手動模擬 ECPay(.NET) 的 UrlEncode 行為
                 	fixedString = encodedString.replaceAll("%20","+").replaceAll("%5f","_").replaceAll("%2e",".").replaceAll("%21","!").replaceAll("%2a","*").replaceAll("%28","(").replaceAll("%29",")").replaceAll("%27","'").replaceAll("%2f","/").replaceAll("%3a",":");
                 	// 6. 轉為小寫
                 	lowerCaseString = fixedString.toLowerCase();
                 	// 7. 使用 SHA256 加密並-將結果轉為大寫
                 	checkMacValue = zoho.encryption.sha256(lowerCaseString).toUpperCase();
                 	return checkMacValue;
                 }
string ECPay.generateCheckoutConfirmationPage(map orderDetails)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：產生一個给客戶看的、包含完整中文訂單資訊的「付款確認頁」
                 	// 版本：1.1 (Syntax Fix)
                 	// 日期：2024-08-05
                 	//
                 	// 邏輯:
                 	// 1. 接收一個包含完整訂單資訊的 map (含中文)。
                 	// 2. 準備一份「給機器看的」、純英文的 map，用於計算簽章。
                 	// 3. 呼叫 thisapp.ECPay.generateCheckMacValue_private 計算出正確的簽章。
                 	// 4. 產生一段 HTML，其中：
                 	//    - 「給人看」的部分，使用傳入的中文訂單資訊，清晰地展示給客戶。
                 	//    - 「給機器算」的部分，被藏在一個 JavaScript 函式中，當客戶點擊按鈕時，
                 	//      這個 JS 會動態建立一個 form，並填入純英文的內容和正確的簽章，然後提交到綠界。
                 	//
                 	// @param orderDetails (map): 包含客戶看到的完整訂單資訊
                 	//     - itemName (string): "開運符令 x 1"
                 	//     - tradeDesc (string): "AI靈學占卜服務-測試訂單"
                 	//     - totalAmount (number): 1
                 	//
                 	// @return (string): 一段完整的、可獨立運作的 HTML 頁面。
                 	//
                 	// --- 1. 準備「給機器看」的參數 ---
                 	paramsForECPay = Map();
                 	merchantID = if(thisapp.variables.ECPay.merchantID != null,thisapp.variables.ECPay.merchantID.toString(),"");
                 	hashKey = if(thisapp.variables.ECPay.hashKey != null,thisapp.variables.ECPay.hashKey.toString(),"");
                 	hashIV = if(thisapp.variables.ECPay.hashIV != null,thisapp.variables.ECPay.hashIV.toString(),"");
                 	tradeNo = "LAI" + zoho.currenttime.toString("yyyyMMddHHmmss");
                 	tradeDate = zoho.currenttime.toString("yyyy/MM/dd HH:mm:ss");
                 	checkoutUrl = "https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5";
                 	paramsForECPay.put("MerchantID",merchantID);
                 	paramsForECPay.put("MerchantTradeNo",tradeNo);
                 	paramsForECPay.put("MerchantTradeDate",tradeDate);
                 	paramsForECPay.put("PaymentType","aio");
                 	paramsForECPay.put("TotalAmount",orderDetails.get("totalAmount"));
                 	// 讀取 Public Key 並組合 returnURL
                 	publicKey = if(thisapp.variables.ECPay.PublicKey != null,thisapp.variables.ECPay.PublicKey.toString(),"");
                 	defaultReturnURL = "https://ecpay-webhook-proxy-ptmk.vercel.app/api/webhook";
                 	// 使用傳入的 returnURL，如果沒有則使用含 Public Key 的預設值
                 	returnURL = if(orderDetails.get("returnURL") != null,orderDetails.get("returnURL"),defaultReturnURL);
                 	paramsForECPay.put("ReturnURL",returnURL);
                 	paramsForECPay.put("ClientBackURL","https://www.google.com");
                 	paramsForECPay.put("ChoosePayment","Credit");
                 	paramsForECPay.put("EncryptType",1);
                 	// 使用純英文內容進行簽章
                 	paramsForECPay.put("ItemName","AI-Divination-Service");
                 	paramsForECPay.put("TradeDesc","Item based on " + tradeNo);
                 	// --- 2. 計算 CheckMacValue ---
                 	checkMacValue = thisapp.ECPay.generateCheckMacValue_private(paramsForECPay,hashKey,hashIV);
                 	// 將簽章加入到要提交的參數中
                 	paramsForECPay.put("CheckMacValue",checkMacValue);
                 	// 將完整的參數 map 轉為 JSON 字串，以便嵌入到 HTML 的 JS 中
                 	paramsJson = paramsForECPay.toString();
                 	// --- 3. 產生 HTML 確認頁 ---
                 	html = "<!DOCTYPE html><html lang=\"zh-Hant\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>訂單確認</title><style>body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background-color: #f8f9fa; } .container { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); text-align: center; max-width: 400px; width: 90%; } h1 { color: #333; margin-bottom: 20px; } .item { text-align: left; margin-bottom: 15px; } .item span { font-weight: bold; color: #555; } .price { font-size: 24px; font-weight: bold; color: #007bff; margin-top: 20px; } .button { background-color: #28a745; color: white; border: none; padding: 15px 30px; font-size: 18px; border-radius: 8px; cursor: pointer; transition: background-color 0.3s; margin-top: 30px; } .button:hover { background-color: #218838; } .footer { font-size: 12px; color: #999; margin-top: 20px; } </style></head><body><div class=\"container\"><h1>訂單確認</h1><div class=\"item\"><span>商品項目：</span>" + orderDetails.get("itemName") + "</div><div class=\"item\"><span>訂單描述：</span>" + orderDetails.get("tradeDesc") + "</div><div class=\"price\">NT$ " + orderDetails.get("totalAmount") + "</div><button class=\"button\" onclick=\"goToECPay()\">確認無誤，前往綠界安全支付</button><div class=\"footer\">您即將被引導至綠界科技的金流頁面</div></div><script>function goToECPay() { var params = " + paramsJson + "; var form = document.createElement('form'); form.method = 'post'; form.action = '" + checkoutUrl + "'; form.style.display = 'none'; for (var key in params) { if (params.hasOwnProperty(key)) { var hiddenField = document.createElement('input'); hiddenField.type = 'hidden'; hiddenField.name = key; hiddenField.value = params[key]; form.appendChild(hiddenField); } } document.body.appendChild(form); form.submit(); }</script></body></html>";
                 	return html;
                 }
string ECPay.generateCheckoutForm_Production(map orderInfo)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：【生產環境】生成綠界金流付款表單 HTML
                 	// 版本：1.0 (Production)
                 	// 日期：2025-01-21
                 	//
                 	// 輸入參數：
                 	// - orderInfo (map): 訂單資訊，包含：
                 	//   - merchantTradeNo: 商店訂單編號
                 	//   - totalAmount: 交易金額
                 	//   - itemName: 商品名稱
                 	//   - tradeDesc: 交易描述
                 	//
                 	// @return (string): 完整的 HTML 付款頁面
                 	//
                 	// --- 取得生產環境金鑰 ---
                 	merchantID = thisapp.variables.ECPay.merchantID_Production;
                 	hashKey = thisapp.variables.ECPay.hashKey_Production;
                 	hashIV = thisapp.variables.ECPay.hashIV_Production;
                 	if(merchantID == null || hashKey == null || hashIV == null)
                 	{
                 		info "❌ 錯誤：生產環境 ECPay 變數未設定";
                 		return "錯誤：請先設定生產環境金鑰";
                 	}
                 	// --- 準備付款參數 ---
                 	params = Map();
                 	params.put("MerchantID",merchantID);
                 	params.put("MerchantTradeNo",orderInfo.get("merchantTradeNo"));
                 	params.put("MerchantTradeDate",zoho.currenttime.toString("yyyy/MM/dd HH:mm:ss"));
                 	params.put("PaymentType","aio");
                 	params.put("TotalAmount",orderInfo.get("totalAmount"));
                 	params.put("TradeDesc",orderInfo.get("tradeDesc"));
                 	params.put("ItemName",orderInfo.get("itemName"));
                 	return_url = orderInfo.get("returnURL");
				if(return_url == null || return_url == "")
				{
					return_url = if(thisapp.variables.ECPay.ReturnURL_Production != null,thisapp.variables.ECPay.ReturnURL_Production.toString(),"");
				}
				params.put("ReturnURL",return_url);
                 	params.put("ChoosePayment","Credit");
                 	params.put("EncryptType",1);
                 	// 客戶返回頁面（付款完成後的跳轉頁面）
                 	clientBackURL = orderInfo.get("clientBackURL");
                 	if(clientBackURL == null || clientBackURL == "")
                 	{
                 		clientBackURL = if(thisapp.variables.ECPay.ClientBackURL_Production != null,thisapp.variables.ECPay.ClientBackURL_Production.toString(),"");
				// 請替換為您的網站
                 		// 請替換為您的網站
                 	}
                 	params.put("ClientBackURL",clientBackURL);
                 	// --- 計算 CheckMacValue ---
                 	checkMacValue = thisapp.ECPay.generateCheckMacValue_private(params,hashKey,hashIV);
                 	params.put("CheckMacValue",checkMacValue);
                 	// --- 生成付款確認頁面 HTML ---
                 	html = "<!DOCTYPE html>";
                 	html = html + "<html lang=\"zh-Hant\">";
                 	html = html + "<head>";
                 	html = html + "<meta charset=\"UTF-8\">";
                 	html = html + "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">";
                 	html = html + "<title>訂單確認 - " + orderInfo.get("merchantTradeNo") + "</title>";
                 	html = html + "<style>";
                 	html = html + "body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; background-color: #f8f9fa; padding: 20px; box-sizing: border-box; }";
                 	html = html + ".container { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); text-align: center; max-width: 500px; width: 100%; }";
                 	html = html + "h1 { color: #333; margin-bottom: 30px; font-size: 28px; }";
                 	html = html + ".order-info { background: #f8f9fa; padding: 25px; border-radius: 8px; margin-bottom: 30px; text-align: left; }";
                 	html = html + ".info-row { display: flex; justify-content: space-between; margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid #e9ecef; }";
                 	html = html + ".info-row:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }";
                 	html = html + ".info-label { font-weight: 600; color: #555; }";
                 	html = html + ".info-value { color: #333; }";
                 	html = html + ".total-amount { font-size: 32px; font-weight: bold; color: #007bff; margin: 30px 0; }";
                 	html = html + ".button { background-color: #28a745; color: white; border: none; padding: 18px 40px; font-size: 18px; border-radius: 8px; cursor: pointer; transition: all 0.3s; display: inline-block; text-decoration: none; }";
                 	html = html + ".button:hover { background-color: #218838; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3); }";
                 	html = html + ".security-note { display: flex; align-items: center; justify-content: center; margin-top: 25px; font-size: 14px; color: #6c757d; }";
                 	html = html + ".lock-icon { margin-right: 8px; }";
                 	html = html + ".footer { font-size: 12px; color: #999; margin-top: 30px; }";
                 	html = html + "</style>";
                 	html = html + "</head>";
                 	html = html + "<body>";
                 	html = html + "<div class=\"container\">";
                 	html = html + "<h1>訂單確認</h1>";
                 	html = html + "<div class=\"order-info\">";
                 	html = html + "<div class=\"info-row\">";
                 	html = html + "<span class=\"info-label\">訂單編號</span>";
                 	html = html + "<span class=\"info-value\">" + orderInfo.get("merchantTradeNo") + "</span>";
                 	html = html + "</div>";
                 	html = html + "<div class=\"info-row\">";
                 	html = html + "<span class=\"info-label\">商品名稱</span>";
                 	html = html + "<span class=\"info-value\">" + orderInfo.get("itemName") + "</span>";
                 	html = html + "</div>";
                 	html = html + "<div class=\"info-row\">";
                 	html = html + "<span class=\"info-label\">商品描述</span>";
                 	html = html + "<span class=\"info-value\">" + orderInfo.get("tradeDesc") + "</span>";
                 	html = html + "</div>";
                 	html = html + "</div>";
                 	html = html + "<div class=\"total-amount\">NT$ " + orderInfo.get("totalAmount") + "</div>";
                 	html = html + "<button class=\"button\" onclick=\"goToECPay()\">確認付款</button>";
                 	html = html + "<div class=\"security-note\">";
                 	html = html + "<svg class=\"lock-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg>";
                 	html = html + "安全加密連線，由綠界科技提供金流服務";
                 	html = html + "</div>";
                 	html = html + "<div class=\"footer\">點擊確認付款後，您將被導向至綠界科技的安全付款頁面</div>";
                 	html = html + "</div>";
                 	// JavaScript 自動提交表單
                 	html = html + "<script>";
                 	html = html + "function goToECPay() {";
                 	html = html + " var params = " + params.toString() + ";";
                 	html = html + " var form = document.createElement('form');";
                 	html = html + " form.method = 'post';";
                 	// 生產環境 URL
                 	html = html + " form.action = 'https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5';";
                 	html = html + " form.style.display = 'none';";
                 	html = html + " for (var key in params) {";
                 	html = html + "  if (params.hasOwnProperty(key)) {";
                 	html = html + "   var hiddenField = document.createElement('input');";
                 	html = html + "   hiddenField.type = 'hidden';";
                 	html = html + "   hiddenField.name = key;";
                 	html = html + "   hiddenField.value = params[key];";
                 	html = html + "   form.appendChild(hiddenField);";
                 	html = html + "  }";
                 	html = html + " }";
                 	html = html + " document.body.appendChild(form);";
                 	html = html + " form.submit();";
                 	html = html + "}";
                 	html = html + "</script>";
                 	html = html + "</body>";
                 	html = html + "</html>";
                 	return html;
                 }
string ECPay.generateECPayCheckoutForm(string merchantID, string hashKey, string hashIV, string checkoutUrl, map orderInfoMap)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：產生導向綠界 ECPay 付款頁面的自動提交 HTML 表單
                 	// 版本：1.1
                 	// 日期：2024-07-31
                 	//
                 	// 邏輯：
                 	// 1. 準備所有需要傳送給綠界的參數。
                 	// 2. 呼叫私有函式 ECPay.generateCheckMacValue_private 產生簽章。
                 	// 3. 組合出完整的 HTML form，並包含自動提交的 JavaScript。
                 	//
                 	// @param merchantID (string)：您的綠界商店代號。
                 	// @param hashKey (string)：綠界後台設定的 HashKey。
                 	// @param hashIV (string)：綠界後台設定的 HashIV。
                 	// @param checkoutUrl (string)：綠界結帳頁面的 URL (測試或正式)。
                 	// @param orderInfoMap (map)：包含訂單詳細資訊的 map，欄位應符合綠界 API 規範。
                 	//     - MerchantTradeNo (string)
                 	//     - MerchantTradeDate (string: yyyy/MM/dd HH:mm:ss)
                 	//     - TotalAmount (number)
                 	//     - TradeDesc (string)
                 	//     - ItemName (string)
                 	//     - ReturnURL (string)
                 	//     - ClientBackURL (string) [可選]
                 	//     - ChoosePayment (string: ALL, Credit, ATM...) [可選, 預設為 ALL]
                 	//
                 	// @return (string)：包含自動提交表單的完整 HTML 程式碼。
                 	//
                 	// 1. 準備所有必要參數
                 	params = Map();
                 	params.put("MerchantID",merchantID);
                 	params.put("MerchantTradeNo",orderInfoMap.get("MerchantTradeNo"));
                 	params.put("MerchantTradeDate",orderInfoMap.get("MerchantTradeDate"));
                 	params.put("PaymentType","aio");
                 	params.put("TotalAmount",orderInfoMap.get("TotalAmount"));
                 	params.put("TradeDesc",orderInfoMap.get("TradeDesc"));
                 	params.put("ItemName",orderInfoMap.get("ItemName"));
                 	params.put("ReturnURL",orderInfoMap.get("ReturnURL"));
                 	// 設定預設付款方式為 ALL，但可被 orderInfoMap 覆寫
                 	params.put("ChoosePayment",if(orderInfoMap.containKey("ChoosePayment"),orderInfoMap.get("ChoosePayment"),"ALL"));
                 	params.put("EncryptType",1);
                 	// 根據 ECPay 文件，固定為 1 (SHA256)
                 	if(orderInfoMap.containKey("ClientBackURL"))
                 	{
                 		params.put("ClientBackURL",orderInfoMap.get("ClientBackURL"));
                 	}
                 	// 2. 產生 CheckMacValue (注意: 官方文件v5版指定用SHA256)
                 	checkMacValue = thisapp.ECPay.generateCheckMacValue_private(params,hashKey,hashIV);
                 	params.put("CheckMacValue",checkMacValue);
                 	// 3. 組合 HTML 表單
                 	htmlForm = "<!DOCTYPE html><html><head><meta charset=\"utf-8\"></head><body>";
                 	htmlForm = htmlForm + "<h1 style=\"text-align:center;\">頁面載入中，請稍候...</h1>";
                 	htmlForm = htmlForm + "<form id=\"ecpay-form\" method=\"post\" action=\"" + checkoutUrl + "\" style=\"display:none;\">";
                 	for each  key in params.keys()
                 	{
                 		htmlForm = htmlForm + "<input type=\"hidden\" name=\"" + key + "\" value=\"" + params.get(key) + "\">";
                 	}
                 	htmlForm = htmlForm + "</form>";
                 	htmlForm = htmlForm + "<script>document.getElementById('ecpay-form').submit();</script>";
                 	htmlForm = htmlForm + "</body></html>";
                 	return htmlForm;
                 }
map ECPay.generatePaymentLink(string itemName, string itemDesc, decimal amount, string customerName, string divinationLogId)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：生成 ECPay 付款連結（供 SalesIQ 調用）
                 	// 版本：1.1 - 修正欄位對應和關聯
                 	// 日期：2025-01-21
                 	//
                 	// 輸入參數：
                 	// - itemName (string): 商品名稱（用於顯示）
                 	// - itemDesc (string): 商品描述（用於顯示）
                 	// - amount (decimal): 付款金額
                 	// - customerName (string): 客戶姓名（僅供顯示）
                 	// - divinationLogId (string): 占卜紀錄 ID（用於關聯）
                 	//
                 	// @return (map): 包含付款連結和訂單資訊
                 	//
                 	// --- 初始化結果 ---
                 	result = Map();
                 	try 
                 	{
                 		// --- 驗證占卜紀錄是否存在 ---
                 		if(divinationLogId != null && divinationLogId != "")
                 		{
                 			divinationRecord = Divination_Logs[ID == divinationLogId.toLong()];
                 			if(divinationRecord.count() == 0)
                 			{
                 				result.put("success",false);
                 				result.put("error","找不到對應的占卜紀錄");
                 				return result;
                 			}
                 			// 取得第一筆紀錄
                 			targetRecord = null;
                 			for each  record in divinationRecord
                 			{
                 				targetRecord = record;
                 				break;
                 			}
                 			clientId = targetRecord.Client_Link;
                 		}
                 		else
                 		{
                 			clientId = null;
                 		}
                 		// --- 生成唯一訂單編號 ---
                 		timestamp = zoho.currenttime.toString("yyyyMMddHHmmss");
                 		merchantTradeNo = "SIQ" + timestamp;
                 		// --- 建立訂單記錄 ---
                 		newOrder = insert into Talisman_Purchases
                 		[
                 			Added_User=zoho.loginuser
                 			MerchantTradeNo=merchantTradeNo
                 			Status="Pending"
                 			Item_Name_Chinese=itemName
                 			Description_Chinese=itemDesc
                 			TradeAmt=amount
                 			Divination_Log_Link=if(divinationLogId != null && divinationLogId != "",divinationLogId.toLong(),null)
                 			Client_Link=clientId
                 		];
                 		// --- 準備付款參數 ---
                 		orderInfo = Map();
                 		orderInfo.put("MerchantTradeNo",merchantTradeNo);
                 		orderInfo.put("MerchantTradeDate",zoho.currenttime.toString("yyyy/MM/dd HH:mm:ss"));
                 		orderInfo.put("TotalAmount",amount.toString());
                 		orderInfo.put("ItemName","AI-Divination-Service");
                 		// 英文用於簽章
                 		orderInfo.put("TradeDesc","Service-" + merchantTradeNo);
                 		// 英文用於簽章
                 		orderInfo.put("ReturnURL","https://ecpay-webhook-proxy-ptmk.vercel.app/api/webhook");
                 		orderInfo.put("ClientBackURL","https://www.google.com");
                 		// 付款完成後跳轉
                 		orderInfo.put("ChoosePayment","Credit");
                 		// 只允許信用卡付款
                 		// --- 獲取 ECPay 設定 ---
                 		merchantID = thisapp.variables.ECPay.merchantID.toString();
                 		hashKey = thisapp.variables.ECPay.hashKey.toString();
                 		hashIV = thisapp.variables.ECPay.hashIV.toString();
                 		checkoutUrl = "https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5";
                 		// 測試環境
                 		// --- 生成付款 HTML ---
                 		// 使用現有的測試環境函數
                 		paymentHtml = thisapp.ECPay.generateECPayCheckoutForm(merchantID,hashKey,hashIV,checkoutUrl,orderInfo);
                 		// --- 建立臨時檔案（模擬）---
                 		// 在實際環境中，這裡需要將 HTML 儲存到可存取的位置
                 		// 或者回傳 HTML 內容讓 SalesIQ 處理
                 		// --- 組織回傳結果 ---
                 		result.put("success",true);
                 		result.put("orderNo",merchantTradeNo);
                 		result.put("amount",amount);
                 		result.put("itemName",itemName);
                 		result.put("paymentHtml",paymentHtml);
                 		result.put("message","付款連結已生成");
                 		info "✅ 成功生成付款連結：" + merchantTradeNo;
                 	}
                 	catch (e)
                 	{
                 		result.put("success",false);
                 		result.put("error","生成付款連結失敗：" + e.toString());
                 		info "❌ 生成付款連結失敗：" + e.toString();
                 	}
                 	return result;
                 }
map ECPay.handleECPayResponse(map requestParamsMap, string hashKey, string hashIV)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：處理綠界 ECPay 的前端 (ReturnURL) 或後端 (NotifyURL) 回調請求
                 	// 版本：1.0
                 	// 日期：2024-07-31
                 	//
                 	// 邏輯：
                 	// 1. 呼叫 ECPay.verifyECPayCheckMacValue 進行簽章驗證。
                 	// 2. 如果驗證失敗，立即回傳錯誤狀態。
                 	// 3. 如果驗證成功，則解析 RtnCode 來判斷付款狀態。
                 	// 4. 將訂單號、狀態、原始參數打包成一個標準化的 map 回傳。
                 	// 5. **特別注意**：呼叫此函式的外層邏輯，在接收到回傳後，
                 	//    如果是處理 NotifyURL，必須要 `return "1|OK";` 給綠界。
                 	//    此函式本身不直接 return "1|OK"，是為了讓外層有機會做後續處理(如寫入資料庫)。
                 	//
                 	// @param requestParamsMap (map)：從綠界 ReturnURL 或 NotifyURL 收到的所有參數。
                 	// @param hashKey (string)：綠界後台設定的 HashKey。
                 	// @param hashIV (string)：綠界後台設定的 HashIV。
                 	// @return (map)：包含處理結果的 map。
                 	//     - status (string): "Paid", "Failed", "Invalid"
                 	//     - orderNo (string): 商家訂單編號
                 	//     - params (map): 原始的 requestParamsMap
                 	//
                 	responseMap = Map();
                 	responseMap.put("params",requestParamsMap);
                 	// 1. 驗證 CheckMacValue
                 	isValid = thisapp.ECPay.verifyECPayCheckMacValue(requestParamsMap,hashKey,hashIV);
                 	if(!isValid)
                 	{
                 		responseMap.put("status","Invalid");
                 		responseMap.put("orderNo",null);
                 		// 簽章驗證失敗，直接回傳
                 		return responseMap;
                 	}
                 	// 2. 驗證成功，解析付款狀態
                 	// RtnCode = 1 代表交易成功
                 	rtnCode = requestParamsMap.get("RtnCode");
                 	merchantTradeNo = requestParamsMap.get("MerchantTradeNo");
                 	responseMap.put("orderNo",merchantTradeNo);
                 	if(rtnCode == "1")
                 	{
                 		responseMap.put("status","Paid");
                 	}
                 	else
                 	{
                 		responseMap.put("status","Failed");
                 	}
                 	return responseMap;
                 }
string ECPay.processFlowCallback(map flowData)
                 {
                 	// 專門處理來自 Zoho Flow 的 ECPay 回調
                 	// 這個函數由 Zoho Flow 的 "Invoke Function" 動作調用
                 	// 預設回傳值
                 	result = "0|ERROR";
                 	info "======= Flow 回調處理開始 =======";
                 	info "接收時間: " + zoho.currenttime;
                 	info "Flow 傳入資料: " + flowData;
                 	try 
                 	{
                 		// Flow 會將 webhook 接收到的所有參數包在一個 map 中
                 		ecpayParams = flowData;
                 		// 如果 Flow 將參數包在特定 key 中，需要解開
                 		if(flowData.containKey("webhook_data"))
                 		{
                 			ecpayParams = flowData.get("webhook_data");
                 		}
                 		else if(flowData.containKey("data"))
                 		{
                 			ecpayParams = flowData.get("data");
                 		}
                 		info "解析後的綠界參數: " + ecpayParams;
                 		// 獲取金鑰
                 		hashKey = thisapp.variables.ECPay.hashKey;
                 		hashIV = thisapp.variables.ECPay.hashIV;
                 		// 調用現有的處理邏輯
                 		response = thisapp.ECPay.handleECPayResponse(ecpayParams,hashKey,hashIV);
                 		info "處理結果: " + response;
                 		// 根據結果更新資料庫
                 		orderNo = response.get("orderNo");
                 		if(orderNo != null)
                 		{
                 			// 查找並更新訂單
                 			purchaseRecord = Talisman_Purchases[MerchantTradeNo == orderNo];
                 			if(purchaseRecord.count() > 0)
                 			{
                 				for each  record in purchaseRecord
                 				{
                 					// 更新訂單狀態
                 					if(response.get("status") == "success")
                 					{
                 						record.Status="Paid";
                 						record.TradeNo=response.get("TradeNo");
                 						record.PaymentDate=response.get("PaymentDate");
                 						record.PaymentType=response.get("PaymentType");
                 						info "訂單 " + orderNo + " 更新為已付款";
                 					}
                 					else
                 					{
                 						record.Status="Failed";
                 						record.RtnMsg=response.get("error");
                 						info "訂單 " + orderNo + " 付款失敗: " + response.get("error");
                 					}
                 				}
                 			}
                 			else
                 			{
                 				info "警告：找不到訂單 " + orderNo;
                 			}
                 		}
                 		info "======= Flow 回調處理完成 =======";
                 		// 成功處理，設定回傳值
                 		result = "1|OK";
                 	}
                 	catch (e)
                 	{
                 		info "Flow 回調處理錯誤: " + e.toString();
                 		result = "0|ERROR: " + e.toString();
                 	}
                 	// 統一的回傳點
                 	return result;
                 }
string ECPay.publicWebhook(map crmAPIRequest)
                 {
                 	// 公開 Webhook 函數（如果 Creator 支援 POST）
                 	// 設定為 "Everyone can access" 權限
                 	info "======= 公開 Webhook 接收 =======";
                 	info "接收時間: " + zoho.currenttime;
                 	// 預設回傳值
                 	result = "0|ERROR";
                 	try 
                 	{
                 		// 從 crmAPIRequest 獲取 POST 參數
                 		ecpayParams = Map();
                 		if(crmAPIRequest != null)
                 		{
                 			// 複製所有參數
                 			for each  key in crmAPIRequest.keys()
                 			{
                 				value = crmAPIRequest.get(key);
                 				if(value != null)
                 				{
                 					ecpayParams.put(key,value);
                 				}
                 			}
                 		}
                 		info "接收到的參數: " + ecpayParams;
                 		info "參數數量: " + ecpayParams.keys().size();
                 		// 如果沒有接收到參數，記錄並返回錯誤
                 		if(ecpayParams.keys().size() == 0)
                 		{
                 			info "警告：未接收到任何參數";
                 			result = "0|NO_PARAMS";
                 		}
                 		else
                 		{
                 			// 獲取金鑰
                 			hashKey = thisapp.variables.ECPay.hashKey;
                 			hashIV = thisapp.variables.ECPay.hashIV;
                 			// 調用處理邏輯
                 			response = thisapp.ECPay.handleECPayResponse(ecpayParams,hashKey,hashIV);
                 			info "處理結果: " + response;
                 			// 更新資料庫
                 			orderNo = response.get("orderNo");
                 			if(orderNo != null)
                 			{
                 				purchaseRecord = Talisman_Purchases[MerchantTradeNo == orderNo];
                 				if(purchaseRecord.count() > 0)
                 				{
                 					for each  record in purchaseRecord
                 					{
                 						if(response.get("status") == "success")
                 						{
                 							record.Status="Paid";
                 							record.TradeNo=response.get("TradeNo");
                 							record.PaymentDate=response.get("PaymentDate");
                 							record.PaymentType=response.get("PaymentType");
                 							info "訂單 " + orderNo + " 更新為已付款";
                 						}
                 						else
                 						{
                 							record.Status="Failed";
                 							record.RtnMsg=response.get("error");
                 							info "訂單 " + orderNo + " 付款失敗";
                 						}
                 					}
                 				}
                 				else
                 				{
                 					info "警告：找不到訂單 " + orderNo;
                 				}
                 			}
                 			info "======= 公開 Webhook 處理完成 =======";
                 			// 成功處理，設定回傳值
                 			result = "1|OK";
                 		}
                 	}
                 	catch (e)
                 	{
                 		info "公開 Webhook 錯誤: " + e.toString();
                 		result = "0|ERROR: " + e.toString();
                 	}
                 	// 統一的回傳點
                 	return result;
                 }
void ECPay.simulateECPayCallback()
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：【測試工具】模擬綠界付款成功的回調，用於測試 Webhook 資料庫更新邏輯
                 	// 版本：1.0
                 	// 日期：2024-08-05
                 	//
                 	// 用途：當懷疑 Webhook 沒有收到綠界回調時，可以用此函數手動模擬，測試資料庫更新是否正常
                 	//
                 	info "======= 模擬 ECPay 付款成功回調 =======";
                 	// 模擬綠界付款成功後回傳的參數（基於真實的 ECPay 回調格式）
                 	mockParams = Map();
                 	mockParams.put("MerchantID","3002607");
                 	mockParams.put("MerchantTradeNo","LAI20250805232706");
                 	// 使用剛才測試的訂單號
                 	mockParams.put("RtnCode","1");
                 	// 1 = 付款成功
                 	mockParams.put("RtnMsg","Succeeded");
                 	mockParams.put("TradeNo","2408052327000123");
                 	// 模擬的綠界交易編號
                 	mockParams.put("TradeAmt","50");
                 	mockParams.put("PaymentDate","2025/08/05 23:27:30");
                 	mockParams.put("PaymentType","Credit_CreditCard");
                 	mockParams.put("TradeDate","2025/08/05 23:27:06");
                 	mockParams.put("CheckMacValue","MOCK_CHECK_MAC_VALUE_FOR_TEST");
                 	info "模擬的回調參數：" + mockParams;
                 	// 呼叫 Webhook 處理函數
                 	try 
                 	{
                 		result = thisapp.Webhook.handleECPayReturn(mockParams);
                 		info "Webhook 處理結果：" + result;
                 		info "如果返回 '1|OK'，表示 Webhook 函數執行成功。";
                 		info "請現在檢查 Talisman_Purchases 表單中訂單 LAI20250805232706 的狀態是否已更新為 'Paid'。";
                 	}
                 	catch (e)
                 	{
                 		info "Webhook 執行失敗：" + e;
                 	}
                 	info "======= 模擬測試完成 =======";
                 }
				 bool ECPay.verifyECPayCheckMacValue(map requestParamsMap, string hashKey, string hashIV)
                 {
                 	//
                 	// 開發者：Lunar Tom
                 	// 功能：驗證綠界 ECPay 回傳的 CheckMacValue 是否正確
                 	// 版本：1.0
                 	// 日期：2024-07-31
                 	//
                 	// 邏輯：
                 	// 1. 從傳入的參數 map 中，先取出綠界回傳的 CheckMacValue。
                 	// 2. 建立一個新的 map，只包含需要參與驗證的參數 (排除 CheckMacValue 本身)。
                 	// 3. 呼叫私有函式 ECPay.generateCheckMacValue_private 重新計算一次簽章。
                 	// 4. 比對重新計算出的簽章與綠界回傳的是否一致。
                 	//
                 	// @param requestParamsMap (map)：從綠界 ReturnURL 或 NotifyURL 收到的所有參數。
                 	// @param hashKey (string)：綠界後台設定的 HashKey。
                 	// @param hashIV (string)：綠界後台設定的 HashIV。
                 	// @return (bool)：驗證成功回傳 true，失敗則回傳 false。
                 	//
                 	// 1. 取出綠界回傳的 CheckMacValue
                 	if(!requestParamsMap.containKey("CheckMacValue"))
                 	{
                 		// 如果連 CheckMacValue 都沒有，直接視為驗證失敗
                 		return false;
                 	}
                 	ecpayCheckMacValue = requestParamsMap.get("CheckMacValue");
                 	// 2. 準備用於計算的參數 map (排除 CheckMacValue)
                 	paramsForVerification = requestParamsMap.toMap();
                 	// 複製一份以避免修改到原始傳入的 map
                 	paramsForVerification.remove("CheckMacValue");
                 	// 3. 重新計算一次 CheckMacValue
                 	ourCheckMacValue = thisapp.ECPay.generateCheckMacValue_private(paramsForVerification,hashKey,hashIV);
                 	// 4. 比對結果
                 	if(ourCheckMacValue == ecpayCheckMacValue)
                 	{
                 		return true;
                 	}
                 	else
                 	{
                 		// 方便 debug，可以記錄日誌
                 		info "ECPay CheckMacValue verification failed. Our value: " + ourCheckMacValue + ", ECPay value: " + ecpayCheckMacValue;
                 		return false;
                 	}
                 }
map Email.sendTalismanReport(string order_id)
                 {
                 	// =============================================================================
                 	// Email 函數：發送符令完整報告
                 	// 
                 	// 功能：付款成功後自動發送完整符令和占卜報告
                 	// 觸發：ECPay 付款成功回調
                 	// =============================================================================
                 	// 採用單一出口模式
                 	email_result = Map();
                 	try 
                 	{
                 		info "=== 開始發送符令報告 ===";
                 		info "訂單 ID：" + order_id;
                 		// === 步驟 1：查詢訂單資訊 ===
                 		order_records = Talisman_Purchases[ID == order_id.toLong()];
                 		if(order_records.count() == 0)
                 		{
                 			email_result.put("success",false);
                 			email_result.put("message","找不到訂單記錄");
                 			return email_result;
                 		}
                 		// 取得訂單資訊
                 		order_info = null;
                 		for each  order in order_records
                 		{
                 			order_info = order;
                 			break;
                 		}
                 		// 透過 Lookup 取得客戶資訊
                 		client_id = order_info.Client_Link;
                 		customer_name = "";
                 		customer_email = "";
                 		if(client_id != null)
                 		{
                 			client_records = Clients_Report[ID == client_id];
                 			if(client_records.count() > 0)
                 			{
                 				for each  client in client_records
                 				{
                 					customer_name = client.Visitor_Name.first_name + " " + client.Visitor_Name.last_name;
                 					customer_email = client.Email;
                 					break;
                 				}
                 			}
                 		}
                 		// 如果無法取得客戶資訊，回傳錯誤
                 		if(customer_email == "")
                 		{
                 			email_result.put("success",false);
                 			email_result.put("message","無法取得客戶郵件地址");
                 			return email_result;
                 		}
                 		talisman_name = order_info.Item_Name_Chinese;
                 		divination_id = order_info.Divination_Log_Link;
                 		info "客戶：" + customer_name;
                 		info "郵件：" + customer_email;
                 		info "符令：" + talisman_name;
                 		// === 步驟 2：取得占卜記錄詳細資訊 ===
                 		divination_records = Divination_Logs[ID == divination_id];
                 		if(divination_records.count() == 0)
                 		{
                 			email_result.put("success",false);
                 			email_result.put("message","找不到占卜記錄");
                 			return email_result;
                 		}
                 		// 取得占卜資訊
                 		divination_info = null;
                 		for each  divination in divination_records
                 		{
                 			divination_info = divination;
                 			break;
                 		}
                 		user_question = divination_info.Original_Question;
                 		ai_interpretation = divination_info.AI_Interpretation;
                 		primary_card_id = divination_info.Primary_Talisman_Card_ID;
                 		// === 步驟 3：取得符令圖片和詳細資訊 ===
                 		talisman_image_url = "";
                 		talisman_description = "";
                 		talisman_usage_guide = "";
                 		if(primary_card_id != null)
                 		{
                 			card_records = All_Tarot_Cards[ID == primary_card_id];
                 			if(card_records.count() > 0)
                 			{
                 				for each  card in card_records
                 				{
                 					// 根據正逆位選擇符令圖片
                 					primary_polarity = divination_info.Primary_Trend_Polarity;
                 					if(primary_polarity == "正位")
                 					{
                 						talisman_image_url = card.Upright_Talisman_Image;
                 					}
                 					else
                 					{
                 						talisman_image_url = card.Reverse_Talisman_Image;
                 					}
                 					talisman_description = card.Card_Description;
                 					break;
                 				}
                 			}
                 		}
                 		// === 步驟 4：組合 HTML 郵件內容 ===
                 		html_content = "<!DOCTYPE html>";
                 		html_content = html_content + "<html><head><meta charset='UTF-8'>";
                 		html_content = html_content + "<title>您的專屬符令報告</title>";
                 		html_content = html_content + "<style>";
                 		html_content = html_content + "body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }";
                 		html_content = html_content + ".header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; text-align: center; }";
                 		html_content = html_content + ".content { padding: 20px; max-width: 600px; margin: 0 auto; }";
                 		html_content = html_content + ".talisman-box { border: 2px solid #667eea; border-radius: 10px; padding: 15px; margin: 20px 0; text-align: center; }";
                 		html_content = html_content + ".divination-box { background: #f8f9fa; border-radius: 8px; padding: 15px; margin: 15px 0; }";
                 		html_content = html_content + ".footer { background: #333; color: white; padding: 15px; text-align: center; font-size: 12px; }";
                 		html_content = html_content + "</style></head><body>";
                 		// 郵件標題
                 		html_content = html_content + "<div class='header'>";
                 		html_content = html_content + "<h1>? 您的專屬符令報告 ?</h1>";
                 		html_content = html_content + "<p>親愛的 " + customer_name + "，感謝您的信任！</p>";
                 		html_content = html_content + "</div>";
                 		// 主要內容
                 		html_content = html_content + "<div class='content'>";
                 		// 符令部分
                 		html_content = html_content + "<div class='talisman-box'>";
                 		html_content = html_content + "<h2>✨ 您的專屬符令 ✨</h2>";
                 		html_content = html_content + "<h3>" + talisman_name + "</h3>";
                 		if(talisman_image_url != null && talisman_image_url != "")
                 		{
                 			html_content = html_content + "<img src='" + talisman_image_url + "' alt='專屬符令' style='max-width: 300px; height: auto; border-radius: 8px;'>";
                 		}
                 		html_content = html_content + "<p><strong>使用說明</strong>：</p>";
                 		html_content = html_content + "<p>1. 將此符令圖片設為手機桌布或保存在手機相簿中</p>";
                 		html_content = html_content + "<p>2. 每日晨起觀看符令 3 分鐘，進行冥想</p>";
                 		html_content = html_content + "<p>3. 遇到挑戰時觀看符令，獲得力量與智慧</p>";
                 		html_content = html_content + "<p>4. 符令有效期為一年，期間可隨時使用</p>";
                 		html_content = html_content + "</div>";
                 		// 占卜解讀部分 - 根據購買類型顯示不同內容
                 		html_content = html_content + "<div class='divination-box'>";
                 		html_content = html_content + "<h2>? 您的占卜解讀</h2>";
                 		html_content = html_content + "<p><strong>您的問題</strong>：" + user_question + "</p>";
                 		// 檢查是否已有完整報告
                 		full_report_available = divination_info.AI_Interpretation_Full != null && divination_info.AI_Interpretation_Full != "";
                 		pdf_link_available = divination_info.Report_PDF_Link != null && divination_info.Report_PDF_Link != "";
                 		if(full_report_available && pdf_link_available)
                 		{
                 			// 有完整報告和PDF連結 - 顯示PDF下載連結
                 			html_content = html_content + "<div style='background: #e8f4fd; border: 1px solid #bee5eb; border-radius: 8px; padding: 15px; margin: 15px 0;'>";
                 			html_content = html_content + "<h3>? 完整占卜報告</h3>";
                 			html_content = html_content + "<p>您的專業 3000 字完整占卜報告已準備就緒！</p>";
                 			html_content = html_content + "<p><a href='" + divination_info.Report_PDF_Link + "' style='background: #007bff; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block;'>? 下載完整報告 PDF</a></p>";
                 			html_content = html_content + "</div>";
                 		}
                 		else
                 		{
                 			// 暫時顯示 500 字解讀，並說明完整報告準備中
                 			html_content = html_content + "<div style='white-space: pre-line; margin-top: 15px;'>";
                 			html_content = html_content + ai_interpretation;
                 			html_content = html_content + "</div>";
                 			html_content = html_content + "<div style='background: #fff3cd; border: 1px solid #ffeaa7; border-radius: 8px; padding: 15px; margin: 15px 0;'>";
                 			html_content = html_content + "<p><strong>? 專業完整報告準備中...</strong></p>";
                 			html_content = html_content + "<p>您的 3000 字專業完整占卜報告正在生成中，完成後將以 PDF 格式提供下載連結。</p>";
                 			html_content = html_content + "</div>";
                 		}
                 		html_content = html_content + "</div>";
                 		// 感謝和聯絡資訊
                 		html_content = html_content + "<div style='text-align: center; margin-top: 30px;'>";
                 		html_content = html_content + "<h3>? 感謝您的信任</h3>";
                 		html_content = html_content + "<p>願宇宙的智慧與愛與您同在！</p>";
                 		html_content = html_content + "<p>如有任何問題，歡迎隨時聯繫我們的客服團隊。</p>";
                 		html_content = html_content + "</div>";
                 		html_content = html_content + "</div>";
                 		// 頁尾
                 		html_content = html_content + "<div class='footer'>";
                 		html_content = html_content + "<p>© 2025 AI 靈學占卜系統 | 專業塔羅占卜服務</p>";
                 		html_content = html_content + "<p>此為系統自動發送郵件，請勿直接回覆</p>";
                 		html_content = html_content + "</div>";
                 		html_content = html_content + "</body></html>";
                 		// === 步驟 5：發送郵件 ===
                 		email_subject = "? 您的專屬符令報告 - " + customer_name;
                 		info "準備發送郵件給：" + customer_email;
                 		info "郵件主旨：" + email_subject;
                 		// === 步驟 5：發送郵件 ===
                 		try 
                 		{
                 			sendmail
                 			[
                 				from :zoho.adminuserid
                 				to :customer_email
                 				subject :email_subject
                 				message :html_content
                 			]
                 			info "郵件發送命令執行完成";
                 			// === 步驟 6：處理首次購買報告生成 ===
                 			// 檢查是否為首次購買並包含完整報告
                 			is_first_purchase = order_info.Is_First_Purchase;
                 			report_included = order_info.Report_Included;
                 			if(is_first_purchase && report_included)
                 			{
                 				// 首次購買：生成 3000 字完整報告
                 				info "首次購買檢測，準備生成完整報告";
                 				// 呼叫 3000 字完整報告生成函數
                 				// 準備牌陣資料 Map
                 				tarot_spread_data = Map();
                 				tarot_spread_data.put("Position_a_Meaning",divination_info.Position_a_Meaning);
                 				tarot_spread_data.put("Position_b_Meaning",divination_info.Position_b_Meaning);
                 				tarot_spread_data.put("Position_c_Meaning",divination_info.Position_c_Meaning);
                 				tarot_spread_data.put("Position_d_Meaning",divination_info.Position_d_Meaning);
                 				tarot_spread_data.put("Position_e_Meaning",divination_info.Position_e_Meaning);
                 				tarot_spread_data.put("Card_1_Reversed",divination_info.Card_1_Reversed);
                 				tarot_spread_data.put("Card_2_Reversed",divination_info.Card_2_Reversed);
                 				tarot_spread_data.put("Card_3_Reversed",divination_info.Card_3_Reversed);
                 				tarot_spread_data.put("Card_4_Reversed",divination_info.Card_4_Reversed);
                 				tarot_spread_data.put("Card_5_Reversed",divination_info.Card_5_Reversed);
                 				full_report_result = thisapp.AIInterpreter.getTarotInterpretationFull(divination_info.Original_Question,divination_info.Question_Type_AI,tarot_spread_data);
                 				// 更新占卜記錄的完整報告
                 				if(full_report_result != null && full_report_result.get("success") == true)
                 				{
                 					// 從 Map 中提取解讀文字
                 					full_interpretation_text = full_report_result.get("interpretation");
                 					if(full_interpretation_text != null && full_interpretation_text != "")
                 					{
                 						// 使用正確的 update 語法
                 						divination_records_update = Divination_Logs[ID == divination_id];
                 						if(divination_records_update.count() > 0)
                 						{
                 							for each  divination_record in divination_records_update
                 							{
                 								divination_record.AI_Interpretation_Full=full_interpretation_text;
                 								divination_record.Report_Generated=true;
                 								break;
                 							}
                 						}
                 						info "3000字完整報告生成並保存成功，字數：" + full_report_result.get("word_count").toString();
                 					}
                 				}
                 				else if(full_report_result != null)
                 				{
                 					info "完整報告生成失敗：" + full_report_result.get("error");
                 				}
                 				else
                 				{
                 					info "完整報告生成函數回傳空值";
                 				}
                 			}
                 			email_result.put("success",true);
                 			email_result.put("message","符令報告發送成功");
                 			email_result.put("recipient",customer_email);
                 			email_result.put("is_first_purchase",is_first_purchase);
                 			email_result.put("report_included",report_included);
                 			info "郵件處理流程完成";
                 		}
                 		catch (mail_error)
                 		{
                 			email_result.put("success",false);
                 			email_result.put("message","郵件發送失敗：" + mail_error.toString());
                 			info "郵件發送過程發生錯誤：" + mail_error.toString();
                 		}
                 	}
                 	catch (e)
                 	{
                 		email_result.put("success",false);
                 		email_result.put("message","郵件系統錯誤：" + e);
                 		info "sendTalismanReport 函數執行錯誤：" + e;
                 	}
                 	return email_result;
                 }
map Flow.triggerTarotFlowProcessor(map flowParams)
                 {
                 	response = Map();
                 	try 
                 	{
                 		divinationId = flowParams.get("divinationId");
                 		questionText = flowParams.get("questionText");
                 		questionType = flowParams.get("questionType");
                 		tarotSpreadData = flowParams.get("tarotSpreadData");
                 		clientId = flowParams.get("clientId");
                 		existingThreadId = flowParams.get("threadId");
                 		if(divinationId == null || divinationId == "" || questionText == null || questionText == "" || tarotSpreadData == null)
                 		{
                 			response.put("success",false);
                 			response.put("error","Missing required parameters");
                 			return response;
                 		}
                 		flowPayload = Map();
                 		flowPayload.put("trigger","tarot_divination");
                 		flowPayload.put("timestamp",zoho.currenttime);
                 		divinationRecord = Map();
                 		divinationRecord.put("id",divinationId);
                 		divinationRecord.put("clientId",clientId);
                 		divinationRecord.put("originalQuestion",questionText);
                 		divinationRecord.put("questionTypeAi",questionType);
                 		divinationRecord.put("threadId",existingThreadId);
                 		divinationRecord.put("tarotData",tarotSpreadData);
                 		flowPayload.put("divinationRecord",divinationRecord);
                 		updateRecords = Divination_Logs[ID == divinationId.toLong()];
                 		if(updateRecords.count() > 0)
                 		{
                 			for each  updateRecord in updateRecords
                 			{
                 				updateRecord.Status="已提問";
                 				updateRecord.AI_Interpretation="AI正在處理中，請稍候...";
                 				break;
                 			}
                 			info "Updated divination record status, ID: " + divinationId;
                 		}
                 		else
                 		{
                 			info "Warning: Cannot find divination record ID: " + divinationId;
                 		}
                 		info "Starting Flow processing, divination ID: " + divinationId;
                 		flowWebhookUrl = "https://flow.zoho.com/876589298/flow/webhook/incoming?zapikey=1001.176efc3550bccb13d0f6d350b98cf98a.11f2757e15946c0262f1fe0e9e813d0d&isdebug=false";
                 		requestHeaders = Map();
                 		requestHeaders.put("Content-Type","application/json");
                 		info "Preparing to send data to Flow: " + flowPayload.toString();
                 		flowResponse = invokeurl
                 		[
                 			url :flowWebhookUrl
                 			type :POST
                 			parameters:flowPayload.toString()
                 			headers:requestHeaders
                 		];
                 		info "Flow response content: " + flowResponse.toString();
                 		if(flowResponse == null || flowResponse.toString() == "" || flowResponse.toString() == "{}")
                 		{
                 			info "Attempting to resend using different format";
                 			flowResponse = invokeurl
                 			[
                 				url :flowWebhookUrl
                 				type :POST
                 				parameters:flowPayload
                 				headers:requestHeaders
                 			];
                 			info "Second attempt Flow response: " + flowResponse.toString();
                 		}
                 		flowSuccess = false;
                 		if(flowResponse != null)
                 		{
                 			info "Flow response status code: " + flowResponse.get("status");
                 			flowResponseStatus = flowResponse.get("status");
                 			if(flowResponseStatus != null && flowResponseStatus.toString() == "200" || flowResponseStatus.toString() == "success" || flowResponse.get("success") == true)
                 			{
                 				flowSuccess = true;
                 			}
                 		}
                 		if(flowSuccess)
                 		{
                 			response.put("success",true);
                 			response.put("processingMethod","Flow異步");
                 			response.put("message","占卜請求已提交處理，AI解讀將在2-3分鐘內完成");
                 			response.put("divinationId",divinationId);
                 			response.put("estimatedCompletion","2-3分鐘");
                 			info "Flow triggered successfully, divination ID: " + divinationId;
                 		}
                 		else
                 		{
                 			errorDetails = "Flow response is null";
                 			if(flowResponse != null)
                 			{
                 				errorDetails = flowResponse.toString();
                 			}
                 			info "Flow trigger failed, falling back to ChatGPT. Error details: " + errorDetails;
                 			fallbackUpdateRecords = Divination_Logs[ID == divinationId.toLong()];
                 			if(fallbackUpdateRecords != null && fallbackUpdateRecords.count() > 0)
                 			{
                 				for each  fallbackUpdateRecord in fallbackUpdateRecords
                 				{
                 					fallbackUpdateRecord.AI_Interpretation="Flow觸發失敗，正在使用備援ChatGPT處理...";
                 					break;
                 				}
                 			}
                 			chatgptResult = thisapp.AIInterpreter.getTarotInterpretation_v2(questionText,questionType,tarotSpreadData);
                 			if(chatgptResult.get("success") == true)
                 			{
                 				successUpdateRecords = Divination_Logs[ID == divinationId.toLong()];
                 				if(successUpdateRecords != null && successUpdateRecords.count() > 0)
                 				{
                 					for each  successUpdateRecord in successUpdateRecords
                 					{
                 						successUpdateRecord.AI_Interpretation="[備援ChatGPT] " + chatgptResult.get("interpretation");
                 						successUpdateRecord.Status="已完成";
                 						break;
                 					}
                 				}
                 				response.put("success",true);
                 				response.put("processingMethod","備援ChatGPT");
                 				response.put("interpretation",chatgptResult.get("interpretation"));
                 				info "ChatGPT backup processing successful, divination ID: " + divinationId;
                 			}
                 			else
                 			{
                 				failUpdateRecords = Divination_Logs[ID == divinationId.toLong()];
                 				if(failUpdateRecords != null && failUpdateRecords.count() > 0)
                 				{
                 					for each  failUpdateRecord in failUpdateRecords
                 					{
                 						failUpdateRecord.Status="已提問";
                 						failUpdateRecord.AI_Interpretation="很抱歉，系統暫時無法提供占卜解讀，請稍後再試。";
                 						break;
                 					}
                 				}
                 				response.put("success",false);
                 				response.put("error","Flow和ChatGPT都無法使用");
                 			}
                 		}
                 	}
                 	catch (e)
                 	{
                 		response.put("success",false);
                 		response.put("error","API processing error: " + e.toString());
                 		try 
                 		{
                 			if(divinationId != null && divinationId != "")
                 			{
                 				errorUpdateRecords = Divination_Logs[ID == divinationId.toLong()];
                 				if(errorUpdateRecords.count() > 0)
                 				{
                 					for each  errorUpdate in errorUpdateRecords
                 					{
                 						errorUpdate.Status="已提問";
                 						errorUpdate.AI_Interpretation="很抱歉，占卜過程中發生系統錯誤，請重新嘗試。";
                 						break;
                 					}
                 					info "Updated error status, divination ID: " + divinationId;
                 				}
                 				else
                 				{
                 					info "Warning: Cannot find divination record during error handling, ID: " + divinationId;
                 				}
                 			}
                 		}
                 		catch (updateError)
                 		{
                 			info "Failed to update error status: " + updateError.toString();
                 		}
                 		info "Flow.triggerTarotFlowProcessor execution error: " + e.toString();
                 	}
                 	return response;
                 }
void Gamma.generateReportFromLog(int divinationLogId)
                 {
                 	// =============================================================================
                 	// 函數名稱：Gamma.generateReportFromLog
                 	// 函數用途：根據指定的占卜紀錄ID，建立一份新的Gamma報告生成任務，並觸發Zoho Flow。
                 	// 平台：Zoho Creator Function
                 	// 命名空間：Gamma
                 	// =============================================================================
                 	// 1. 查詢原始的占卜紀錄 - 回傳集合
                 	logRecords = Divination_Logs[ID == divinationLogId];
                 	// 2. 檢查集合是否為空
                 	if(logRecords.count() > 0)
                 	{
                 		// 3. 使用 for each 迴圈取得第一筆紀錄
                 		singleLogRecord = null;
                 		for each  record in logRecords
                 		{
                 			singleLogRecord = record;
                 			break;
                 		}
                 		// 4. 從 Client_Link 查詢客戶資料
                 		clientName = "";
                 		if(singleLogRecord.Client_Link != null)
                 		{
                 			clientRecords = Clients_Report[ID == singleLogRecord.Client_Link];
                 			if(clientRecords.count() > 0)
                 			{
                 				singleClientRecord = null;
                 				for each  clientRecord in clientRecords
                 				{
                 					singleClientRecord = clientRecord;
                 					break;
                 				}
                 				if(singleClientRecord != null && singleClientRecord.Visitor_Name != null)
                 				{
                 					firstName = ifnull(singleClientRecord.Visitor_Name.first_name,"");
                 					lastName = ifnull(singleClientRecord.Visitor_Name.last_name,"");
                 					clientName = lastName + " " + firstName;
                 				}
                 			}
                 		}
                 		// 5. 取得占卜內容（優先使用完整解讀，沒有則使用基本描述）
                 		divinationContent = "";
                 		if(singleLogRecord.AI_Interpretation_Full != null && singleLogRecord.AI_Interpretation_Full != "")
                 		{
                 			divinationContent = singleLogRecord.AI_Interpretation_Full;
                 		}
                 		else if(singleLogRecord.AI_Interpretation != null && singleLogRecord.AI_Interpretation != "")
                 		{
                 			divinationContent = singleLogRecord.AI_Interpretation;
                 		}
                 		else
                 		{
                 			divinationContent = "此占卜紀錄暫無詳細解讀內容";
                 		}
                 		// 6. 建立一筆新的報告生成任務
                 		newReportId = insert into Divination_Reports
                 		[
                 			reportTitle="關於「" + singleLogRecord.Original_Question + "」的占卜報告"
                 			reportSubtitle="客戶：" + clientName
                 			reportContentMarkdown=divinationContent
                 			reportTone="鼓舞人心"
                 			imagePrompt="魅惑, 性感色情, 粉色期待, 一堆厲害的忍者龜背景圖"
                 			divinationLog=divinationLogId
                 			status="待處理"
                 			Added_User=zoho.loginuser
                 		];
                 		// 7. 準備呼叫 Flow 的資料
                 		flowPayload = Map();
                 		flowPayload.put("reportTitle","關於「" + singleLogRecord.Original_Question + "」的占卜報告");
                 		flowPayload.put("reportSubtitle","客戶：" + clientName);
                 		flowPayload.put("reportContentMarkdown",divinationContent);
                 		flowPayload.put("reportTone","鼓舞人心");
                 		flowPayload.put("imagePrompt","魅惑, 性感色情, 粉色期待, 一堆厲害的忍者龜背景圖");
                 		flowPayload.put("creatorRecordId",newReportId);
                 		// 8. 呼叫 Zoho Flow 的 Webhook URL
                 		flowWebhookUrl = "https://flow.zoho.com/876589289/flow/webhook/incoming?zapikey=1001.c2f3c731da1c083c0e9b189b9beed841.aeaee06484461f4563e8d52e8cc42f25&isdebug=false";
                 		requestHeaders = Map();
                 		requestHeaders.put("Content-Type","application/json");
                 		response = invokeurl
                 		[
                 			url :flowWebhookUrl
                 			type :POST
                 			parameters:flowPayload.toString()
                 			headers:requestHeaders
                 		];
                 		info "已成功觸發 Gamma 報告生成流程，報告請求 ID 為：" + newReportId;
                 	}
                 	else
                 	{
                 		info "找不到指定的占卜紀錄，ID：" + divinationLogId;
                 	}
                 }
string GuaCalculator.BaziToBitSequence(string bazi)
                 {
                 	// 1. 定義天干、地支順序列表
                 	stems = List();
                 	stems.add("甲");
                 	stems.add("乙");
                 	stems.add("丙");
                 	stems.add("丁");
                 	stems.add("戊");
                 	stems.add("己");
                 	stems.add("庚");
                 	stems.add("辛");
                 	stems.add("壬");
                 	stems.add("癸");
                 	branches = List();
                 	branches.add("子");
                 	branches.add("丑");
                 	branches.add("寅");
                 	branches.add("卯");
                 	branches.add("辰");
                 	branches.add("巳");
                 	branches.add("午");
                 	branches.add("未");
                 	branches.add("申");
                 	branches.add("酉");
                 	branches.add("戌");
                 	branches.add("亥");
                 	// 2. 拆成四柱
                 	pillars = bazi.toList(" ");
                 	// 期望 size=4
                 	// 3. 逐柱計算編號並組字串
                 	seq = "";
                 	for each  pillar in pillars
                 	{
                 		stem = pillar.subString(0,1);
                 		// 取天干
                 		branch = pillar.subString(1);
                 		// 取地支（從第2個字到結尾）
                 		stemIdx = stems.indexOf(stem) + 1;
                 		// 甲為1，乙為2，…，癸為10
                 		branchIdx = branches.indexOf(branch) + 1;
                 		// 子為1，丑為2，…，亥為12
                 		seq = seq + stemIdx.toString() + "," + branchIdx.toString() + ",";
                 	}
                 	// 4. 去掉最後多餘的逗號
                 	seq = seq.subString(0,seq.length() - 1);
                 	return seq;
                 }
string GuaCalculator.BitToHexagramCode(date birthDateTime)
                 {
                 	birthBazi = thisapp.LunarAI.GetSolarDateTimeBazi(birthDateTime);
                 	birthSeqStr = thisapp.GuaCalculator.BaziToBitSequence(birthBazi);
                 	timeBazi = thisapp.LunarAI.GetCurrentTimeBazi();
                 	timeSeqStr = thisapp.GuaCalculator.BaziToBitSequence(timeBazi);
                 	birthSeq = birthSeqStr.toList();
                 	timeSeq = timeSeqStr.toList();
                 	birthSeqNum = list();
                 	for each  item in birthSeq
                 	{
                 		birthSeqNum.add(item.toLong());
                 	}
                 	timeSeqNum = list();
                 	for each  item in timeSeq
                 	{
                 		timeSeqNum.add(item.toLong());
                 	}
                 	bYs = birthSeqNum.get(0);
                 	bYb = birthSeqNum.get(1);
                 	bMs = birthSeqNum.get(2);
                 	bMb = birthSeqNum.get(3);
                 	bDs = birthSeqNum.get(4);
                 	bDb = birthSeqNum.get(5);
                 	bHs = birthSeqNum.get(6);
                 	bHb = birthSeqNum.get(7);
                 	tYs = timeSeqNum.get(0);
                 	tYb = timeSeqNum.get(1);
                 	tMs = timeSeqNum.get(2);
                 	tMb = timeSeqNum.get(3);
                 	tDs = timeSeqNum.get(4);
                 	tDb = timeSeqNum.get(5);
                 	tHs = timeSeqNum.get(6);
                 	tHb = timeSeqNum.get(7);
                 	// 天干
                 	L1 = ((bYs + tYs) / 2).round(0);
                 	if((bYs + tYs) % 2 != 0)
                 	{
                 		L1 = L1 + 1;
                 	}
                 	L2 = ((bMs + tMs) / 2).round(0);
                 	if((bMs + tMs) % 2 != 0)
                 	{
                 		L2 = L2 + 1;
                 	}
                 	L3 = ((bDs + tDs) / 2).round(0);
                 	if((bDs + tDs) % 2 != 0)
                 	{
                 		L3 = L3 + 1;
                 	}
                 	L4 = ((bHs + tHs) / 2).round(0);
                 	if((bHs + tHs) % 2 != 0)
                 	{
                 		L4 = L4 + 1;
                 	}
                 	// 地支
                 	U1 = ((bYb + tYb) / 2).round(0);
                 	if((bYb + tYb) % 2 != 0)
                 	{
                 		U1 = U1 + 1;
                 	}
                 	U2 = ((bMb + tMb) / 2).round(0);
                 	if((bMb + tMb) % 2 != 0)
                 	{
                 		U2 = U2 + 1;
                 	}
                 	U3 = ((bDb + tDb) / 2).round(0);
                 	if((bDb + tDb) % 2 != 0)
                 	{
                 		U3 = U3 + 1;
                 	}
                 	U4 = ((bHb + tHb) / 2).round(0);
                 	if((bHb + tHb) % 2 != 0)
                 	{
                 		U4 = U4 + 1;
                 	}
                 	// 上卦（地支）
                 	X = (U1 + U2) % 2;
                 	Y = (U2 + U3) % 2;
                 	Z = (U3 + U4) % 2;
                 	// 下卦（天干）
                 	A = (L1 + L2) % 2;
                 	B = (L2 + L3) % 2;
                 	C = (L3 + L4) % 2;
                 	return X.toString() + Y.toString() + Z.toString() + A.toString() + B.toString() + C.toString();
                 }
string GuaCalculator.getHexagramBySolarBirthday(date solarDateTime)
                 {
                 	// A7: 陽曆 → 八字 → 爻碼（結合「出生時辰八字」與「系統當前占卜時辰八字」）
                 	// 1. 呼叫 A6：將「生日 + 占卜時間」轉成 6 位爻碼字串
                 	hexCode = thisapp.GuaCalculator.BitToHexagramCode(solarDateTime);
                 	// 2. 直接回傳六爻爻碼（格式例如："001001"）
                 	return hexCode;
                 }
map Hexagram.fetchHexagram(int hex_id)
                 {
                 	// 抓出卦象的資料表中符合 ID 的那一筆
                 	hex_list = I_Ching_Form[ID == hex_id];
                 	// 如果有資料就回傳
                 	if(hex_list.count() > 0)
                 	{
                 		// 將 Record 轉成 map 回傳
                 		return hex_list.get(0).toMap();
                 	}
                 	else
                 	{
                 		// 若找不到，印出提示並回傳空 map
                 		info "⚠ 沒有找到對應的卦象 ID：" + hex_id.toString();
                 		return Map();
                 	}
                 }
map Hexagram.getHexagramByYaoCode(string yao_code)
                 {
                 	result = I_Ching_Form[yao == yao_code];
                 	if(result == null)
                 	{
                 		return {"code":4004,"status":"Not Found","yao_code":yao_code};
                 	}
                 	hex_data = Map();
                 	// ? 卦象核心文字欄位
                 	hex_data.put("yao",result.yao);
                 	hex_data.put("up_yao",result.up_yao);
                 	hex_data.put("down_yao",result.down_yao);
                 	hex_data.put("up_appearance",result.up_appearance);
                 	hex_data.put("down_appearance",result.down_appearance);
                 	hex_data.put("appearance",result.appearance);
                 	hex_data.put("five_elements",result.five_elements);
                 	hex_data.put("life_and_death",result.life_and_death);
                 	// ? 卦象內文與主題分析
                 	hex_data.put("yao_article",result.yao_article);
                 	hex_data.put("yao_comment",result.yao_comment);
                 	hex_data.put("yao_wish",result.yao_wish);
                 	hex_data.put("yao_love",result.yao_love);
                 	hex_data.put("yao_work",result.yao_work);
                 	hex_data.put("yao_business",result.yao_business);
                 	hex_data.put("yao_study",result.yao_study);
                 	hex_data.put("yao_travel",result.yao_travel);
                 	// ? 符令與圖示
                 	hex_data.put("symbol_1",result.symbol_1);
                 	hex_data.put("symbol_2",result.symbol_2);
                 	hex_data.put("symbol_3",result.symbol_3);
                 	hex_data.put("symbol_4",result.symbol_4);
                 	hex_data.put("symbol_5",result.symbol_5);
                 	// ✅ 回傳成功代碼
                 	hex_data.put("code",3000);
                 	hex_data.put("status","Success");
                 	hex_data.put("yao_code",yao_code);
                 	return hex_data;
                 }
map IChing.calculateHexagram(date solar_birthday, date divination_datetime)
                 {
                 	// [[memory:2376637]] [[memory:3369310]] [[memory:3974009]]
                 	// ==================================================================================
                 	// 函數名稱：IChing.calculateHexagram
                 	// 函數目的：根據個案生日和占卜時間，透過三階段的數字轉換邏輯，計算出對應的易經六爻碼。
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// solar_birthday (date)     - 個案的西元國曆生日。
                 	// divination_datetime (date) - 占卜當下的西元國曆日期與時間。
                 	//
                 	// 回傳：
                 	// 一個 Map，包含計算結果。
                 	// 成功時:
                 	// {
                 	//     "success": true,
                 	//     "hexagram_code": "111010", // 最終的六爻碼
                 	//     "intermediate_results": { ... } // 用於偵錯的中間步驟資料
                 	// }
                 	// 失敗時:
                 	// {
                 	//     "success": false,
                 	//     "error": "詳細的錯誤訊息"
                 	// }
                 	//
                 	// ==================================================================================
                 	// 最終回傳的 Map
                 	response_map = Map();
                 	// 用於存放中間過程，方便除錯
                 	intermediate_results = Map();
                 	try 
                 	{
                 		// --- 步驟 0: 建立干支數值對照表 ---
                 		heavenly_stems_map = Map();
                 		heavenly_stems_map.put("甲",1);
                 		heavenly_stems_map.put("乙",2);
                 		heavenly_stems_map.put("丙",3);
                 		heavenly_stems_map.put("丁",4);
                 		heavenly_stems_map.put("戊",5);
                 		heavenly_stems_map.put("己",6);
                 		heavenly_stems_map.put("庚",7);
                 		heavenly_stems_map.put("辛",8);
                 		heavenly_stems_map.put("壬",9);
                 		heavenly_stems_map.put("癸",10);
                 		earthly_branches_map = Map();
                 		earthly_branches_map.put("子",1);
                 		earthly_branches_map.put("丑",2);
                 		earthly_branches_map.put("寅",3);
                 		earthly_branches_map.put("卯",4);
                 		earthly_branches_map.put("辰",5);
                 		earthly_branches_map.put("巳",6);
                 		earthly_branches_map.put("午",7);
                 		earthly_branches_map.put("未",8);
                 		earthly_branches_map.put("申",9);
                 		earthly_branches_map.put("酉",10);
                 		earthly_branches_map.put("戌",11);
                 		earthly_branches_map.put("亥",12);
                 		intermediate_results.put("step0_gan_zhi_maps",{"stems":heavenly_stems_map,"branches":earthly_branches_map});
                 		// --- 步驟 0: 獲取生日和占卜時間的八字 ---
                 		birthday_bazi = thisapp.Bazi.PreciseBaziCalculator(solar_birthday);
                 		divination_bazi = thisapp.Bazi.PreciseBaziCalculator(divination_datetime);
                 		if(birthday_bazi.get("success") == false || divination_bazi.get("success") == false)
                 		{
                 			response_map.put("success",false);
                 			response_map.put("error","獲取八字資料失敗。生日八字錯誤：" + birthday_bazi.get("error") + "，占卜八字錯誤：" + divination_bazi.get("error"));
                 			return response_map;
                 		}
                 		intermediate_results.put("step0_bazi_data",{"birthday":birthday_bazi,"divination":divination_bazi});
                 		// --- 階段一: 干支取數與相加 ---
                 		// 從八字 Map 中提取四柱
                 		birthday_pillars = {birthday_bazi.get("年柱"),birthday_bazi.get("月柱"),birthday_bazi.get("日柱"),birthday_bazi.get("時柱")};
                 		divination_pillars = {divination_bazi.get("年柱"),divination_bazi.get("月柱"),divination_bazi.get("日柱"),divination_bazi.get("時柱")};
                 		// 天干與地支的和
                 		stems_sum = List();
                 		branches_sum = List();
                 		// 使用迴圈處理四柱
                 		i = 0;
                 		for each  pillar_group in {{0,1},{2,3},{4,5},{6,7}}
                 		{
                 			// 生日八字
                 			birth_pillar = birthday_pillars.get(i);
                 			birth_stem = birth_pillar.substring(0,1);
                 			birth_branch = birth_pillar.substring(1,2);
                 			// 占卜八字
                 			div_pillar = divination_pillars.get(i);
                 			div_stem = div_pillar.substring(0,1);
                 			div_branch = div_pillar.substring(1,2);
                 			// 相加
                 			current_stem_sum = heavenly_stems_map.get(birth_stem) + heavenly_stems_map.get(div_stem);
                 			current_branch_sum = earthly_branches_map.get(birth_branch) + earthly_branches_map.get(div_branch);
                 			stems_sum.add(current_stem_sum);
                 			branches_sum.add(current_branch_sum);
                 			i = i + 1;
                 		}
                 		intermediate_results.put("step1_sums",{"stems_sum":stems_sum,"branches_sum":branches_sum});
                 		// --- 階段二: 分組、除二並無條件進位 ---
                 		upper_yao_source = List();
                 		lower_yao_source = List();
                 		// 處理地支和 (上爻來源)
                 		for each  val in branches_sum
                 		{
                 			result_float = val.toDecimal() / 2;
                 			result_long = result_float.toLong();
                 			if(result_float > result_long)
                 			{
                 				upper_yao_source.add(result_long + 1);
                 			}
                 			else
                 			{
                 				upper_yao_source.add(result_long);
                 			}
                 		}
                 		// 處理天干和 (下爻來源)
                 		for each  val in stems_sum
                 		{
                 			result_float = val.toDecimal() / 2;
                 			result_long = result_float.toLong();
                 			if(result_float > result_long)
                 			{
                 				lower_yao_source.add(result_long + 1);
                 			}
                 			else
                 			{
                 				lower_yao_source.add(result_long);
                 			}
                 		}
                 		intermediate_results.put("step2_ceiling_results",{"upper_source":upper_yao_source,"lower_source":lower_yao_source});
                 		// --- 階段三: 相鄰加總與奇偶轉換 ---
                 		upper_yao = "";
                 		lower_yao = "";
                 		// 計算上爻 (地支)
                 		sum1 = upper_yao_source.get(0) + upper_yao_source.get(1);
                 		sum2 = upper_yao_source.get(1) + upper_yao_source.get(2);
                 		sum3 = upper_yao_source.get(2) + upper_yao_source.get(3);
                 		upper_yao = upper_yao + sum1 % 2 + sum2 % 2 + sum3 % 2;
                 		// 計算下爻 (天干)
                 		sum1 = lower_yao_source.get(0) + lower_yao_source.get(1);
                 		sum2 = lower_yao_source.get(1) + lower_yao_source.get(2);
                 		sum3 = lower_yao_source.get(2) + lower_yao_source.get(3);
                 		lower_yao = lower_yao + sum1 % 2 + sum2 % 2 + sum3 % 2;
                 		intermediate_results.put("step3_yao_strings",{"upper_yao":upper_yao,"lower_yao":lower_yao});
                 		// --- 組合最終結果 ---
                 		final_hexagram_code = upper_yao + lower_yao;
                 		// 組合成功回傳
                 		response_map.put("success",true);
                 		response_map.put("hexagram_code",final_hexagram_code);
                 		response_map.put("intermediate_results",intermediate_results);
                 	}
                 	catch (e)
                 	{
                 		response_map.put("success",false);
                 		response_map.put("error","計算過程中發生未知錯誤：" + e);
                 	}
                 	return response_map;
                 }
map IChing.getDivinationResult(date solar_birthday)
                 {
                 	// [[memory:2376637]] [[memory:3974009]]
                 	// ==================================================================================
                 	// 函數名稱：IChing.getDivinationResult
                 	// 函數目的：【易經占卜總查詢函數】
                 	//
                 	// 這是一個高階的「總引擎」函數，旨在簡化整個易經占卜的呼叫流程。
                 	// 它會自動處理所有中間步驟，您只需要提供「個案生日」，就能一步到位得到最終的完整卦象詳解。
                 	//
                 	// 核心運作流程：
                 	// 1. 自動獲取【當下】的系統時間作為占卜時間。
                 	// 2. 呼叫 IChing.calculateHexagram 函數，將生日與占卜時間轉換為「六爻碼」。
                 	// 3. 呼叫 IChing.getHexagramDetails 函數，用上一步得到的「六爻碼」查詢對應的詳細卦象資料。
                 	// 4. 回傳完整的卦象資料 Map。
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// solar_birthday (date) - 個案的西元國曆生日。
                 	//
                 	// 回傳：
                 	// 一個 Map，直接是 IChing.getHexagramDetails 的回傳結果，包含該卦象的完整資訊。
                 	// 成功時: {"success": true, "appearance": "乾", "yao_article": "困龍得水...", ...}
                 	// 失敗時: {"success": false, "error": "詳細的錯誤訊息"}
                 	//
                 	// ==================================================================================
                 	// 建立一個最終回傳用的 Map，確保函數只有一個出口點
                 	final_response = Map();
                 	try 
                 	{
                 		// 步驟 1: 自動獲取當前系統時間作為占卜時間
                 		divination_datetime = zoho.currenttime;
                 		// 步驟 2: 呼叫計算函數，從日期產生爻碼
                 		hexagram_result = thisapp.IChing.calculateHexagram(solar_birthday,divination_datetime);
                 		// 檢查第一步是否有誤
                 		if(hexagram_result.get("success") == false)
                 		{
                 			// 如果計算爻碼出錯，將錯誤資訊複製到最終回傳的 Map 中
                 			final_response.putAll(hexagram_result);
                 		}
                 		else
                 		{
                 			// 步驟 3: 從上一步的結果中提取爻碼
                 			hexagram_code = hexagram_result.get("hexagram_code");
                 			// 步驟 4: 呼叫查詢函數，用爻碼獲取詳細卦象資料
                 			details_result = thisapp.IChing.getHexagramDetails(hexagram_code);
                 			// 步驟 5: 將最終的查詢結果複製到最終回傳的 Map 中
                 			final_response.putAll(details_result);
                 		}
                 	}
                 	catch (e)
                 	{
                 		final_response.put("success",false);
                 		final_response.put("error","在 getDivinationResult 總查詢函數中發生未知錯誤：" + e);
                 	}
                 	// 在函數的最後，統一回傳結果
                 	return final_response;
                 }
map IChing.getHexagramDetails(string hexagram_code)
                 {
                 	// [[memory:2376637]] [[memory:3369427]]
                 	// ==================================================================================
                 	// 函數名稱：IChing.getHexagramDetails
                 	// 函數目的：根據輸入的六爻碼，從 I_Ching_Form 表中查詢對應的卦象詳細資料。
                 	// ==================================================================================
                 	//
                 	// 參數：
                 	// hexagram_code (string) - 六位數字的爻碼字串，例如 "111111" 代表乾卦。
                 	//
                 	// 回傳：
                 	// 一個 Map，包含該卦象的完整資訊。
                 	// 如果成功，Map 結構將包含：
                 	// {
                 	//     "success": true,
                 	//     "yao_code": "111111",
                 	//     "appearance": "乾",
                 	//     "yao_article": "困龍得水好運交...",
                 	//     "yao_comment": "象徵天，喻龍...",
                 	//     "symbol_1": "<符令1的URL或ID>",
                 	//     "symbol_2": "<符令2的URL或ID>",
                 	//     ... 其他欄位 ...
                 	// }
                 	// 如果找不到對應的卦象，回傳的 Map 將包含：
                 	// {
                 	//     "success": false,
                 	//     "error": "找不到對應的卦象資料，請檢查爻碼是否正確。"
                 	// }
                 	//
                 	// ==================================================================================
                 	// 根據傳入的爻碼查詢 I_Ching_Form 表單
                 	hexagram_record = I_Ching_Form[yao == hexagram_code];
                 	// 準備回傳的 Map
                 	response_map = Map();
                 	// 檢查是否有查詢到紀錄
                 	if(hexagram_record.count() > 0)
                 	{
                 		// 查詢成功，組合回傳的資料
                 		response_map.put("success",true);
                 		response_map.put("yao_code",hexagram_record.yao);
                 		response_map.put("appearance",hexagram_record.appearance);
                 		response_map.put("up_appearance",hexagram_record.up_appearance);
                 		response_map.put("down_appearance",hexagram_record.down_appearance);
                 		response_map.put("five_elements",hexagram_record.five_elements);
                 		response_map.put("life_and_death",hexagram_record.life_and_death);
                 		response_map.put("symbol_1",hexagram_record.symbol_1);
                 		response_map.put("symbol_2",hexagram_record.symbol_2);
                 		response_map.put("symbol_3",hexagram_record.symbol_3);
                 		response_map.put("symbol_4",hexagram_record.symbol_4);
                 		response_map.put("symbol_5",hexagram_record.symbol_5);
                 		response_map.put("yao_article",hexagram_record.yao_article);
                 		response_map.put("yao_comment",hexagram_record.yao_comment);
                 		response_map.put("yao_work",hexagram_record.yao_work);
                 		response_map.put("yao_business",hexagram_record.yao_business);
                 		response_map.put("yao_study",hexagram_record.yao_study);
                 		response_map.put("yao_travel",hexagram_record.yao_travel);
                 		response_map.put("yao_love",hexagram_record.yao_love);
                 		response_map.put("yao_wish",hexagram_record.yao_wish);
                 	}
                 	else
                 	{
                 		// 查詢失敗，回傳錯誤訊息
                 		response_map.put("success",false);
                 		response_map.put("error","在 I_Ching_Form 中找不到爻碼為 " + hexagram_code + " 的資料。");
                 	}
                 	return response_map;
                 }
map LunarAI.calculateLunarDetails(date current_solar_date, map lunar_constants)
                 {
                 	/*
                 	 * ======================================================================
                 	 * 內部函數：通用農曆計算引擎
                 	 * 功能：接收一個國曆日期和常數資料庫，回傳完整的農曆資訊。
                 	 *      這是所有農曆計算的核心，被上層的業務邏輯函數調用。
                 	 * 命名空間：LunarAI (內部使用)
                 	 * 參數：
                 	 *   - current_solar_date (date): 需要計算的國曆日期
                 	 *   - lunar_constants (map): 由 LunarData.getConstants() 提供的資料庫
                 	 * 回傳：Map - 包含該日期的詳細農曆資訊
                 	 * 作者：Gemini (Refactored)
                 	 * ======================================================================
                 	 */
                 	// 1. 初始化回傳的 Map 和從常數庫中提取資料
                 	result_map = Map();
                 	new_year_map = lunar_constants.get("new_year_map");
                 	lunar_month_structure_map = lunar_constants.get("lunar_month_structure_map");
                 	leap_month_map = lunar_constants.get("leap_month_map");
                 	month_name_map = lunar_constants.get("month_name_map");
                 	day_name_map = lunar_constants.get("day_name_map");
                 	keys = new_year_map.keys();
                 	lunar_year_str = "";
                 	// 2. 判斷國曆日期對應的農曆年份
                 	current_gregorian_year = current_solar_date.getYear();
                 	current_gregorian_year_str = current_gregorian_year.toString();
                 	if(!keys.contains(current_gregorian_year_str))
                 	{
                 		result_map.put("error","年份超出計算範圍 (" + current_gregorian_year_str + ")");
                 		return result_map;
                 	}
                 	this_year_new_year_dt = new_year_map.get(current_gregorian_year_str).toDate("yyyy-MM-dd HH:mm:ss");
                 	if(current_solar_date < this_year_new_year_dt)
                 	{
                 		lunar_year_numeric = current_gregorian_year - 1;
                 		lunar_year_str = lunar_year_numeric.toString();
                 		if(!keys.contains(lunar_year_str))
                 		{
                 			result_map.put("error","年份 (判斷農曆年後 " + lunar_year_str + ") 超出計算範圍");
                 			return result_map;
                 		}
                 		this_year_new_year_dt = new_year_map.get(lunar_year_str).toDate("yyyy-MM-dd HH:mm:ss");
                 	}
                 	else
                 	{
                 		lunar_year_str = current_gregorian_year_str;
                 	}
                 	// 3. 計算距離農曆新年的天數差
                 	/*
                 	 * [[BUG FIX]] 修正天數計算方法
                 	 * 舊方法：使用 epoch 秒數相減再除以一天的秒數，此方法容易因時區或微小誤差導致結果少一天。
                 	 * 新方法：改用 Deluge 內建的 daysBetween() 函數，此函數基於日曆計算，更穩定可靠。
                 	 */
                 	days_passed_since_lunar_new_year = this_year_new_year_dt.daysBetween(current_solar_date);
                 	// 4. 根據大小月 & 閏月資料計算農曆月和日
                 	month_days_list = lunar_month_structure_map.get(lunar_year_str);
                 	current_leap_month_num = ifnull(leap_month_map.get(lunar_year_str),0);
                 	calculated_lunar_month = 1;
                 	calculated_lunar_day = 0;
                 	temp_days_passed = days_passed_since_lunar_new_year;
                 	for each  num_days_in_month in month_days_list
                 	{
                 		if(temp_days_passed < num_days_in_month)
                 		{
                 			calculated_lunar_day = temp_days_passed + 1;
                 			break;
                 		}
                 		temp_days_passed = temp_days_passed - num_days_in_month;
                 		calculated_lunar_month = calculated_lunar_month + 1;
                 	}
                 	// 5. 處理閏月情況，得到最終顯示的月份
                 	is_this_month_leap = false;
                 	display_lunar_month = calculated_lunar_month;
                 	if(current_leap_month_num != 0)
                 	{
                 		if(calculated_lunar_month == current_leap_month_num + 1)
                 		{
                 			is_this_month_leap = true;
                 			display_lunar_month = current_leap_month_num;
                 		}
                 		else if(calculated_lunar_month > current_leap_month_num + 1)
                 		{
                 			display_lunar_month = calculated_lunar_month - 1;
                 		}
                 	}
                 	// 6. 判斷時辰文字 (新增格式化邏輯)
                 	hour_of_day = current_solar_date.getHour();
                 	shichen_text = "";
                 	if(hour_of_day >= 23 || hour_of_day < 1)
                 	{
                 		if(hour_of_day >= 23)
                 		{
                 			shichen_text = " 夜子時生";
                 		}
                 		else
                 		{
                 			shichen_text = " 早子時生";
                 		}
                 	}
                 	else if(hour_of_day >= 1 && hour_of_day < 3)
                 	{
                 		shichen_text = " 丑時生";
                 	}
                 	else if(hour_of_day >= 3 && hour_of_day < 5)
                 	{
                 		shichen_text = " 寅時生";
                 	}
                 	else if(hour_of_day >= 5 && hour_of_day < 7)
                 	{
                 		shichen_text = " 卯時生";
                 	}
                 	else if(hour_of_day >= 7 && hour_of_day < 9)
                 	{
                 		shichen_text = " 辰時生";
                 	}
                 	else if(hour_of_day >= 9 && hour_of_day < 11)
                 	{
                 		shichen_text = " 巳時生";
                 	}
                 	else if(hour_of_day >= 11 && hour_of_day < 13)
                 	{
                 		shichen_text = " 午時生";
                 	}
                 	else if(hour_of_day >= 13 && hour_of_day < 15)
                 	{
                 		shichen_text = " 未時生";
                 	}
                 	else if(hour_of_day >= 15 && hour_of_day < 17)
                 	{
                 		shichen_text = " 申時生";
                 	}
                 	else if(hour_of_day >= 17 && hour_of_day < 19)
                 	{
                 		shichen_text = " 酉時生";
                 	}
                 	else if(hour_of_day >= 19 && hour_of_day < 21)
                 	{
                 		shichen_text = " 戌時生";
                 	}
                 	else if(hour_of_day >= 21 && hour_of_day < 23)
                 	{
                 		shichen_text = " 亥時生";
                 	}
                 	// 7. 組合最終的回傳 Map
                 	is_leap_month_text_val = if(is_this_month_leap,"是","否");
                 	lunar_month_with_leap_prefix = if(is_this_month_leap,"閏","") + display_lunar_month.toString();
                 	chinese_month_name = if(is_this_month_leap,"閏","") + month_name_map.get(display_lunar_month) + "月";
                 	chinese_day_name = day_name_map.get(calculated_lunar_day) + "日";
                 	result_map.put("國曆",current_solar_date.toString("yyyy/MM/dd HH:mm:ss"));
                 	result_map.put("閏月",is_leap_month_text_val);
                 	result_map.put("農曆",lunar_year_str + "年" + lunar_month_with_leap_prefix + "月" + calculated_lunar_day.toString() + "日" + shichen_text);
                 	result_map.put("中文日期",lunar_year_str + ", " + chinese_month_name + chinese_day_name + shichen_text);
                 	result_map.put("lunar_month_numeric",display_lunar_month);
                 	result_map.put("lunar_day_numeric",calculated_lunar_day);
                 	result_map.put("error","");
                 	return result_map;
                 }
map LunarAI.convertToBaZi(date solar_date, map lunar)
                 {
                 	// 1. 先拿到農曆資訊
                 	y = lunar.get("lunar_year").toLong();
                 	m = lunar.get("lunar_month").toLong();
                 	d = lunar.get("lunar_day").toLong();
                 	isLeap = ifnull(lunar.get("is_leap_month"),false);
                 	h = solar_date.getHour();
                 	// 0–23
                 	// 2. 天干、地支陣列
                 	stems = {"甲","乙","丙","丁","戊","己","庚","辛","壬","癸"};
                 	branches = {"子","丑","寅","卯","辰","巳","午","未","申","酉","戌","亥"};
                 	// 3. 年柱（甲子年對應西元4年）
                 	offset = (y - 4) % 60;
                 	if(offset < 0)
                 	{
                 		offset = offset + 60;
                 	}
                 	year_stem = stems.get(offset % 10);
                 	year_branch = branches.get(offset % 12);
                 	// 4. 月柱：先算出月干起點，再加上 (m-2)，保證不為負
                 	y_stem_idx = stems.indexOf(year_stem);
                 	month_stem_start = (y_stem_idx * 2 + 2) % 10;
                 	month_stem_idx = (month_stem_start + m - 2 + 10) % 10;
                 	month_stem = stems.get(month_stem_idx);
                 	month_branch_idx = (m + 1) % 12;
                 	month_branch = branches.get(month_branch_idx);
                 	// 5. 日柱：基準日用固定字串轉 Date；days_diff 取模後正規化
                 	base_date = "1900-01-01".toDate("yyyy-MM-dd");
                 	days_diff = ((solar_date.toLong() - base_date.toLong()) / (1000 * 60 * 60 * 24)).toLong();
                 	idx_day = days_diff % 60;
                 	if(idx_day < 0)
                 	{
                 		idx_day = idx_day + 60;
                 	}
                 	day_stem_idx = idx_day % 10;
                 	day_branch_idx = idx_day % 12;
                 	day_stem = stems.get(day_stem_idx);
                 	day_branch = branches.get(day_branch_idx);
                 	// 6. 時柱：半點制 + 正規化
                 	hour_idx = ((h + 1) / 2).toLong() % 12;
                 	if(hour_idx < 0)
                 	{
                 		hour_idx = hour_idx + 12;
                 	}
                 	hour_branch = branches.get(hour_idx);
                 	hour_stem_idx = (day_stem_idx * 2 + hour_idx) % 10;
                 	if(hour_stem_idx < 0)
                 	{
                 		hour_stem_idx = hour_stem_idx + 10;
                 	}
                 	hour_stem = stems.get(hour_stem_idx);
                 	// 7. 組回傳 Map
                 	bazi = Map();
                 	bazi.put("year_pillar",year_stem + year_branch);
                 	bazi.put("month_pillar",month_stem + month_branch);
                 	bazi.put("day_pillar",day_stem + day_branch);
                 	bazi.put("hour_pillar",hour_stem + hour_branch);
                 	return bazi;
                 }
