											{
												input.Chinese_Zodiac = chinese_zodiac_result.get("zodiac_id");
												// ======================================================================
												// 虛歲功能
												// ======================================================================
												birth_lunar_year = chinese_zodiac_result.get("zodiac_year");
												current_year = zoho.currentdate.getYear();
												current_lunar_year = current_year;
												// 判斷當前日期是否已過農曆新年，以決定當前的農曆年份
												current_lunar_data_record = LunarData[Solar_Year == current_year];
												if(current_lunar_data_record.count() > 0)
												{
													current_lunar_new_year = current_lunar_data_record.Lunar_New_Year;
													if(zoho.currentdate < current_lunar_new_year.toDate())
													{
														current_lunar_year = current_year - 1;
													}
													// 虛歲 = 當前農曆年份 - 出生農曆年份 + 1
													nominal_age = current_lunar_year - birth_lunar_year + 1;
													input.Nominal_Age = nominal_age;
												}
												else
												{
													input.Nominal_Age = null;
												}
											}
											else
											{
												input.Chinese_Zodiac = null;
												input.Nominal_Age = null;
											}
											// ======================================================================
											// 犯太歲功能
											// ======================================================================
											current_year_for_taisui = zoho.currentdate.getYear();
											taisui_result = thisapp.Zodiac.getTaisuiStatus(input.Date_Of_Birth,current_year_for_taisui);
											if(taisui_result.get("success") == true)
											{
												// 更新「本命太歲」和「流年太歲」的 Lookup 欄位
												input.Taisui_Deity_Name_Birth = taisui_result.get("birth_ganzhi_id");
												input.Taisui_Deity_Name_Year = taisui_result.get("query_year_ganzhi_id");
												// (可選) 如果您有一個文字欄位來顯示犯太歲狀態，可以取消下面這行的註解
												// input.Taisui_Conflict_Status = taisui_result.get("conflict_type");
											}
											else
											{
												// 如果計算失敗，清空相關欄位
												input.Taisui_Deity_Name_Birth = null;
												input.Taisui_Deity_Name_Year = null;
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空所有相關的衍生欄位
											input.Zodiac_Signs = null;
											input.Chinese_Zodiac = null;
											input.Nominal_Age = null;
											input.Taisui_Deity_Name_Birth = null;
											input.Taisui_Deity_Name_Year = null;
										}
						)
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnEdit_UpdateLunarMansion.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會根據國曆生日，
										//               自動查詢並帶入對應的「二十八星宿」Lookup 記錄。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.Star.getLunarMansion (函數)
										//   - Twenty_Eight_Lunar_Mansions (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 1. 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// 2. 呼叫我們建立的 Star.getLunarMansion 函數來查詢星宿名稱
											mansion_result = thisapp.Star.getLunarMansion(input.Date_Of_Birth);
											// 3. 檢查函數是否成功執行並回傳了星宿名稱
											if(mansion_result.get("success") == true)
											{
												// 4. 從回傳結果中取得星宿名稱
												mansion_name = mansion_result.get("mansion_name");
												// 5. 使用星宿名稱去查詢 "二十八星宿詳細資訊表" (Twenty_Eight_Lunar_Mansions)
												mansion_info_record = Twenty_Eight_Lunar_Mansions[Star_Name == mansion_name];
												// 6. 處理查詢結果
												if(mansion_info_record != null)
												{
													// 如果找到了對應的記錄，就將個案表單的 Lookup 欄位更新為該記錄的 ID
													input.Twenty_Eight_Lunar_Mansions = mansion_info_record.ID;
												}
												else
												{
													// 如果在詳細資訊表中找不到該星宿，則清空 Lookup 欄位
													input.Twenty_Eight_Lunar_Mansions = null;
													// (可選) 您可以在此處加上 alert 通知管理員資料不完整
													// alert "資料庫警告：在 Twenty_Eight_Lunar_Mansions 表中找不到名為 '" + mansion_name + "' 的星宿記錄。";
												}
											}
											else
											{
												// 如果 getLunarMansion 函數執行失敗，也清空 Lookup 欄位
												input.Twenty_Eight_Lunar_Mansions = null;
												// (可選) 您可以在此處加上 alert 通知使用者或管理員
												// alert "無法計算星宿，錯誤訊息：" + mansion_result.get("error");
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空星宿 Lookup 欄位
											input.Twenty_Eight_Lunar_Mansions = null;
										}
						)
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnSuccess_UpdateBaziPillars.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 的紀錄成功儲存後觸發。
										//               此腳本會根據「生日」(Date_Of_Birth) 欄位，自動呼叫八字計算函數，
										//               並將計算出的年、月、日、時四柱（共八個干支）的 Lookup 欄位，
										//               以及一個完整的八字命盤字串，回填到目前的個案紀錄中。
										//
										// @trigger_event: On Add / On Edit -> On Success (新增/編輯 -> 成功時)
										// @trigger_form: Clients_Report (個案表單)
										//
										// @dependencies: 
										//   - thisapp.Bazi.PreciseBaziCalculator (函數)
										//   - Heavenly_Stems (表單)
										//   - Earthly_Branches (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 "On Add / On Edit -> On Success" 事件中。
										//
										// 1. 從 input 物件中獲取生日。
										dob = input.Date_Of_Birth;
										// 檢查生日欄位是否有值，以避免執行錯誤。
										if(dob != null)
										{
											// 2. 呼叫主要的八字計算函數，獲取完整的八字命盤 map。
											bazi_map = thisapp.Bazi.PreciseBaziCalculator(dob);
											// 檢查計算是否成功。
											if(bazi_map.get("success") == true)
											{
												// 3. 從回傳結果中，提取四柱各自的詳細 map。
												year_pillar_details = bazi_map.get("年柱詳情");
												month_pillar_details = bazi_map.get("月柱詳情");
												day_pillar_details = bazi_map.get("日柱詳情");
												hour_pillar_details = bazi_map.get("時柱詳情");
												// 4. 從各柱的詳情中，取得天干與地支的名稱。
												year_stem_name = year_pillar_details.get("stem");
												year_branch_name = year_pillar_details.get("branch");
												month_stem_name = month_pillar_details.get("stem");
												month_branch_name = month_pillar_details.get("branch");
												day_stem_name = day_pillar_details.get("stem");
												day_branch_name = day_pillar_details.get("branch");
												hour_stem_name = hour_pillar_details.get("stem");
												hour_branch_name = hour_pillar_details.get("branch");
												// 5. 將干支名稱組合成一個格式化的完整八字字串。
												full_bazi_string = (year_stem_name + year_branch_name) + " " + (month_stem_name + month_branch_name) + " " + (day_stem_name + day_branch_name) + " " + (hour_stem_name + hour_branch_name);
												// 6. 從 Lookup 表單中查詢對應干支的紀錄 ID。
												// 查詢天干
												year_stem_record = Heavenly_Stems[Stem_Name == year_stem_name];
												month_stem_record = Heavenly_Stems[Stem_Name == month_stem_name];
												day_stem_record = Heavenly_Stems[Stem_Name == day_stem_name];
												hour_stem_record = Heavenly_Stems[Stem_Name == hour_stem_name];
												// 查詢地支
												year_branch_record = Earthly_Branches[Branch_Name == year_branch_name];
												month_branch_record = Earthly_Branches[Branch_Name == month_branch_name];
												day_branch_record = Earthly_Branches[Branch_Name == day_branch_name];
												hour_branch_record = Earthly_Branches[Branch_Name == hour_branch_name];
												// 7. 直接更新當前的個案紀錄。
												// 包含 8 個 Lookup 欄位和一個新建的組合字串欄位。
												client_record = Clients_Report[ID == input.ID];
												client_record.Year_Heavenly_Stem=year_stem_record.ID;
												client_record.Year_Earthly_Branch=year_branch_record.ID;
												client_record.Month_Heavenly_Stem=month_stem_record.ID;
												client_record.Month_Earthly_Branch=month_branch_record.ID;
												client_record.Day_Heavenly_Stem=day_stem_record.ID;
												client_record.Day_Earthly_Branch=day_branch_record.ID;
												client_record.Hour_Heavenly_Stem=hour_stem_record.ID;
												client_record.Hour_Earthly_Branch=hour_branch_record.ID;
												// 更新新建的文字欄位 "Full_Bazi"。
												client_record.Full_Bazi=full_bazi_string;
												info "成功更新八字欄位！";
											}
											else
											{
												// 如果八字計算失敗，紀錄錯誤訊息並清空相關欄位。
												error_message = bazi_map.get("error");
												info "八字計算失敗：" + error_message;
												client_record = Clients_Report[ID == input.ID];
												client_record.Full_Bazi="";
												// 清空所有 Lookup 欄位
												client_record.Year_Heavenly_Stem=null;
												client_record.Year_Earthly_Branch=null;
												client_record.Month_Heavenly_Stem=null;
												client_record.Month_Earthly_Branch=null;
												client_record.Day_Heavenly_Stem=null;
												client_record.Day_Earthly_Branch=null;
												client_record.Hour_Heavenly_Stem=null;
												client_record.Hour_Earthly_Branch=null;
											}
										}
										else
										{
											// 如果生日欄位被清空，也一併清空所有八字相關欄位。
											info "出生日期為空，略過八字計算。";
											client_record = Clients_Report[ID == input.ID];
											client_record.Full_Bazi="";
											// 清空所有 Lookup 欄位
											client_record.Year_Heavenly_Stem=null;
											client_record.Year_Earthly_Branch=null;
											client_record.Month_Heavenly_Stem=null;
											client_record.Month_Earthly_Branch=null;
											client_record.Day_Heavenly_Stem=null;
											client_record.Day_Earthly_Branch=null;
											client_record.Hour_Heavenly_Stem=null;
											client_record.Hour_Earthly_Branch=null;
										}
						)
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnEdit_UpdateLunarBirthday.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會結合
										//               國曆轉農曆以及八字計算的結果，生成一個包含干支年份和出生時辰的
										//               完整農曆生日字串，並更新到「農曆生日」欄位。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.LunarAI.SolarToLunar (函數)
										//   - thisapp.Bazi.PreciseBaziCalculator (函數)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 1. 檢查生日欄位是否存在，若不存在則清空農曆生日欄位並結束。
										if(input.Date_Of_Birth != null)
										{
											info "--- Workflow Start: Update Lunar Birthday for DOB = " + input.Date_Of_Birth + " ---";
											// 2. 呼叫核心函數
											solarToLunarResult = thisapp.LunarAI.SolarToLunar(input.Date_Of_Birth);
											info "1. solarToLunarResult: " + solarToLunarResult;
											baziResult = thisapp.Bazi.PreciseBaziCalculator(input.Date_Of_Birth);
											info "2. baziResult: " + baziResult;
											// 3. 從回傳的 Map 中，取出"生日"部分的子 Map。
											birthdayMap = solarToLunarResult.get("生日");
											// 4. 確認兩個函數都成功回傳且無錯誤，才進行後續處理。
											if(birthdayMap != null && birthdayMap.get("error") == "" && baziResult != null && baziResult.get("success") == true)
											{
												originalLunarText = birthdayMap.get("中文日期");
												if(originalLunarText != null && originalLunarText.contains(","))
												{
													// a. 從 baziResult 的巢狀 Map 中安全地取得年柱的干支
													yearPillarDetails = baziResult.get("年柱詳情");
													// b. 再次檢查巢狀 Map 是否存在
													if(yearPillarDetails != null)
													{
														yearGanZhi = yearPillarDetails.get("stem") + yearPillarDetails.get("branch");
														// c. 核心修正：直接替換，不再自行拼接時辰
														// 將 "2023, 十月廿三日 丑時生" 替換成 "癸卯年 十月廿三日 丑時生"
														finalString = originalLunarText.replaceAll(originalLunarText.toList(",").get(0) + ", ",yearGanZhi + "年 ");
														// d. 更新欄位
														input.Lunar_Birthday = finalString;
													}
													else
													{
														// 如果巢狀 Map 不存在，也視為錯誤
														input.Lunar_Birthday = "";
														info "八字計算結果缺少 '年柱詳情' 的巢狀 Map。";
													}
												}
												else
												{
													// 如果農曆日期格式不符預期，直接寫入原始回傳文字。
													input.Lunar_Birthday = originalLunarText;
												}
											}
											else
											{
												// 如果任一轉換過程出錯，清空農曆生日欄位並記錄錯誤。
												input.Lunar_Birthday = "";
												info "農曆生日或八字轉換失敗：solarToLunar error: " + birthdayMap.get("error") + " / bazi success: " + baziResult.get("success");
											}
										}
										else
										{
											// 如果國曆生日欄位被清空，則同步清空農曆生日欄位。
											input.Lunar_Birthday = "";
										}
						)
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnSuccess_UpdateFourPillars.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 的紀錄成功儲存後觸發。
										//               此腳本會根據「生日」(Date_Of_Birth) 欄位，自動計算八字，並將
										//               代表年月日時的「四柱」干支組合，以 Lookup 形式回填到對應的四個欄位中。
										//               此腳本與 OnSuccess_UpdateBaziPillars.deluge 互為補充，用於更新不同的欄位。
										//
										// @trigger_event: On Add / On Edit -> On Success (新增/編輯 -> 成功時)
										// @trigger_form: Clients_Report (個案表單)
										//
										// @dependencies: 
										//   - thisapp.Bazi.PreciseBaziCalculator (函數)
										//   - Sixty_GanZhi_Table (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 "On Add / On Edit -> On Success" 事件中。
										//
										// 1. 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											info "生日欄位已更新，開始計算並更新四柱 Lookup 欄位...";
											// 2. 呼叫核心的精確八字計算函數
											bazi_result = thisapp.Bazi.PreciseBaziCalculator(input.Date_Of_Birth);
											// 3. 檢查計算是否成功
											if(bazi_result.get("success") == true)
											{
												// 4. 從回傳的 Map 中獲取四柱的干支字串
												year_pillar_str = bazi_result.get("年柱");
												month_pillar_str = bazi_result.get("月柱");
												day_pillar_str = bazi_result.get("日柱");
												hour_pillar_str = bazi_result.get("時柱");
												// 在 On Success 事件中，需先取得當前紀錄才能更新
												client_record = Clients_Report[ID == input.ID];
												// 5. 分別查詢 Sixty_GanZhi_Table 以獲取對應的記錄 ID
												// 年柱
												year_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == year_pillar_str];
												if(year_ganzhi_record != null)
												{
													client_record.Year_Pillar=year_ganzhi_record.ID;
												}
												// 月柱
												month_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == month_pillar_str];
												if(month_ganzhi_record != null)
												{
													client_record.Month_Pillar=month_ganzhi_record.ID;
												}
												// 日柱
												day_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == day_pillar_str];
												if(day_ganzhi_record != null)
												{
													client_record.Day_Pillar=day_ganzhi_record.ID;
												}
												// 時柱
												hour_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == hour_pillar_str];
												if(hour_ganzhi_record != null)
												{
													client_record.Hour_Pillar=hour_ganzhi_record.ID;
												}
												info "四柱 Lookup 欄位更新成功！";
											}
											else
											{
												// 如果八字計算失敗，記錄錯誤訊息
												error_message = "四柱 Lookup 更新失敗，八字計算錯誤：" + bazi_result.get("error");
												info error_message;
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空所有四柱欄位
											client_record = Clients_Report[ID == input.ID];
											client_record.Year_Pillar=null;
											client_record.Month_Pillar=null;
											client_record.Day_Pillar=null;
											client_record.Hour_Pillar=null;
											info "生日欄位為空，已清空四柱 Lookup 欄位。";
										}
						)
						custom deluge script
						(
											// [WORKFLOW]
										// Form: Clients_Report (個案報告)
										// Trigger: On User Input (當使用者輸入時)
										// Field: Date_Of_Birth (出生日期)
										// -----------------------------------------------------------------------------
										// Description:
										// 當使用者在「個案報告」表單中填寫或修改「出生日期」欄位時，
										// 此工作流會自動觸發，調用核心函數 Tarot.getLifePathTarot() 來計算本命塔羅牌陣，
										// 並將結果更新到對應的四個Lookup欄位中。
										// 如果「出生日期」被清空，此腳本也會一併清空相關的塔羅牌欄位。
										// -----------------------------------------------------------------------------
										// 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// 呼叫我們的核心函數來計算三張牌
											tarot_results = thisapp.Tarot.getLifePathTarot(input.Date_Of_Birth);
											// 將函數回傳的ID更新到對應的Lookup欄位中
											// 請確保以下的 Deluge 名稱與您在表單中建立的 Lookup 欄位相符
											// 更新本命塔羅 (來自"本世功課")
											input.Ben_Ming_Tarot = tarot_results.get("本世功課_ID");
											// 更新現狀塔羅 (來自"時事地")
											input.Xian_Zhuang_Tarot = tarot_results.get("時事地_ID");
											// 更新業力塔羅 (來自"業力因果")
											input.Ye_Li_Tarot = tarot_results.get("業力因果_ID");
											// 關於 "天緣塔羅":
											// 目前的核心函數尚未包含計算第四張牌的邏輯。
											// 在其計算規則確定後，我們可以在 Tarot.getLifePathTarot 中增加邏輯，
											// 並在此處增加一行 "input.Tian_Yuan_Tarot = tarot_results.get("天緣塔羅_ID");" 即可。
											input.Tian_Yuan_Tarot = null;
											info "本命塔羅牌陣已自動更新";
										}
										else
										{
											// 如果生日被清空，也清空對應的塔羅牌欄位
											input.Ben_Ming_Tarot = null;
											input.Xian_Zhuang_Tarot = null;
											input.Ye_Li_Tarot = null;
											input.Tian_Yuan_Tarot = null;
											info "生日已清除，本命塔羅牌陣已重設";
										}
						)
						custom deluge script
						(
											// Workflow: On Add/Edit -> On Success for Clients_Report Form
										//
										// 作用：當個案的資料被建立或生日被更新時，自動計算並填入所有本命塔羅相關欄位。
										// 觸發點：On Add -> On Success, On Edit -> On Success (當 Date_Of_Birth 欄位被修改)
										// ====================================================================================
										// 從 input 中獲取當前被操作的個案紀錄ID
										clientID = input.ID;
										client_record = Clients_Report[ID == clientID];
										// 檢查個案紀錄是否存在並且有生日資訊
										if(client_record != null && client_record.Date_Of_Birth != null)
										{
											// 調用核心計算函數，傳入個案的生日
											tarot_results_map = thisapp.Tarot.getLifePathTarot(client_record.Date_Of_Birth);
											// 準備一個 Map 用來存放所有要更新的欄位資料
											update_data = Map();
											// 逐一檢查計算結果，並放入 update_data Map 中
											if(tarot_results_map.containKey("Ben_Ming_Tarot_ID"))
											{
												update_data.put("Ben_Ming_Tarot",tarot_results_map.get("Ben_Ming_Tarot_ID"));
												update_data.put("Ben_Ming_Tarot_Image",tarot_results_map.get("Ben_Ming_Tarot_Image_Value"));
											}
											if(tarot_results_map.containKey("Xian_Zhuang_Tarot_ID"))
											{
												update_data.put("Xian_Zhuang_Tarot",tarot_results_map.get("Xian_Zhuang_Tarot_ID"));
												update_data.put("Xian_Zhuang_Tarot_Image",tarot_results_map.get("Xian_Zhuang_Tarot_Image_Value"));
											}
											if(tarot_results_map.containKey("Ye_Li_Tarot_ID"))
											{
												update_data.put("Ye_Li_Tarot",tarot_results_map.get("Ye_Li_Tarot_ID"));
												update_data.put("Ye_Li_Tarot_Image",tarot_results_map.get("Ye_Li_Tarot_Image_Value"));
											}
											if(tarot_results_map.containKey("Tian_Yuan_Tarot_ID"))
											{
												update_data.put("Tian_Yuan_Tarot",tarot_results_map.get("Tian_Yuan_Tarot_ID"));
												update_data.put("Tian_Yuan_Tarot_Image",tarot_results_map.get("Tian_Yuan_Tarot_Image_Value"));
											}
											// 如果 update_data 中有任何需要更新的資料，則執行更新操作
											if(update_data.size() > 0)
											{
												// 為了確保資料的完整性，即使某些牌卡沒有計算出來（例如第四張），也用 null 去覆蓋，避免殘留舊資料
												client_record.Ben_Ming_Tarot=if(update_data.containKey("Ben_Ming_Tarot"),update_data.get("Ben_Ming_Tarot"),null);
												client_record.Ben_Ming_Tarot_Image=if(update_data.containKey("Ben_Ming_Tarot_Image"),update_data.get("Ben_Ming_Tarot_Image"),null);
												client_record.Xian_Zhuang_Tarot=if(update_data.containKey("Xian_Zhuang_Tarot"),update_data.get("Xian_Zhuang_Tarot"),null);
												client_record.Xian_Zhuang_Tarot_Image=if(update_data.containKey("Xian_Zhuang_Tarot_Image"),update_data.get("Xian_Zhuang_Tarot_Image"),null);
												client_record.Ye_Li_Tarot=if(update_data.containKey("Ye_Li_Tarot"),update_data.get("Ye_Li_Tarot"),null);
												client_record.Ye_Li_Tarot_Image=if(update_data.containKey("Ye_Li_Tarot_Image"),update_data.get("Ye_Li_Tarot_Image"),null);
												client_record.Tian_Yuan_Tarot=if(update_data.containKey("Tian_Yuan_Tarot"),update_data.get("Tian_Yuan_Tarot"),null);
												client_record.Tian_Yuan_Tarot_Image=if(update_data.containKey("Tian_Yuan_Tarot_Image"),update_data.get("Tian_Yuan_Tarot_Image"),null);
											}
										}
						)
					}
					actions 
					{
						custom deluge script
						(
											//
										// Workflow/Clients_Report/OnSuccess_GeneratePersonalityProfile.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 的紀錄成功儲存後觸發。
										//               此腳本會檢查是否需要生成個性側寫，並在所有命理資料計算完成後
										//               自動調用 AI 生成個性側寫報告。
										//
										// @trigger_event: On Add -> On Success (新增 -> 成功時)
										// @trigger_form: Clients_Report (個案表單)
										//
										// @dependencies: 
										//   - thisapp.AIInterpreter.generatePersonalityProfile (函數)
										//
										// @placement: 應設定於 Clients_Report 表單的 "On Add -> On Success" 事件中。
										//             建議設定執行順序在所有其他命理計算 Workflow 之後。
										//
										// 檢查是否為新增的記錄（避免編輯時重複生成）
										if(input.ID != null && input.Added_Time == input.Modified_Time)
										{
											// 檢查是否已有個性側寫
											if(input.Personality_Profile == null || input.Personality_Profile == "")
											{
												info "=== 開始生成個性側寫（Workflow）===";
												info "個案 ID：" + input.ID;
												info "個案姓名：" + input.Visitor_Name.last_name + input.Visitor_Name.first_name;
												// 檢查命理資料是否已計算完成
												data_complete = true;
												missing_fields = List();
												if(input.Zodiac_Signs == null)
												{
													missing_fields.add("星座");
													data_complete = false;
												}
												if(input.Chinese_Zodiac == null)
												{
													missing_fields.add("生肖");
													data_complete = false;
												}
												if(input.Full_Bazi == null || input.Full_Bazi == "")
												{
													missing_fields.add("八字");
													data_complete = false;
												}
												if(input.Twenty_Eight_Lunar_Mansions == null)
												{
													missing_fields.add("星宿");
													data_complete = false;
												}
												if(data_complete)
												{
													// 所有資料已完備，生成個性側寫
													try 
													{
														personality_result = thisapp.AIInterpreter.generatePersonalityProfile(input.ID.toString());
														if(personality_result.get("success") == true)
														{
															personality_profile = personality_result.get("personality_profile");
															character_count = personality_result.get("character_count");
															// 更新個案記錄
															client_record = Clients_Report[ID == input.ID];
															client_record.Personality_Profile=personality_profile;
															info "個性側寫已生成並儲存，字數：" + character_count;
														}
														else
														{
															info "個性側寫生成失敗：" + personality_result.get("error");
														}
													}
													catch (e)
													{
														info "生成個性側寫時發生錯誤：" + e.toString();
													}
												}
												else
												{
													info "命理資料尚未完整，缺少：" + missing_fields.toString();
													info "將等待下次觸發時再生成個性側寫";
												}
											}
											else
											{
												info "個性側寫已存在，跳過生成";
											}
										}
						)
					}
				}

			}
			OnPaymentSuccess as "OnPaymentSuccess"
			{
				type =  form
				form = Talisman_Purchases

				record event = on edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											//
										// Form Validation: OnPaymentSuccess (Talisman_Purchases 表單)
										// 觸發條件：Talisman_Purchases 表單的 Status 欄位更新為 "Paid" 時觸發
										// 功能：自動觸發完整報告生成和交付流程
										//
										// 開發者：Lunar Tom
										// 版本：2.1 (Talisman_Purchases Form Validation 語法)
										// 日期：2025-01-21
										//
										// 在 Talisman_Purchases Form Validation 中，直接使用欄位名稱
										currentStatus = input.Status;
										currentOrderId = input.ID;
										linkedDivinationId = input.Divination_Log_Link;
										// 確保這是付款成功的觸發
										if(currentStatus == "Paid")
										{
											info "✅ 訂單付款成功，開始處理完整報告生成流程";
											info "訂單 ID：" + currentOrderId;
											info "關聯的占卜記錄 ID：" + linkedDivinationId;
											try 
											{
												// --- 步驟 1：檢查是否有關聯的占卜記錄 ---
												if(linkedDivinationId != null && linkedDivinationId != 0)
												{
													// 轉換為正確的數字類型
													targetDivinationId = linkedDivinationId.toLong();
													// --- 步驟 2：更新占卜記錄的付費狀態 ---
													divinationRecords = Divination_Logs[ID == targetDivinationId];
													if(divinationRecords.count() > 0)
													{
														for each  divRecord in divinationRecords
														{
															divRecord.Has_Paid_Report=true;
															divRecord.Report_Generated=false;
														}
														info "✅ 已更新占卜記錄的付費狀態";
														// --- 步驟 3：獲取占卜記錄詳情，準備生成完整報告 ---
														divinationDetails = Divination_Logs[ID == targetDivinationId];
														if(divinationDetails.count() > 0)
														{
															// 獲取占卜記錄詳情
															divination = null;
															for each  record in divinationDetails
															{
																divination = record;
																break;
															}
															originalQuestion = divination.Original_Question;
															questionType = divination.Question_Type_AI;
															info "準備生成完整報告 - 問題：" + originalQuestion;
															info "問題類型：" + questionType;
															// --- 步驟 4：構建塔羅牌陣資料（用於 AI 完整解讀）---
															tarotSpreadData = Map();
															// 從占卜記錄中提取塔羅牌陣資料
															tarotSpreadData.put("Card_1_Reversed",divination.Card_1_Reversed);
															tarotSpreadData.put("Card_2_Reversed",divination.Card_2_Reversed);
															tarotSpreadData.put("Card_3_Reversed",divination.Card_3_Reversed);
															tarotSpreadData.put("Card_4_Reversed",divination.Card_4_Reversed);
															tarotSpreadData.put("Card_5_Reversed",divination.Card_5_Reversed);
															// 使用新的 a-e 格式牌位意義
															tarotSpreadData.put("Position_a_Meaning",divination.Position_a_Meaning);
															tarotSpreadData.put("Position_b_Meaning",divination.Position_b_Meaning);
															tarotSpreadData.put("Position_c_Meaning",divination.Position_c_Meaning);
															tarotSpreadData.put("Position_d_Meaning",divination.Position_d_Meaning);
															tarotSpreadData.put("Position_e_Meaning",divination.Position_e_Meaning);
															// --- 步驟 5：調用付費版 AI 塔羅解讀函數生成 3000 字完整報告 ---
															fullReportResult = thisapp.AIInterpreter.getTarotInterpretationFull(originalQuestion,questionType,tarotSpreadData);
															if(fullReportResult.get("success") == true)
															{
																fullInterpretation = fullReportResult.get("interpretation");
																// --- 步驟 6：更新占卜記錄，儲存完整報告 ---
																divinationRecord2 = Divination_Logs[ID == targetDivinationId];
																if(divinationRecord2.count() > 0)
																{
																	for each  divRecord2 in divinationRecord2
																	{
																		divRecord2.AI_Interpretation_Full=fullInterpretation;
																		divRecord2.Report_Generated=true;
																	}
																}
																info "✅ 完整報告已生成並儲存";
																// --- 步驟 7：生成 PDF 報告連結 ---
																// 使用實際的占卜記錄 ID 生成 PDF 連結
																pdfLink = "https://creator.zoho.com/reports/divination/" + targetDivinationId + "/pdf";
																divinationRecord3 = Divination_Logs[ID == targetDivinationId];
																if(divinationRecord3.count() > 0)
																{
																	for each  divRecord3 in divinationRecord3
																	{
																		divRecord3.Report_PDF_Link=pdfLink;
																	}
																}
																info "✅ PDF 報告連結已設定：" + pdfLink;
																// --- 步驟 8：記錄成功完成 ---
																info "? 付費報告處理流程完成";
																info "客戶現在可以查看 3000 字完整解讀和下載 PDF 報告";
																// --- 步驟 9：記錄到當前訂單（可選）---
																// 可以在 Talisman_Purchases 記錄中加入處理完成的時間戳
																currentTime = zoho.currenttime;
																info "報告生成完成時間：" + currentTime;
															}
															else
															{
																info "❌ AI 完整報告生成失敗：" + fullReportResult.get("error");
																// 標記報告生成失敗，但保持付費狀態
																divinationRecordError = Divination_Logs[ID == targetDivinationId];
																if(divinationRecordError.count() > 0)
																{
																	for each  divRecordError in divinationRecordError
																	{
																		divRecordError.Report_Generated=false;
																		divRecordError.AI_Interpretation_Full="報告生成失敗，請聯繫客服：" + fullReportResult.get("error");
																	}
																}
															}
														}
														else
														{
															info "❌ 找不到對應的占卜記錄詳情";
														}
													}
													else
													{
														info "❌ 找不到 ID 為 " + targetDivinationId + " 的占卜記錄";
													}
												}
												else
												{
													info "⚠️ 此訂單沒有關聯的占卜記錄，跳過報告生成";
													info "Divination_Log_Link 值：" + linkedDivinationId;
												}
											}
											catch (e)
											{
												info "❌ 付費報告處理過程發生錯誤：" + e.toString();
												// 如果有關聯的占卜記錄，標記錯誤狀態
												if(linkedDivinationId != null && linkedDivinationId != 0)
												{
													targetDivinationIdError = linkedDivinationId.toLong();
													divinationRecordSysError = Divination_Logs[ID == targetDivinationIdError];
													if(divinationRecordSysError.count() > 0)
													{
														for each  divRecordSysError in divinationRecordSysError
														{
															divRecordSysError.Report_Generated=false;
															divRecordSysError.AI_Interpretation_Full="系統錯誤，請聯繫客服處理：" + e.toString();
														}
													}
												}
											}
										}
										else
										{
											info "⏭️ 訂單狀態更新為：" + currentStatus + "，不觸發報告生成流程";
										}
						)
					}
				}

			}
			Run_Scripts_While_Adding_ as "Run Scripts - While Adding a Record"
			{
				type =  form
				form = Register_As_Member

				record event = on add
					status = inactive

				on success
				{
					actions 
					{
						custom deluge script
						(
											//Here notification mail will be sent to member
										if(input.Membership_Type == "Monthly Membership")
										{
											amount = input.Monthly_Membership_plans;
										}
										else
										{
											amount = input.Yearly_Membership_plans;
										}
										sendmail
										[
											from :zoho.adminuserid
											to :input.Email
											subject :"Registration completed successfully"
											message :"<div><i>Hi...Thanks for registering with us.</i></div><div><i><br></i></div><div><i>You have opted&nbsp;" + input.Membership_Type + " for&nbsp;" + amount + ".</i></div>"
										]
						)
					}
				}

			}
			Run_Scripts_On_Always as "Run Scripts - On Always"
			{
				type =  form
				form = Register_As_Member

				record event = on add or edit
					status = inactive

				field rules
				{
					actions  (Membership_Type == "Monthly Membership")
					{
						hide Yearly_Membership_plans;
						show Monthly_Membership_plans;
					}
				}

			}
			Run_Scripts_On_Always1 as "Run Scripts - On Always"
			{
				type =  form
				form = Register_As_Member

				record event = on add or edit
					status = inactive

				on validate
				{
					actions 
					{
						custom deluge script
						(
											//Mandate the membership plan field here
										if((input.Membership_Type == "Monthly Membership" && input.Monthly_Membership_plans == null) || (input.Membership_Type == "Yearly Membership" && input.Yearly_Membership_plans == null))
										{
											alert "Please specify the membership plan!";
											cancel submit;
										}
										if(input.Membership_Type == "Monthly Membership")
										{
											input.Yearly_Membership_plans = null;
										}
										else
										{
											input.Monthly_Membership_plans = null;
										}
						)
					}
				}

			}
		}




		blueprint
		{
    			runRegistration as "runRegistration"
    			{
        			type = Blueprint
        			form = Register_As_Member
        			start
        			{
        			}
        			stages
        			{
        			}
        			transitions
        			{
        			}
    			}
		}


		functions
		{
			Update_Data as "Update Data"
			{
				type =  functions
				form = Clients_Report
				execution type = for each record	
				on start
				{
					actions 
					{
						thisapp.AIInterpreter.getGenderFromName(ID);
					on click
					(
						//
										// Workflow/Clients_Report/OnEdit_UpdateZodiacAndTaisui.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會自動計算並
										//               填充星座、生肖、虛歲和犯太歲狀態等相關命理欄位。
										//               如果生日欄位被清空，此腳本會同步清空所有相關的衍生欄位。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.Zodiac.getZodiacSign (函數)
										//   - thisapp.Zodiac.getChineseZodiacSign (函數)
										//   - thisapp.Zodiac.getTaisuiStatus (函數)
										//   - LunarData (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// ======================================================================
											// 星座功能
											// ======================================================================
											zodiac_result = thisapp.Zodiac.getZodiacSign(input.Date_Of_Birth);
											if(zodiac_result.get("success") == true)
											{
												input.Zodiac_Signs = zodiac_result.get("sign_id");
											}
											else
											{
												input.Zodiac_Signs = null;
											}
											// ======================================================================
											// 生肖功能
											// ======================================================================
											chinese_zodiac_result = thisapp.Zodiac.getChineseZodiacSign(input.Date_Of_Birth);
											if(chinese_zodiac_result.get("success") == true)
											{
												input.Chinese_Zodiac = chinese_zodiac_result.get("zodiac_id");
												// ======================================================================
												// 虛歲功能
												// ======================================================================
												birth_lunar_year = chinese_zodiac_result.get("zodiac_year");
												current_year = zoho.currentdate.getYear();
												current_lunar_year = current_year;
												// 判斷當前日期是否已過農曆新年，以決定當前的農曆年份
												current_lunar_data_record = LunarData[Solar_Year == current_year];
												if(current_lunar_data_record.count() > 0)
												{
													current_lunar_new_year = current_lunar_data_record.Lunar_New_Year;
													if(zoho.currentdate < current_lunar_new_year.toDate())
													{
														current_lunar_year = current_year - 1;
													}
													// 虛歲 = 當前農曆年份 - 出生農曆年份 + 1
													nominal_age = current_lunar_year - birth_lunar_year + 1;
													input.Nominal_Age = nominal_age;
												}
												else
												{
													input.Nominal_Age = null;
												}
											}
											else
											{
												input.Chinese_Zodiac = null;
												input.Nominal_Age = null;
											}
											// ======================================================================
											// 犯太歲功能
											// ======================================================================
											current_year_for_taisui = zoho.currentdate.getYear();
											taisui_result = thisapp.Zodiac.getTaisuiStatus(input.Date_Of_Birth,current_year_for_taisui);
											if(taisui_result.get("success") == true)
											{
												// 更新「本命太歲」和「流年太歲」的 Lookup 欄位
												input.Taisui_Deity_Name_Birth = taisui_result.get("birth_ganzhi_id");
												input.Taisui_Deity_Name_Year = taisui_result.get("query_year_ganzhi_id");
												// 更新「犯太歲狀態」下拉選單欄位
												input.Taisui_Conflict_Status = taisui_result.get("conflict_type");
											}
											else
											{
												// 如果計算失敗，清空相關欄位
												input.Taisui_Deity_Name_Birth = null;
												input.Taisui_Deity_Name_Year = null;
												input.Taisui_Conflict_Status = null;
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空所有相關的衍生欄位
											input.Zodiac_Signs = null;
											input.Chinese_Zodiac = null;
											input.Nominal_Age = null;
											input.Taisui_Deity_Name_Birth = null;
											input.Taisui_Deity_Name_Year = null;
											input.Taisui_Conflict_Status = null;
										}
					)
					on click
					(
						//
										// Workflow/Clients_Report/OnEdit_UpdateZodiacAndTaisui.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會自動計算並
										//               填充星座、生肖、虛歲和犯太歲狀態等相關命理欄位。
										//               如果生日欄位被清空，此腳本會同步清空所有相關的衍生欄位。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.Zodiac.getZodiacSign (函數)
										//   - thisapp.Zodiac.getChineseZodiacSign (函數)
										//   - thisapp.Zodiac.getTaisuiStatus (函數)
										//   - LunarData (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// ======================================================================
											// 星座功能
											// ======================================================================
											zodiac_result = thisapp.Zodiac.getZodiacSign(input.Date_Of_Birth);
											if(zodiac_result.get("success") == true)
											{
												input.Zodiac_Signs = zodiac_result.get("sign_id");
											}
											else
											{
												input.Zodiac_Signs = null;
											}
											// ======================================================================
											// 生肖功能
											// ======================================================================
											chinese_zodiac_result = thisapp.Zodiac.getChineseZodiacSign(input.Date_Of_Birth);
											if(chinese_zodiac_result.get("success") == true)
											{
												input.Chinese_Zodiac = chinese_zodiac_result.get("zodiac_id");
												// ======================================================================
												// 虛歲功能
												// ======================================================================
												birth_lunar_year = chinese_zodiac_result.get("zodiac_year");
												current_year = zoho.currentdate.getYear();
												current_lunar_year = current_year;
												// 判斷當前日期是否已過農曆新年，以決定當前的農曆年份
												current_lunar_data_record = LunarData[Solar_Year == current_year];
												if(current_lunar_data_record.count() > 0)
												{
													current_lunar_new_year = current_lunar_data_record.Lunar_New_Year;
													if(zoho.currentdate < current_lunar_new_year.toDate())
													{
														current_lunar_year = current_year - 1;
													}
													// 虛歲 = 當前農曆年份 - 出生農曆年份 + 1
													nominal_age = current_lunar_year - birth_lunar_year + 1;
													input.Nominal_Age = nominal_age;
												}
												else
												{
													input.Nominal_Age = null;
												}
											}
											else
											{
												input.Chinese_Zodiac = null;
												input.Nominal_Age = null;
											}
											// ======================================================================
											// 犯太歲功能
											// ======================================================================
											current_year_for_taisui = zoho.currentdate.getYear();
											taisui_result = thisapp.Zodiac.getTaisuiStatus(input.Date_Of_Birth,current_year_for_taisui);
											if(taisui_result.get("success") == true)
											{
												// 更新「本命太歲」和「流年太歲」的 Lookup 欄位
												input.Taisui_Deity_Name_Birth = taisui_result.get("birth_ganzhi_id");
												input.Taisui_Deity_Name_Year = taisui_result.get("query_year_ganzhi_id");
												// (可選) 如果您有一個文字欄位來顯示犯太歲狀態，可以取消下面這行的註解
												// input.Taisui_Conflict_Status = taisui_result.get("conflict_type");
											}
											else
											{
												// 如果計算失敗，清空相關欄位
												input.Taisui_Deity_Name_Birth = null;
												input.Taisui_Deity_Name_Year = null;
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空所有相關的衍生欄位
											input.Zodiac_Signs = null;
											input.Chinese_Zodiac = null;
											input.Nominal_Age = null;
											input.Taisui_Deity_Name_Birth = null;
											input.Taisui_Deity_Name_Year = null;
										}
					)
					on click
					(
						//
										// Workflow/Clients_Report/OnEdit_UpdateLunarMansion.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會根據國曆生日，
										//               自動查詢並帶入對應的「二十八星宿」Lookup 記錄。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.Star.getLunarMansion (函數)
										//   - Twenty_Eight_Lunar_Mansions (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 1. 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// 2. 呼叫我們建立的 Star.getLunarMansion 函數來查詢星宿名稱
											mansion_result = thisapp.Star.getLunarMansion(input.Date_Of_Birth);
											// 3. 檢查函數是否成功執行並回傳了星宿名稱
											if(mansion_result.get("success") == true)
											{
												// 4. 從回傳結果中取得星宿名稱
												mansion_name = mansion_result.get("mansion_name");
												// 5. 使用星宿名稱去查詢 "二十八星宿詳細資訊表" (Twenty_Eight_Lunar_Mansions)
												mansion_info_record = Twenty_Eight_Lunar_Mansions[Star_Name == mansion_name];
												// 6. 處理查詢結果
												if(mansion_info_record != null)
												{
													// 如果找到了對應的記錄，就將個案表單的 Lookup 欄位更新為該記錄的 ID
													input.Twenty_Eight_Lunar_Mansions = mansion_info_record.ID;
												}
												else
												{
													// 如果在詳細資訊表中找不到該星宿，則清空 Lookup 欄位
													input.Twenty_Eight_Lunar_Mansions = null;
													// (可選) 您可以在此處加上 alert 通知管理員資料不完整
													// alert "資料庫警告：在 Twenty_Eight_Lunar_Mansions 表中找不到名為 '" + mansion_name + "' 的星宿記錄。";
												}
											}
											else
											{
												// 如果 getLunarMansion 函數執行失敗，也清空 Lookup 欄位
												input.Twenty_Eight_Lunar_Mansions = null;
												// (可選) 您可以在此處加上 alert 通知使用者或管理員
												// alert "無法計算星宿，錯誤訊息：" + mansion_result.get("error");
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空星宿 Lookup 欄位
											input.Twenty_Eight_Lunar_Mansions = null;
										}
					)
					on click
					(
						//
										// Workflow/Clients_Report/OnSuccess_UpdateBaziPillars.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 的紀錄成功儲存後觸發。
										//               此腳本會根據「生日」(Date_Of_Birth) 欄位，自動呼叫八字計算函數，
										//               並將計算出的年、月、日、時四柱（共八個干支）的 Lookup 欄位，
										//               以及一個完整的八字命盤字串，回填到目前的個案紀錄中。
										//
										// @trigger_event: On Add / On Edit -> On Success (新增/編輯 -> 成功時)
										// @trigger_form: Clients_Report (個案表單)
										//
										// @dependencies: 
										//   - thisapp.Bazi.PreciseBaziCalculator (函數)
										//   - Heavenly_Stems (表單)
										//   - Earthly_Branches (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 "On Add / On Edit -> On Success" 事件中。
										//
										// 1. 從 input 物件中獲取生日。
										dob = input.Date_Of_Birth;
										// 檢查生日欄位是否有值，以避免執行錯誤。
										if(dob != null)
										{
											// 2. 呼叫主要的八字計算函數，獲取完整的八字命盤 map。
											bazi_map = thisapp.Bazi.PreciseBaziCalculator(dob);
											// 檢查計算是否成功。
											if(bazi_map.get("success") == true)
											{
												// 3. 從回傳結果中，提取四柱各自的詳細 map。
												year_pillar_details = bazi_map.get("年柱詳情");
												month_pillar_details = bazi_map.get("月柱詳情");
												day_pillar_details = bazi_map.get("日柱詳情");
												hour_pillar_details = bazi_map.get("時柱詳情");
												// 4. 從各柱的詳情中，取得天干與地支的名稱。
												year_stem_name = year_pillar_details.get("stem");
												year_branch_name = year_pillar_details.get("branch");
												month_stem_name = month_pillar_details.get("stem");
												month_branch_name = month_pillar_details.get("branch");
												day_stem_name = day_pillar_details.get("stem");
												day_branch_name = day_pillar_details.get("branch");
												hour_stem_name = hour_pillar_details.get("stem");
												hour_branch_name = hour_pillar_details.get("branch");
												// 5. 將干支名稱組合成一個格式化的完整八字字串。
												full_bazi_string = (year_stem_name + year_branch_name) + " " + (month_stem_name + month_branch_name) + " " + (day_stem_name + day_branch_name) + " " + (hour_stem_name + hour_branch_name);
												// 6. 從 Lookup 表單中查詢對應干支的紀錄 ID。
												// 查詢天干
												year_stem_record = Heavenly_Stems[Stem_Name == year_stem_name];
												month_stem_record = Heavenly_Stems[Stem_Name == month_stem_name];
												day_stem_record = Heavenly_Stems[Stem_Name == day_stem_name];
												hour_stem_record = Heavenly_Stems[Stem_Name == hour_stem_name];
												// 查詢地支
												year_branch_record = Earthly_Branches[Branch_Name == year_branch_name];
												month_branch_record = Earthly_Branches[Branch_Name == month_branch_name];
												day_branch_record = Earthly_Branches[Branch_Name == day_branch_name];
												hour_branch_record = Earthly_Branches[Branch_Name == hour_branch_name];
												// 7. 直接更新當前的個案紀錄。
												// 包含 8 個 Lookup 欄位和一個新建的組合字串欄位。
												client_record = Clients_Report[ID == input.ID];
												client_record.Year_Heavenly_Stem=year_stem_record.ID;
												client_record.Year_Earthly_Branch=year_branch_record.ID;
												client_record.Month_Heavenly_Stem=month_stem_record.ID;
												client_record.Month_Earthly_Branch=month_branch_record.ID;
												client_record.Day_Heavenly_Stem=day_stem_record.ID;
												client_record.Day_Earthly_Branch=day_branch_record.ID;
												client_record.Hour_Heavenly_Stem=hour_stem_record.ID;
												client_record.Hour_Earthly_Branch=hour_branch_record.ID;
												// 更新新建的文字欄位 "Full_Bazi"。
												client_record.Full_Bazi=full_bazi_string;
												info "成功更新八字欄位！";
											}
											else
											{
												// 如果八字計算失敗，紀錄錯誤訊息並清空相關欄位。
												error_message = bazi_map.get("error");
												info "八字計算失敗：" + error_message;
												client_record = Clients_Report[ID == input.ID];
												client_record.Full_Bazi="";
												// 清空所有 Lookup 欄位
												client_record.Year_Heavenly_Stem=null;
												client_record.Year_Earthly_Branch=null;
												client_record.Month_Heavenly_Stem=null;
												client_record.Month_Earthly_Branch=null;
												client_record.Day_Heavenly_Stem=null;
												client_record.Day_Earthly_Branch=null;
												client_record.Hour_Heavenly_Stem=null;
												client_record.Hour_Earthly_Branch=null;
											}
										}
										else
										{
											// 如果生日欄位被清空，也一併清空所有八字相關欄位。
											info "出生日期為空，略過八字計算。";
											client_record = Clients_Report[ID == input.ID];
											client_record.Full_Bazi="";
											// 清空所有 Lookup 欄位
											client_record.Year_Heavenly_Stem=null;
											client_record.Year_Earthly_Branch=null;
											client_record.Month_Heavenly_Stem=null;
											client_record.Month_Earthly_Branch=null;
											client_record.Day_Heavenly_Stem=null;
											client_record.Day_Earthly_Branch=null;
											client_record.Hour_Heavenly_Stem=null;
											client_record.Hour_Earthly_Branch=null;
										}
					)
					on click
					(
						//
										// Workflow/Clients_Report/OnEdit_UpdateLunarBirthday.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 上觸發。
										//               當「生日」(Date_Of_Birth) 欄位被填寫或修改時，此腳本會結合
										//               國曆轉農曆以及八字計算的結果，生成一個包含干支年份和出生時辰的
										//               完整農曆生日字串，並更新到「農曆生日」欄位。
										//
										// @trigger_event: On User Input (使用者輸入時)
										// @trigger_form: Clients_Report (個案表單)
										// @trigger_field: Date_Of_Birth (生日)
										//
										// @dependencies: 
										//   - thisapp.LunarAI.SolarToLunar (函數)
										//   - thisapp.Bazi.PreciseBaziCalculator (函數)
										//
										// @placement: 應設定於 Clients_Report 表單的 Date_Of_Birth 欄位的 "On User Input" 事件中。
										//
										// 1. 檢查生日欄位是否存在，若不存在則清空農曆生日欄位並結束。
										if(input.Date_Of_Birth != null)
										{
											info "--- Workflow Start: Update Lunar Birthday for DOB = " + input.Date_Of_Birth + " ---";
											// 2. 呼叫核心函數
											solarToLunarResult = thisapp.LunarAI.SolarToLunar(input.Date_Of_Birth);
											info "1. solarToLunarResult: " + solarToLunarResult;
											baziResult = thisapp.Bazi.PreciseBaziCalculator(input.Date_Of_Birth);
											info "2. baziResult: " + baziResult;
											// 3. 從回傳的 Map 中，取出"生日"部分的子 Map。
											birthdayMap = solarToLunarResult.get("生日");
											// 4. 確認兩個函數都成功回傳且無錯誤，才進行後續處理。
											if(birthdayMap != null && birthdayMap.get("error") == "" && baziResult != null && baziResult.get("success") == true)
											{
												originalLunarText = birthdayMap.get("中文日期");
												if(originalLunarText != null && originalLunarText.contains(","))
												{
													// a. 從 baziResult 的巢狀 Map 中安全地取得年柱的干支
													yearPillarDetails = baziResult.get("年柱詳情");
													// b. 再次檢查巢狀 Map 是否存在
													if(yearPillarDetails != null)
													{
														yearGanZhi = yearPillarDetails.get("stem") + yearPillarDetails.get("branch");
														// c. 核心修正：直接替換，不再自行拼接時辰
														// 將 "2023, 十月廿三日 丑時生" 替換成 "癸卯年 十月廿三日 丑時生"
														finalString = originalLunarText.replaceAll(originalLunarText.toList(",").get(0) + ", ",yearGanZhi + "年 ");
														// d. 更新欄位
														input.Lunar_Birthday = finalString;
													}
													else
													{
														// 如果巢狀 Map 不存在，也視為錯誤
														input.Lunar_Birthday = "";
														info "八字計算結果缺少 '年柱詳情' 的巢狀 Map。";
													}
												}
												else
												{
													// 如果農曆日期格式不符預期，直接寫入原始回傳文字。
													input.Lunar_Birthday = originalLunarText;
												}
											}
											else
											{
												// 如果任一轉換過程出錯，清空農曆生日欄位並記錄錯誤。
												input.Lunar_Birthday = "";
												info "農曆生日或八字轉換失敗：solarToLunar error: " + birthdayMap.get("error") + " / bazi success: " + baziResult.get("success");
											}
										}
										else
										{
											// 如果國曆生日欄位被清空，則同步清空農曆生日欄位。
											input.Lunar_Birthday = "";
										}
					)
					on click
					(
						//
										// Workflow/Clients_Report/OnSuccess_UpdateFourPillars.deluge
										//
										// @description: (Workflow 腳本) 在「個案表單」(Clients_Report) 的紀錄成功儲存後觸發。
										//               此腳本會根據「生日」(Date_Of_Birth) 欄位，自動計算八字，並將
										//               代表年月日時的「四柱」干支組合，以 Lookup 形式回填到對應的四個欄位中。
										//               此腳本與 OnSuccess_UpdateBaziPillars.deluge 互為補充，用於更新不同的欄位。
										//
										// @trigger_event: On Add / On Edit -> On Success (新增/編輯 -> 成功時)
										// @trigger_form: Clients_Report (個案表單)
										//
										// @dependencies: 
										//   - thisapp.Bazi.PreciseBaziCalculator (函數)
										//   - Sixty_GanZhi_Table (表單)
										//
										// @placement: 應設定於 Clients_Report 表單的 "On Add / On Edit -> On Success" 事件中。
										//
										// 1. 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											info "生日欄位已更新，開始計算並更新四柱 Lookup 欄位...";
											// 2. 呼叫核心的精確八字計算函數
											bazi_result = thisapp.Bazi.PreciseBaziCalculator(input.Date_Of_Birth);
											// 3. 檢查計算是否成功
											if(bazi_result.get("success") == true)
											{
												// 4. 從回傳的 Map 中獲取四柱的干支字串
												year_pillar_str = bazi_result.get("年柱");
												month_pillar_str = bazi_result.get("月柱");
												day_pillar_str = bazi_result.get("日柱");
												hour_pillar_str = bazi_result.get("時柱");
												// 在 On Success 事件中，需先取得當前紀錄才能更新
												client_record = Clients_Report[ID == input.ID];
												// 5. 分別查詢 Sixty_GanZhi_Table 以獲取對應的記錄 ID
												// 年柱
												year_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == year_pillar_str];
												if(year_ganzhi_record != null)
												{
													client_record.Year_Pillar=year_ganzhi_record.ID;
												}
												// 月柱
												month_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == month_pillar_str];
												if(month_ganzhi_record != null)
												{
													client_record.Month_Pillar=month_ganzhi_record.ID;
												}
												// 日柱
												day_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == day_pillar_str];
												if(day_ganzhi_record != null)
												{
													client_record.Day_Pillar=day_ganzhi_record.ID;
												}
												// 時柱
												hour_ganzhi_record = Sixty_GanZhi_Table[GanZhi_Combination == hour_pillar_str];
												if(hour_ganzhi_record != null)
												{
													client_record.Hour_Pillar=hour_ganzhi_record.ID;
												}
												info "四柱 Lookup 欄位更新成功！";
											}
											else
											{
												// 如果八字計算失敗，記錄錯誤訊息
												error_message = "四柱 Lookup 更新失敗，八字計算錯誤：" + bazi_result.get("error");
												info error_message;
											}
										}
										else
										{
											// 如果生日欄位被清空，則同步清空所有四柱欄位
											client_record = Clients_Report[ID == input.ID];
											client_record.Year_Pillar=null;
											client_record.Month_Pillar=null;
											client_record.Day_Pillar=null;
											client_record.Hour_Pillar=null;
											info "生日欄位為空，已清空四柱 Lookup 欄位。";
										}
					)
					on click
					(
						// [WORKFLOW]
										// Form: Clients_Report (個案報告)
										// Trigger: On User Input (當使用者輸入時)
										// Field: Date_Of_Birth (出生日期)
										// -----------------------------------------------------------------------------
										// Description:
										// 當使用者在「個案報告」表單中填寫或修改「出生日期」欄位時，
										// 此工作流會自動觸發，調用核心函數 Tarot.getLifePathTarot() 來計算本命塔羅牌陣，
										// 並將結果更新到對應的四個Lookup欄位中。
										// 如果「出生日期」被清空，此腳本也會一併清空相關的塔羅牌欄位。
										// -----------------------------------------------------------------------------
										// 檢查生日欄位是否有值
										if(input.Date_Of_Birth != null)
										{
											// 呼叫我們的核心函數來計算三張牌
											tarot_results = thisapp.Tarot.getLifePathTarot(input.Date_Of_Birth);
											// 將函數回傳的ID更新到對應的Lookup欄位中
											// 請確保以下的 Deluge 名稱與您在表單中建立的 Lookup 欄位相符
											// 更新本命塔羅 (來自"本世功課")
											input.Ben_Ming_Tarot = tarot_results.get("本世功課_ID");
											// 更新現狀塔羅 (來自"時事地")
											input.Xian_Zhuang_Tarot = tarot_results.get("時事地_ID");
											// 更新業力塔羅 (來自"業力因果")
											input.Ye_Li_Tarot = tarot_results.get("業力因果_ID");
											// 關於 "天緣塔羅":
											// 目前的核心函數尚未包含計算第四張牌的邏輯。
											// 在其計算規則確定後，我們可以在 Tarot.getLifePathTarot 中增加邏輯，
											// 並在此處增加一行 "input.Tian_Yuan_Tarot = tarot_results.get("天緣塔羅_ID");" 即可。
											input.Tian_Yuan_Tarot = null;
											info "本命塔羅牌陣已自動更新";
										}
										else
										{
											// 如果生日被清空，也清空對應的塔羅牌欄位
											input.Ben_Ming_Tarot = null;
											input.Xian_Zhuang_Tarot = null;
											input.Ye_Li_Tarot = null;
											input.Tian_Yuan_Tarot = null;
											info "生日已清除，本命塔羅牌陣已重設";
										}
					)
					}
				}
			}
			TarotDivinationButton as "TarotDivinationButton"
			{
				type =  functions
				form = Clients_Report
				execution type = for each record	
				on start
				{
					actions 
					{
						thisapp.Tarot.TarotDivinationFunction(Modified_User);
					}
				}
			}
		}
	}
