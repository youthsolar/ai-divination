		 functions
		 {
			 Deluge
			 {
				 map Batch.processBatch(string sheetId, string worksheetName, int startRow, int endRow)
                 {
                 	// Batch.processBatch
                 	// 目的：批次處理 Sheet 資料，調用 AI 清理並寫回結果
                 	// 初始化結果變數（單一出口模式）
                 	resultMap = Map();
                 	// 初始化統計變數
                 	successCount = 0;
                 	failureCount = 0;
                 	warningCount = 0;
                 	totalTokens = 0;
                 	errorMessages = List();
                 	try 
                 	{
                 		// 步驟 1：讀取 Sheet 資料
                 		configMap = Map();
                 		configMap.put("max_records",endRow - startRow + 1);
                 		sheetResponse = zoho.sheet.getRecords(sheetId,worksheetName,configMap,"zoho_sheet_connection");
                 		if(sheetResponse == null || sheetResponse.get("records") == null)
                 		{
                 			resultMap.put("status","failed");
                 			resultMap.put("message","無法讀取 Sheet 資料");
                 			resultMap.put("success_count",0);
                 			resultMap.put("failure_count",0);
                 			resultMap.put("warning_count",0);
                 		}
                 		else
                 		{
                 			records = sheetResponse.get("records");
                 			// 步驟 2：逐筆處理
                 			for each  record in records
                 			{
                 				try 
                 				{
                 					rowIndex = record.get("row_index");
                 					// 調用 AI 清理函數
                 					cleanedData = thisapp.OpenAI.cleanContactData(record);
                 					// 檢查清理結果狀態
                 					cleanStatus = cleanedData.get("Cleaning_Status");
                 					if(cleanStatus == "Success")
                 					{
                 						successCount = successCount + 1;
                 					}
                 					else if(cleanStatus == "Warning")
                 					{
                 						warningCount = warningCount + 1;
                 					}
                 					else
                 					{
                 						failureCount = failureCount + 1;
                 					}
                 					// 預估 Token 使用量（每筆約 3000 tokens）
                 					totalTokens = totalTokens + 3000;
                 					// 步驟 3：寫回 Sheet
                 					updateMap = Map();
                 					updateMap.put("Salutation",cleanedData.get("Salutation"));
                 					updateMap.put("First_Name",cleanedData.get("First_Name"));
                 					updateMap.put("Last_Name",cleanedData.get("Last_Name"));
                 					updateMap.put("Nickname",cleanedData.get("Nickname"));
                 					updateMap.put("Mobile",cleanedData.get("Mobile"));
                 					updateMap.put("Phone",cleanedData.get("Phone"));
                 					updateMap.put("Extension",cleanedData.get("Extension"));
                 					updateMap.put("Email",cleanedData.get("Email"));
                 					updateMap.put("Secondary_Email",cleanedData.get("Secondary_Email"));
                 					updateMap.put("Designation",cleanedData.get("Designation"));
                 					updateMap.put("Company",cleanedData.get("Company"));
                 					updateMap.put("Country",cleanedData.get("Country"));
                 					updateMap.put("State",cleanedData.get("State"));
                 					updateMap.put("City",cleanedData.get("City"));
                 					updateMap.put("Zip_Code",cleanedData.get("Zip_Code"));
                 					updateMap.put("Website",cleanedData.get("Website"));
                 					updateMap.put("Description",cleanedData.get("Description"));
                 					updateMap.put("Processing_Status",cleanStatus);
                 					updateMap.put("Cleaning_Notes",cleanedData.get("Cleaning_Notes"));
                 					// 寫回 Sheet（使用 row_index 作為篩選條件）
                 					criteria = "row_index==" + rowIndex;
                 					optionalMap = Map();
                 					zoho.sheet.updateRecords(sheetId,worksheetName,criteria,updateMap,optionalMap,"zoho_sheet_connection");
                 				}
                 				catch (e)
                 				{
                 					failureCount = failureCount + 1;
                 					errorMessages.add("Row " + rowIndex + ": " + e);
                 				}
                 			}
                 			// 步驟 4：計算成本
                 			estimatedCost = totalTokens * 0.0000003;
                 			// 步驟 5：組裝回傳結果
                 			resultMap.put("status","success");
                 			resultMap.put("success_count",successCount);
                 			resultMap.put("failure_count",failureCount);
                 			resultMap.put("warning_count",warningCount);
                 			resultMap.put("total_tokens",totalTokens);
                 			resultMap.put("estimated_cost",estimatedCost);
                 			resultMap.put("processed_range",startRow + " - " + endRow);
                 			if(errorMessages.size() > 0)
                 			{
                 				resultMap.put("errors",errorMessages.toString());
                 			}
                 		}
                 	}
                 	catch (e)
                 	{
                 		resultMap.put("status","failed");
                 		resultMap.put("message","批次處理失敗：" + e);
                 		resultMap.put("success_count",successCount);
                 		resultMap.put("failure_count",failureCount);
                 		resultMap.put("warning_count",warningCount);
                 	}
                 	return resultMap;
                 }
				 map Batch.startProcessing(string fileId)
                 {
                 	resultMap = Map();
                 	try 
                 	{
                 		if(fileId == null || fileId == "")
                 		{
                 			resultMap.put("status","failed");
                 			resultMap.put("message","檔案 ID 不能為空");
                 		}
                 		else
                 		{
                 			fileIdLong = fileId.toLong();
                 			if(fileIdLong == null)
                 			{
                 				resultMap.put("status","failed");
                 				resultMap.put("message","無效的檔案 ID 格式：" + fileId);
                 			}
                 			else
                 			{
                 				fileRec = Files_Master[ID == fileIdLong];
                 				if(fileRec == null)
                 				{
                 					resultMap.put("status","failed");
                 					resultMap.put("message","找不到檔案記錄 ID: " + fileId);
                 				}
                 				else
                 				{
                 					sheetId = ifnull(fileRec.Sheet_Resource_ID,"");
                 					worksheetName = ifnull(fileRec.Worksheet_Name,"");
                 					if(sheetId == "" || worksheetName == "")
                 					{
                 						resultMap.put("status","failed");
                 						resultMap.put("message","檔案資訊不完整：缺少 Sheet ID 或工作表名稱");
                 					}
                 					else
                 					{
                 						// Create Processing_Tasks record
                 						newTask = insert into Processing_Tasks
                 						[
                 							Files_Master=fileRec.ID
                 							Batch_Number=1
                 							Start_Row=2
                 							End_Row=2
                 							Task_Status="處理中"
                 							Start_Time=zoho.currenttime
                 							Added_User=zoho.loginuser
                 						];
                 						taskId = newTask.get("ID");
                 						// Call processBatch
                 						batchResult = thisapp.Batch.processBatch(sheetId,worksheetName,2,2);
                 						batchStatus = ifnull(batchResult.get("status"),"failed");
                 						if(batchStatus == "success")
                 						{
                 							// Update Processing_Tasks
                 							for each  taskRec in Processing_Tasks[ID == taskId]
                 							{
                 								taskRec.Task_Status="已完成";
                 								taskRec.Success_Count=batchResult.get("success_count");
                 								taskRec.Error_Count=batchResult.get("failure_count");
                 								taskRec.End_Time=zoho.currenttime;
                 							}
                 							// Update Files_Master
                 							for each  fileRecUpdate in Files_Master[ID == fileIdLong]
                 							{
                 								fileRecUpdate.Processed_Rows=1;
                 								fileRecUpdate.Success_Count=batchResult.get("success_count");
                 								fileRecUpdate.Error_Count=batchResult.get("failure_count");
                 								fileRecUpdate.Processing_Status="處理中";
                 							}
                 							// Assemble success result
                 							resultMap.put("status","success");
                 							resultMap.put("message","第一批處理完成（測試 1 筆）");
                 							resultMap.put("task_id",taskId.toString());
                 							resultMap.put("batch_number",1);
                 							resultMap.put("processed_range","2 - 2");
                 							resultMap.put("success_count",batchResult.get("success_count"));
                 							resultMap.put("failure_count",batchResult.get("failure_count"));
                 							resultMap.put("total_tokens",batchResult.get("total_tokens"));
                 							resultMap.put("estimated_cost",batchResult.get("estimated_cost"));
                 						}
                 						else
                 						{
                 							// Handle failure
                 							for each  taskRec in Processing_Tasks[ID == taskId]
                 							{
                 								taskRec.Task_Status="失敗";
                 								taskRec.Error_Message=ifnull(batchResult.get("message"),"未知錯誤");
                 								taskRec.End_Time=zoho.currenttime;
                 							}
                 							for each  fileRecUpdate in Files_Master[ID == fileIdLong]
                 							{
                 								fileRecUpdate.Processing_Status="失敗";
                 							}
                 							resultMap.put("status","failed");
                 							resultMap.put("message","批次處理失敗：" + batchResult.get("message"));
                 							resultMap.put("task_id",taskId.toString());
                 						}
                 					}
                 				}
                 			}
                 		}
                 	}
                 	catch (e)
                 	{
                 		resultMap.put("status","failed");
                 		resultMap.put("message","系統錯誤：" + e);
                 	}
                 	return resultMap;
                 }
				 map OpenAI.cleanContactData(map rawData)
                 {
                 	// OpenAI.cleanContactData
                 	// 目的：使用 AI 智能清理聯絡人資料（完全符合 E.164 標準 + CRM Leads 欄位對應）
                 	// 參數：rawData - 從 Sheet 讀取的原始資料（任意欄位結構）
                 	// 回傳：標準化的清理後資料
                 	cleanedData = Map();
                 	cleanedData.put("success",false);
                 	cleanedData.put("error","");
                 	try 
                 	{
                 		// 建立完整的 AI Prompt（使用字串連接）
                 		systemPrompt = "你是專業的聯絡人資料清理專家，精通國際電話號碼標準 E.164 和台灣聯絡人資料處理。\n\n" + "## 任務\n" + "將混亂的聯絡人資料標準化為符合 Zoho CRM Leads 格式的資料。\n\n" + "## 輸入\n" + "你會收到一個 JSON 物件，包含一個聯絡人的資料。\n" + "欄位名稱不固定，可能是中文或英文，可能包含：\n" + "- 姓名相關：Name, First Name, Last Name, 名字, 姓名, nickname, 暱稱等\n" + "- 電話相關：Phone, Mobile, Office Phone, 手機, 市話, 行動電話, 電話, extension, 分機, Area_Code, 區碼等\n" + "- Email 相關：Email, Email Address, 電子郵件, Mail, Non Primary E-mails 等（可能用分號 ; 分隔多個）\n" + "- 地址相關：Country, City, State, Street, 國家, 城市, 省市, 地址等\n" + "- 其他：Title, Designation, Company, Description, Website, 職稱, 公司, 描述, 網站等\n\n" + "## 處理規則\n\n" + "### 1. 姓名處理\n" + "- 如果有分開的 First Name 和 Last Name：直接使用\n" + "- 如果是完整姓名（中文）：第一個字是 Last Name，其他是 First Name\n" + "  例如：陳淑芬 → Last_Name: 陳, First_Name: 淑芬\n" + "- 如果是完整姓名（英文）：空格前是 First Name，空格後是 Last Name\n" + "  例如：John Smith → First_Name: John, Last_Name: Smith\n" + "- 如果姓名是 ? 或 ？ → First_Name: 空白, Last_Name: N/A\n" + "- 如果沒有名字但有 nickname 或 email 前綴：First_Name: 空白, Nickname: 提取的值\n" + "- 移除所有前後空格和多餘空格\n\n" + "### 2. 性別判斷（只有明確才填寫）\n" + "優先順序：\n" + "1. 從 First Name 判斷性別（中文/英文名字）\n" + "2. 如果 First Name 無法判斷，從 Nickname 判斷\n" + "3. 如果還無法判斷，從 Email 前綴判斷（依照常用英文名字）\n" + "4. 如果是無意義前綴（abc123, customerservice 等）→ 不填寫 Nickname，性別留空\n\n" + "**從 Email 前綴提取英文名字的規則：**\n" + "- 提取 @ 符號前的英文名字部分（忽略數字和特殊符號）\n" + "- 只提取常用的英文名字，例如：\n" + "  * 男性：John, Mike, David, Peter, Tom, James, Robert, William, Richard, Charles, Joseph, Thomas, Christopher, Daniel, Matthew, Anthony, Mark, Donald, Steven, Paul, Andrew, Joshua, Kenneth, Kevin, Brian, George, Edward, Ronald, Timothy, Jason, Jeffrey, Ryan, Jacob, Gary, Nicholas, Eric, Jonathan, Stephen, Larry, Justin, Scott, Brandon, Benjamin, Samuel, Gregory, Frank, Alexander, Raymond, Patrick, Jack, Dennis, Jerry, Tyler, Aaron, Jose, Adam, Henry, Nathan, Douglas, Zachary, Kyle, Walter, Ethan, Jeremy, Harold, Keith, Christian, Roger, Noah, Gerald, Carl, Terry, Sean, Austin, Arthur, Lawrence, Jesse, Dylan, Bryan, Joe, Jordan, Billy, Bruce, Albert, Willie, Gabriel, Logan, Alan, Juan, Wayne, Roy, Ralph, Randy, Eugene, Vincent, Russell, Elijah, Louis, Bobby, Philip, Johnny\n" + "  * 女性：Mary, Lisa, Amy, Jennifer, Linda, Patricia, Susan, Jessica, Sarah, Karen, Nancy, Betty, Margaret, Sandra, Ashley, Dorothy, Kimberly, Emily, Donna, Michelle, Carol, Amanda, Melissa, Deborah, Stephanie, Rebecca, Laura, Sharon, Cynthia, Kathleen, Amy, Shirley, Angela, Helen, Anna, Brenda, Pamela, Nicole, Samantha, Katherine, Emma, Ruth, Christine, Catherine, Debra, Rachel, Carolyn, Janet, Virginia, Maria, Heather, Diane, Julie, Joyce, Victoria, Kelly, Christina, Lauren, Joan, Evelyn, Judith, Megan, Cheryl, Andrea, Hannah, Jacqueline, Martha, Gloria, Teresa, Ann, Sara, Madison, Frances, Kathryn, Janice, Jean, Alice, Abigail, Sophia, Judy, Judy, Alexis, Grace\n" + "- **重要：如果從 Email 前綴識別出英文名字並判斷性別，必須同時將該英文名字填入 Nickname 欄位（首字母大寫）**\n" + "- 範例處理：\n" + "  * jeffery0408@gmail.com → 識別 \"jeffery\" 是男性英文名 → Nickname: \"Jeffery\", Salutation: \"Mr.\" （必須兩者都填）\n" + "  * mary.lee@hinet.net → 識別 \"mary\" 是女性英文名 → Nickname: \"Mary\", Salutation: \"Ms.\" （必須兩者都填）\n" + "  * john_wang@company.com → 識別 \"john\" 是男性英文名 → Nickname: \"John\", Salutation: \"Mr.\" （忽略數字和特殊符號）\n" + "  * abc123@gmail.com → \"abc123\" 不是英文名字 → Nickname: \"\", Salutation: \"\" （兩者都留空）\n" + "  * customerservice@company.com → 不是人名 → Nickname: \"\", Salutation: \"\" （兩者都留空）\n\n" + "- 只回傳 Mr. 或 Ms.\n" + "- 如果無法明確判斷，留空（不要猜測）\n" + "- 中文名字範例：淑芬、雅婷、小芳 → Ms. / 大明、俊傑、志明 → Mr.\n\n" + "### 3. 電話處理（E.164 國際標準）\n" + "**手機（Mobile）：**\n" + "- 識別手機號碼（台灣 09 開頭，或中國 13/15/18 開頭等）\n" + "- 格式：+[國碼][國內號碼]\n" + "- 移除所有非數字字元（空格、括號、連字號、點等）\n" + "- 移除國內號碼開頭的 0\n" + "- 加上國碼（根據 Country 欄位或號碼判斷）\n" + "- 必須以 + 開頭，總長度不超過 15 位數字\n" + "- 範例：0912-345-678 + TW → +886912345678\n\n" + "**市話（Phone）：**\n" + "- 識別市話（非手機格式，例如 02-2345-6789）\n" + "- 檢查是否有 Area_Code（區碼）欄位\n" + "- 如果沒有區碼，從地址判斷（必須嚴格遵守）：\n" + "  * 如果地址包含「台北市」或「台北」或「新北市」或「新北」→ 區碼必須是 02\n" + "  * 如果地址包含「高雄市」或「高雄」→ 區碼必須是 07（絕對不是 02！）\n" + "  * 如果地址包含「台中市」或「台中」→ 區碼必須是 04\n" + "  * 如果地址包含「台南市」或「台南」→ 區碼必須是 06\n" + "  * 如果地址是其他城市（桃園、新竹、基隆、宜蘭等）→ 無法判斷，留空\n" + "  * 如果完全沒有地址資訊 → 留空（絕對不要預設或猜測）\n" + "- 格式：+886 + [區碼] + [號碼]\n" + "- 範例：\n" + "  * (02) 2345-6789 + 台北市 → +886223456789\n" + "  * 27123456（無區碼）+ 高雄市 → +886727123456\n" + "  * 23456789（無區碼）+ 無地址 → 留空（不處理）\n" + "- 重要：如果無法從資料中明確判斷區碼，寧可留空，不要猜測\n" + "- 重要：高雄的區碼是 07，絕對不是 02！\n\n" + "**分機（Extension）：**\n" + "- 從 extension, ext, 分機 等欄位提取\n" + "- 只保留數字\n" + "- 獨立儲存，不加在 Phone 後面\n\n" + "**國碼對應：**\n" + "TW/台灣→+886, CN/中國→+86, US/美國→+1, GB/英國→+44, SG/新加坡→+65, JP/日本→+81, HK/香港→+852, KR/韓國→+82\n\n" + "### 4. Email 處理（分號分隔 + 優先順序排序）\n" + "**重要：原始資料中，同一個欄位可能用分號(;)分隔多個 Email**\n" + "例如：darren_hsu@everrich.com.tw;compact70@yahoo.com.tw;radioheadluvme@gmail.com\n\n" + "**處理步驟：**\n" + "1. 如果 Email 欄位包含分號(;)，拆分成多個\n" + "2. 統一轉小寫，移除前後空格\n" + "3. 驗證格式（必須有 @ 和 .）\n" + "4. 移除無效或非人名的 Email（例如 customerservice@company.com）\n" + "5. **按優先順序排序（這是絕對規則，必須嚴格遵守）：**\n" + "   **第一優先：gmail.com**\n" + "   **第二優先：outlook.com / hotmail.com / live.com / msn.com**\n" + "   **第三優先：yahoo.com / yahoo.com.tw**\n" + "   **第四優先：hinet.net**\n" + "   **最後：公司網域（例如 @company.com.tw）和其他**\n" + "6. Email（主要）：優先順序最高的\n" + "7. Secondary_Email（第二）：優先順序第二高的（如果有）\n\n" + "**重要規則：**\n" + "- 優先順序完全依據「網域」，不考慮 Email 地址的內容\n" + "- 即使 mary.lee@hinet.net 有完整人名，maryl@outlook.com 仍然優先（因為 outlook > hinet）\n" + "- 即使 manager@company.com.tw 看起來很正式，john@gmail.com 仍然優先（因為 gmail > 公司）\n" + "- 必須嚴格按照網域優先順序排序，不可以有例外\n\n" + "**範例：**\n" + "範例 1：\n" + "輸入：darren_hsu@everrich.com.tw;compact70@yahoo.com.tw;radioheadluvme@gmail.com\n" + "輸出：\n" + "  Email: radioheadluvme@gmail.com（gmail 第一優先）\n" + "  Secondary_Email: compact70@yahoo.com.tw（yahoo 第二優先）\n\n" + "範例 2：\n" + "輸入：manager@bigcompany.com.tw;mary.lee@hinet.net;maryl@outlook.com\n" + "輸出：\n" + "  Email: maryl@outlook.com（outlook 第一優先，不是 hinet！）\n" + "  Secondary_Email: mary.lee@hinet.net（hinet 第二優先）\n\n" + "### 5. 國別處理（轉繁體中文）\n" + "- 將國碼或英文國名轉換為繁體中文\n" + "- TW → 台灣（使用「台」不是「臺」）\n" + "- CN → 中國\n" + "- US → 美國\n" + "- GB → 英國\n" + "- SG → 新加坡\n" + "- JP → 日本\n" + "- HK → 香港\n" + "- KR → 韓國\n" + "- 其他國家自動查詢轉換\n" + "- 如果無國碼且無法從電話判斷，預設：台灣\n\n" + "### 6. 描述處理（激進改寫）\n" + "**重要：這些是 2017 年前的歷史資料**\n\n" + "處理規則：\n" + "1. 移除所有 HTML 標籤（<p>, </p>, <br>, <div> 等）\n" + "2. 移除所有明確署名（例如：/ Alston, - Mary, /Mary 等格式）\n" + "3. 移除所有時效性描述（下個月、明天、本週、最近、上週、昨天等）\n" + "4. 識別 6 位碼日期（YYMMDD 格式）→ 只保留年份\n" + "   例如：170816 → 2017年, 150320 → 2015年\n" + "5. 保留資料來源（例如：展覽、LinkedIn、電話聯繫等）\n" + "6. 保留對聯絡人的具體描述（興趣、需求、背景等）\n" + "7. AI 改寫為清晰易懂的簡短語句\n" + "8. 移除多餘空格，前後 trim\n\n" + "**範例：**\n" + "輸入：<p>170816 展覽認識，客戶下個月要開記者會，對產品很有興趣 / Alston</p>\n" + "輸出：2017年展覽認識，對產品有興趣\n\n" + "輸入：150320 電話聯繫 - Mary\n" + "輸出：2015年電話聯繫\n\n" + "### 7. 其他欄位\n" + "- Designation（職稱）：保留原文，trim 空格\n" + "- Company（公司）：保留原文，trim 空格\n" + "- Website（網站）：保留原文，trim 空格\n" + "- City, State, Zip_Code：保留原文，trim 空格\n" + "- Fax（傳真）：不處理，不回傳\n\n" + "## 輸出格式\n" + "必須回傳有效的 JSON（不要包含任何解釋或其他文字）：\n" + "{\n" + "  \"Salutation\": \"Mr.\" or \"Ms.\" or \"\",\n" + "  \"First_Name\": \"\",\n" + "  \"Last_Name\": \"\",\n" + "  \"Nickname\": \"\",\n" + "  \"Mobile\": \"+886912345678\",\n" + "  \"Phone\": \"+886223456789\",\n" + "  \"Extension\": \"123\",\n" + "  \"Email\": \"john@gmail.com\",\n" + "  \"Secondary_Email\": \"test@yahoo.com\",\n" + "  \"Company\": \"\",\n" + "  \"Designation\": \"\",\n" + "  \"Description\": \"\",\n" + "  \"Country\": \"台灣\",\n" + "  \"State\": \"\",\n" + "  \"City\": \"\",\n" + "  \"Zip_Code\": \"\",\n" + "  \"Website\": \"\"\n" + "}\n\n" + "## 重要提醒\n" + "1. 回傳的必須是純 JSON，不要包含任何其他文字或解釋\n" + "2. 電話號碼必須嚴格符合 E.164：+[國碼][號碼]，只能包含數字\n" + "3. Email 如果有分號(;)，必須拆分並按優先順序排序\n" + "4. 國別必須是繁體中文（台灣、中國等）\n" + "5. 性別只有明確才填寫，無法確定就留空\n" + "6. 問號(?)代表無資料：First_Name 留空，Last_Name 填 N/A\n" + "7. 描述要激進改寫，移除署名和時效性內容\n" + "8. 所有欄位值必須是字串類型\n" + "9. 所有文字前後必須 trim，移除多餘空格";
                 		// 準備使用者訊息
                 		userMessage = "請清理以下聯絡人資料：\n\n" + rawData.toString();
                 		// 建立 API 請求
                 		messages = List();
                 		messages.add({"role":"system","content":systemPrompt});
                 		messages.add({"role":"user","content":userMessage});
                 		apiParams = Map();
                 		apiParams.put("model",thisapp.variables.OpenAI_Model);
                 		apiParams.put("messages",messages);
                 		apiParams.put("temperature",0.1);
                 		apiParams.put("max_tokens",1000);
                 		headers = Map();
                 		headers.put("Authorization","Bearer " + thisapp.variables.OpenAI_API_Key);
                 		headers.put("Content-Type","application/json");
                 		// 調用 OpenAI API
                 		aiResponse = invokeurl
                 		[
                 			url :thisapp.variables.OpenAI_API_URL
                 			type :POST
                 			parameters:apiParams.toString()
                 			headers:headers
                 		];
                 		// 解析 AI 回應
                 		if(aiResponse.get("choices") != null && aiResponse.get("choices").size() > 0)
                 		{
                 			aiContent = aiResponse.get("choices").get(0).get("message").get("content").trim();
                 			// 移除可能的 markdown 代碼塊標記
                 			if(aiContent.startsWith("```json"))
                 			{
                 				aiContent = aiContent.subString(7);
                 			}
                 			if(aiContent.startsWith("```"))
                 			{
                 				aiContent = aiContent.subString(3);
                 			}
                 			if(aiContent.endsWith("```"))
                 			{
                 				aiContent = aiContent.subString(0,aiContent.length() - 3);
                 			}
                 			aiContent = aiContent.trim();
                 			// 將 AI 回傳的 JSON 字串轉換成 Map
                 			try 
                 			{
                 				aiResult = aiContent.toMap();
                 				// 驗證並整合到回傳結果
                 				cleanedData.put("success",true);
                 				cleanedData.put("Salutation",ifnull(aiResult.get("Salutation"),""));
                 				cleanedData.put("First_Name",ifnull(aiResult.get("First_Name"),""));
                 				cleanedData.put("Last_Name",ifnull(aiResult.get("Last_Name"),""));
                 				cleanedData.put("Nickname",ifnull(aiResult.get("Nickname"),""));
                 				cleanedData.put("Mobile",ifnull(aiResult.get("Mobile"),""));
                 				cleanedData.put("Phone",ifnull(aiResult.get("Phone"),""));
                 				cleanedData.put("Extension",ifnull(aiResult.get("Extension"),""));
                 				cleanedData.put("Email",ifnull(aiResult.get("Email"),""));
                 				cleanedData.put("Secondary_Email",ifnull(aiResult.get("Secondary_Email"),""));
                 				cleanedData.put("Company",ifnull(aiResult.get("Company"),""));
                 				cleanedData.put("Designation",ifnull(aiResult.get("Designation"),""));
                 				cleanedData.put("Description",ifnull(aiResult.get("Description"),""));
                 				cleanedData.put("Country",ifnull(aiResult.get("Country"),""));
                 				cleanedData.put("State",ifnull(aiResult.get("State"),""));
                 				cleanedData.put("City",ifnull(aiResult.get("City"),""));
                 				cleanedData.put("Zip_Code",ifnull(aiResult.get("Zip_Code"),""));
                 				cleanedData.put("Website",ifnull(aiResult.get("Website"),""));
                 				// E.164 格式驗證（手機）
                 				mobile = cleanedData.get("Mobile");
                 				if(mobile != "")
                 				{
                 					if(!mobile.startsWith("+"))
                 					{
                 						cleanedData.put("Mobile","");
                 						cleanedData.put("error",cleanedData.get("error") + " 手機格式不符合 E.164;");
                 					}
                 				}
                 				// E.164 格式驗證（市話）
                 				phone = cleanedData.get("Phone");
                 				if(phone != "")
                 				{
                 					if(!phone.startsWith("+"))
                 					{
                 						cleanedData.put("Phone","");
                 						cleanedData.put("error",cleanedData.get("error") + " 市話格式不符合 E.164;");
                 					}
                 				}
                 			}
                 			catch (parseError)
                 			{
                 				cleanedData.put("success",false);
                 				cleanedData.put("error","AI 回應格式錯誤：" + aiContent.subString(0,200));
                 			}
                 		}
                 		else
                 		{
                 			cleanedData.put("success",false);
                 			cleanedData.put("error","AI 沒有回應");
                 		}
                 	}
                 	catch (e)
                 	{
                 		cleanedData.put("success",false);
                 		cleanedData.put("error",e.toString());
                 	}
                 	return cleanedData;
                 }
				 string TEST.testBatchStart()
                 {
                 	// TEST.testBatchStart
                 	// 目的：測試 Batch.startProcessing 函數
