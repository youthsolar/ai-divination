				 string TEST.testCleanData()
                 {
                 	// TEST.testCleanData
                 	// 目的：測試 OpenAI.cleanContactData 函數（完整功能驗證）
                 	resultMessage = "";
                 	try 
                 	{
                 		// 建立測試資料（模擬真實的混亂資料）
                 		testData = Map();
                 		testData.put("Name","陳淑芬");
                 		testData.put("手機","0912-345-678");
                 		testData.put("市話","(02) 2712-3456");
                 		testData.put("分機","123");
                 		testData.put("countries_code_c","TW");
                 		testData.put("Email Address","darren_hsu@everrich.com.tw;compact70@yahoo.com.tw;radioheadluvme@gmail.com");
                 		testData.put("Company","測試公司");
                 		testData.put("Title","經理");
                 		testData.put("Description","<p>170816 展覽認識，客戶下個月要開記者會，對產品很有興趣 / Alston</p>");
                 		testData.put("City","台北市");
                 		testData.put("State","台北");
                 		testData.put("Website","http://www.test.com.tw");
                 		resultMessage = "=== 測試 AI 資料清理（完整功能）===\n\n";
                 		resultMessage = resultMessage + "? 原始資料：\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		resultMessage = resultMessage + "姓名: " + testData.get("Name") + "\n";
                 		resultMessage = resultMessage + "手機: " + testData.get("手機") + "\n";
                 		resultMessage = resultMessage + "市話: " + testData.get("市話") + "\n";
                 		resultMessage = resultMessage + "分機: " + testData.get("分機") + "\n";
                 		resultMessage = resultMessage + "Email: " + testData.get("Email Address") + "\n";
                 		resultMessage = resultMessage + "  （注意：分號分隔多個）\n";
                 		resultMessage = resultMessage + "國別: " + testData.get("countries_code_c") + "\n";
                 		resultMessage = resultMessage + "城市: " + testData.get("City") + "\n";
                 		resultMessage = resultMessage + "描述: " + testData.get("Description") + "\n";
                 		resultMessage = resultMessage + "  （注意：HTML + 6位碼日期 + 署名）\n";
                 		resultMessage = resultMessage + "網站: " + testData.get("Website") + "\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n\n";
                 		resultMessage = resultMessage + "? 開始調用 AI 清理...\n\n";
                 		// 調用清理函數
                 		result = thisapp.OpenAI.cleanContactData(testData);
                 		// 顯示結果
                 		if(result.get("success") == true)
                 		{
                 			resultMessage = resultMessage + "✅ 清理成功！\n\n";
                 			resultMessage = resultMessage + "? 清理結果：\n";
                 			resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 			resultMessage = resultMessage + "稱謂: " + result.get("Salutation") + "\n";
                 			resultMessage = resultMessage + "姓: " + result.get("Last_Name") + "\n";
                 			resultMessage = resultMessage + "名: " + result.get("First_Name") + "\n";
                 			resultMessage = resultMessage + "暱稱: " + result.get("Nickname") + "\n";
                 			resultMessage = resultMessage + "手機: " + result.get("Mobile") + "\n";
                 			resultMessage = resultMessage + "市話: " + result.get("Phone") + "\n";
                 			resultMessage = resultMessage + "分機: " + result.get("Extension") + "\n";
                 			resultMessage = resultMessage + "主要信箱: " + result.get("Email") + "\n";
                 			resultMessage = resultMessage + "第二信箱: " + result.get("Secondary_Email") + "\n";
                 			resultMessage = resultMessage + "職稱: " + result.get("Designation") + "\n";
                 			resultMessage = resultMessage + "公司: " + result.get("Company") + "\n";
                 			resultMessage = resultMessage + "國別: " + result.get("Country") + "\n";
                 			resultMessage = resultMessage + "省市: " + result.get("State") + "\n";
                 			resultMessage = resultMessage + "城市: " + result.get("City") + "\n";
                 			resultMessage = resultMessage + "郵編: " + result.get("Zip_Code") + "\n";
                 			resultMessage = resultMessage + "網站: " + result.get("Website") + "\n";
                 			resultMessage = resultMessage + "描述: " + result.get("Description") + "\n";
                 			resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n\n";
                 			// 驗證關鍵功能
                 			resultMessage = resultMessage + "? 功能驗證：\n";
                 			resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 			// 1. E.164 格式驗證
                 			mobile = result.get("Mobile");
                 			phone = result.get("Phone");
                 			if(mobile != "" && mobile.startsWith("+") && mobile.length() >= 12 && mobile.length() <= 16)
                 			{
                 				resultMessage = resultMessage + "✅ 手機符合 E.164 標準\n";
                 			}
                 			else if(mobile != "")
                 			{
                 				resultMessage = resultMessage + "❌ 手機不符合 E.164: " + mobile + "\n";
                 			}
                 			else
                 			{
                 				resultMessage = resultMessage + "⚠️  手機為空\n";
                 			}
                 			if(phone != "" && phone.startsWith("+") && phone.length() >= 12 && phone.length() <= 16)
                 			{
                 				resultMessage = resultMessage + "✅ 市話符合 E.164 標準\n";
                 			}
                 			else if(phone != "")
                 			{
                 				resultMessage = resultMessage + "❌ 市話不符合 E.164: " + phone + "\n";
                 			}
                 			else
                 			{
                 				resultMessage = resultMessage + "⚠️  市話為空\n";
                 			}
                 			// 2. Email 優先順序驗證
                 			email1 = result.get("Email");
                 			email2 = result.get("Secondary_Email");
                 			if(email1.contains("gmail.com"))
                 			{
                 				resultMessage = resultMessage + "✅ Email 優先順序正確（gmail 優先）\n";
                 			}
                 			else if(email1 != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  Email 優先順序可能不正確: " + email1 + "\n";
                 			}
                 			if(email2.contains("yahoo.com"))
                 			{
                 				resultMessage = resultMessage + "✅ 第二信箱正確識別（yahoo）\n";
                 			}
                 			else if(email2 != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  第二信箱: " + email2 + "\n";
                 			}
                 			// 3. 國別繁體中文驗證
                 			country = result.get("Country");
                 			if(country == "台灣")
                 			{
                 				resultMessage = resultMessage + "✅ 國別轉換正確（台灣）\n";
                 			}
                 			else if(country != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  國別轉換: " + country + "\n";
                 			}
                 			// 4. 描述改寫驗證
                 			desc = result.get("Description");
                 			if(desc != "" && !desc.contains("<p>") && !desc.contains("Alston") && !desc.contains("下個月"))
                 			{
                 				resultMessage = resultMessage + "✅ 描述成功改寫（移除 HTML、署名、時效性）\n";
                 			}
                 			else if(desc != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  描述改寫可能不完整\n";
                 			}
                 			if(desc.contains("2017"))
                 			{
                 				resultMessage = resultMessage + "✅ 6位碼日期轉換成功（保留年份）\n";
                 			}
                 			else if(desc != "" && testData.get("Description").contains("170816"))
                 			{
                 				resultMessage = resultMessage + "⚠️  6位碼日期未正確轉換\n";
                 			}
                 			// 5. 姓名分割驗證
                 			lastName = result.get("Last_Name");
                 			firstName = result.get("First_Name");
                 			if(lastName == "陳" && firstName == "淑芬")
                 			{
                 				resultMessage = resultMessage + "✅ 中文姓名正確分割\n";
                 			}
                 			else if(lastName != "" || firstName != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  姓名分割: " + lastName + " / " + firstName + "\n";
                 			}
                 			// 6. 錯誤訊息檢查
                 			errorMsg = result.get("error");
                 			if(errorMsg != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  警告訊息: " + errorMsg + "\n";
                 			}
                 			resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		}
                 		else
                 		{
                 			resultMessage = resultMessage + "❌ 清理失敗！\n";
                 			resultMessage = resultMessage + "錯誤訊息: " + result.get("error") + "\n";
                 		}
                 	}
                 	catch (e)
                 	{
                 		resultMessage = resultMessage + "❌ 測試函數執行錯誤\n";
                 		resultMessage = resultMessage + "錯誤訊息: " + e.toString();
                 	}
                 	resultMessage = resultMessage + "\n=== 測試完成 ===\n\n";
                 	resultMessage = resultMessage + "? 提示：\n";
                 	resultMessage = resultMessage + "- 如果驗證通過，可以開始處理真實資料\n";
                 	resultMessage = resultMessage + "- 建議先測試幾筆真實資料，確認 AI 判斷準確度\n";
                 	resultMessage = resultMessage + "- 每 500 筆人工校對一次，調整 AI Prompt";
                 	return resultMessage;
                 }
				 string TEST.testEdgeCases()
                 {
                 	// TEST.testEdgeCases
                 	// 目的：進階邊緣案例測試 + 執行時間壓力測試（5個案例連續測試）
                 	resultMessage = "";
                 	startTime = zoho.currenttime;
                 	try 
                 	{
                 		resultMessage = "=== 進階邊緣案例測試（壓力測試）===\n";
                 		resultMessage = resultMessage + "⏱️  開始時間: " + startTime.toString("yyyy-MM-dd HH:mm:ss") + "\n\n";
                 		// 測試案例 1：台北市話（確認沒被高雄修正影響）
                 		resultMessage = resultMessage + "【測試 1】台北市話區碼判斷（確認 02 正確）\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		test1Start = zoho.currenttime;
                 		testData1 = Map();
                 		testData1.put("Name","陳經理");
                 		testData1.put("市話","2712-3456");
                 		testData1.put("分機","101");
                 		testData1.put("City","台北市");
                 		testData1.put("State","台北");
                 		testData1.put("countries_code_c","TW");
                 		resultMessage = resultMessage + "原始: 市話=2712-3456, 分機=101, City=台北市\n";
                 		result1 = thisapp.OpenAI.cleanContactData(testData1);
                 		test1End = zoho.currenttime;
                 		test1Duration = ((test1End - test1Start)) / 1000;
                 		if(result1.get("success") == true)
                 		{
                 			resultMessage = resultMessage + "結果:\n";
                 			resultMessage = resultMessage + "  Phone: \"" + result1.get("Phone") + "\"\n";
                 			resultMessage = resultMessage + "  Extension: \"" + result1.get("Extension") + "\"\n";
                 			resultMessage = resultMessage + "  執行時間: " + test1Duration + " 秒\n";
                 			if(result1.get("Phone") == "+886227123456" && result1.get("Extension") == "101")
                 			{
                 				resultMessage = resultMessage + "✅ 台北區碼正確（02）+ 分機正確\n";
                 			}
                 			else
                 			{
                 				resultMessage = resultMessage + "⚠️  結果不符預期\n";
                 			}
                 		}
                 		else
                 		{
                 			resultMessage = resultMessage + "❌ 失敗: " + result1.get("error") + "\n";
                 		}
                 		resultMessage = resultMessage + "\n";
                 		// 測試案例 2：無地址市話（應該留空）
                 		resultMessage = resultMessage + "【測試 2】無地址的市話（應該留空，不預設）\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		test2Start = zoho.currenttime;
                 		testData2 = Map();
                 		testData2.put("Name","王小華");
                 		testData2.put("市話","23456789");
                 		testData2.put("手機","0912345678");
                 		testData2.put("countries_code_c","TW");
                 		resultMessage = resultMessage + "原始: 市話=23456789（無區碼）, 無地址資訊\n";
                 		result2 = thisapp.OpenAI.cleanContactData(testData2);
                 		test2End = zoho.currenttime;
                 		test2Duration = ((test2End - test2Start)) / 1000;
                 		if(result2.get("success") == true)
                 		{
                 			resultMessage = resultMessage + "結果:\n";
                 			resultMessage = resultMessage + "  Mobile: \"" + result2.get("Mobile") + "\"\n";
                 			resultMessage = resultMessage + "  Phone: \"" + result2.get("Phone") + "\"\n";
                 			resultMessage = resultMessage + "  執行時間: " + test2Duration + " 秒\n";
                 			if(result2.get("Phone") == "" && result2.get("Mobile") == "+886912345678")
                 			{
                 				resultMessage = resultMessage + "✅ 無地址時正確留空市話（保守處理）\n";
                 			}
                 			else if(result2.get("Phone") != "")
                 			{
                 				resultMessage = resultMessage + "⚠️  AI 預設了區碼: " + result2.get("Phone") + "（不符預期）\n";
                 			}
                 		}
                 		else
                 		{
                 			resultMessage = resultMessage + "❌ 失敗: " + result2.get("error") + "\n";
                 		}
                 		resultMessage = resultMessage + "\n";
                 		// 測試案例 3：複雜 Email 前綴（包含點和下劃線）
                 		resultMessage = resultMessage + "【測試 3】複雜 Email 前綴提取（含點和底線）\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		test3Start = zoho.currenttime;
                 		testData3 = Map();
                 		testData3.put("Email","mary.wang_123@hotmail.com");
                 		testData3.put("手機","0933567890");
                 		testData3.put("countries_code_c","TW");
                 		resultMessage = resultMessage + "原始: Email=mary.wang_123@hotmail.com（含點、底線、數字）\n";
                 		result3 = thisapp.OpenAI.cleanContactData(testData3);
                 		test3End = zoho.currenttime;
                 		test3Duration = ((test3End - test3Start)) / 1000;
                 		if(result3.get("success") == true)
                 		{
                 			resultMessage = resultMessage + "結果:\n";
                 			resultMessage = resultMessage + "  Nickname: \"" + result3.get("Nickname") + "\"\n";
                 			resultMessage = resultMessage + "  Salutation: \"" + result3.get("Salutation") + "\"\n";
                 			resultMessage = resultMessage + "  執行時間: " + test3Duration + " 秒\n";
                 			if(result3.get("Nickname").toLowerCase().contains("mary") && result3.get("Salutation") == "Ms.")
                 			{
                 				resultMessage = resultMessage + "✅ 成功提取 Mary（忽略點、底線、數字）\n";
                 			}
                 			else if(result3.get("Nickname") == "" && result3.get("Salutation") == "")
                 			{
                 				resultMessage = resultMessage + "⚠️  未能提取（可能太複雜）\n";
                 			}
                 		}
                 		else
                 		{
                 			resultMessage = resultMessage + "❌ 失敗: " + result3.get("error") + "\n";
                 		}
                 		resultMessage = resultMessage + "\n";
                 		// 測試案例 4：中國手機號碼（國際號碼識別）
                 		resultMessage = resultMessage + "【測試 4】中國手機號碼識別（國際號碼）\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		test4Start = zoho.currenttime;
                 		testData4 = Map();
                 		testData4.put("Name","李明");
                 		testData4.put("手機","18601681022");
                 		testData4.put("Email","liming@qq.com");
                 		testData4.put("City","北京");
                 		resultMessage = resultMessage + "原始: 手機=18601681022（中國格式）, City=北京\n";
                 		result4 = thisapp.OpenAI.cleanContactData(testData4);
                 		test4End = zoho.currenttime;
                 		test4Duration = ((test4End - test4Start)) / 1000;
                 		if(result4.get("success") == true)
                 		{
                 			resultMessage = resultMessage + "結果:\n";
                 			resultMessage = resultMessage + "  Mobile: \"" + result4.get("Mobile") + "\"\n";
                 			resultMessage = resultMessage + "  Country: \"" + result4.get("Country") + "\"\n";
                 			resultMessage = resultMessage + "  執行時間: " + test4Duration + " 秒\n";
                 			if(result4.get("Mobile").contains("+8618601681022") && result4.get("Country") == "中國")
                 			{
                 				resultMessage = resultMessage + "✅ 正確識別中國手機（+86）+ 國別繁體中文\n";
                 			}
                 			else if(result4.get("Mobile").startsWith("+86"))
                 			{
                 				resultMessage = resultMessage + "⚠️  識別為中國但格式可能不正確: " + result4.get("Mobile") + "\n";
                 			}
                 			else
                 			{
                 				resultMessage = resultMessage + "⚠️  未能正確識別中國手機\n";
                 			}
                 		}
                 		else
                 		{
                 			resultMessage = resultMessage + "❌ 失敗: " + result4.get("error") + "\n";
                 		}
                 		resultMessage = resultMessage + "\n";
                 		// 測試案例 5：多層次描述改寫（多個6位碼日期）
                 		resultMessage = resultMessage + "【測試 5】複雜描述改寫（多個日期 + 多個署名）\n";
                 		resultMessage = resultMessage + "━━━━━━━━━━━━━━━━━━━━\n";
                 		test5Start = zoho.currenttime;
                 		testData5 = Map();
                 		testData5.put("Name","張經理");
                 		testData5.put("Description","<p>140512 電話初次聯繫 / John<br>150820 展覽見面，客戶下週要來訪，對產品很滿意 - Mary<br>161103 報價單已寄出 / David</p>");
                 		testData5.put("countries_code_c","TW");
                 		resultMessage = resultMessage + "原始: 多個6位碼日期 + 多個署名 + HTML + 時效性\n";
                 		result5 = thisapp.OpenAI.cleanContactData(testData5);
                 		test5End = zoho.currenttime;
                 		test5Duration = ((test5End - test5Start)) / 1000;
                 		if(result5.get("success") == true)
                 		{
                 			resultMessage = resultMessage + "結果:\n";
                 			resultMessage = resultMessage + "  Description: \"" + result5.get("Description") + "\"\n";
                 			resultMessage = resultMessage + "  執行時間: " + test5Duration + " 秒\n";
                 			desc = result5.get("Description");
                 			hasYears = desc.contains("2014") || desc.contains("2015") || desc.contains("2016");
                 			noHTML = !desc.contains("<p>") && !desc.contains("<br>");
                 			noSignatures = !desc.contains("John") && !desc.contains("Mary") && !desc.contains("David") && !desc.contains("/") && !desc.contains("-");
                 			noTimeSensitive = !desc.contains("下週");
                 			if(hasYears && noHTML && noSignatures && noTimeSensitive)
                 			{
                 				resultMessage = resultMessage + "✅ 複雜描述改寫成功（保留年份，移除 HTML/署名/時效性）\n";
                 			}
                 			else
                 			{
                 				resultMessage = resultMessage + "⚠️  部分改寫可能不完整\n";
                 				if(!hasYears)
                 				{
                 					resultMessage = resultMessage + "  - 年份轉換可能有問題\n";
                 				}
                 				if(!noHTML)
                 				{
                 					resultMessage = resultMessage + "  - HTML 未完全移除\n";
                 				}
                 				if(!noSignatures)
                 				{
                 					resultMessage = resultMessage + "  - 署名未完全移除\n";
                 				}
                 			}
                 		}
                 		else
                 		{
                 			resultMessage = resultMessage + "❌ 失敗: " + result5.get("error") + "\n";
                 		}
                 		// 總結
                 		endTime = zoho.currenttime;
                 		totalDuration = ((endTime - startTime)) / 1000;
                 		resultMessage = resultMessage + "\n=== 測試完成 ===\n";
                 		resultMessage = resultMessage + "⏱️  結束時間: " + endTime.toString("yyyy-MM-dd HH:mm:ss") + "\n";
                 		resultMessage = resultMessage + "⏱️  總執行時間: " + totalDuration + " 秒\n";
                 		resultMessage = resultMessage + "? 平均每筆: " + (totalDuration / 5).round(1) + " 秒\n\n";
                 		resultMessage = resultMessage + "? 壓力測試分析：\n";
                 		resultMessage = resultMessage + "- 5 筆測試總時間: " + totalDuration + " 秒\n";
                 		resultMessage = resultMessage + "- 500 筆預估時間: " + (totalDuration * 100).round(0) + " 秒 ≈ " + ((totalDuration * 100) / 60).round(1) + " 分鐘\n";
                 		resultMessage = resultMessage + "- 30 萬筆預估時間: " + ((totalDuration * 60000) / 3600).round(1) + " 小時\n\n";
                 		resultMessage = resultMessage + "✅ 如果所有測試通過，可以開始處理真實資料！\n";
                 		resultMessage = resultMessage + "⚠️  建議：先處理 500 筆，人工校對後再批量處理";
                 	}
                 	catch (e)
                 	{
                 		resultMessage = resultMessage + "❌ 測試執行錯誤: " + e.toString();
                 	}
                 	return resultMessage;
                 }
				 string TEST.testOpenAI()
                 {
                 	// testOpenAI
                 	// 目的：測試 OpenAI API 連接和基本的性別判斷功能
                 	// 回傳：測試結果訊息
                 	info "=== OpenAI API 測試開始 ===";
                 	// 測試用的名字
                 	testName = "淑芬";
                 	// 建立 System Prompt
                 	systemPrompt = "你是一個中文名字性別判斷專家。根據使用者提供的名字，判斷其最可能的性別。你的回答必須只能是「Mr.」或「Ms.」，不能包含任何其他標點符號、文字或解釋。";
                 	// 建立訊息陣列
                 	messages = List();
                 	// 添加 System Message
                 	systemMsg = Map();
                 	systemMsg.put("role","system");
                 	systemMsg.put("content",systemPrompt);
                 	messages.add(systemMsg);
                 	// 添加範例（Few-shot）
                 	messages.add({"role":"user","content":"大明"});
                 	messages.add({"role":"assistant","content":"Mr."});
                 	messages.add({"role":"user","content":"淑芬"});
                 	messages.add({"role":"assistant","content":"Ms."});
                 	messages.add({"role":"user","content":"俊傑"});
                 	messages.add({"role":"assistant","content":"Mr."});
                 	// 添加實際要測試的名字
                 	userMsg = Map();
                 	userMsg.put("role","user");
                 	userMsg.put("content",testName);
                 	messages.add(userMsg);
                 	// 建立 API 請求參數
                 	apiParams = Map();
                 	apiParams.put("model",thisapp.variables.OpenAI_Model);
                 	apiParams.put("messages",messages);
                 	apiParams.put("temperature",0.1);
                 	apiParams.put("max_tokens",10);
                 	// 設定請求標頭
                 	headers = Map();
                 	headers.put("Authorization","Bearer " + thisapp.variables.OpenAI_API_Key);
                 	headers.put("Content-Type","application/json");
                 	// 執行 API 調用
                 	resultMessage = "";
                 	try 
                 	{
                 		info "開始調用 OpenAI API...";
                 		info "測試名字：" + testName;
                 		response = invokeurl
                 		[
                 			url :thisapp.variables.OpenAI_API_URL
                 			type :POST
                 			parameters:apiParams.toString()
                 			headers:headers
                 		];
                 		info "API 回應：" + response.toString();
                 		// 解析回應
                 		if(response.get("choices") != null && response.get("choices").size() > 0)
                 		{
                 			aiReply = response.get("choices").get(0).get("message").get("content").trim();
                 			info "AI 判斷結果：" + aiReply;
                 			resultMessage = "✅ 測試成功！\n";
                 			resultMessage = resultMessage + "測試名字：" + testName + "\n";
                 			resultMessage = resultMessage + "AI 判斷：" + aiReply + "\n";
                 			resultMessage = resultMessage + "API 狀態：正常運作";
                 		}
                 		else
                 		{
                 			resultMessage = "❌ API 回應格式錯誤\n";
                 			resultMessage = resultMessage + "回應內容：" + response.toString();
                 		}
                 	}
                 	catch (e)
                 	{
                 		info "❌ API 調用失敗：" + e.toString();
                 		resultMessage = "❌ 測試失敗！\n";
                 		resultMessage = resultMessage + "錯誤訊息：" + e.toString();
                 	}
                 	info "=== 測試完成 ===";
                 	return resultMessage;
                 }
				 string TEST.testReadSheet()
                 {
                 	// testReadSheet
                 	// 目的：測試讀取 Zoho Sheet 資料（最簡化版）
                 	// 回傳：測試結果訊息
                 	resultMessage = "";
                 	try 
                 	{
                 		sheetResourceId = "63665b5f4ce28cde340f9999910832b4ce6c5";
                 		worksheetName = "190620_Leads";
                 		// 準備參數
                 		configMap = Map();
                 		configMap.put("max_records",2);
                 		// 讀取資料
                 		records = zoho.sheet.getRecords(sheetResourceId,worksheetName,configMap,"zoho_sheet_connection");
                 		// 檢查是否有資料
                 		if(records != null)
                 		{
                 			resultMessage = "✅ 成功讀取到資料！\n\n";
                 			// 嘗試取得第一筆資料的所有欄位名稱
                 			try 
                 			{
                 				firstRecord = records.toList().get(0);
                 				resultMessage = resultMessage + "第一筆資料的欄位：\n";
                 				resultMessage = resultMessage + firstRecord.keys().toString();
                 			}
                 			catch (ex)
                 			{
                 				resultMessage = resultMessage + "資料格式：" + records.toString().subString(0,500);
                 			}
                 		}
                 		else
                 		{
                 			resultMessage = "⚠️ records 為 null";
                 		}
                 	}
                 	catch (e)
                 	{
                 		resultMessage = "❌ 錯誤：" + e.toString();
                 	}
                 	return resultMessage;
                 }
			 }
		 }
		workflow
		{






		functions
		{
			startProcessingButton as "startProcessingButton"
			{
				type =  functions
				form = Files_Master
				execution type = for each record	
				on start
				{
					actions 
					{
					on click
					(
						// 獲取當前記錄的 ID
										fileId = input.ID.toString();
										// 調用 Batch.startProcessing 函數
										result = thisapp.Batch.startProcessing(fileId);
										// 處理完成，結果已記錄在資料庫中
										// 用戶可以通過報表查看處理結果
					)
					}
				}
			}
		}
	}
