		list member_tickets_Report
		{
			displayName = "會員客服單 Report"
			show all rows from Client_Support_Tickets    
			(
				member as "會員"
				subject_1 as "主旨"
				description as "描述"
				status as "狀態"
				priority as "優先順序"
				case as "案件"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "已關閉")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "處理中")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "開啟")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban member_tickets_by_status
		{
