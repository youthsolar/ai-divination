 application "會員中心"
 {
 	date format = "yyyy/MM/dd"
 	time zone = "Asia/Taipei"
 	time format = "24-hr"
 	forms
	{
		form Client_Support_Tickets
		{
			displayname = "客服工單"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			member
			(
				type = picklist	
				displayname = "會員"
				values  = Client_Members.ID
    			displayformat = [member_code]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			subject_1
			(
    			type = text
				displayname = "主旨"
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "描述"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "狀態"
				values = {"開啟","已解決","處理中","已關閉"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			priority
			(
				type = picklist
				displayname = "優先順序"
				values = {"高","中","低"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			case
			(
				type = picklist	
				displayname = "案件"
				datasource = cases
    			displayformat = [case_origin]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Ticket Created","Ticket Assigned","Ticket Cancelled","Ticket In Progress","Ticket Reopened","Ticket Resolved","Ticket Escalated","Ticket On Hold","Ticket Closed"}
			}
		}
		form Client_Support_Sessions
		{
			displayname = "支援會話"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			member
			(
				type = picklist	
				displayname = "會員"
				values  = Client_Members.ID
    			displayformat = [member_code]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			start_time
			(
    			type = datetime
				displayname = "開始時間"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			end_time
			(
    			type = datetime
				displayname = "結束時間"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			channel
			(
				type = radiobuttons
				displayname = "支援渠道"
				values = {"SalesIQ","Desk"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "狀態"
				values = {"已結束","進行中","已轉交"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			case
			(
				type = picklist	
				displayname = "案件"
				datasource = cases
    			displayformat = [case_origin]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form Client_Members
		{
			displayname = "會員資料"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			member_code
			(
    			type = autonumber
				displayname = "會員編號"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			google_id
			(
    			type = text
				displayname = "Google帳號ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			email
			(
    			type = email
				displayname = "電子郵件"
	 			row = 1
	 			column = 1   
				width = medium
			)
			name
			(
    			type = name
				displayname = "姓名"
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
	     			 visibility = false
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = medium
			)
			phone
			(
    			type = phonenumber
				displayname = "電話"
	 			row = 1
	 			column = 1   
				width = medium
			)
			register_date
			(
    			type = datetime
				displayname = "註冊日期"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "狀態"
				values = {"啟用","停用","待驗證"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			lead
			(
				type = picklist	
				displayname = "潛在客戶"
				datasource = zohocrm_leads
    			displayformat = [company]
	 			row = 1
	 			column = 1   
				width = medium
			)
			contact
			(
				type = picklist	
				displayname = "聯絡人"
				datasource = zohocrm_contacts
    			displayformat = [last_name]
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"會員註冊","驗證中","驗證成功","驗證失敗","啟用中","啟用成功","啟用失敗"}
			}
		}
