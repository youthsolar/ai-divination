	reports
	{
		list members_Report
		{
			displayName = "會員 Report"
			show all rows from Client_Members    
			(
				member_code as "會員編號"
				google_id as "Google帳號ID"
				email as "電子郵件"
				name  as "姓名"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				phone as "電話"
				register_date as "註冊日期"
				status as "狀態"
				lead as "潛在客戶"
				contact as "聯絡人"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "停用")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "啟用")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban members_by_status
		{
			displayName = "Board"
			show all rows from Client_Members    
			(
				member_code as "會員編號"
				google_id as "Google帳號ID"
				email as "電子郵件"
				name  as "姓名"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				phone as "電話"
				register_date as "註冊日期"
				status as "狀態"
				lead as "潛在客戶"
				contact as "聯絡人"
			)
			options
			(
	 			display field = status
	 		)
		}
		list member_support_sessions_Report
		{
			displayName = "會員支援會話 Report"
			show all rows from Client_Support_Sessions    
			(
				member as "會員"
				start_time as "開始時間"
				end_time as "結束時間"
				channel as "支援渠道"
				status as "狀態"
				case as "案件"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "已結束")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "已轉交")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban member_support_sessions_by_status
		{
			displayName = "Board"
			show all rows from Client_Support_Sessions    
			(
				member as "會員"
				start_time as "開始時間"
				end_time as "結束時間"
