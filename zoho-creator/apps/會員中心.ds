				}
				"New Formatting2"
				{
				condition = (participation_status == "已拒絕")
				fields = [participation_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (participation_status == "未參加")
				fields = [participation_status]
