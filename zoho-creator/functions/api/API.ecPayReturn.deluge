string API.ecPayReturn(map ecpay_params)
{
	// =============================================================================
	// 函數名稱：API.ecPayReturn
	// 函數用途：綠界 ECPay 付款回拋 API（ReturnURL）
	// 平台：Zoho Creator
	// 命名空間：API
	// 功能描述：ECPay server-to-server 付款回拋處理：
	//           - 驗簽 CheckMacValue（使用生產環境 hashKey/hashIV）
	//           - 更新訂單狀態（Pending → Paid/Failed）
	//           - 生成交付 Token（SHA256，7 天有效期）
	//           - 通知編排層推播交付連結
	//           - 付款成功後 POST AppSail /paid-divination（異步生成完整版解讀 + LINE 推播）
	// 參數說明：
	//   - ecpay_params (map): ECPay 回拋參數（MerchantTradeNo, RtnCode, TradeNo, CheckMacValue 等）
	// 回傳格式：string - "1|OK"（成功）或 "0|FAIL"（失敗）
	// 相依性：Talisman_Purchases, Clients_Report,
	//         ECPay.generateCheckMacValue
	// 架構：ecPayReturn → AppSail /paid-divination（立即 200）→ generatePaidInterpretation（背景）
	// 注意：原名 ECPayReturn，已重命名為 camelCase；此 API 必須為 ECPay 可呼叫的公開 endpoint
	// =============================================================================
	result = Map();
	response_text = "0|FAIL";
	try
	{
		if(ecpay_params == null)
		{
			result.put("success",false);
			result.put("message","參數為空");
			return response_text;
		}

		merchant_trade_no = if(ecpay_params.get("MerchantTradeNo") != null,ecpay_params.get("MerchantTradeNo").toString(),"");
		rtn_code = if(ecpay_params.get("RtnCode") != null,ecpay_params.get("RtnCode").toString(),"");
		trade_no = if(ecpay_params.get("TradeNo") != null,ecpay_params.get("TradeNo").toString(),"");
		payment_date = if(ecpay_params.get("PaymentDate") != null,ecpay_params.get("PaymentDate").toString(),"");
		recv_mac = if(ecpay_params.get("CheckMacValue") != null,ecpay_params.get("CheckMacValue").toString(),"");

		if(merchant_trade_no == "")
		{
			result.put("success",false);
			result.put("message","MerchantTradeNo 缺失");
			return response_text;
		}

		// 1) 驗簽：用生產環境 hashKey/hashIV 重算 CheckMacValue
		verify_params = Map();
		for each  k in ecpay_params.keys()
		{
			if(k != "CheckMacValue")
			{
				verify_params.put(k,ecpay_params.get(k));
			}
		}
		hash_key = thisapp.variables.ECPay.hashKey_Production;
		hash_iv = thisapp.variables.ECPay.hashIV_Production;
		if(hash_key == null || hash_iv == null || hash_key.toString() == "" || hash_iv.toString() == "")
		{
			result.put("success",false);
			result.put("message","生產環境 hashKey/hashIV 未設定");
			return response_text;
		}
		calc_mac = thisapp.ECPay.generateCheckMacValue(verify_params,hash_key,hash_iv);
		if(recv_mac == "" || calc_mac.toString().toUpperCase() != recv_mac.toString().toUpperCase())
		{
			result.put("success",false);
			result.put("message","CheckMacValue 驗證失敗");
			result.put("merchantTradeNo",merchant_trade_no);
			return response_text;
		}

		// 2) 更新訂單狀態（以 MerchantTradeNo 對應）
		orders = Talisman_Purchases[MerchantTradeNo == merchant_trade_no];
		if(orders.count() == 0)
		{
			result.put("success",false);
			result.put("message","找不到對應訂單");
			result.put("merchantTradeNo",merchant_trade_no);
			return response_text;
		}

		new_status = "Paid";
		if(rtn_code != "1")
		{
			new_status = "Failed";
		}
		should_notify = false;
		already_paid = false;
		token_created = false;

		for each  o in orders
		{
			already_paid = (o.Status == "Paid");
			o.Status=new_status;
			token_created = false;
			if(new_status == "Paid" && (o.Delivery_Token == null || o.Delivery_Token == ""))
			{
				// 生成難猜的交付 token（以訂單資訊+時間做 sha256）
				token_source = merchant_trade_no + "|" + trade_no + "|" + zoho.currenttime.toLong();
				delivery_token = zoho.encryption.sha256(token_source).toLowerCase();
				o.Delivery_Token=delivery_token;
				// Token 到期：預設 7 天（可再調）
				o.Delivery_Token_ExpiresAt=zoho.currenttime.addDay(7);
				token_created = true;
			}

			o.TradeNo=trade_no;
			o.PaymentDate=payment_date;
			o.RtnCode=rtn_code.toNumber();
			o.RtnMsg=if(ecpay_params.get("RtnMsg") != null,ecpay_params.get("RtnMsg").toString(),"");
			o.CheckMacValue=recv_mac;
			if(new_status == "Paid" && (!already_paid || token_created))
			{
				should_notify = true;
			}
			break;
		}

		// 3) 付款成功後通知編排層推播交付連結（Zoho Flow 主線 / n8n 備援）
		try
		{
			if(new_status == "Paid" && should_notify == true)
			{
				notify_url = if(thisapp.variables.System.ECPayPaidNotifyURL != null,thisapp.variables.System.ECPayPaidNotifyURL.toString(),"");
				base_url = if(thisapp.variables.System.DeliveryPageBaseURL != null,thisapp.variables.System.DeliveryPageBaseURL.toString(),"");
				if(notify_url != "" && base_url != "")
				{
					order_rec = null;
					orders2 = Talisman_Purchases[MerchantTradeNo == merchant_trade_no];
					for each  oo in orders2
					{
						order_rec = oo;
						break;
					}
					if(order_rec != null)
					{
						line_uid = if(order_rec.Line_User_ID != null,order_rec.Line_User_ID,"");
						if(line_uid == "" && order_rec.Client_Link != null)
						{
							client_rec = Clients_Report[ID == order_rec.Client_Link];
							for each  cc in client_rec
							{
								line_uid = if(cc.Line_User_ID != null,cc.Line_User_ID,"");
								break;
							}
						}
						// 把 client 的 lineUserId 回寫到訂單，方便追蹤
						if(order_rec.Line_User_ID == null || order_rec.Line_User_ID == "")
						{
							order_rec.Line_User_ID=line_uid;
						}
						delivery_token = if(order_rec.Delivery_Token != null,order_rec.Delivery_Token,"");
						if(line_uid != "" && delivery_token != "")
						{
							push_payload = Map();
							push_payload.put("lineUserId",line_uid);
							push_payload.put("merchantTradeNo",merchant_trade_no);
							push_payload.put("deliveryToken",delivery_token);
							push_payload.put("deliveryUrl",base_url + "?deliveryToken=" + delivery_token);
							notifyHeaders = Map();
							notifyHeaders.put("Content-Type","application/json");
							ignore = invokeurl
							[
								url :notify_url
								type :POST
								parameters:push_payload.toString()
								headers:notifyHeaders
							];
						}
					}
				}
			}
		}
		catch (e)
		{
			// 不影響回拋主要流程
		}

		// 4) 付款成功後：POST AppSail /paid-divination（異步生成完整版 + LINE 推播）
		//    AppSail 立即回 200 → ecPayReturn 不會因 LLM 呼叫超時
		//    AppSail 背景呼叫 Creator generatePaidInterpretation → LLM + linePushText
		try
		{
			if(new_status == "Paid" && should_notify == true && order_rec != null)
			{
				div_id = if(order_rec.Divination_Log_Link != null,order_rec.Divination_Log_Link.toString(),"");
				line_uid2 = if(order_rec.Line_User_ID != null,order_rec.Line_User_ID,"");
				delivery_token2 = if(order_rec.Delivery_Token != null,order_rec.Delivery_Token,"");
				if(div_id != "" && line_uid2 != "")
				{
					appsail_url = "https://divinationserver-10121308063.development.catalystappsail.com/paid-divination";
					paid_payload = Map();
					paid_payload.put("divination_log_id",div_id);
					paid_payload.put("line_user_id",line_uid2);
					paid_payload.put("delivery_token",delivery_token2);
					paid_headers = Map();
					paid_headers.put("Content-Type","application/json");
					ignore2 = invokeurl
					[
						url :appsail_url
						type :POST
						parameters:paid_payload.toString()
						headers:paid_headers
					];
				}
			}
		}
		catch (e_push_full)
		{
			// AppSail 呼叫失敗不影響 ECPay 回拋主流程（回 1|OK）
		}

		result.put("success",true);
		result.put("message","ok");
		result.put("merchantTradeNo",merchant_trade_no);
		result.put("status",new_status);
	}
	catch (e)
	{
		result.put("success",false);
		result.put("message","系統錯誤：" + e);
	}
	if(result.get("success") == true)
	{
		response_text = "1|OK";
	}
	return response_text;
}
