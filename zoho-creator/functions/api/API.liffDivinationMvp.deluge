map API.liffDivinationMvp(string lineUserId, string birthday, string question, string lastName, string firstName, string phone, string email, string topicKey, string subKey, string thirdKey, string topicTitle, string subTitle, string thirdTitle)
{
	// =============================================================================
	// 函數名稱：API.liffDivinationMvp
	// 函數用途：LINE LIFF 占卜入口 API（V2）
	// 平台：Zoho Creator
	// 命名空間：API
	// 功能描述：LINE LIFF 占卜入口，處理「生日+問題+個人資料」的占卜流程：
	//           - 參數驗證（lineUserId, birthday, question）
	//           - 依 LINE User ID 查找或建立個案（去重：有則更新，無則新建）
	//           - 寫入 Zoho CRM Leads（以 Email 去重）
	//           - 冷卻時間檢查（防止重複占卜）
	//           - 占卜方式自動選擇（感情→塔羅、其他→易經）
	//           - 生成免費摘要（約 300 字）
	//           - 建立 Divination_Logs 記錄
	//           - LINE 推播免費摘要 + 解鎖引導
	// 參數說明：
	//   - lineUserId (string): LINE 使用者 ID
	//   - birthday (string): 生日，格式 YYYY-MM-DD
	//   - question (string): 占卜問題
	//   - lastName (string): 姓氏（V2 新增，可空）
	//   - firstName (string): 名字（V2 新增，可空）
	//   - phone (string): 手機 E.164（V2 新增，可空）
	//   - email (string): Email（V2 新增，可空）
	//   - topicKey/subKey/thirdKey (string): 三層選題 key（V2 新增，可空）
	//   - topicTitle/subTitle/thirdTitle (string): 三層選題標題（V2 新增，可空）
	// 回傳格式：map - {success, reading_id, summary_text, next_action, blocked?, cooldown?, ...}
	// 相依性：Clients_Report, Divination_Logs, AIInterpreter.checkCooldownStatus,
	//         LLM.callChat, API.linePushText, Zoho CRM (Leads)
	// =============================================================================
	api_result = Map();
	try
	{
		// 1) Validate
		if(lineUserId == null || lineUserId.trim() == "")
		{
			api_result.put("success",false);
			api_result.put("message","lineUserId 不能為空");
			return api_result;
		}
		if(birthday == null || birthday.trim() == "")
		{
			api_result.put("success",false);
			api_result.put("message","生日不能為空");
			return api_result;
		}
		if(question == null || question.trim() == "")
		{
			api_result.put("success",false);
			api_result.put("message","問題不能為空");
			return api_result;
		}

		// 2) Find or create client by LINE user id — 去重：有則更新，無則新建
		// Normalize optional V2 params
		v2_lastName = if(lastName != null, lastName.trim(), "");
		v2_firstName = if(firstName != null, firstName.trim(), "");
		v2_phone = if(phone != null, phone.trim(), "");
		v2_email = if(email != null, email.trim(), "");

		client_id = "";
		client_records = Clients_Report[Line_User_ID == lineUserId];
		if(client_records.count() > 0)
		{
			// 回訪用戶 — 使用既有記錄，更新 V2 欄位
			for each c in client_records
			{
				client_id = c.ID.toString();
				break;
			}
			// 有新資料時更新既有記錄
			update_map = Map();
			if(v2_lastName != "" && v2_lastName != "(LINE)")
			{
				update_map.put("Visitor_Name.last_name", v2_lastName);
			}
			if(v2_firstName != "" && v2_firstName != "使用者")
			{
				update_map.put("Visitor_Name.first_name", v2_firstName);
			}
			if(v2_phone != "")
			{
				update_map.put("Phone_Number", v2_phone);
			}
			if(v2_email != "")
			{
				update_map.put("Email", v2_email);
			}
			birth_dt = null;
			try
			{
				// LIFF 送的格式為 "yyyy-MM-dd HH:mm"（含時間），先嘗試完整解析
				birth_dt = birthday.toDate("yyyy-MM-dd HH:mm");
			}
			catch (eBdt1)
			{
				try { birth_dt = birthday.toDate("yyyy-MM-dd"); } catch (eBdt2) { birth_dt = null; }
			}
			if(birth_dt != null) { update_map.put("Date_Of_Birth", birth_dt); }
			// 用原生 Deluge 語法直接更新（不需要 Connection）
			for each rec in Clients_Report[ID == client_id.toLong()]
			{
				if(v2_lastName != "" && v2_lastName != "(LINE)") { rec.Visitor_Name.last_name = v2_lastName; }
				if(v2_firstName != "" && v2_firstName != "使用者") { rec.Visitor_Name.first_name = v2_firstName; }
				if(v2_phone != "") { rec.Phone_Number = v2_phone; }
				if(v2_email != "") { rec.Email = v2_email; }
				if(birth_dt != null) { rec.Date_Of_Birth = birth_dt; }
				rec.Client_Type = "真實";
				break;
			}
		}
		else
		{
			// 新用戶 — 建立 Clients_Report 記錄
			birth_dt = null;
			try
			{
				// LIFF 送的格式為 "yyyy-MM-dd HH:mm"（含時間），先嘗試完整解析
				birth_dt = birthday.toDate("yyyy-MM-dd HH:mm");
			}
			catch (eBdt3)
			{
				try { birth_dt = birthday.toDate("yyyy-MM-dd"); } catch (eBdt4) { birth_dt = zoho.currenttime; }
			}
			display_last = if(v2_lastName != "", v2_lastName, "(LINE)");
			display_first = if(v2_firstName != "", v2_firstName, "使用者");
			new_client = insert into Clients_Report
			[
				Added_User=zoho.loginuser
				Client_Type="LIFF"
				Visitor_Name.last_name=display_last
				Visitor_Name.first_name=display_first
				Line_User_ID=lineUserId
				Date_Of_Birth=birth_dt
				Phone_Number=v2_phone
				Email=v2_email
			];
			if(new_client != null)
			{
				client_id = new_client.toString();
			}
		}

		if(client_id == null || client_id == "")
		{
			api_result.put("success",false);
			api_result.put("message","個案建立/查詢失敗");
			return api_result;
		}

		// 2b) Zoho CRM Leads — 以 Email 去重，首次建立 Lead
		if(v2_email != "" && v2_email.contains("@"))
		{
			try
			{
				crm_criteria = "(Email:equals:" + v2_email + ")";
				existing_leads = zoho.crm.searchRecords("Leads", crm_criteria);
				if(existing_leads.size() == 0)
				{
					lead_data = Map();
					lead_data.put("Last_Name", if(v2_lastName != "", v2_lastName, "(LINE)"));
					lead_data.put("First_Name", v2_firstName);
					lead_data.put("Mobile", v2_phone);
					lead_data.put("Email", v2_email);
					lead_data.put("Lead_Source", "LINE占卜LIFF");
					zoho.crm.createRecord("Leads", lead_data);
				}
			}
			catch (crm_err)
			{
				info "CRM Leads write error: " + crm_err.toString();
				// CRM 失敗不影響占卜主流程
			}
		}

		// 3) Cooldown check (use existing logic)
		now_time = zoho.currenttime;
		cooldown_check = thisapp.AIInterpreter.checkCooldownStatus(client_id,question,now_time);
		selected_question_type = "其他";
		if(cooldown_check != null && cooldown_check.get("question_type") != null)
		{
			selected_question_type = cooldown_check.get("question_type");
		}
		if(cooldown_check != null && cooldown_check.get("allowed") == false)
		{
			// 冷卻是正常結果，不應讓前端誤判為系統錯誤
			api_result.put("success",true);
			api_result.put("blocked",true);
			api_result.put("cooldown",true);
			api_result.put("message",if(cooldown_check.get("message") != null,cooldown_check.get("message"),"冷卻中，請稍後再來"));
			return api_result;
		}

		// 4) Choose divination method (MVP policy)
		// Jeffery rule: 感情/人際→塔羅；大方向/抉擇→易經；fallback=易經
		div_method = "易經";
		if(selected_question_type == "愛情" || selected_question_type == "婚姻")
		{
			div_method = "塔羅";
		}
		else
		{
			// 人際關係 keyword fallback
			q2 = question;
			if(q2 != null)
			{
				q2 = q2.toLowerCase();
				if(q2.contains("同事") || q2.contains("朋友") || q2.contains("家人") || q2.contains("主管") || q2.contains("同學") || q2.contains("老闆"))
				{
					div_method = "塔羅";
				}
			}
		}

		// 5A) 取得本次起卦的爻碼（供符令系統使用，用現在時間起卦，與占卜函數規則一致）
		hex_code = "";
		talisman_element_1 = "";
		try
		{
			hex_code = thisapp.GuaCalculator.bitToHexagramCode(now_time).toString();
			if(hex_code != "")
			{
				tmp_iching = I_Ching_Form[yao == hex_code];
				if(tmp_iching != null) { talisman_element_1 = if(tmp_iching.symbol_1 != null, tmp_iching.symbol_1.toString(), ""); }
			}
		}
		catch (eHex) { info "取卦失敗：" + eHex; }

		// 5B) 依方法執行完整占卜（尊重完整的占卜法則函數）
		new_log_id = "";
		summary_text = "";
		tarot_card_display = "";

		if(div_method == "塔羅")
		{
			// 塔羅：呼叫完整塔羅函數（含牌位意義、主卦分析、AI 解讀、符令元素）
			tarot_result = thisapp.Tarot.tarotDivinationFunction(client_id, question);
			if(tarot_result.get("success") == true)
			{
				new_log_id = tarot_result.get("divination_id").toString();
				// 讀取 AI 解讀文字（可能是同步完成或 async 等待中）
				div_log_recs = Divination_Logs[ID == new_log_id.toLong()];
				for each dl in div_log_recs
				{
					summary_text = if(dl.AI_Interpretation != null, dl.AI_Interpretation.toString(), "");
					// 建立牌陣顯示清單（Card_1_Link ~ Card_5_Link）
					card_display_list = List();
					cpos = 1;
					cid_list = List();
					cid_list.add(if(dl.Card_1_Link != null, dl.Card_1_Link, 0));
					cid_list.add(if(dl.Card_2_Link != null, dl.Card_2_Link, 0));
					cid_list.add(if(dl.Card_3_Link != null, dl.Card_3_Link, 0));
					cid_list.add(if(dl.Card_4_Link != null, dl.Card_4_Link, 0));
					cid_list.add(if(dl.Card_5_Link != null, dl.Card_5_Link, 0));
					crev_list = List();
					crev_list.add(if(dl.Card_1_Reversed == true, true, false));
					crev_list.add(if(dl.Card_2_Reversed == true, true, false));
					crev_list.add(if(dl.Card_3_Reversed == true, true, false));
					crev_list.add(if(dl.Card_4_Reversed == true, true, false));
					crev_list.add(if(dl.Card_5_Reversed == true, true, false));
					for each cid in cid_list
					{
						if(cid != null && cid != 0)
						{
							c_recs = All_Tarot_Cards[ID == cid];
							for each cr in c_recs
							{
								c_name = if(cr.Card_Name != null, cr.Card_Name.toString(), "");
								is_rev = crev_list.get(cpos - 1);
								c_orient = if(is_rev == true, "逆位", "正位");
								card_display_list.add("  第" + cpos + "張：" + c_name + "（" + c_orient + "）");
								break;
							}
						}
						cpos = cpos + 1;
					}
					tarot_card_display = card_display_list.toString("\n");
					break;
				}
				// 取得主牌符令元素（覆蓋易經的 symbol_1）
				p_card_id = tarot_result.get("primary_card_id");
				p_polarity = if(tarot_result.get("primary_polarity") != null, tarot_result.get("primary_polarity").toString(), "正位");
				if(p_card_id != null && p_card_id != 0)
				{
					p_card_recs = All_Tarot_Cards[ID == p_card_id];
					for each pc in p_card_recs
					{
						p_element = if(p_polarity == "逆位",
							if(pc.Reversed_Outsight_Element != null, pc.Reversed_Outsight_Element.toString(), ""),
							if(pc.Outsight_Element != null, pc.Outsight_Element.toString(), ""));
						if(p_element != "") { talisman_element_1 = p_element; }
						break;
					}
				}
			}
			else
			{
				// 塔羅函數失敗，建立簡易 fallback 記錄
				fb_id = insert into Divination_Logs
				[
					Added_User=zoho.loginuser
					Client_Link=client_id.toLong()
					Original_Question=question
					Divination_Timestamp=now_time
					Divination_Method=div_method
					Status="已提問"
					Question_Type_AI=selected_question_type
					AI_Interpretation="AI 占卜服務暫時無法使用，請稍後再試。"
					Hexagram_Code=hex_code
				];
				new_log_id = fb_id.toString();
				summary_text = "AI 占卜服務暫時無法使用，請稍後再試。";
			}
		}
		else
		{
			// 易經：呼叫完整易經函數（含八字個性線索、四種語氣、完整爻象 prompt）
			// 函數內部使用 now_time 起卦，並自動建立 Divination_Logs 記錄
			summary_text = thisapp.AIInterpreter.getPredictionByQuestionAndBirthday(question, now_time, client_id);
			// 查詢剛建立的記錄（取此 client 最新的易經記錄 ID）
			all_iching_logs = Divination_Logs[Client_Link == client_id.toLong() && Divination_Method == "易經"];
			max_log_id = 0;
			for each ail in all_iching_logs
			{
				if(ail.ID > max_log_id) { max_log_id = ail.ID; }
			}
			if(max_log_id > 0) { new_log_id = max_log_id.toString(); }
		}

		// 5C) 補寫 Hexagram_Code 到 Divination_Logs（符令推薦系統需要此欄位）
		if(new_log_id != "" && hex_code != "")
		{
			div_log_update = Divination_Logs[ID == new_log_id.toLong()];
			for each dlu in div_log_update
			{
				dlu.Hexagram_Code = hex_code;
				break;
			}
		}

		api_result.put("success",true);
		api_result.put("reading_id",new_log_id);
		api_result.put("summary_text",summary_text);
		next_action = Map();
		next_action.put("kind","offer_unlock");
		next_action.put("price",360);
		next_action.put("currency","TWD");
		next_action.put("cta_label","解鎖完整版/購買符令");
		next_action.put("talisman_name","改運符令");
		next_action.put("element",talisman_element_1);
		api_result.put("next_action",next_action);

		// 6) Push summary to LINE (MVP: text + unlock hint)
		try
		{
			base_url = if(thisapp.variables.System.DeliveryPageBaseURL != null,thisapp.variables.System.DeliveryPageBaseURL.toString(),"");
			// Security: free summary link should NOT expose numeric div id. Link back to LIFF entry only.
			unlock_hint = "\n\n👉 解鎖完整版/購買符令：" + (if(base_url != "", base_url, "（待設定 LIFF URL）"));
			// 塔羅在摘要前加上牌陣清單；易經解讀本身已含卦象資訊
			divination_header = "";
			if(div_method == "塔羅" && tarot_card_display != "")
			{
				divination_header = "🃏 本次塔羅牌陣（五張）：\n" + tarot_card_display + "\n\n";
			}
			line_text = "【免費摘要】\n" + divination_header + summary_text + unlock_hint;
			push_res = thisapp.API.linePushText(lineUserId,line_text);
			api_result.put("line_pushed", if(push_res != null && push_res.get("success") == true, true, false));
			if(push_res != null && push_res.get("success") == false)
			{
				api_result.put("line_push_error", push_res.get("message"));
			}
		}
		catch (pushErr)
		{
			api_result.put("line_pushed", false);
			api_result.put("line_push_error", pushErr.toString());
		}

		return api_result;
	}
	catch (e)
	{
		api_result.put("success",false);
		api_result.put("message","系統錯誤：" + e.toString());
		return api_result;
	}
	return api_result;
}
