map API.linePushText(string lineUserId, string messageText)
{
	// =============================================================================
	// 函數名稱：API.linePushText
	// 函數用途：LINE Push Message 純文字推播
	// 平台：Zoho Creator
	// 命名空間：API
	// 功能描述：透過 LINE Messaging API 推送純文字訊息給指定使用者：
	//           - 使用 Map 建構 body（與 LLM.callChat 相同模式，Custom API 中可正常運作）
	//           - 驗證 LINE Channel Access Token 與使用者 ID
	//           - 呼叫 LINE Push Message API (v2/bot/message/push)
	// 參數說明：
	//   - lineUserId (string): LINE 使用者 ID
	//   - messageText (string): 推播的文字內容
	// 回傳格式：map - {success, message/api_response}
	// 相依性：thisapp.variables.System.LINE_ChannelAccessToken
	// 注意：原名 LINE_PushText，已重命名為 camelCase
	// 修正歷程：
	//   1. postUrl 在 Custom API 環境中無法發出外部 HTTP 請求 → 改用 invokeUrl
	//   2. 手動組 JSON string 作為 invokeUrl parameters 無法正確送出 → 改用 Map body
	//      （與 LLM.callChat 使用 Map.toString() 呼叫 Claude API 的模式一致）
	// =============================================================================
	res = Map();
	try
	{
		token = if(thisapp.variables.System.LINE_ChannelAccessToken != null,thisapp.variables.System.LINE_ChannelAccessToken.toString(),"");
		if(token == "")
		{
			res.put("success",false);
			res.put("message","LINE token 未設定");
			return res;
		}
		if(lineUserId == null || lineUserId.trim() == "")
		{
			res.put("success",false);
			res.put("message","lineUserId 為空");
			return res;
		}

		// 建構 LINE Push Message body（Map 方式）
		msgObj = Map();
		msgObj.put("type","text");
		msgObj.put("text",messageText);
		msgList = List();
		msgList.add(msgObj);
		bodyMap = Map();
		bodyMap.put("to",lineUserId);
		bodyMap.put("messages",msgList);

		headers = Map();
		headers.put("Authorization","Bearer " + token);
		headers.put("Content-Type","application/json");

		api_response = invokeurl
		[
			url: "https://api.line.me/v2/bot/message/push"
			type: POST
			parameters: bodyMap.toString()
			headers: headers
		];
		res.put("success",true);
		res.put("api_response",api_response);
		return res;
	}
	catch (e)
	{
		res.put("success",false);
		res.put("message","LINE push error: " + e.toString());
		return res;
	}
	return res;
}
