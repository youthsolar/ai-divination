        <div class="winds-third-card" data-third="4.3.3" data-service="karma">
          <div class="winds-third-card-title">走到某些地方就覺得不舒服，需要老師指點可能原因</div>
          <div>空間對你造成不恰當的壓力。</div>
        </div>
        <div class="winds-third-card" data-third="4.3.4" data-service="fortune">
          <div class="winds-third-card-title">我不確定是不是體質變敏感，想讓老師看一下我的能量</div>
          <div>請老師協助鑑別能量來源。</div>
        </div>
      </div>

      <!-- 第三層：老師/直白 -->
      <div class="winds-third-row" id="winds-third-teacher-direct">
        <div class="winds-third-card" data-third="4.4.1" data-service="event">
          <div class="winds-third-card-title">我不想被安慰，想要老師直接講真話</div>
          <div>需要不拖泥帶水、敢說實話的老師。</div>
        </div>
        <div class="winds-third-card" data-third="4.4.2" data-service="karma">
          <div class="winds-third-card-title">希望老師直接告訴我：該走還是該留？</div>
          <div>決策型個案最重視的「方向」。</div>
        </div>
        <div class="winds-third-card" data-third="4.4.3" data-service="event">
          <div class="winds-third-card-title">我需要老師幫我看清關鍵問題在哪</div>
          <div>希望老師能一針見血指出核心。</div>
        </div>
        <div class="winds-third-card" data-third="4.4.4" data-service="event">
          <div class="winds-third-card-title">我只想知道最重要的一句話，請老師幫我判斷</div>
          <div>最適合快速抽問單一事件。</div>
        </div>
      </div>

      <!-- ── 個人資料表單（Phase 2，選定第三層卡片後展開） ── -->
      <div id="birthCardWrapper" class="winds-hidden">
        <div class="winds-bottom-row">
          <div class="winds-input-card">
            <div class="winds-form-step-label">✦ 步驟 2：填入基本資料</div>

            <!-- 姓名 + 手機 + Email -->
            <div class="winds-contact-row">
              <div class="winds-contact-field">
                <label for="windsLastName">姓<span class="winds-required">*</span></label>
                <input id="windsLastName" type="text" class="winds-input" placeholder="請輸入姓氏">
              </div>
              <div class="winds-contact-field">
                <label for="windsFirstName">名<span class="winds-required">*</span></label>
                <input id="windsFirstName" type="text" class="winds-input" placeholder="請輸入名字">
              </div>
              <div class="winds-contact-field">
                <label for="windsPhone">手機<span class="winds-required" id="phoneRequiredMark">*</span></label>
                <input id="windsPhone" type="tel" class="winds-input" placeholder="例：0912345678">
              </div>
              <div class="winds-contact-field">
                <label for="windsEmail">Email</label>
                <input id="windsEmail" type="email" class="winds-input" placeholder="（選填）">
              </div>
            </div>

            <!-- 生日 + 出生時間 -->
            <div class="winds-birth-row">
              <div class="winds-contact-field">
                <label for="birthDate">國曆生日<span class="winds-required">*</span></label>
                <input id="birthDate" type="date" class="birth-card-input"
                       min="1920-01-01" max="2015-12-31">
              </div>
              <div class="winds-contact-field">
                <label for="birthTime">出生時間（選填）</label>
                <input id="birthTime" type="time" step="300" class="birth-card-input">
              </div>
            </div>

            <!-- 生日預覽 -->
            <div id="previewArea"><div id="previewText"></div></div>

            <!-- 自動生成問題文字（可補充） -->
            <textarea id="windsSummary" class="winds-textarea" maxlength="200"
                      placeholder="（系統自動產生問題描述，可在後方補充你的實際狀況）"></textarea>
            <div id="winds-char-counter" class="winds-char-counter">0 / 200</div>

            <!-- 送出按鈕 -->
            <button class="btn-primary" id="btnSubmit">確認送出 →</button>
          </div>
        </div>
      </div><!-- /#birthCardWrapper -->

    </div><!-- /.winds-topic-section -->
  </div><!-- /#mainContent -->

</div><!-- /.winds-card -->

<script>
(function () {
  // ══════════════════════════════════════════════════════════════════════
  // 【設定區】部署後必須修改以下設定值
  // ══════════════════════════════════════════════════════════════════════

  // LIFF ID（與 LIFF_Divination_MVP 相同）
  var LIFF_ID = '2009168674-G2KqF3Jv';

  // Creator Microservices Custom API：line_binding endpoint
  var BINDING_API_URL =
    'https://www.zohoapis.com/creator/custom/uneedwind/line_binding' +
    '?public_key=__LINE_BINDING_PUBLIC_KEY__';

  // Creator Microservices Custom API：liff_divination_mvp endpoint
  var DIVINATION_API_URL =
    'https://www.zohoapis.com/creator/custom/uneedwind/liff_divination_mvp' +
    '?public_key=__LIFF_DIVINATION_PUBLIC_KEY__';

  // ══════════════════════════════════════════════════════════════════════
  // 全域狀態
  // ══════════════════════════════════════════════════════════════════════
  var lineUserId       = '';
  var selectedThirdKey    = null;
  var selectedServiceType = '';
  var selectedSubKey      = null;
  var selectedTopicKey    = null;
  var selectedTopicTitle  = '';
  var selectedTopicDesc   = '';
  var selectedSubTitle    = '';
  var selectedSubDesc     = '';
  var selectedThirdTitle  = '';
  var selectedThirdDesc   = '';

  var topicSection = document.querySelector('.winds-topic-section');

  // ── LIFF 初始化：取得 LINE User ID ──────────────────────────────────
  liff.init({ liffId: LIFF_ID })
    .then(function () {
      if (!liff.isLoggedIn()) {
        // 尚未登入 LINE → 導向 LINE 登入（帶回原 URL）
        liff.login();
        return;
      }
      return liff.getProfile();
    })
    .then(function (profile) {
      if (profile && profile.userId) {
        lineUserId = profile.userId;
      }
    })
    .catch(function (err) {
      // 桌面瀏覽器測試時會走到這裡，不中斷頁面
      // 後端 API.bindLineUser 會因 missing_line_user_id 擋下
      console.warn('[LIFF] init error:', err);
    });

  // ══════════════════════════════════════════════════════════════════════
  // 工具函數
  // ══════════════════════════════════════════════════════════════════════

  function forEachNode(list, cb) {
    Array.prototype.forEach.call(list, cb);
  }

  // .closest() polyfill（for older Android WebView）
  function closestByClass(el, className) {
    while (el && el !== document) {
      if (el.classList && el.classList.contains(className)) return el;
      el = el.parentNode;
    }
    return null;
  }

  function showError(msg) {
    var el = document.getElementById('errorMsg');
    el.textContent = '⚠️ ' + msg;
    el.classList.add('show');
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideError() {
    document.getElementById('errorMsg').classList.remove('show');
  }

  function showLoading(msg) {
    document.getElementById('loadingMsg').textContent = msg || '處理中，請稍候...';
    document.getElementById('loadingOverlay').classList.add('show');
  }

  function updateLoading(msg) {
    document.getElementById('loadingMsg').textContent = msg;
  }

  function hideLoading() {
    document.getElementById('loadingOverlay').classList.remove('show');
  }

  // ── 輸入欄位取值 ──────────────────────────────────────────────────
  function getInputs() {
    return {
      lastNameInput:  document.getElementById('windsLastName'),
      firstNameInput: document.getElementById('windsFirstName'),
      phoneInput:     document.getElementById('windsPhone'),
      emailInput:     document.getElementById('windsEmail'),
      birthDateInput: document.getElementById('birthDate'),
      birthTimeInput: document.getElementById('birthTime'),
      summaryInput:   document.getElementById('windsSummary'),
      charCounter:    document.getElementById('winds-char-counter'),
      previewArea:    document.getElementById('previewArea'),
      previewText:    document.getElementById('previewText'),
      birthWrap:      document.getElementById('birthCardWrapper')
    };
  }

  // ── 同步 UI 階段狀態 ───────────────────────────────────────────────
  function syncUIState() {
    if (!topicSection) return;
    var hasTopicActive = document.querySelector('.winds-topic-card.active');
    var hasSubActive   = document.querySelector('.winds-sub-card.active');
    var hasThirdActive = document.querySelector('.winds-third-card.active');
    if (!hasTopicActive && !hasSubActive && !hasThirdActive) {
      topicSection.classList.remove('winds-has-sub-selected', 'winds-has-third-selected', 'winds-step-3');
    } else {
      if (!hasTopicActive) {
        topicSection.classList.remove('winds-has-sub-selected', 'winds-has-third-selected', 'winds-step-3');
      } else if (hasTopicActive && !hasSubActive) {
        topicSection.classList.remove('winds-has-third-selected', 'winds-step-3');
      } else if (hasSubActive && !hasThirdActive) {
        topicSection.classList.remove('winds-step-3');
      }
    }
  }

  // ── 重置所有選擇 ──────────────────────────────────────────────────
  function resetAll() {
    var ref = getInputs();
    forEachNode(document.querySelectorAll('.winds-topic-card'), function (c) {
      c.classList.remove('active', 'winds-hidden');
    });
    forEachNode(document.querySelectorAll('.winds-sub-row'), function (r) {
      r.classList.remove('active');
    });
    forEachNode(document.querySelectorAll('.winds-sub-card'), function (c) {
      c.classList.remove('active', 'winds-hidden');
    });
    forEachNode(document.querySelectorAll('.winds-third-row'), function (r) {
      r.classList.remove('active');
    });
    forEachNode(document.querySelectorAll('.winds-third-card'), function (c) {
      c.classList.remove('active', 'winds-hidden');
    });
    if (ref.birthWrap) ref.birthWrap.classList.add('winds-hidden');
    selectedThirdKey = null; selectedServiceType = ''; selectedSubKey = null;
    selectedTopicKey = null; selectedTopicTitle = ''; selectedTopicDesc = '';
    selectedSubTitle = ''; selectedSubDesc = ''; selectedThirdTitle = ''; selectedThirdDesc = '';
    if (topicSection) {
      topicSection.classList.remove('winds-has-sub-selected', 'winds-has-third-selected', 'winds-step-3');
    }
    if (ref.lastNameInput)  ref.lastNameInput.value  = '';
    if (ref.firstNameInput) ref.firstNameInput.value = '';
    if (ref.phoneInput)     ref.phoneInput.value     = '';
    if (ref.emailInput)     ref.emailInput.value     = '';
    if (ref.birthDateInput) ref.birthDateInput.value = '';
    if (ref.birthTimeInput) ref.birthTimeInput.value = '';
    if (ref.summaryInput)   ref.summaryInput.value   = '';
    if (ref.previewArea)    ref.previewArea.style.display = 'none';
    if (ref.charCounter)    ref.charCounter.textContent = '0 / 200';
  }

  // ── 第一層：主題卡片點擊 ────────────────────────────────────────
  function handleTopicClick(card) {
    var topic = card.getAttribute('data-topic');
    if (!topic) return;
    var subRow = document.getElementById('winds-sub-' + topic);
    if (!subRow) return;
    // 再次點擊已選中的卡片 → 重置
    if (card.classList.contains('active')) { resetAll(); return; }
    resetAll();
    selectedTopicKey = topic;
    var titleEl = card.querySelector('.winds-topic-card-title');
    selectedTopicTitle = titleEl ? titleEl.textContent.trim() : '';
    var divs = card.querySelectorAll('div');
    selectedTopicDesc = divs.length >= 2 ? divs[1].textContent.trim() : '';
    card.classList.add('active');
    forEachNode(document.querySelectorAll('.winds-topic-card'), function (other) {
      if (other !== card) other.classList.add('winds-hidden');
    });
    subRow.classList.add('active');
    if (topicSection) topicSection.classList.add('winds-has-sub-selected');
  }

  // ── 第二層：子分類卡片點擊 ──────────────────────────────────────
  function handleSubClick(card) {
    var key = card.getAttribute('data-sub');
    if (!key) return;
    var thirdRow = document.getElementById('winds-third-' + key);
    var row = card.parentNode;
    var rowCards = row ? row.querySelectorAll('.winds-sub-card') : [];
    var ref = getInputs();
    // 再次點擊已選中的子分類 → 退選
    if (card.classList.contains('active')) {
      forEachNode(rowCards, function (c) { c.classList.remove('active', 'winds-hidden'); });
      forEachNode(document.querySelectorAll('.winds-third-row'), function (r) { r.classList.remove('active'); });
      forEachNode(document.querySelectorAll('.winds-third-card'), function (c) { c.classList.remove('active', 'winds-hidden'); });
      if (ref.birthWrap) ref.birthWrap.classList.add('winds-hidden');
      selectedSubKey = null; selectedThirdKey = null; selectedServiceType = '';
      if (topicSection) topicSection.classList.remove('winds-has-third-selected', 'winds-step-3');
      setTimeout(function () { syncUIState(); }, 10);
      return;
    }
    selectedSubKey = key;
    var subTitleEl = card.querySelector('.winds-sub-card-title');
    selectedSubTitle = subTitleEl ? subTitleEl.textContent.trim() : '';
    var divs2 = card.querySelectorAll('div');
    selectedSubDesc = divs2.length >= 2 ? divs2[1].textContent.trim() : '';
    forEachNode(rowCards, function (c) {
      if (c === card) { c.classList.add('active'); c.classList.remove('winds-hidden'); }
      else { c.classList.remove('active'); c.classList.add('winds-hidden'); }
    });
    if (thirdRow) thirdRow.classList.add('active');
    if (topicSection) topicSection.classList.add('winds-has-third-selected');
    if (ref.birthWrap) ref.birthWrap.classList.add('winds-hidden');
  }

  // ── 第三層：情境卡片點擊 ──────────────────────────────────────
  function handleThirdClick(card) {
    var key     = card.getAttribute('data-third');
    var service = card.getAttribute('data-service');
    if (!key) return;
    var row = card.parentNode;
    var rowCards = row ? row.querySelectorAll('.winds-third-card') : [];
    var ref = getInputs();
    // 再次點擊已選中的情境卡片 → 退選
    if (card.classList.contains('active')) {
      card.classList.remove('active');
      forEachNode(rowCards, function (c) { c.classList.remove('winds-hidden'); });
      if (ref.birthWrap) ref.birthWrap.classList.add('winds-hidden');
      selectedThirdKey = null; selectedServiceType = '';
      if (topicSection) topicSection.classList.remove('winds-step-3');
      setTimeout(function () { syncUIState(); }, 10);
      return;
    }
    selectedThirdKey    = key;
    selectedServiceType = service;
    var titleEl = card.querySelector('.winds-third-card-title');
    selectedThirdTitle = titleEl ? titleEl.textContent.trim() : '';
    var divs = card.querySelectorAll('div');
    selectedThirdDesc = divs.length >= 2 ? divs[1].textContent.trim() : '';
    forEachNode(rowCards, function (c) {
      if (c === card) { c.classList.add('active'); c.classList.remove('winds-hidden'); }
      else { c.classList.remove('active'); c.classList.add('winds-hidden'); }
    });
    if (topicSection) topicSection.classList.add('winds-step-3');
    // 展開資料表單並滾動到可見
    if (ref.birthWrap) {
      ref.birthWrap.classList.remove('winds-hidden');
      setTimeout(function () {
        ref.birthWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 100);
    }
    updateSummaryTemplate();
  }

  // ── 生日預覽更新 ────────────────────────────────────────────────
  function updateBirthPreview() {
    var ref = getInputs();
    if (!ref.previewArea || !ref.previewText) return;
    var d = ref.birthDateInput ? ref.birthDateInput.value : '';
    var t = ref.birthTimeInput ? ref.birthTimeInput.value : '';
    var text = '';
    if (d && t) text = '生日：' + d + ' ' + t;
    else if (d) text = '生日：' + d;
    if (text) { ref.previewText.innerText = text; ref.previewArea.style.display = 'block'; }
    else { ref.previewArea.style.display = 'none'; }
  }

  // ── 字數計數器 ──────────────────────────────────────────────────
  function updateCharCounter() {
    var ref = getInputs();
    if (!ref.summaryInput || !ref.charCounter) return;
    var len = ref.summaryInput.value ? ref.summaryInput.value.length : 0;
    ref.charCounter.textContent = len + ' / 200';
  }

  // ── 自動生成問題文字（updateSummaryTemplate） ───────────────────
  // 複用自 Simplybook 對話卡片 JS
  function updateSummaryTemplate() {
    var ref = getInputs();
    if (!ref.summaryInput) return;
    if (!selectedTopicTitle || !selectedSubTitle || !selectedThirdTitle) return;
    var template;
    if (selectedTopicKey === 'teacher') {
      template = '我希望能由「' + selectedSubTitle + '」來協助我，目前狀況是「' +
                 selectedThirdTitle + '」：' + selectedThirdDesc +
                 ' 實際情況是：（請簡單在後面補充）';
    } else {
      template = '我目前最想處理的問題是「' + selectedTopicTitle + ' - ' + selectedSubTitle +
                 '」，狀況比較接近「' + selectedThirdTitle + '」：' + selectedThirdDesc +
                 ' 實際情況是：（請簡單在後面補充）';
    }
    ref.summaryInput.value = template;
    updateCharCounter();
  }

  // ── 驗證函數 ────────────────────────────────────────────────────
  function validatePhoneLocal(phone) {
    if (!phone) return false;
    return /^09\d{8}$/.test(phone.trim());
  }

  function formatPhoneToE164TW(phone) {
    if (!validatePhoneLocal(phone)) return null;
    return '+886' + phone.trim().slice(1);
  }

  function validateEmail(email) {
    if (!email) return false;
    return email.trim().indexOf('@') > 0;
  }

  // ── 路由判斷 ────────────────────────────────────────────────────
  // teacher topic 的所有子分類 → 永遠走 Simplybook
  // karma service type → 走 Simplybook（通靈水鏡法需真人老師）
  // fortune / event service type（非 teacher topic）→ 走 LINE AI 占卜
  function isSimplybookRoute() {
    if (selectedTopicKey === 'teacher') return true;
    if (selectedServiceType === 'karma') return true;
    return false;
  }

  function getSimplybookUrl() {
    if (selectedTopicKey === 'teacher') {
      // teacher-energy → 通靈水鏡法（service/4）
      // 其他 teacher 子分類 → 命書籤詩問事（service/43）
      return selectedSubKey === 'teacher-energy'
        ? 'https://winds.tw/v2/#book/service/4'
        : 'https://winds.tw/v2/#book/service/43';
    }
    // karma → 通靈水鏡法（service/4）
    return 'https://winds.tw/v2/#book/service/4';
  }

  // ══════════════════════════════════════════════════════════════════════
  // 主要送出邏輯
  // ══════════════════════════════════════════════════════════════════════
  function handleSubmitClick() {
    hideError();
    var ref = getInputs();

    // 驗證：姓名必填
    if (!ref.lastNameInput || !ref.lastNameInput.value.trim()) {
      showError('請先輸入姓氏。'); return;
    }
    if (!ref.firstNameInput || !ref.firstNameInput.value.trim()) {
      showError('請先輸入名字。'); return;
    }

    // 驗證：手機（karma/teacher 必填，其他選填但格式要正確）
    var phoneLocal = ref.phoneInput ? ref.phoneInput.value.trim() : '';
    var phoneE164  = formatPhoneToE164TW(phoneLocal);
    if (isSimplybookRoute() && !phoneE164) {
      showError('預約老師服務需要手機號碼，請輸入正確格式（09 開頭的 10 碼台灣手機）。');
      return;
    }
    if (phoneLocal && !phoneE164) {
      showError('手機號碼格式有誤，請輸入 09 開頭的 10 碼台灣手機。');
      return;
    }

    // 驗證：國曆生日必填
    if (!ref.birthDateInput || !ref.birthDateInput.value) {
      showError('請先選擇你的國曆出生日期。'); return;
    }

    // 驗證：卡片必選
    if (!selectedThirdKey) {
      showError('請先在上方選擇一張對應的情境卡片。'); return;
    }

    // 驗證：問題說明必填（自動生成但需保留）
    if (!ref.summaryInput || !ref.summaryInput.value.trim()) {
      showError('請在說明欄補充你的實際狀況。'); return;
    }

    // 收集所有資料
    var lastName  = ref.lastNameInput.value.trim();
    var firstName = ref.firstNameInput.value.trim();
    var email     = ref.emailInput ? ref.emailInput.value.trim() : '';
    var birthday  = ref.birthDateInput.value;
    var birthTime = ref.birthTimeInput ? ref.birthTimeInput.value : '';
    var summary   = ref.summaryInput.value.trim();

    // 顯示 Loading + 禁用按鈕（防止重複送出）
    showLoading('綁定中，請稍候...');
    var btn = document.getElementById('btnSubmit');
    if (btn) btn.disabled = true;

    // ── Step 1：呼叫 line_binding（儲存 LINE ID + 生日 + 完整 profile） ──
    var bindPayload = {
      lineUserId : lineUserId,
      birthday   : birthday,
      birthTime  : birthTime,
      lastName   : lastName,
      firstName  : firstName,
      phone      : phoneE164 || '',
      email      : email,
      topicKey   : selectedTopicKey || '',
      thirdKey   : selectedThirdKey || ''
    };

    fetch(BINDING_API_URL, {
      method  : 'POST',
      headers : { 'Content-Type': 'application/json' },
      body    : JSON.stringify(bindPayload)
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (!data || !data.ok) {
        hideLoading();
        if (btn) btn.disabled = false;
        showError(data ? data.message : '資料提交失敗，請稍後再試。');
        return;
      }

      // ── Step 2：智慧分流 ──
      if (isSimplybookRoute()) {
        // karma / teacher → 跳轉 Simplybook 預約頁
        hideLoading();
        window.location.href = getSimplybookUrl();
      } else {
        // fortune / event → 呼叫 liff_divination_mvp → 顯示等待 → 關閉視窗
        updateLoading('AI 正在計算你的命盤，請稍候...');
        fetch(DIVINATION_API_URL, {
          method  : 'POST',
          headers : { 'Content-Type': 'application/json' },
          body    : JSON.stringify({
            lineUserId : lineUserId,
            birthday   : birthday,
            question   : summary
          })
        })
        .then(function () {
          // API 成功或失敗皆顯示成功畫面（後端為非同步 push，不等結果）
          hideLoading();
          showSuccessAndClose();
        })
        .catch(function () {
          // 即使 divination API 失敗，生日已綁定，視為部分成功
          hideLoading();
          showSuccessAndClose();
        });
      }
    })
    .catch(function () {
      hideLoading();
      if (btn) btn.disabled = false;
      showError('網路連線異常，請確認後再試。');
    });
  }

  // ── 顯示成功畫面並關閉 LIFF ────────────────────────────────────
  function showSuccessAndClose() {
    var mainContent = document.getElementById('mainContent');
    if (mainContent) mainContent.style.display = 'none';
    var sc = document.getElementById('successScreen');
    if (sc) sc.classList.add('show');
    // 2.5 秒後關閉 LIFF 視窗，返回 LINE 聊天室
    setTimeout(function () {
      try {
        liff.closeWindow();
      } catch (e) {
        // 桌面瀏覽器（測試用）→ 導向 LINE OA 網頁版
        window.location.href = 'https://line.me/R/';
      }
    }, 2500);
  }

  // ══════════════════════════════════════════════════════════════════════
  // 事件監聽（委派模式，與 Simplybook JS 相同）
  // ══════════════════════════════════════════════════════════════════════
  document.addEventListener('click', function (e) {
    var target = e.target;

    // 第一層卡片
    var topicCard = target.closest
      ? target.closest('.winds-topic-card')
      : closestByClass(target, 'winds-topic-card');
    if (topicCard) { handleTopicClick(topicCard); return; }

    // 第二層卡片
    var subCard = target.closest
      ? target.closest('.winds-sub-card')
      : closestByClass(target, 'winds-sub-card');
    if (subCard) { handleSubClick(subCard); return; }

    // 第三層卡片
    var thirdCard = target.closest
      ? target.closest('.winds-third-card')
      : closestByClass(target, 'winds-third-card');
    if (thirdCard) { handleThirdClick(thirdCard); return; }

    // 送出按鈕
    var btn = document.getElementById('btnSubmit');
    if (btn && (target === btn || btn.contains(target))) {
      e.preventDefault();
      handleSubmitClick();
    }
  });

  // 生日/時間變更 → 更新預覽
  document.addEventListener('change', function (e) {
    if (e.target && (e.target.id === 'birthDate' || e.target.id === 'birthTime')) {
      updateBirthPreview();
    }
  });

  // 補充說明字數計數
  var summaryEl = document.getElementById('windsSummary');
  if (summaryEl) {
    summaryEl.addEventListener('input', updateCharCounter);
    updateCharCounter();
  }

  // 瀏覽器返回時同步 UI 狀態（防 bfcache 殘留）
  window.addEventListener('pageshow', function () {
    setTimeout(function () { syncUIState(); }, 50);
  });

  // 初始化後同步 UI 狀態
  setTimeout(function () { syncUIState(); }, 100);

})();
</script>

</body>
</html>
<%} %>
