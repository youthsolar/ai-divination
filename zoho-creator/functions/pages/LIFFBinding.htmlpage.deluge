// =============================================================================
// 【頁面說明】LINE LIFF 增強版 — 3 層卡片問題引導 + 資料表單 + 智慧分流
// 【頁面名稱】LIFFBinding（在 Creator → Pages 建立）
// 【用途】引導用戶透過 3 層卡片找到問題語言，填入個人資料後自動分流
//
// 【部署步驟】
//   1. Zoho Creator → AI易經 → Pages → 新增 Page → 名稱：LIFFBinding
//   2. 加入 HTML Snippet 元件
//   3. 將下方 htmlpage 程式碼貼入
//   4. Save / Publish
//   5. 複製頁面完整 URL（格式：https://creatorapp.zoho.com/uneedwind/ai/page/LIFFBinding）
//   6. 在 LINE Developers Console → LIFF 2009168674-G2KqF3Jv → Additional URLs
//      加入此 URL
//
// 【設定】部署後必填：
//   - 將 __LINE_BINDING_PUBLIC_KEY__ 替換為 Creator Microservices → line_binding endpoint 的 public_key
//   - 將 __LIFF_DIVINATION_PUBLIC_KEY__ 替換為 Creator Microservices → liff_divination_mvp endpoint 的 public_key
//
// 【流程（3 Phase）】
//   Phase 1 — 3 層卡片選擇（降低進入障礙，幫用戶找到問題的語言）
//   Phase 2 — 個人資料表單（姓名、生日、手機、Email + 自動生成問題文字）
//   Phase 3 — 智慧分流：
//     fortune / event → POST line_binding + POST liff_divination_mvp → "AI 計算中" → liff.closeWindow()
//     karma / teacher → POST line_binding → redirect to Simplybook 預約頁
//
// 【API 呼叫】
//   POST https://www.zohoapis.com/creator/custom/uneedwind/line_binding?public_key=<KEY>
//   Body: { lineUserId, birthday, birthTime, lastName, firstName, phone, email, topicKey, thirdKey }
//   POST https://www.zohoapis.com/creator/custom/uneedwind/liff_divination_mvp?public_key=<KEY>
//   Body: { lineUserId, birthday, question }
//
// 【Simplybook 服務 URL 對照】
//   fortune      → 不跳轉，走 LINE AI 占卜（元辰宮代觀 AI）
//   karma        → https://winds.tw/v2/#book/service/4（通靈水鏡法）
//   event        → 不跳轉，走 LINE AI 占卜（命書籤詩問事 AI）
//   teacher-energy → https://winds.tw/v2/#book/service/4（通靈水鏡法）
//   teacher-love / teacher-work / teacher-direct → https://winds.tw/v2/#book/service/43
//
// 【設計規格】複用 Simplybook 對話卡片 CSS 設計系統
//   主色     : #be6f80（玫瑰粉）
//   按鈕色   : #e6c068（金色）
//   按鈕文字 : #474747（深灰）
//   卡片邊框 : #5a656b
//   卡片選中 : #f0e6e6 背景
//   動畫     : windsFadeInUp（opacity 0→1, translateY 15px→0, 0.6s ease）
//   背景圖   : https://cdn.store-assets.com/s/818160/i/95309874.png
// =============================================================================

htmlpage html_snippet()
content
<%{ %>
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>找問題 — 找風問幸福</title>

  <!-- LINE LIFF SDK v2 -->
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>

  <style>
    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Body 背景（同 SalesIQ.css） ── */
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
                   'Noto Sans TC', 'Helvetica Neue', Arial, sans-serif;
      min-height: 100vh;
      padding: 16px 12px 32px;
      background: url('https://cdn.store-assets.com/s/818160/i/95309874.png')
                  center / cover no-repeat fixed;
    }

    /* ── 外層白底卡片容器 ── */
    .winds-card {
      max-width: 640px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 8px;
      box-shadow: 0 3px 8px rgba(0, 0, 0, 0.08);
      padding: 24px 18px 28px;
      position: relative;
    }

    /* ── 動畫 ── */
    @keyframes windsFadeInUp {
      0%   { opacity: 0; transform: translateY(15px); }
      100% { opacity: 1; transform: translateY(0);    }
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .winds-card { animation: windsFadeInUp 0.5s ease both; }

    /* ── 品牌 Header ── */
    .brand-logo     { text-align: center; font-size: 32px; margin-bottom: 4px; }
    .brand-title    { text-align: center; font-size: 18px; font-weight: 700; color: #be6f80; margin-bottom: 2px; }
    .brand-subtitle { text-align: center; font-size: 12px; color: #999999; margin-bottom: 14px; }

    /* ── 步驟標籤 ── */
    .phase-label {
      font-size: 12px;
      font-weight: 700;
      color: #be6f80;
      letter-spacing: 0.3px;
      margin-bottom: 10px;
      padding-left: 2px;
    }

    /* ── 錯誤訊息 ── */
    .error-msg {
      display: none;
      font-size: 12px;
      color: #c0392b;
      background: #fff5f5;
      border: 1px solid #f5c6cb;
      border-radius: 6px;
      padding: 8px 12px;
      margin: 10px 0 0;
    }
    .error-msg.show { display: block; animation: windsFadeInUp 0.3s ease both; }

    /* ── Loading 覆蓋層（全頁） ── */
    .loading-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(255, 255, 255, 0.92);
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 14px;
      font-size: 14px;
      color: #be6f80;
      z-index: 9999;
      text-align: center;
      padding: 20px;
    }
    .loading-overlay.show { display: flex; }
    .loading-spinner {
      width: 38px; height: 38px;
      border: 3px solid #f0dde2;
      border-top-color: #be6f80;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    /* ── 主要按鈕（金色，SalesIQ 規格） ── */
    .btn-primary {
      display: block;
      width: 100%;
      padding: 13px;
      background: #e6c068;
      color: #474747;
      font-size: 15px;
      font-weight: 700;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      text-align: center;
      transition: background 0.2s, transform 0.1s;
      letter-spacing: 0.5px;
      margin-top: 14px;
    }
    .btn-primary:hover  { background: #dbb558; }
    .btn-primary:active { transform: scale(0.98); }
    .btn-primary:disabled { background: #e0d8c4; color: #999999; cursor: not-allowed; }

    /* ── 成功畫面 ── */
    .success-screen       { display: none; text-align: center; padding: 24px 0; }
    .success-screen.show  { display: block; animation: windsFadeInUp 0.4s ease both; }
    .success-icon  { font-size: 52px; margin-bottom: 14px; }
    .success-title { font-size: 20px; font-weight: 700; color: #be6f80; margin-bottom: 8px; }
    .success-desc  { font-size: 13px; color: #777777; line-height: 1.7; }

    /* ══════════════════════════════════════════════════
       Winds 卡片 CSS（複用自 Simplybook 對話卡片 JS）
       ══════════════════════════════════════════════════ */

    .winds-topic-section {
      margin: 14px 0 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      gap: 12px;
    }

    .winds-hidden { display: none !important; }

    .winds-topic-row,
    .winds-sub-row,
    .winds-third-row,
    #birthCardWrapper {
      box-sizing: border-box;
      flex: 0 0 100% !important;
      max-width: 100% !important;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin: 0;
    }

    .winds-sub-row,
    .winds-third-row { display: none !important; }

    .winds-sub-row.active,
    .winds-third-row.active {
      display: flex !important;
      animation: windsFadeInUp 0.6s ease-out forwards;
    }

    /* 階段1：只有第一層被選定 */
    .winds-topic-section.winds-has-sub-selected:not(.winds-has-third-selected) .winds-topic-row {
      flex: 0 0 100% !important;
      max-width: 100% !important;
      justify-content: center;
    }

    /* 階段2：第一層+第二層被選定 - 雙欄並排 */
    .winds-topic-section.winds-has-sub-selected.winds-has-third-selected:not(.winds-step-3) .winds-topic-row,
    .winds-topic-section.winds-has-sub-selected.winds-has-third-selected:not(.winds-step-3) .winds-sub-row.active {
      flex: 0 0 calc(50% - 6px) !important;
      max-width: calc(50% - 6px) !important;
    }

    /* 階段3：三層都被選定 - 三欄並排 */
    .winds-topic-section.winds-step-3 .winds-topic-row,
    .winds-topic-section.winds-step-3 .winds-sub-row.active,
    .winds-topic-section.winds-step-3 .winds-third-row.active {
      flex: 0 0 calc(33.33% - 8px) !important;
      max-width: calc(33.33% - 8px) !important;
    }

    .winds-topic-card,
    .winds-sub-card,
    .winds-third-card {
      box-sizing: border-box;
      flex: 0 0 calc(50% - 6px) !important;
      max-width: calc(50% - 6px) !important;
      background: #ffffff;
      border: 0.5px solid #5a656b;
      border-radius: 8px;
      padding: 10px;
      font-size: 12px;
      color: #474747;
      cursor: pointer;
      transition: background-color 0.3s, border-color 0.3s, color 0.3s, box-shadow 0.3s;
    }

    .winds-topic-card-title,
    .winds-sub-card-title,
    .winds-third-card-title {
      font-weight: 600;
      margin-bottom: 4px;
      font-size: 13px;
    }

    .winds-topic-card:hover,
    .winds-sub-card:hover,
    .winds-third-card:hover {
      border-color: #5a656b;
      background: #f0e6e6;
      color: #3b262a;
      box-shadow: 0 3px 8px rgba(0, 0, 0, 0.08);
    }

    /* 階段1：第一層被選定時保持原寬度 */
    .winds-topic-section.winds-has-sub-selected:not(.winds-has-third-selected) .winds-topic-card.active {
      flex: 0 0 calc(50% - 6px) !important;
      max-width: calc(50% - 6px) !important;
      border-color: #5a656b;
      background: #f0e6e6;
      color: #3b262a;
      box-shadow: 0 3px 8px rgba(0, 0, 0, 0.12);
    }

    /* 階段2、3：選中的卡片在其 row 內佔滿 100% */
    .winds-topic-section.winds-has-sub-selected.winds-has-third-selected .winds-topic-card.active,
    .winds-topic-section.winds-has-sub-selected.winds-has-third-selected .winds-sub-card.active,
    .winds-topic-section.winds-step-3 .winds-topic-card.active,
    .winds-topic-section.winds-step-3 .winds-sub-card.active,
    .winds-topic-section.winds-step-3 .winds-third-card.active {
      flex: 0 0 100% !important;
      max-width: 100% !important;
      border-color: #5a656b;
      background: #f0e6e6;
      color: #3b262a;
      box-shadow: 0 3px 8px rgba(0, 0, 0, 0.12);
    }

    #birthCardWrapper { margin-top: 0; }
    #birthCardWrapper:not(.winds-hidden) {
      animation: windsFadeInUp 0.6s ease-out forwards;
    }

    .winds-bottom-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: flex-start;
      justify-content: center;
    }

    .winds-input-card {
      flex: 0 0 100% !important;
      max-width: 100% !important;
      background: #ffffff;
      border-radius: 8px;
      padding: 14px 12px;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
      border: 0.5px solid #5a656b;
      font-size: 12px;
      color: #474747;
    }

    .winds-form-step-label {
      font-size: 12px;
      font-weight: 700;
      color: #be6f80;
      margin-bottom: 10px;
    }

    .winds-contact-row,
    .winds-birth-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 10px;
    }

    .winds-contact-field {
      flex: 1 1 100px;
      min-width: 100px;
    }

    .winds-contact-field label {
      display: block;
      font-size: 11px;
      margin-bottom: 4px;
      color: #5a656b;
      font-weight: 600;
    }

    .winds-required { color: #d9534f; margin-left: 2px; }

    .winds-input,
    .birth-card-input {
      width: 100%;
      padding: 4px 6px;
      border-radius: 6px;
      border: 1px solid #dcd2d2;
      font-size: 12px !important;
      outline: none;
      color: #474747;
      box-sizing: border-box;
      height: 30px;
    }

    .winds-input::placeholder,
    .birth-card-input::placeholder { font-size: 12px !important; color: #999999; }

    .winds-input:focus,
    .birth-card-input:focus {
      border-color: #5a656b;
      box-shadow: 0 0 0 1px rgba(90, 101, 107, 0.18);
    }

    .birth-card-input[type="date"],
    .birth-card-input[type="time"] {
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
    }

    .winds-textarea {
      width: 100%;
      min-height: 100px;
      border-radius: 6px;
      border: 1px solid #dcd2d2;
      padding: 6px 7px;
      font-size: 12px !important;
      resize: vertical;
      outline: none;
      line-height: 1.6;
      color: #474747;
    }

    .winds-textarea::placeholder { font-size: 12px !important; color: #999999; }
    .winds-textarea:focus {
      border-color: #5a656b;
      box-shadow: 0 0 0 1px rgba(90, 101, 107, 0.18);
    }

    .winds-char-counter {
      text-align: right;
      font-size: 11px;
      margin-top: 2px;
      color: #777777;
    }

    #previewArea {
      display: none;
      padding: 6px 8px;
      border: 1px solid #eeeeee;
      border-radius: 6px;
      margin: 4px 0 8px 0;
      background: #fafafa;
      box-sizing: border-box;
      font-size: 12px;
      color: #474747;
    }

    /* ── 手機版響應式 ── */
    @media (max-width: 768px) {
      .winds-topic-section { display: block; gap: 0; }

      .winds-topic-row,
      .winds-sub-row,
      .winds-third-row,
      #birthCardWrapper,
      .winds-topic-section.winds-has-sub-selected:not(.winds-has-third-selected) .winds-topic-row,
      .winds-topic-section.winds-has-sub-selected.winds-has-third-selected:not(.winds-step-3) .winds-topic-row,
      .winds-topic-section.winds-has-sub-selected.winds-has-third-selected:not(.winds-step-3) .winds-sub-row.active,
      .winds-topic-section.winds-step-3 .winds-topic-row,
      .winds-topic-section.winds-step-3 .winds-sub-row.active,
      .winds-topic-section.winds-step-3 .winds-third-row.active {
        flex: none !important;
        max-width: 100% !important;
        width: 100% !important;
        margin-top: 12px !important;
      }

      .winds-topic-card,
      .winds-sub-card,
      .winds-third-card {
        flex: 0 0 100% !important;
        max-width: 100% !important;
      }

      .winds-topic-section.winds-has-sub-selected:not(.winds-has-third-selected) .winds-topic-card.active,
      .winds-topic-section.winds-has-sub-selected.winds-has-third-selected .winds-topic-card.active,
      .winds-topic-section.winds-has-sub-selected.winds-has-third-selected .winds-sub-card.active,
      .winds-topic-section.winds-step-3 .winds-topic-card.active,
      .winds-topic-section.winds-step-3 .winds-sub-card.active,
      .winds-topic-section.winds-step-3 .winds-third-card.active {
        flex: 0 0 100% !important;
        max-width: 100% !important;
      }

      .winds-bottom-row { flex-direction: column; }

      .winds-input-card {
        flex: none !important;
        max-width: 100% !important;
        width: 100% !important;
      }

      .winds-contact-field {
        flex: 1 1 calc(50% - 5px) !important;
        max-width: calc(50% - 5px) !important;
        min-width: calc(50% - 5px) !important;
      }

      .winds-birth-row { flex-wrap: nowrap !important; }
    }
  </style>
</head>
<body>

<!-- ── Loading 覆蓋層（全頁，呼叫 API 時顯示） ── -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
  <span id="loadingMsg">處理中，請稍候...</span>
</div>

<!-- ── 外層白底卡片 ── -->
<div class="winds-card" id="mainCard">

  <!-- 品牌 Header -->
  <div class="brand-logo">🔮</div>
  <div class="brand-title">找風問幸福</div>
  <div class="brand-subtitle">選擇最接近你狀況的卡片，讓 AI 幫你找到問題的語言</div>

  <!-- 錯誤訊息 -->
  <div class="error-msg" id="errorMsg"></div>

  <!-- ── 成功畫面（送出後顯示） ── -->
  <div class="success-screen" id="successScreen">
    <div class="success-icon">🔮</div>
    <div class="success-title" id="successTitle">AI 正在為你計算中</div>
    <div class="success-desc" id="successDesc">命盤計算中，稍後請回到 LINE 查看占卜結果。<br>大約 30 秒內送達。</div>
  </div>

  <!-- ── 主要內容區（Phase 1 + Phase 2） ── -->
  <div id="mainContent">
    <div class="phase-label">✦ 步驟 1：選擇最接近你狀況的問題</div>

    <!-- ════════════════════════════════════════════════════ -->
    <!--  3 層卡片選擇系統                                    -->
    <!-- ════════════════════════════════════════════════════ -->
    <div class="winds-topic-section">

      <!-- 第一層：4 大主題 -->
      <div class="winds-topic-row">
        <div class="winds-topic-card" data-topic="love">
          <div class="winds-topic-card-title">感情與婚姻困擾</div>
          <div>關於感情、婚姻、關係拉扯與擔心，想看清彼此的真實想法與走向。</div>
        </div>
        <div class="winds-topic-card" data-topic="career">
          <div class="winds-topic-card-title">事業與財富規劃</div>
          <div>包含工作方向、轉職創業、財務壓力與收入穩定度，想釐清下一步。</div>
        </div>
        <div class="winds-topic-card" data-topic="health">
          <div class="winds-topic-card-title">身心與健康狀態</div>
          <div>對身心狀態、睡眠、壓力或長期不適感到擔心，希望調整能量。</div>
        </div>
        <div class="winds-topic-card" data-topic="teacher">
          <div class="winds-topic-card-title">想直接選擇老師</div>
          <div>已大致了解自己的課題，希望依擅長領域，直接媒合適合的老師。</div>
        </div>
      </div>

      <!-- 第二層：感情 -->
      <div class="winds-sub-row" id="winds-sub-love">
        <div class="winds-sub-card" data-sub="love-reunion">
          <div class="winds-sub-card-title">復合與舊愛</div>
          <div>分手後想知道是否還有機會，或徹底放下。</div>
        </div>
        <div class="winds-sub-card" data-sub="love-crush">
          <div class="winds-sub-card-title">暗戀與曖昧</div>
          <div>想知道對方心意、發展可能或行動時機。</div>
        </div>
        <div class="winds-sub-card" data-sub="love-partner">
          <div class="winds-sub-card-title">伴侶與婚姻</div>
          <div>解決爭執、冷淡、懷疑或改善關係。</div>
        </div>
        <div class="winds-sub-card" data-sub="love-single">
          <div class="winds-sub-card-title">單身與桃花</div>
          <div>求正緣、斬爛桃花、查詢桃花運勢。</div>
        </div>
      </div>

      <!-- 第三層：感情/復合 -->
      <div class="winds-third-row" id="winds-third-love-reunion">
        <div class="winds-third-card" data-third="1.1.1" data-service="fortune">
          <div class="winds-third-card-title">我們分手了，我想知道復合機會有多大？</div>
          <div>想知道對方是否已真分，還是有機會。</div>
        </div>
        <div class="winds-third-card" data-third="1.1.2" data-service="karma">
          <div class="winds-third-card-title">我想知道他跟我分手的真正原因是什麼？</div>
          <div>對方沒說清楚，想查清是否有隱情。</div>
        </div>
        <div class="winds-third-card" data-third="1.1.3" data-service="event">
          <div class="winds-third-card-title">這段感情讓我好痛苦，我該放下還是繼續等？</div>
          <div>需要一個明確的指引，幫助我做決定讓我好好走下去。</div>
        </div>
